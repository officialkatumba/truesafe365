<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="main-wrapper">
  <div class="content container py-4">
    <div class="worksite-details-container" style="max-width: 1000px; margin: 0 auto;">
      <!-- Worksite Header - Enterprise Admin Style -->
      <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
        <div>
          <h3 class="mb-1">
            <i class="fas fa-hard-hat me-2" style="color: #26a69a;"></i>
            <%= worksite.name %>
          </h3>
          <div class="d-flex gap-2 flex-wrap">
            <span class="badge text-bg-secondary">
              <i class="fas fa-tag me-1"></i> <%= worksite.siteType %>
            </span>
            <span class="badge text-bg-secondary">
              <i class="fas fa-hashtag me-1"></i> #<%= worksite.worksiteNumber %>
            </span>
            <span class="badge <%= 
              worksite.status === 'active' ? 'text-bg-success' : 
              worksite.status === 'inactive' ? 'text-bg-secondary' : 
              worksite.status === 'under_review' ? 'text-bg-warning' : 
              'text-bg-info' 
            %>">
              <i class="fas fa-circle me-1"></i> <%= worksite.status %>
            </span>
          </div>
        </div>
        <div class="text-end">
          <span class="text-muted small d-block">
            <i class="fas fa-map-marker-alt me-1" style="color: #f44336;"></i> <%= worksite.location %>
          </span>
          <span class="text-muted small mt-1 d-block">
            <i class="fas fa-calendar-alt me-1"></i> Created: <%= worksite.createdAt ? new Date(worksite.createdAt).toLocaleDateString() : 'N/A' %>
          </span>
        </div>
      </div>

      <!-- Quick Actions Row -->
      <div class="d-flex gap-2 justify-content-between mb-4">
        <div>
          <a href="/worksites/<%= worksite._id %>/edit" class="btn btn-outline-primary btn-sm">
            <i class="fas fa-edit me-1"></i> Edit Worksite
          </a>
          <a href="/work-areas/create?worksiteId=<%= worksite._id %>" class="btn btn-outline-success btn-sm">
            <i class="fas fa-plus-circle me-1"></i> Add Work Area
          </a>
        </div>
        <div>
          <span class="text-muted small">
            <i class="fas fa-user me-1"></i> <strong><%= user.email %></strong>
            <span class="badge <%= user.role === 'system_admin' ? 'bg-warning text-dark' : (user.role === 'safety_officer' ? 'bg-success' : 'bg-info') %> ms-2">
              <i class="fas fa-<%= user.role === 'system_admin' ? 'crown' : (user.role === 'safety_officer' ? 'user-shield' : 'user') %> me-1"></i>
              <%= user.role === 'system_admin' ? 'System Admin' : (user.role === 'safety_officer' ? 'Safety Officer' : (user.role === 'supervisor' ? 'Supervisor' : 'Worker')) %>
            </span>
          </span>
        </div>
      </div>

      <!-- Stats Cards -->
      <div class="row g-3 mb-4">
        <div class="col-md-3 col-6">
          <div class="d-flex align-items-center p-2 rounded bg-light">
            <div class="rounded-circle d-flex align-items-center justify-content-center me-2" style="background: linear-gradient(135deg, #2196f3 0%, #1976d2 100%); width: 35px; height: 35px;">
              <i class="fas fa-map-marked-alt text-white" style="font-size: 0.9rem;"></i>
            </div>
            <div>
              <strong><%= workAreas.length %></strong>
              <small class="text-muted d-block">Work Areas</small>
            </div>
          </div>
        </div>
        <div class="col-md-3 col-6">
          <div class="d-flex align-items-center p-2 rounded bg-light">
            <div class="rounded-circle d-flex align-items-center justify-content-center me-2" style="background: linear-gradient(135deg, #ff9800 0%, #f57c00 100%); width: 35px; height: 35px;">
              <i class="fas fa-users text-white" style="font-size: 0.9rem;"></i>
            </div>
            <div>
              <strong><%= worksite.assignedSafetyOfficers.length %></strong>
              <small class="text-muted d-block">Officers</small>
            </div>
          </div>
        </div>
        <div class="col-md-3 col-6">
          <div class="d-flex align-items-center p-2 rounded bg-light">
            <div class="rounded-circle d-flex align-items-center justify-content-center me-2" style="background: linear-gradient(135deg, #4caf50 0%, #388e3c 100%); width: 35px; height: 35px;">
              <i class="fas fa-shield-alt text-white" style="font-size: 0.9rem;"></i>
            </div>
            <div>
              <strong><%= worksite.performance?.overallSafetyScore || 100 %>%</strong>
              <small class="text-muted d-block">Safety Score</small>
            </div>
          </div>
        </div>
        <div class="col-md-3 col-6">
          <div class="d-flex align-items-center p-2 rounded bg-light">
            <div class="rounded-circle d-flex align-items-center justify-content-center me-2" style="background: linear-gradient(135deg, #f44336 0%, #d32f2f 100%); width: 35px; height: 35px;">
              <i class="fas fa-calendar-check text-white" style="font-size: 0.9rem;"></i>
            </div>
            <div>
              <strong><%= worksite.performance?.daysWithoutIncident || 0 %></strong>
              <small class="text-muted d-block">Days Safe</small>
            </div>
          </div>
        </div>
      </div>

      <!-- ==================== NEW: COMPLIANCE SECTION ==================== -->
      <div class="card border-0 shadow-sm mb-4" style="border-radius: 16px; background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);">
        <div class="card-header bg-transparent border-0 pt-4 px-4">
          <div class="d-flex justify-content-between align-items-center">
            <h4 class="fw-bold mb-0" style="color: #1e3c5c;">
              <i class="fas fa-gavel me-2" style="color: #ff9800;"></i>Compliance with Zambian Regulations
            </h4>
            <span class="badge bg-primary">AI-Assisted</span>
          </div>
          <p class="text-muted small mt-2">Based on the Occupational Health and Safety Act 2025, Minerals Regulation Commission Act 2024, and Environmental Impact Assessment Regulations 2026</p>
        </div>
        <div class="card-body p-4">
          
          <!-- OHS Act Section -->
          <div class="compliance-section mb-4">
            <div class="d-flex align-items-center mb-3">
              <div class="rounded-circle d-flex align-items-center justify-content-center me-2" style="background: linear-gradient(135deg, #dc3545 0%, #c82333 100%); width: 35px; height: 35px;">
                <i class="fas fa-shield-alt text-white" style="font-size: 1rem;"></i>
              </div>
              <h5 class="fw-bold mb-0" style="color: #dc3545;">Occupational Health and Safety Act, 2025</h5>
              <span class="badge bg-secondary ms-2">Bill No. 17 of 2025</span>
            </div>
            
            <div class="row g-3">
              <!-- Section 14: Duties of Employer -->
              <div class="col-md-6">
                <div class="card border-0 shadow-sm h-100" style="border-left: 4px solid #dc3545; border-radius: 12px;">
                  <div class="card-body p-3">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                      <h6 class="fw-bold mb-0">Section 14 - Duties of Employer</h6>
                      <span class="badge bg-<%= worksite.complianceStatus?.sections?.find(s => s.sectionNumber === '14')?.status === 'completed' ? 'success' : 'warning' %>">
                        <%= worksite.complianceStatus?.sections?.find(s => s.sectionNumber === '14')?.status === 'completed' ? 'Completed' : 'Pending' %>
                      </span>
                    </div>
                    <p class="small text-muted">Provide and maintain a safe working environment, safe plant and systems, information and training, protective clothing, and emergency arrangements.</p>
                    <div class="progress mb-2" style="height: 4px;">
                      <div class="progress-bar bg-danger" style="width: <%= worksite.complianceStatus?.sections?.find(s => s.sectionNumber === '14')?.progress || 0 %>%"></div>
                    </div>
                    <div class="d-flex justify-content-between align-items-center">
                      <small class="text-muted"><%= worksite.complianceStatus?.sections?.find(s => s.sectionNumber === '14')?.progress || 0 %>% complete</small>
                      <button class="btn btn-sm btn-outline-danger" onclick="openComplianceModal('ohs', '14')" style="border-radius: 40px;">View Checklist</button>
                    </div>
                  </div>
                </div>
              </div>
              
              <!-- Section 16: Duties of Employee -->
              <div class="col-md-6">
                <div class="card border-0 shadow-sm h-100" style="border-left: 4px solid #ff9800; border-radius: 12px;">
                  <div class="card-body p-3">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                      <h6 class="fw-bold mb-0">Section 16 - Duties of Employee</h6>
                      <span class="badge bg-<%= worksite.complianceStatus?.sections?.find(s => s.sectionNumber === '16')?.status === 'completed' ? 'success' : 'warning' %>">
                        <%= worksite.complianceStatus?.sections?.find(s => s.sectionNumber === '16')?.status === 'completed' ? 'Completed' : 'Pending' %>
                      </span>
                    </div>
                    <p class="small text-muted">Take reasonable care of own health and safety, cooperate with employer, and report dangerous situations immediately.</p>
                    <div class="progress mb-2" style="height: 4px;">
                      <div class="progress-bar bg-warning" style="width: <%= worksite.complianceStatus?.sections?.find(s => s.sectionNumber === '16')?.progress || 0 %>%"></div>
                    </div>
                    <div class="d-flex justify-content-between align-items-center">
                      <small class="text-muted"><%= worksite.complianceStatus?.sections?.find(s => s.sectionNumber === '16')?.progress || 0 %>% complete</small>
                      <button class="btn btn-sm btn-outline-warning" onclick="openComplianceModal('ohs', '16')" style="border-radius: 40px;">View Checklist</button>
                    </div>
                  </div>
                </div>
              </div>
              
              <!-- Section 23: Risk Assessment -->
              <div class="col-md-6">
                <div class="card border-0 shadow-sm h-100" style="border-left: 4px solid #26a69a; border-radius: 12px;">
                  <div class="card-body p-3">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                      <h6 class="fw-bold mb-0">Section 23 - Risk Assessment</h6>
                      <span class="badge bg-<%= worksite.complianceStatus?.sections?.find(s => s.sectionNumber === '23')?.status === 'completed' ? 'success' : 'warning' %>">
                        <%= worksite.complianceStatus?.sections?.find(s => s.sectionNumber === '23')?.status === 'completed' ? 'Completed' : 'Pending' %>
                      </span>
                    </div>
                    <p class="small text-muted">Conduct risk assessment every 2 years, identify hazards, assess risks, and implement control measures.</p>
                    <div class="progress mb-2" style="height: 4px;">
                      <div class="progress-bar bg-success" style="width: <%= worksite.complianceStatus?.sections?.find(s => s.sectionNumber === '23')?.progress || 0 %>%"></div>
                    </div>
                    <div class="d-flex justify-content-between align-items-center">
                      <small class="text-muted"><%= worksite.complianceStatus?.sections?.find(s => s.sectionNumber === '23')?.progress || 0 %>% complete</small>
                      <button class="btn btn-sm btn-outline-success" onclick="openComplianceModal('ohs', '23')" style="border-radius: 40px;">View Checklist</button>
                    </div>
                  </div>
                </div>
              </div>
              
              <!-- Section 24-34: Medical Examinations -->
              <div class="col-md-6">
                <div class="card border-0 shadow-sm h-100" style="border-left: 4px solid #9c27b0; border-radius: 12px;">
                  <div class="card-body p-3">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                      <h6 class="fw-bold mb-0">Section 24-34 - Medical Examinations</h6>
                      <span class="badge bg-<%= worksite.complianceStatus?.sections?.find(s => s.sectionNumber === '24-34')?.status === 'completed' ? 'success' : 'warning' %>">
                        <%= worksite.complianceStatus?.sections?.find(s => s.sectionNumber === '24-34')?.status === 'completed' ? 'Completed' : 'Pending' %>
                      </span>
                    </div>
                    <p class="small text-muted">Pre-placement, in-employment, exit, and post-employment medical examinations for exposed workers.</p>
                    <div class="progress mb-2" style="height: 4px;">
                      <div class="progress-bar bg-purple" style="width: <%= worksite.complianceStatus?.sections?.find(s => s.sectionNumber === '24-34')?.progress || 0 %>%"></div>
                    </div>
                    <div class="d-flex justify-content-between align-items-center">
                      <small class="text-muted"><%= worksite.complianceStatus?.sections?.find(s => s.sectionNumber === '24-34')?.progress || 0 %>% complete</small>
                      <button class="btn btn-sm btn-outline-secondary" onclick="openComplianceModal('ohs', '24-34')" style="border-radius: 40px;">View Checklist</button>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
          
          <!-- Minerals Regulation Commission Act Section -->
          <div class="compliance-section mb-4 mt-4">
            <div class="d-flex align-items-center mb-3">
              <div class="rounded-circle d-flex align-items-center justify-content-center me-2" style="background: linear-gradient(135deg, #f39c12 0%, #e67e22 100%); width: 35px; height: 35px;">
                <i class="fas fa-hard-hat text-white" style="font-size: 1rem;"></i>
              </div>
              <h5 class="fw-bold mb-0" style="color: #e67e22;">Minerals Regulation Commission Act, 2024</h5>
              <span class="badge bg-secondary ms-2">Act No. 14 of 2024</span>
            </div>
            
            <div class="row g-3">
              <!-- Section 59-60: Environmental and Health Protection -->
              <div class="col-md-6">
                <div class="card border-0 shadow-sm h-100" style="border-left: 4px solid #e67e22; border-radius: 12px;">
                  <div class="card-body p-3">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                      <h6 class="fw-bold mb-0">Section 59-60 - Environmental & Health Protection</h6>
                      <span class="badge bg-<%= worksite.complianceStatus?.sections?.find(s => s.sectionNumber === '59-60')?.status === 'completed' ? 'success' : 'warning' %>">
                        <%= worksite.complianceStatus?.sections?.find(s => s.sectionNumber === '59-60')?.status === 'completed' ? 'Completed' : 'Pending' %>
                      </span>
                    </div>
                    <p class="small text-muted">Conserve air, water, soil, flora, fauna; prevent socio-economic impact; implement rehabilitation plans.</p>
                    <div class="progress mb-2" style="height: 4px;">
                      <div class="progress-bar bg-warning" style="width: <%= worksite.complianceStatus?.sections?.find(s => s.sectionNumber === '59-60')?.progress || 0 %>%"></div>
                    </div>
                    <div class="d-flex justify-content-between align-items-center">
                      <small class="text-muted"><%= worksite.complianceStatus?.sections?.find(s => s.sectionNumber === '59-60')?.progress || 0 %>% complete</small>
                      <button class="btn btn-sm btn-outline-warning" onclick="openComplianceModal('minerals', '59-60')" style="border-radius: 40px;">View Checklist</button>
                    </div>
                  </div>
                </div>
              </div>
              
              <!-- Section 64: Notification of Accidents -->
              <div class="col-md-6">
                <div class="card border-0 shadow-sm h-100" style="border-left: 4px solid #f44336; border-radius: 12px;">
                  <div class="card-body p-3">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                      <h6 class="fw-bold mb-0">Section 64 - Notification of Accidents</h6>
                      <span class="badge bg-<%= worksite.complianceStatus?.sections?.find(s => s.sectionNumber === '64')?.status === 'completed' ? 'success' : 'warning' %>">
                        <%= worksite.complianceStatus?.sections?.find(s => s.sectionNumber === '64')?.status === 'completed' ? 'Completed' : 'Pending' %>
                      </span>
                    </div>
                    <p class="small text-muted">Report accidents and dangerous occurrences to the Commission in prescribed manner.</p>
                    <div class="progress mb-2" style="height: 4px;">
                      <div class="progress-bar bg-danger" style="width: <%= worksite.complianceStatus?.sections?.find(s => s.sectionNumber === '64')?.progress || 0 %>%"></div>
                    </div>
                    <div class="d-flex justify-content-between align-items-center">
                      <small class="text-muted"><%= worksite.complianceStatus?.sections?.find(s => s.sectionNumber === '64')?.progress || 0 %>% complete</small>
                      <button class="btn btn-sm btn-outline-danger" onclick="openComplianceModal('minerals', '64')" style="border-radius: 40px;">View Checklist</button>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
          
          <!-- EIA Regulations Section -->
          <div class="compliance-section mb-4 mt-4">
            <div class="d-flex align-items-center mb-3">
              <div class="rounded-circle d-flex align-items-center justify-content-center me-2" style="background: linear-gradient(135deg, #26a69a 0%, #00897b 100%); width: 35px; height: 35px;">
                <i class="fas fa-leaf text-white" style="font-size: 1rem;"></i>
              </div>
              <h5 class="fw-bold mb-0" style="color: #26a69a;">Environmental Management (EIA) Regulations, 2026</h5>
              <span class="badge bg-secondary ms-2">S.I. No. 3 of 2026</span>
            </div>
            
            <div class="row g-3">
              <!-- EIA Classification -->
              <div class="col-md-6">
                <div class="card border-0 shadow-sm h-100" style="border-left: 4px solid #26a69a; border-radius: 12px;">
                  <div class="card-body p-3">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                      <h6 class="fw-bold mb-0">Project Classification</h6>
                      <span class="badge bg-<%= worksite.complianceStatus?.sections?.find(s => s.sectionNumber === 'eia_class')?.status === 'completed' ? 'success' : 'warning' %>">
                        <%= worksite.complianceStatus?.sections?.find(s => s.sectionNumber === 'eia_class')?.status === 'completed' ? 'Completed' : 'Pending' %>
                      </span>
                    </div>
                    <p class="small text-muted">Determine EIA Class (I-V) based on project type and size. Submit appropriate documentation to ZEMA.</p>
                    <div class="progress mb-2" style="height: 4px;">
                      <div class="progress-bar bg-success" style="width: <%= worksite.complianceStatus?.sections?.find(s => s.sectionNumber === 'eia_class')?.progress || 0 %>%"></div>
                    </div>
                    <div class="d-flex justify-content-between align-items-center">
                      <small class="text-muted"><%= worksite.complianceStatus?.sections?.find(s => s.sectionNumber === 'eia_class')?.progress || 0 %>% complete</small>
                      <button class="btn btn-sm btn-outline-success" onclick="openComplianceModal('eia', 'class')" style="border-radius: 40px;">View Checklist</button>
                    </div>
                  </div>
                </div>
              </div>
              
              <!-- Public Consultation -->
              <div class="col-md-6">
                <div class="card border-0 shadow-sm h-100" style="border-left: 4px solid #ff9800; border-radius: 12px;">
                  <div class="card-body p-3">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                      <h6 class="fw-bold mb-0">Public Consultation</h6>
                      <span class="badge bg-<%= worksite.complianceStatus?.sections?.find(s => s.sectionNumber === 'eia_consult')?.status === 'completed' ? 'success' : 'warning' %>">
                        <%= worksite.complianceStatus?.sections?.find(s => s.sectionNumber === 'eia_consult')?.status === 'completed' ? 'Completed' : 'Pending' %>
                      </span>
                    </div>
                    <p class="small text-muted">Conduct public consultation with affected communities, stakeholders, and interested parties.</p>
                    <div class="progress mb-2" style="height: 4px;">
                      <div class="progress-bar bg-warning" style="width: <%= worksite.complianceStatus?.sections?.find(s => s.sectionNumber === 'eia_consult')?.progress || 0 %>%"></div>
                    </div>
                    <div class="d-flex justify-content-between align-items-center">
                      <small class="text-muted"><%= worksite.complianceStatus?.sections?.find(s => s.sectionNumber === 'eia_consult')?.progress || 0 %>% complete</small>
                      <button class="btn btn-sm btn-outline-warning" onclick="openComplianceModal('eia', 'consult')" style="border-radius: 40px;">View Checklist</button>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
          
          <!-- Overall Compliance Summary -->
          <div class="mt-4 pt-3 border-top">
            <div class="d-flex justify-content-between align-items-center">
              <div>
                <h6 class="fw-bold mb-1">Overall Compliance Status</h6>
                <p class="small text-muted mb-0">Based on completed sections</p>
              </div>
              <div class="text-end">
                <div class="progress" style="width: 200px; height: 8px;">
                  <div class="progress-bar bg-success" style="width: <%= overallCompliancePercentage || 0 %>%"></div>
                </div>
                <span class="fw-bold ms-2"><%= overallCompliancePercentage || 0 %>%</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Work Areas Section -->
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="fw-bold mb-0" style="color: #2d3748; font-size: 1.3rem;">
          <i class="fas fa-map-marked-alt me-2" style="color: #26a69a;"></i>Work Areas
        </h4>
        <span class="badge text-bg-secondary" style="font-size: 0.9rem;">
          <i class="fas fa-layer-group me-1"></i> <%= workAreas.length %> Total
        </span>
      </div>

      <!-- Work Areas Table -->
      <% if (workAreas && workAreas.length > 0) { %>
      <div class="row mb-5">
        <div class="col-12">
          <div class="card border-0 shadow-sm" style="border-radius: 16px;">
            <div class="card-body p-0">
              <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                  <thead class="bg-light">
                    <tr>
                      <th class="px-4 py-3" style="border-radius: 16px 0 0 0;">Work Area</th>
                      <th class="py-3">Location</th>
                      <th class="py-3 text-center">Status</th>
                      <th class="py-3 text-center">Stats</th>
                      <th class="py-3 text-center" style="border-radius: 0 16px 0 0;">Actions</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% workAreas.forEach(area => { %>
                    <tr class="hover-row">
                      <td class="px-4">
                        <div class="d-flex align-items-center">
                          <div class="rounded-circle d-flex align-items-center justify-content-center me-3" 
                               style="background: linear-gradient(135deg, #26a69a 0%, #00897b 100%); width: 40px; height: 40px;">
                            <i class="fas fa-map-marked-alt text-white" style="font-size: 1rem;"></i>
                          </div>
                          <div>
                            <strong class="fs-6"><%= area.name %></strong>
                          </div>
                        </div>
                      </td>
                      <td>
                        <i class="fas fa-map-pin me-1" style="color: #f44336;"></i>
                        <%= area.location?.zone || area.location || 'Not specified' %>
                      </td>
                      <td class="text-center">
                        <span class="badge <%= 
                          area.status === 'active' ? 'bg-success' : 
                          area.status === 'planned' ? 'bg-warning text-dark' : 
                          area.status === 'on_hold' ? 'bg-danger' : 
                          area.status === 'completed' ? 'bg-info' : 
                          'bg-secondary' 
                        %>" style="border-radius: 40px;">
                          <%= area.status %>
                        </span>
                      </td>
                      <td class="text-center">
                        <div class="d-flex gap-2 justify-content-center">
                          <span class="badge bg-light text-dark" style="border-radius: 40px;" title="Incidents">
                            <i class="fas fa-exclamation-triangle text-danger me-1"></i><%= area.statistics?.incidents || 0 %>
                          </span>
                          <span class="badge bg-light text-dark" style="border-radius: 40px;" title="Safety Score">
                            <i class="fas fa-shield-alt text-success me-1"></i><%= area.statistics?.safetyScore || 100 %>%
                          </span>
                        </div>
                      </td>
                      <td class="text-center">
                        <a href="/work-areas/<%= area._id %>" class="btn btn-sm btn-outline-primary" title="View" style="border-radius: 40px;">
                          <i class="fas fa-eye"></i>
                        </a>
                      </td>
                    </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
      </div>
      <% } else { %>
      <div class="row mb-5">
        <div class="col-12">
          <div class="card border-0 bg-light" style="border-radius: 24px;">
            <div class="card-body text-center p-5">
              <div class="mb-4">
                <i class="fas fa-map-marked-alt fa-4x" style="color: #26a69a;"></i>
              </div>
              <h4 class="fw-bold mb-3" style="color: #1e3c5c;">No Work Areas Yet</h4>
              <p class="text-muted mb-4">Get started by creating your first work area for this worksite.</p>
              <a href="/work-areas/create?worksiteId=<%= worksite._id %>" class="btn btn-lg px-4" style="background: #26a69a; color: white; border-radius: 40px;">
                <i class="fas fa-plus-circle me-2"></i> Create First Work Area
              </a>
            </div>
          </div>
        </div>
      </div>
      <% } %>

      <!-- Assigned Safety Officers Section -->
      <div class="row mb-4">
        <div class="col-12">
          <h4 class="fw-bold mb-3" style="color: #2d3748; font-size: 1.2rem;">
            <i class="fas fa-users me-2" style="color: #f093fb;"></i>All Safety Officers
          </h4>
          
          <% if (worksite.assignedSafetyOfficers && worksite.assignedSafetyOfficers.length > 0) { %>
          <div class="row g-2">
            <% worksite.assignedSafetyOfficers.forEach(assignment => { %>
            <div class="col-md-4">
              <div class="d-flex align-items-center p-2 rounded bg-light">
                <div class="rounded-circle d-flex align-items-center justify-content-center me-2" style="background: linear-gradient(135deg, #ff9800 0%, #f57c00 100%); width: 30px; height: 30px;">
                  <i class="fas fa-user-tie text-white" style="font-size: 0.8rem;"></i>
                </div>
                <div class="flex-grow-1">
                  <strong style="font-size: 0.9rem;"><%= assignment.officer?.name ? assignment.officer.name.split(' ')[0] : 'Unknown' %></strong>
                  <span class="badge bg-light text-dark ms-1" style="font-size: 0.6rem;"><%= assignment.role %></span>
                </div>
              </div>
            </div>
            <% }) %>
          </div>
          <% } else { %>
          <div class="card border-0 bg-light" style="border-radius: 16px;">
            <div class="card-body text-center p-3">
              <p class="text-muted mb-2 small">No safety officers assigned to this worksite.</p>
              <a href="/admin/assign-officers" class="btn btn-sm btn-outline-primary" style="border-radius: 40px;">
                <i class="fas fa-user-plus me-1"></i> Assign Officers
              </a>
            </div>
          </div>
          <% } %>
        </div>
      </div>

      <!-- Info Banner -->
      <div class="row mt-4">
        <div class="col-12">
          <div class="alert alert-info text-center mb-0" style="border-radius: 8px; border-left: 5px solid #26a69a; background-color: #f8f9fa;">
            <i class="fas fa-info-circle me-2" style="color: #26a69a;"></i>
            <strong>Worksite Details:</strong> Click any work area to manage detailed safety data, incidents, and risk assessments.
          </div>
        </div>
      </div>

      <!-- Back Button -->
      <div class="row mt-4">
        <div class="col-12">
          <a href="/worksites/my-worksites" class="btn btn-outline-secondary btn-sm px-3" style="border-radius: 40px;">
            <i class="fas fa-arrow-left me-2"></i> Back to Worksites
          </a>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Compliance Checklist Modal -->
<div class="modal fade" id="complianceModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content" style="border-radius: 16px;">
      <div class="modal-header border-0">
        <h5 class="modal-title fw-bold" id="complianceModalTitle">Compliance Checklist</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body" id="complianceModalBody">
        <!-- Content will be loaded dynamically -->
        <div class="text-center py-4">
          <div class="spinner-border text-primary" role="status"></div>
          <p class="mt-2">Loading checklist...</p>
        </div>
      </div>
      <div class="modal-footer border-0">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal" style="border-radius: 40px;">Close</button>
        <button type="button" class="btn btn-primary" onclick="updateComplianceStatus()" style="border-radius: 40px;">
          <i class="fas fa-save me-1"></i> Update Status
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  let currentSection = null;
  let currentAct = null;

  function openComplianceModal(act, section) {
    currentAct = act;
    currentSection = section;
    
    const modal = new bootstrap.Modal(document.getElementById('complianceModal'));
    const titleMap = {
      ohs: 'Occupational Health and Safety Act, 2025',
      minerals: 'Minerals Regulation Commission Act, 2024',
      eia: 'Environmental Management (EIA) Regulations, 2026'
    };
    
    const sectionMap = {
      '14': 'Section 14 - Duties of Employer',
      '16': 'Section 16 - Duties of Employee',
      '23': 'Section 23 - Risk Assessment',
      '24-34': 'Section 24-34 - Medical Examinations',
      '59-60': 'Section 59-60 - Environmental & Health Protection',
      '64': 'Section 64 - Notification of Accidents',
      'class': 'EIA Project Classification',
      'consult': 'Public Consultation Requirements'
    };
    
    document.getElementById('complianceModalTitle').innerHTML = `
      <i class="fas fa-gavel me-2" style="color: #ff9800;"></i>
      ${titleMap[act]} - ${sectionMap[section]}
    `;
    
    // Fetch checklist items (you can implement API call here)
    fetchComplianceChecklist(act, section);
    modal.show();
  }
  
  async function fetchComplianceChecklist(act, section) {
    try {
      const response = await fetch(`/api/compliance/checklist/${act}/${section}?worksiteId=<%= worksite._id %>`);
      const data = await response.json();
      
      let html = `
        <div class="mb-3">
          <h6 class="fw-bold">Compliance Checklist Items</h6>
          <p class="text-muted small">Complete these items to ensure compliance with the relevant regulations.</p>
        </div>
        <div class="list-group">
      `;
      
      if (data.checklistItems && data.checklistItems.length > 0) {
        data.checklistItems.forEach((item, index) => {
          html += `
            <div class="list-group-item d-flex justify-content-between align-items-start">
              <div class="form-check">
                <input class="form-check-input" type="checkbox" id="item_${index}" value="${item.id}" ${item.completed ? 'checked' : ''}>
                <label class="form-check-label" for="item_${index}">
                  <strong>${item.title}</strong>
                  <div class="small text-muted">${item.description}</div>
                  ${item.deadline ? `<div class="small text-warning mt-1"><i class="fas fa-clock me-1"></i>Deadline: ${item.deadline}</div>` : ''}
                </label>
              </div>
              <button class="btn btn-sm btn-outline-secondary" onclick="getAIHelp('${act}', '${section}', '${item.id}')" style="border-radius: 40px;">
                <i class="fas fa-robot me-1"></i> AI Help
              </button>
            </div>
          `;
        });
      } else {
        html += `<div class="list-group-item text-center text-muted">No checklist items available yet.</div>`;
      }
      
      html += `</div>`;
      document.getElementById('complianceModalBody').innerHTML = html;
    } catch (error) {
      console.error('Error fetching checklist:', error);
      document.getElementById('complianceModalBody').innerHTML = `
        <div class="alert alert-danger">
          <i class="fas fa-exclamation-triangle me-2"></i>
          Error loading checklist. Please try again.
        </div>
      `;
    }
  }
  
  async function getAIHelp(act, section, itemId) {
    Swal.fire({
      title: 'Getting AI Help...',
      text: 'Analyzing compliance requirements...',
      allowOutsideClick: false,
      didOpen: () => Swal.showLoading()
    });
    
    try {
      const response = await fetch(`/api/compliance/ai-help`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          act,
          section,
          itemId,
          worksiteId: '<%= worksite._id %>'
        })
      });
      
      const data = await response.json();
      Swal.close();
      
      Swal.fire({
        title: 'AI Compliance Guidance',
        html: `<div class="text-start" style="max-height: 400px; overflow-y: auto;">${data.guidance}</div>`,
        icon: 'info',
        confirmButtonText: 'Got it',
        confirmButtonColor: '#26a69a'
      });
    } catch (error) {
      Swal.close();
      Swal.fire({
        title: 'Error',
        text: 'Failed to get AI assistance',
        icon: 'error'
      });
    }
  }
  
  async function updateComplianceStatus() {
    const checkedItems = [];
    document.querySelectorAll('#complianceModalBody input[type="checkbox"]').forEach(checkbox => {
      if (checkbox.checked) {
        checkedItems.push(checkbox.value);
      }
    });
    
    try {
      const response = await fetch(`/api/compliance/update-status`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          act: currentAct,
          section: currentSection,
          worksiteId: '<%= worksite._id %>',
          completedItems: checkedItems
        })
      });
      
      const data = await response.json();
      
      Swal.fire({
        title: 'Status Updated',
        text: 'Compliance status has been updated.',
        icon: 'success',
        timer: 2000,
        showConfirmButton: false
      }).then(() => {
        location.reload();
      });
    } catch (error) {
      Swal.fire({
        title: 'Error',
        text: 'Failed to update compliance status',
        icon: 'error'
      });
    }
  }
</script>

