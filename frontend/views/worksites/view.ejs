<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="content container py-5" style="max-width: 1000px;">
  <!-- Worksite Header - Hero Section -->
  <div class="row mb-4">
    <div class="col-12">
      <div class="card border-0 overflow-hidden" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 24px;">
        <div class="card-body p-0">
          <div class="row g-0">
            <div class="col-lg-8 p-4">
              <div class="d-flex align-items-center mb-3">
                <div class="bg-white bg-opacity-20 p-3 rounded-3 me-3" style="backdrop-filter: blur(10px); border-radius: 16px;">
                  <i class="fas fa-hard-hat fa-2x text-white"></i>
                </div>
                <div>
                  <h1 class="fw-bold text-white mb-1" style="font-size: 2rem;"><%= worksite.name %></h1>
                  <div class="d-flex align-items-center">
                    <i class="fas fa-map-marker-alt text-white-50 me-2"></i>
                    <p class="text-white-50 mb-0"><%= worksite.location %></p>
                  </div>
                </div>
              </div>
              
              <div class="d-flex flex-wrap gap-2">
                <span class="badge px-3 py-2" style="background: rgba(255,255,255,0.2); backdrop-filter: blur(5px); color: white; border-radius: 40px;">
                  <i class="fas fa-tag me-1"></i> <%= worksite.siteType %>
                </span>
                <span class="badge px-3 py-2" style="background: rgba(255,255,255,0.2); backdrop-filter: blur(5px); color: white; border-radius: 40px;">
                  <i class="fas fa-hashtag me-1"></i> #<%= worksite.worksiteNumber %>
                </span>
                <span class="badge px-3 py-2" style="background: <%= 
                  worksite.status === 'active' ? 'linear-gradient(135deg, #4caf50, #45a049)' : 
                  worksite.status === 'inactive' ? 'linear-gradient(135deg, #9e9e9e, #757575)' : 
                  worksite.status === 'under_review' ? 'linear-gradient(135deg, #ff9800, #f57c00)' : 
                  'linear-gradient(135deg, #00acc1, #0097a7)' 
                %>; color: white; border-radius: 40px;">
                  <i class="fas fa-check-circle me-1"></i> <%= worksite.status %>
                </span>
              </div>
            </div>
            
            <div class="col-lg-4 bg-dark bg-opacity-25 p-4 d-flex flex-column justify-content-center">
              <div class="d-grid gap-2">
                <a href="/worksites/<%= worksite._id %>/edit" class="btn btn-light btn-sm" style="border-radius: 40px;">
                  <i class="fas fa-edit me-2"></i>Edit Worksite
                </a>
                <a href="/work-areas/create?worksiteId=<%= worksite._id %>" class="btn btn-outline-light btn-sm" style="border-radius: 40px;">
                  <i class="fas fa-plus-circle me-2"></i>Add Work Area
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Stats Cards - Stacked Vertically -->
  <div class="row mb-5">
    <div class="col-md-3">
      <div class="card border-0 shadow-sm mb-3" style="border-radius: 16px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
        <div class="card-body p-3">
          <div class="d-flex align-items-center">
            <div class="bg-white bg-opacity-20 p-2 rounded-3 me-3" style="border-radius: 12px;">
              <i class="fas fa-map-marked-alt fa-2x text-white"></i>
            </div>
            <div class="flex-grow-1">
              <div class="d-flex justify-content-between align-items-center">
                <h6 class="text-white-50 mb-0">Work Areas</h6>
                <span class="badge bg-white text-primary" style="border-radius: 40px;"><%= workAreas.length %></span>
              </div>
              <h3 class="fw-bold text-white mb-0"><%= workAreas.length %></h3>
            </div>
          </div>
        </div>
      </div>

      <div class="card border-0 shadow-sm mb-3" style="border-radius: 16px; background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);">
        <div class="card-body p-3">
          <div class="d-flex align-items-center">
            <div class="bg-white bg-opacity-20 p-2 rounded-3 me-3" style="border-radius: 12px;">
              <i class="fas fa-users fa-2x text-white"></i>
            </div>
            <div class="flex-grow-1">
              <div class="d-flex justify-content-between align-items-center">
                <h6 class="text-white-50 mb-0">Safety Officers</h6>
                <span class="badge bg-white text-danger" style="border-radius: 40px;"><%= worksite.assignedSafetyOfficers.length %></span>
              </div>
              <h3 class="fw-bold text-white mb-0"><%= worksite.assignedSafetyOfficers.length %></h3>
            </div>
          </div>
        </div>
      </div>

      <div class="card border-0 shadow-sm mb-3" style="border-radius: 16px; background: linear-gradient(135deg, #5f2c82 0%, #49a09d 100%);">
        <div class="card-body p-3">
          <div class="d-flex align-items-center">
            <div class="bg-white bg-opacity-20 p-2 rounded-3 me-3" style="border-radius: 12px;">
              <i class="fas fa-shield-alt fa-2x text-white"></i>
            </div>
            <div class="flex-grow-1">
              <div class="d-flex justify-content-between align-items-center">
                <h6 class="text-white-50 mb-0">Safety Score</h6>
                <span class="badge bg-white text-success" style="border-radius: 40px;">Current</span>
              </div>
              <h3 class="fw-bold text-white mb-0"><%= worksite.performance?.overallSafetyScore || 100 %>%</h3>
            </div>
          </div>
        </div>
      </div>

      <div class="card border-0 shadow-sm" style="border-radius: 16px; background: linear-gradient(135deg, #ff9a9e 0%, #fad0c4 100%);">
        <div class="card-body p-3">
          <div class="d-flex align-items-center">
            <div class="bg-white bg-opacity-20 p-2 rounded-3 me-3" style="border-radius: 12px;">
              <i class="fas fa-calendar-check fa-2x text-white"></i>
            </div>
            <div class="flex-grow-1">
              <div class="d-flex justify-content-between align-items-center">
                <h6 class="text-white-50 mb-0">Clean Streak</h6>
                <span class="badge bg-white text-warning" style="border-radius: 40px;"><%= worksite.performance?.daysWithoutIncident || 0 %> days</span>
              </div>
              <h3 class="fw-bold text-white mb-0"><%= worksite.performance?.daysWithoutIncident || 0 %></h3>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Main Content Area (Work Areas and Safety Officers) -->
    <div class="col-md-9">
      <!-- Work Areas Section Header -->
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold mb-0" style="color: #2d3748; font-size: 1.5rem;">
          <i class="fas fa-map-marked-alt me-2" style="color: #667eea;"></i>Work Areas
        </h3>
        <a href="/work-areas/create?worksiteId=<%= worksite._id %>" class="btn btn-sm px-4" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; border: none; border-radius: 40px;">
          <i class="fas fa-plus-circle me-2"></i>New Work Area
        </a>
      </div>

      <!-- Work Areas Grid -->
      <% if (workAreas.length > 0) { %>
      <div class="row g-3 mb-5">
        <% workAreas.forEach(area => { %>
        <div class="col-lg-4">
          <div class="card h-100 border-0 shadow-sm hover-card" style="border-radius: 16px; overflow: hidden;">
            <div class="card-header border-0 p-3" style="background: linear-gradient(135deg, <%= area.status === 'active' ? '#667eea, #764ba2' : '#ff9a9e, #fad0c4' %>);">
              <div class="d-flex justify-content-between align-items-center">
                <h5 class="fw-bold text-white mb-0"><%= area.name.length > 15 ? area.name.substring(0, 15) + '...' : area.name %></h5>
                <span class="badge bg-white text-dark px-2 py-1" style="border-radius: 40px; font-size: 0.7rem;">
                  <i class="fas fa-<%= area.status === 'active' ? 'check-circle' : 'clock' %> me-1"></i><%= area.status %>
                </span>
              </div>
            </div>
            <div class="card-body p-3">
              <p class="text-muted small mb-2">
                <i class="fas fa-map-pin me-1" style="color: #667eea;"></i> <%= area.location ? (area.location.length > 20 ? area.location.substring(0, 20) + '...' : area.location) : 'N/A' %>
              </p>
              
              <!-- Mini stats row -->
              <div class="row g-1 mb-2">
                <div class="col-4">
                  <div class="p-1 rounded text-center" style="background: #fff5f5;">
                    <small class="d-block fw-bold text-danger"><%= area.statistics?.incidents || 0 %></small>
                    <small class="text-muted" style="font-size: 0.6rem;">Inc</small>
                  </div>
                </div>
                <div class="col-4">
                  <div class="p-1 rounded text-center" style="background: #fff9e6;">
                    <small class="d-block fw-bold text-warning"><%= area.statistics?.nearMisses || 0 %></small>
                    <small class="text-muted" style="font-size: 0.6rem;">Near</small>
                  </div>
                </div>
                <div class="col-4">
                  <div class="p-1 rounded text-center" style="background: #e6f7e6;">
                    <small class="d-block fw-bold text-success"><%= area.statistics?.safetyScore || 100 %>%</small>
                    <small class="text-muted" style="font-size: 0.6rem;">Score</small>
                  </div>
                </div>
              </div>
              
              <div class="d-flex gap-1">
                <a href="/work-areas/<%= area._id %>" class="btn btn-outline-primary btn-sm flex-fill" style="border-radius: 40px; font-size: 0.8rem;">
                  <i class="fas fa-eye"></i>
                </a>
                <a href="/work-areas/<%= area._id %>/edit" class="btn btn-outline-secondary btn-sm flex-fill" style="border-radius: 40px; font-size: 0.8rem;">
                  <i class="fas fa-edit"></i>
                </a>
              </div>
            </div>
          </div>
        </div>
        <% }) %>
      </div>
      <% } else { %>
      <div class="card border-0 bg-light mb-5" style="border-radius: 16px;">
        <div class="card-body text-center p-4">
          <i class="fas fa-map-marked-alt fa-3x text-muted mb-3"></i>
          <p class="text-muted mb-3">No work areas yet</p>
          <a href="/work-areas/create?worksiteId=<%= worksite._id %>" class="btn btn-primary btn-sm" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border: none; border-radius: 40px;">
            <i class="fas fa-plus-circle me-2"></i>Create First
          </a>
        </div>
      </div>
      <% } %>

      <!-- Assigned Safety Officers Section -->
      <div class="card border-0 shadow-sm mt-4" style="border-radius: 16px;">
        <div class="card-header bg-transparent border-0 pt-3 px-3">
          <h4 class="fw-bold mb-0" style="color: #2d3748; font-size: 1.2rem;">
            <i class="fas fa-users me-2" style="color: #f093fb;"></i>Safety Team
          </h4>
        </div>
        <div class="card-body p-3">
          <% if (worksite.assignedSafetyOfficers && worksite.assignedSafetyOfficers.length > 0) { %>
          <div class="row g-2">
            <% worksite.assignedSafetyOfficers.forEach(assignment => { %>
            <div class="col-md-4">
              <div class="d-flex align-items-center p-2 rounded" style="background: #f8f9fa;">
                <div class="rounded-circle bg-primary d-flex align-items-center justify-content-center me-2" style="width: 30px; height: 30px;">
                  <i class="fas fa-user-tie text-white" style="font-size: 0.8rem;"></i>
                </div>
                <div class="flex-grow-1">
                  <strong style="font-size: 0.9rem;"><%= assignment.officer?.name ? assignment.officer.name.split(' ')[0] : 'Unknown' %></strong>
                  <span class="badge bg-light text-dark ms-1" style="font-size: 0.6rem;"><%= assignment.role %></span>
                </div>
              </div>
            </div>
            <% }) %>
          </div>
          <% } else { %>
          <p class="text-muted text-center py-2 small">No safety officers assigned</p>
          <% } %>
        </div>
      </div>
    </div>
  </div>

  <!-- Back Button -->
  <div class="row">
    <div class="col-12">
      <a href="/worksites/my-worksites" class="btn btn-outline-secondary btn-sm px-3" style="border-radius: 40px;">
        <i class="fas fa-arrow-left me-2"></i> Back
      </a>
    </div>
  </div>
</div>

<style>
  .hover-card {
    transition: transform 0.2s ease;
  }
  .hover-card:hover {
    transform: translateY(-3px);
  }
  .bg-opacity-20 {
    background: rgba(255,255,255,0.2);
  }
  .content.container {
    max-width: 1000px;
  }
  .badge {
    font-weight: 500;
  }
</style>

<%- include('../partials/footer') %>