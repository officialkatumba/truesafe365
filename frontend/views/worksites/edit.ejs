<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-10">
      <div class="card shadow-lg border-0">
        <div class="card-header bg-transparent border-0 pt-4 px-4">
          <div class="d-flex justify-content-between align-items-center">
            <div>
              <h3 class="fw-bold mb-0" style="color: #2196f3">
                <i class="fas fa-edit me-2"></i>Edit Worksite
              </h3>
              <p class="text-muted">Update worksite information</p>
            </div>
            <span class="badge bg-info"><%= worksite.status %></span>
          </div>
        </div>
        
        <div class="card-body p-4">
          <form action="/worksites/<%= worksite._id %>/edit" method="POST">
            <!-- ==================== SECTION 1: BASIC INFORMATION ==================== -->
            <div class="form-section mb-5">
              <h5 class="fw-bold mb-3" style="color: #1e3c5c">
                <i class="fas fa-info-circle me-2"></i>1. Basic Information
              </h5>
              
              <div class="row g-3">
                <div class="col-md-6">
                  <label for="name" class="form-label fw-semibold">Worksite Name *</label>
                  <input type="text" class="form-control form-control-lg" id="name" name="name" 
                         value="<%= worksiteData.name %>" placeholder="e.g., Lusaka City Mall Construction" required>
                </div>
                
                <div class="col-md-6">
                  <label for="location" class="form-label fw-semibold">Location *</label>
                  <input type="text" class="form-control form-control-lg" id="location" name="location" 
                         value="<%= worksiteData.location %>" placeholder="e.g., Lusaka, Zambia" required>
                </div>
                
                <div class="col-md-6">
                  <label for="siteType" class="form-label fw-semibold">Site Type *</label>
                  <select class="form-select form-select-lg" id="siteType" name="siteType" required>
                    <option value="">Select site type</option>
                    <option value="construction" <%= worksiteData.siteType === 'construction' ? 'selected' : '' %>>🏗️ Construction</option>
                    <option value="mining" <%= worksiteData.siteType === 'mining' ? 'selected' : '' %>>⛏️ Mining</option>
                    <option value="manufacturing" <%= worksiteData.siteType === 'manufacturing' ? 'selected' : '' %>>🏭 Manufacturing</option>
                    <option value="oil_gas" <%= worksiteData.siteType === 'oil_gas' ? 'selected' : '' %>>🛢️ Oil & Gas</option>
                    <option value="warehouse" <%= worksiteData.siteType === 'warehouse' ? 'selected' : '' %>>📦 Warehouse</option>
                    <option value="office" <%= worksiteData.siteType === 'office' ? 'selected' : '' %>>💼 Office</option>
                    <option value="other" <%= worksiteData.siteType === 'other' ? 'selected' : '' %>>Other</option>
                  </select>
                </div>
                
                <div class="col-md-6">
                  <label for="status" class="form-label fw-semibold">Status</label>
                  <select class="form-select form-select-lg" id="status" name="status">
                    <option value="active" <%= worksiteData.status === 'active' ? 'selected' : '' %>>Active</option>
                    <option value="draft" <%= worksiteData.status === 'draft' ? 'selected' : '' %>>Draft</option>
                    <option value="on_hold" <%= worksiteData.status === 'on_hold' ? 'selected' : '' %>>On Hold</option>
                    <option value="completed" <%= worksiteData.status === 'completed' ? 'selected' : '' %>>Completed</option>
                    <option value="archived" <%= worksiteData.status === 'archived' ? 'selected' : '' %>>Archived</option>
                  </select>
                </div>
                
                <div class="col-md-6">
                  <label for="clientName" class="form-label fw-semibold">Client Name</label>
                  <input type="text" class="form-control" id="clientName" name="clientName" 
                         value="<%= worksiteData.clientName %>" placeholder="e.g., Zambia National Construction">
                </div>
                
                <div class="col-md-6">
                  <label for="clientEmail" class="form-label fw-semibold">Client Email</label>
                  <input type="email" class="form-control" id="clientEmail" name="clientEmail" 
                         value="<%= worksiteData.clientEmail %>" placeholder="client@company.com">
                </div>
                
                <div class="col-md-6">
                  <label for="clientContact" class="form-label fw-semibold">Client Phone</label>
                  <input type="text" class="form-control" id="clientContact" name="clientContact" 
                         value="<%= worksiteData.clientContact %>" placeholder="+260 XXX XXX XXX">
                </div>
                
                <div class="col-12">
                  <label for="description" class="form-label fw-semibold">Description</label>
                  <textarea class="form-control" id="description" name="description" rows="2" 
                            placeholder="Brief description of the worksite..."><%= worksiteData.description %></textarea>
                </div>
              </div>
            </div>
            
            <!-- ==================== SECTION 2: PROJECT TIMELINE & WORKFORCE ==================== -->
            <div class="form-section mb-5">
              <h5 class="fw-bold mb-3" style="color: #1e3c5c">
                <i class="fas fa-calendar-alt me-2"></i>2. Project Timeline & Workforce
              </h5>
              
              <div class="row g-3">
                <div class="col-md-4">
                  <label for="startDate" class="form-label fw-semibold">Start Date</label>
                  <input type="date" class="form-control" id="startDate" name="startDate" value="<%= worksiteData.startDate %>">
                </div>
                
                <div class="col-md-4">
                  <label for="endDate" class="form-label fw-semibold">End Date</label>
                  <input type="date" class="form-control" id="endDate" name="endDate" value="<%= worksiteData.endDate %>">
                </div>
                
                <div class="col-md-4">
                  <label for="durationMonths" class="form-label fw-semibold">Duration (months)</label>
                  <input type="number" class="form-control" id="durationMonths" name="durationMonths" step="1" value="<%= worksiteData.durationMonths %>">
                </div>
              </div>
              
              <div class="row g-3 mt-2">
                <div class="col-md-4">
                  <label for="totalWorkers" class="form-label fw-semibold">Total Workers</label>
                  <input type="number" class="form-control" id="totalWorkers" name="totalWorkers" value="<%= worksiteData.totalWorkers %>">
                </div>
                
                <div class="col-md-4">
                  <label for="peakWorkers" class="form-label fw-semibold">Peak Workers</label>
                  <input type="number" class="form-control" id="peakWorkers" name="peakWorkers" value="<%= worksiteData.peakWorkers %>">
                </div>
                
                <div class="col-md-4">
                  <label for="contractors" class="form-label fw-semibold">Contractors</label>
                  <input type="number" class="form-control" id="contractors" name="contractors" value="<%= worksiteData.contractors %>">
                </div>
              </div>
              
              <div class="mt-3">
                <label class="form-label fw-semibold">Shifts</label>
                <div class="row g-3">
                  <div class="col-md-4">
                    <div class="form-check">
                      <input class="form-check-input" type="checkbox" id="shiftMorning" name="shifts" value="morning" <%= worksiteData.shifts && worksiteData.shifts.includes('morning') ? 'checked' : '' %>>
                      <label class="form-check-label" for="shiftMorning">🌅 Morning Shift (6:00 - 14:00)</label>
                    </div>
                  </div>
                  <div class="col-md-4">
                    <div class="form-check">
                      <input class="form-check-input" type="checkbox" id="shiftAfternoon" name="shifts" value="afternoon" <%= worksiteData.shifts && worksiteData.shifts.includes('afternoon') ? 'checked' : '' %>>
                      <label class="form-check-label" for="shiftAfternoon">☀️ Afternoon Shift (14:00 - 22:00)</label>
                    </div>
                  </div>
                  <div class="col-md-4">
                    <div class="form-check">
                      <input class="form-check-input" type="checkbox" id="shiftNight" name="shifts" value="night" <%= worksiteData.shifts && worksiteData.shifts.includes('night') ? 'checked' : '' %>>
                      <label class="form-check-label" for="shiftNight">🌙 Night Shift (22:00 - 6:00)</label>
                    </div>
                  </div>
                </div>
              </div>
            </div>
            
            <!-- ==================== SECTION 3: SITE CHARACTERISTICS ==================== -->
            <div class="form-section mb-5">
              <h5 class="fw-bold mb-3" style="color: #1e3c5c">
                <i class="fas fa-map-marked-alt me-2"></i>3. Site Characteristics
              </h5>
              
              <div class="row g-3">
                <div class="col-md-4">
                  <label for="siteArea" class="form-label fw-semibold">Site Area (hectares)</label>
                  <input type="number" class="form-control" id="siteArea" name="siteArea" step="0.1" value="<%= worksiteData.siteArea %>">
                </div>
                
                <div class="col-md-4">
                  <label for="terrain" class="form-label fw-semibold">Terrain Type</label>
                  <select class="form-select" id="terrain" name="terrain">
                    <option value="flat" <%= worksiteData.terrain === 'flat' ? 'selected' : '' %>>Flat</option>
                    <option value="gentle_slope" <%= worksiteData.terrain === 'gentle_slope' ? 'selected' : '' %>>Gentle Slope</option>
                    <option value="steep_slope" <%= worksiteData.terrain === 'steep_slope' ? 'selected' : '' %>>Steep Slope</option>
                    <option value="mountainous" <%= worksiteData.terrain === 'mountainous' ? 'selected' : '' %>>Mountainous</option>
                    <option value="undulating" <%= worksiteData.terrain === 'undulating' ? 'selected' : '' %>>Undulating</option>
                  </select>
                </div>
                
                <div class="col-md-4">
                  <label for="soilType" class="form-label fw-semibold">Soil Type</label>
                  <select class="form-select" id="soilType" name="soilType">
                    <option value="clay" <%= worksiteData.soilType === 'clay' ? 'selected' : '' %>>Clay</option>
                    <option value="sandy" <%= worksiteData.soilType === 'sandy' ? 'selected' : '' %>>Sandy</option>
                    <option value="loamy" <%= worksiteData.soilType === 'loamy' ? 'selected' : '' %>>Loamy</option>
                    <option value="rocky" <%= worksiteData.soilType === 'rocky' ? 'selected' : '' %>>Rocky</option>
                    <option value="mixed" <%= worksiteData.soilType === 'mixed' ? 'selected' : '' %>>Mixed</option>
                    <option value="unknown" <%= worksiteData.soilType === 'unknown' ? 'selected' : '' %>>Unknown</option>
                  </select>
                </div>
              </div>
              
              <div class="row g-3 mt-2">
                <div class="col-md-6">
                  <label for="waterProximity" class="form-label fw-semibold">Proximity to Water Bodies</label>
                  <select class="form-select" id="waterProximity" name="waterProximity">
                    <option value="none" <%= worksiteData.waterProximity === 'none' ? 'selected' : '' %>>No water bodies nearby</option>
                    <option value="within_100m" <%= worksiteData.waterProximity === 'within_100m' ? 'selected' : '' %>>Within 100m</option>
                    <option value="within_500m" <%= worksiteData.waterProximity === 'within_500m' ? 'selected' : '' %>>Within 500m</option>
                    <option value="within_1km" <%= worksiteData.waterProximity === 'within_1km' ? 'selected' : '' %>>Within 1km</option>
                    <option value="beyond_1km" <%= worksiteData.waterProximity === 'beyond_1km' ? 'selected' : '' %>>Beyond 1km</option>
                    <option value="on_site" <%= worksiteData.waterProximity === 'on_site' ? 'selected' : '' %>>On site</option>
                  </select>
                </div>
                
                <div class="col-md-6">
                  <label for="waterBodyType" class="form-label fw-semibold">Type of Water Body</label>
                  <select class="form-select" id="waterBodyType" name="waterBodyType">
                    <option value="not_applicable" <%= worksiteData.waterBodyType === 'not_applicable' ? 'selected' : '' %>>Not applicable</option>
                    <option value="river" <%= worksiteData.waterBodyType === 'river' ? 'selected' : '' %>>River</option>
                    <option value="stream" <%= worksiteData.waterBodyType === 'stream' ? 'selected' : '' %>>Stream</option>
                    <option value="lake" <%= worksiteData.waterBodyType === 'lake' ? 'selected' : '' %>>Lake</option>
                    <option value="dam" <%= worksiteData.waterBodyType === 'dam' ? 'selected' : '' %>>Dam</option>
                    <option value="wetland" <%= worksiteData.waterBodyType === 'wetland' ? 'selected' : '' %>>Wetland</option>
                    <option value="groundwater" <%= worksiteData.waterBodyType === 'groundwater' ? 'selected' : '' %>>Groundwater</option>
                  </select>
                </div>
              </div>
              
              <div class="mt-3">
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" id="inProtectedArea" name="inProtectedArea" value="true" <%= worksiteData.inProtectedArea ? 'checked' : '' %>>
                  <label class="form-check-label" for="inProtectedArea">🏞️ Site is located in or near a protected area</label>
                </div>
              </div>
            </div>
            
            <!-- ==================== SECTION 4: ACTIVITIES & OPERATIONS ==================== -->
            <div class="form-section mb-5">
              <h5 class="fw-bold mb-3" style="color: #1e3c5c">
                <i class="fas fa-tools me-2"></i>4. Activities & Operations
              </h5>
              
              <div class="mb-4">
                <label class="form-label fw-semibold">Site Overview</label>
                <textarea class="form-control" id="siteOverview" name="siteOverview" rows="2" 
                          placeholder="General overview of the site..."><%= worksiteData.siteOverview %></textarea>
              </div>
              
              <div class="mb-4">
                <label class="form-label fw-semibold">Known Challenges</label>
                <textarea class="form-control" id="knownChallenges" name="knownChallenges" rows="2" 
                          placeholder="e.g., confined spaces, working at heights, nearby traffic..."><%= worksiteData.knownChallenges %></textarea>
                <small class="text-muted">Separate multiple challenges with commas</small>
              </div>
              
              <div class="mb-4">
                <label class="form-label fw-semibold">Primary Activities</label>
                <div class="border rounded p-3 bg-light">
                  <div id="activitiesContainer">
                    <% if (worksiteData.primaryActivities && worksiteData.primaryActivities.length > 0) { %>
                      <% worksiteData.primaryActivities.forEach((activity, idx) => { %>
                        <div class="activity-entry mb-2">
                          <div class="row g-2">
                            <div class="col-md-5">
                              <input type="text" class="form-control" name="primaryActivities[]" value="<%= activity.activity %>" placeholder="Activity name">
                            </div>
                            <div class="col-md-5">
                              <input type="text" class="form-control" name="activityDescriptions[]" value="<%= activity.description %>" placeholder="Brief description">
                            </div>
                            <div class="col-md-2">
                              <button type="button" class="btn btn-outline-danger w-100" onclick="this.closest('.activity-entry').remove()">
                                <i class="fas fa-trash"></i>
                              </button>
                            </div>
                          </div>
                        </div>
                      <% }) %>
                    <% } else { %>
                      <div class="activity-entry mb-2">
                        <div class="row g-2">
                          <div class="col-md-5">
                            <input type="text" class="form-control" name="primaryActivities[]" placeholder="Activity name">
                          </div>
                          <div class="col-md-5">
                            <input type="text" class="form-control" name="activityDescriptions[]" placeholder="Brief description">
                          </div>
                          <div class="col-md-2">
                            <button type="button" class="btn btn-outline-danger w-100" onclick="this.closest('.activity-entry').remove()">
                              <i class="fas fa-trash"></i>
                            </button>
                          </div>
                        </div>
                      </div>
                    <% } %>
                  </div>
                  <button type="button" class="btn btn-sm btn-outline-primary mt-2" onclick="addActivity()">
                    <i class="fas fa-plus me-1"></i> Add Activity
                  </button>
                </div>
              </div>
              
              <!-- Risk Factors -->
              <div class="row g-3">
                <div class="col-md-6">
                  <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="hasWorkAtHeights" name="hasWorkAtHeights" value="true" <%= worksiteData.hasWorkAtHeights ? 'checked' : '' %>>
                    <label class="form-check-label" for="hasWorkAtHeights">🪜 Working at Heights</label>
                  </div>
                  <div id="heightsDetails" class="mt-2 ms-4" style="<%= worksiteData.hasWorkAtHeights ? 'display: block;' : 'display: none;' %>">
                    <input type="number" class="form-control form-control-sm mb-2" name="maxHeight" placeholder="Maximum height (meters)" value="<%= worksiteData.maxHeight %>">
                    <input type="text" class="form-control form-control-sm" name="fallProtection" placeholder="Fall protection used" value="<%= worksiteData.fallProtection %>">
                  </div>
                </div>
                
                <div class="col-md-6">
                  <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="hasConfinedSpaces" name="hasConfinedSpaces" value="true" <%= worksiteData.hasConfinedSpaces ? 'checked' : '' %>>
                    <label class="form-check-label" for="hasConfinedSpaces">📦 Confined Spaces</label>
                  </div>
                  <div id="confinedDetails" class="mt-2 ms-4" style="<%= worksiteData.hasConfinedSpaces ? 'display: block;' : 'display: none;' %>">
                    <input type="text" class="form-control form-control-sm" name="confinedSpacesDesc" placeholder="Describe confined spaces" value="<%= worksiteData.confinedSpacesDesc %>">
                  </div>
                </div>
                
                <div class="col-md-6">
                  <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="hasHeavyEquipment" name="hasHeavyEquipment" value="true" <%= worksiteData.hasHeavyEquipment ? 'checked' : '' %>>
                    <label class="form-check-label" for="hasHeavyEquipment">🚜 Heavy Equipment</label>
                  </div>
                  <div id="equipmentDetails" class="mt-2 ms-4" style="<%= worksiteData.hasHeavyEquipment ? 'display: block;' : 'display: none;' %>">
                    <input type="text" class="form-control form-control-sm" name="equipmentTypes" placeholder="Types of equipment" value="<%= worksiteData.equipmentTypes %>">
                  </div>
                </div>
                
                <div class="col-md-6">
                  <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="hasHazardousSubstances" name="hasHazardousSubstances" value="true" <%= worksiteData.hasHazardousSubstances ? 'checked' : '' %>>
                    <label class="form-check-label" for="hasHazardousSubstances">⚠️ Hazardous Substances</label>
                  </div>
                  <div id="hazardousDetails" class="mt-2 ms-4" style="<%= worksiteData.hasHazardousSubstances ? 'display: block;' : 'display: none;' %>">
                    <input type="text" class="form-control form-control-sm" name="hazardousSubstancesList" placeholder="List substances" value="<%= worksiteData.hazardousSubstancesList %>">
                  </div>
                </div>
                
                <div class="col-md-6">
                  <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="hasExcavation" name="hasExcavation" value="true" <%= worksiteData.hasExcavation ? 'checked' : '' %>>
                    <label class="form-check-label" for="hasExcavation">⛏️ Excavation Work</label>
                  </div>
                  <div id="excavationDetails" class="mt-2 ms-4" style="<%= worksiteData.hasExcavation ? 'display: block;' : 'display: none;' %>">
                    <input type="number" class="form-control form-control-sm mb-2" name="excavationDepth" placeholder="Maximum depth (meters)" value="<%= worksiteData.excavationDepth %>">
                    <input type="text" class="form-control form-control-sm" name="utilitiesNearby" placeholder="Nearby utilities" value="<%= worksiteData.utilitiesNearby %>">
                  </div>
                </div>
                
                <div class="col-md-6">
                  <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="hasElectricalWork" name="hasElectricalWork" value="true" <%= worksiteData.hasElectricalWork ? 'checked' : '' %>>
                    <label class="form-check-label" for="hasElectricalWork">⚡ Electrical Work</label>
                  </div>
                  <div id="electricalDetails" class="mt-2 ms-4" style="<%= worksiteData.hasElectricalWork ? 'display: block;' : 'display: none;' %>">
                    <input type="text" class="form-control form-control-sm" name="voltageLevels" placeholder="Voltage levels" value="<%= worksiteData.voltageLevels %>">
                  </div>
                </div>
              </div>
            </div>
            
            <!-- ==================== SECTION 5: HEALTH & SAFETY RESOURCES ==================== -->
            <div class="form-section mb-5">
              <h5 class="fw-bold mb-3" style="color: #1e3c5c">
                <i class="fas fa-ambulance me-2"></i>5. Health & Safety Resources
              </h5>
              
              <div class="row g-3">
                <div class="col-md-4">
                  <label class="form-label fw-semibold">Safety Personnel</label>
                  <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="hasSafetyOfficer" name="hasSafetyOfficer" value="true" <%= worksiteData.hasSafetyOfficer ? 'checked' : '' %>>
                    <label class="form-check-label" for="hasSafetyOfficer">Dedicated Safety Officer</label>
                  </div>
                  <div id="officerCount" class="mt-2" style="<%= worksiteData.hasSafetyOfficer ? 'display: block;' : 'display: none;' %>">
                    <input type="number" class="form-control" name="safetyOfficerCount" placeholder="Number of safety officers" value="<%= worksiteData.safetyOfficerCount %>">
                  </div>
                </div>
                
                <div class="col-md-4">
                  <label class="form-label fw-semibold">Safety Committee</label>
                  <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="hasSafetyCommittee" name="hasSafetyCommittee" value="true" <%= worksiteData.hasSafetyCommittee ? 'checked' : '' %>>
                    <label class="form-check-label" for="hasSafetyCommittee">Has Safety Committee</label>
                  </div>
                  <div id="committeeMembers" class="mt-2" style="<%= worksiteData.hasSafetyCommittee ? 'display: block;' : 'display: none;' %>">
                    <input type="number" class="form-control" name="committeeMembers" placeholder="Number of members" value="<%= worksiteData.committeeMembers %>">
                  </div>
                </div>
                
                <div class="col-md-4">
                  <label class="form-label fw-semibold">First Aid</label>
                  <input type="number" class="form-control" name="firstAidBoxes" placeholder="First aid boxes" value="<%= worksiteData.firstAidBoxes %>">
                  <input type="number" class="form-control mt-2" name="trainedFirstAiders" placeholder="Trained first aiders" value="<%= worksiteData.trainedFirstAiders %>">
                </div>
              </div>
              
              <div class="row g-3 mt-2">
                <div class="col-md-6">
                  <label class="form-label fw-semibold">Medical Facilities</label>
                  <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="hasOnSiteClinic" name="hasOnSiteClinic" value="true" <%= worksiteData.hasOnSiteClinic ? 'checked' : '' %>>
                    <label class="form-check-label" for="hasOnSiteClinic">On-site Clinic</label>
                  </div>
                  <input type="text" class="form-control mt-2" name="nearestHospital" placeholder="Nearest hospital" value="<%= worksiteData.nearestHospital %>">
                  <input type="text" class="form-control mt-2" name="emergencyContact" placeholder="Emergency contact" value="<%= worksiteData.emergencyContact %>">
                </div>
                
                <div class="col-md-6">
                  <label class="form-label fw-semibold">Fire Safety</label>
                  <div class="row">
                    <div class="col-6">
                      <input type="number" class="form-control" name="fireExtinguishers" placeholder="Extinguishers" value="<%= worksiteData.fireExtinguishers %>">
                    </div>
                    <div class="col-6">
                      <input type="number" class="form-control" name="fireHoses" placeholder="Fire hoses" value="<%= worksiteData.fireHoses %>">
                    </div>
                  </div>
                  <div class="form-check mt-2">
                    <input class="form-check-input" type="checkbox" id="hasEvacuationPlan" name="hasEvacuationPlan" value="true" <%= worksiteData.hasEvacuationPlan ? 'checked' : '' %>>
                    <label class="form-check-label" for="hasEvacuationPlan">Has Evacuation Plan</label>
                  </div>
                  <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="hasAssemblyPoint" name="hasAssemblyPoint" value="true" <%= worksiteData.hasAssemblyPoint ? 'checked' : '' %>>
                    <label class="form-check-label" for="hasAssemblyPoint">Has Assembly Point</label>
                  </div>
                </div>
              </div>
            </div>
            
            <!-- Assigned Safety Officers (Read-only for edit) -->
            <% if (worksite.assignedSafetyOfficers && worksite.assignedSafetyOfficers.length > 0) { %>
            <div class="mb-4">
              <h5 class="fw-bold mb-3" style="color: #1e3c5c">Currently Assigned Safety Officers</h5>
              <div class="row g-3">
                <% worksite.assignedSafetyOfficers.forEach(assignment => { %>
                <div class="col-md-6">
                  <div class="d-flex align-items-center p-2 rounded bg-light">
                    <div class="rounded-circle bg-primary bg-opacity-10 p-2 me-2">
                      <i class="fas fa-user-tie" style="color: #2196f3;"></i>
                    </div>
                    <div>
                      <strong><%= assignment.officer?.name || 'Unknown' %></strong><br>
                      <small class="text-muted">Role: <%= assignment.role %></small>
                      <% if (assignment.isPrimary) { %>
                      <span class="badge bg-success ms-2">Primary</span>
                      <% } %>
                    </div>
                  </div>
                </div>
                <% }) %>
              </div>
              <p class="text-muted small mt-2">
                <i class="fas fa-info-circle me-1"></i> To modify officer assignments, use the Assign Officers page.
              </p>
            </div>
            <% } %>
            
            <div class="d-flex gap-2 justify-content-end mt-4 pt-3 border-top">
              <a href="/worksites/<%= worksite._id %>" class="btn btn-secondary btn-lg px-4">Cancel</a>
              <button type="submit" class="btn btn-primary btn-lg px-4" style="background: linear-gradient(135deg, #2196f3 0%, #1976d2 100%); border: none;">
                <i class="fas fa-save me-2"></i> Update Worksite
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  // Show/hide conditional fields
  const toggleFields = {
    hasWorkAtHeights: 'heightsDetails',
    hasConfinedSpaces: 'confinedDetails',
    hasHeavyEquipment: 'equipmentDetails',
    hasHazardousSubstances: 'hazardousDetails',
    hasExcavation: 'excavationDetails',
    hasElectricalWork: 'electricalDetails',
    hasSafetyOfficer: 'officerCount',
    hasSafetyCommittee: 'committeeMembers'
  };
  
  for (const [checkboxId, detailsId] of Object.entries(toggleFields)) {
    const checkbox = document.getElementById(checkboxId);
    const details = document.getElementById(detailsId);
    if (checkbox && details) {
      checkbox.addEventListener('change', function() {
        details.style.display = this.checked ? 'block' : 'none';
      });
    }
  }
  
  // Add activity function
  function addActivity() {
    const container = document.getElementById('activitiesContainer');
    const newEntry = document.createElement('div');
    newEntry.className = 'activity-entry mb-2';
    newEntry.innerHTML = `
      <div class="row g-2">
        <div class="col-md-5">
          <input type="text" class="form-control" name="primaryActivities[]" placeholder="Activity name">
        </div>
        <div class="col-md-5">
          <input type="text" class="form-control" name="activityDescriptions[]" placeholder="Brief description">
        </div>
        <div class="col-md-2">
          <button type="button" class="btn btn-outline-danger w-100" onclick="this.closest('.activity-entry').remove()">
            <i class="fas fa-trash"></i>
          </button>
        </div>
      </div>
    `;
    container.appendChild(newEntry);
  }
</script>

<style>
  .form-section {
    border-left: 4px solid #2196f3;
    padding-left: 1.5rem;
  }
  
  .form-control:focus, .form-select:focus {
    border-color: #2196f3;
    box-shadow: 0 0 0 0.2rem rgba(33, 150, 243, 0.25);
  }
  
  .form-check-input:checked {
    background-color: #2196f3;
    border-color: #2196f3;
  }
  
  .badge {
    font-size: 0.9rem;
    padding: 0.5rem 1rem;
  }
</style>

<%- include('../partials/footer') %>