<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="main-wrapper">
  <div class="content container py-4">
    <!-- Work Area Style Header -->
    <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
      <div>
        <h3 class="mb-1">
          <i class="fas fa-hard-hat me-2" style="color: #26a69a;"></i>
          All Worksites
        </h3>
        <div class="d-flex gap-2">
          <span class="badge text-bg-secondary">
            <i class="fas fa-chart-line me-1"></i> <%= worksites.length %> Total
          </span>
          <span class="badge text-bg-success">
            <i class="fas fa-check-circle me-1"></i> <%= worksites.filter(w => w.status === 'active').length %> Active
          </span>
        </div>
      </div>
      <span class="text-muted small">
        <i class="fas fa-user me-1"></i> Welcome back, <strong><%= user.safetyOfficer?.name || user.email %></strong>
      </span>
    </div>

    <!-- Search & Filter Bar - Work Area Style -->
    <div class="row mb-4">
      <div class="col-12">
        <div class="card border-0 shadow-sm" style="border-radius: 16px;">
          <div class="card-body p-3">
            <form method="GET" class="row g-2">
              <div class="col-md-6">
                <div class="input-group">
                  <span class="input-group-text bg-light border-0">
                    <i class="fas fa-search text-muted"></i>
                  </span>
                  <input type="text" class="form-control border-0 bg-light" name="search" 
                         placeholder="Search worksites..." value="<%= typeof search !== 'undefined' ? search : '' %>">
                </div>
              </div>
              <div class="col-md-3">
                <select class="form-select border-0 bg-light" name="status">
                  <option value="">All Status</option>
                  <option value="active" <%= typeof status !== 'undefined' && status === 'active' ? 'selected' : '' %>>Active</option>
                  <option value="inactive" <%= typeof status !== 'undefined' && status === 'inactive' ? 'selected' : '' %>>Inactive</option>
                  <option value="under_review" <%= typeof status !== 'undefined' && status === 'under_review' ? 'selected' : '' %>>Under Review</option>
                  <option value="completed" <%= typeof status !== 'undefined' && status === 'completed' ? 'selected' : '' %>>Completed</option>
                </select>
              </div>
              <div class="col-md-3">
                <button type="submit" class="btn w-100" style="background: #26a69a; color: white; border: none; border-radius: 40px;">
                  <i class="fas fa-filter me-1"></i> Filter
                </button>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>

    <!-- Quick Actions Row (like work area action buttons) -->
    <div class="d-flex gap-2 justify-content-end mb-4">
      <a href="/worksites/create" class="btn btn-outline-primary btn-sm">
        <i class="fas fa-plus-circle me-1"></i> New Worksite
      </a>
    </div>

    <!-- Worksites Table - Work Area Styled -->
    <% if (worksites && worksites.length > 0) { %>
    <div class="row">
      <div class="col-12">
        <div class="card border-0 shadow-sm" style="border-radius: 16px;">
          <div class="card-body p-0">
            <div class="table-responsive">
              <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                  <tr>
                    <th class="px-4 py-3" style="border-radius: 16px 0 0 0;">Worksite</th>
                    <th class="py-3">Location</th>
                    <th class="py-3 text-center" style="border-radius: 0 16px 0 0;">Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% worksites.forEach(worksite => { %>
                  <tr class="hover-row">
                    <td class="px-4">
                      <div class="d-flex align-items-center">
                        <div class="rounded-circle d-flex align-items-center justify-content-center me-3" 
                             style="background: linear-gradient(135deg, #26a69a 0%, #00897b 100%); width: 40px; height: 40px;">
                          <i class="fas fa-hard-hat text-white" style="font-size: 1rem;"></i>
                        </div>
                        <div>
                          <div class="d-flex align-items-center gap-2 flex-wrap">
                            <strong class="fs-6"><%= worksite.name %></strong>
                            <span class="badge <%= 
                              worksite.status === 'active' ? 'bg-success' : 
                              worksite.status === 'inactive' ? 'bg-secondary' : 
                              worksite.status === 'under_review' ? 'bg-warning text-dark' : 
                              'bg-info' 
                            %>" style="border-radius: 40px; font-size: 0.65rem;"><%= worksite.status %></span>
                            <span class="badge bg-light text-dark" style="border-radius: 40px; font-size: 0.65rem;">
                              <i class="fas fa-hashtag me-1"></i> <%= worksite.worksiteNumber %>
                            </span>
                          </div>
                          <div class="d-flex gap-3 mt-1">
                            <small class="text-muted">
                              <i class="fas fa-tag me-1" style="color: #26a69a;"></i> <%= worksite.siteType %>
                            </small>
                            <small class="text-muted">
                              <i class="fas fa-layer-group me-1" style="color: #26a69a;"></i> <%= worksite.workAreas?.length || 0 %> areas
                            </small>
                            <small class="text-muted">
                              <i class="fas fa-users me-1" style="color: #26a69a;"></i> <%= worksite.assignedSafetyOfficers?.length || 0 %> officers
                            </small>
                            <small class="text-muted">
                              <i class="fas fa-chart-line me-1" style="color: #26a69a;"></i> <%= worksite.performance?.overallSafetyScore || 100 %>% score
                            </small>
                          </div>
                          <% if (worksite.description) { %>
                          <small class="text-muted d-block mt-1">
                            <i class="fas fa-align-left me-1"></i> <%= worksite.description.substring(0, 60) %><%= worksite.description.length > 60 ? '...' : '' %>
                          </small>
                          <% } %>
                        </div>
                      </div>
                    </td>
                    <td>
                      <i class="fas fa-map-marker-alt me-1" style="color: #f44336;"></i>
                      <%= worksite.location %>
                    </td>
                    <td class="text-center">
                      <div class="d-flex gap-2 justify-content-center">
                        <a href="/worksites/<%= worksite._id %>" class="btn btn-sm btn-outline-primary" title="View" style="border-radius: 40px; border-color: #26a69a; color: #26a69a;">
                          <i class="fas fa-eye"></i>
                        </a>
                        <a href="/worksites/<%= worksite._id %>/edit" class="btn btn-sm btn-outline-secondary" title="Edit" style="border-radius: 40px;">
                          <i class="fas fa-edit"></i>
                        </a>
                        <div class="dropdown">
                          <button class="btn btn-sm btn-outline-info dropdown-toggle" type="button" data-bs-toggle="dropdown" style="border-radius: 40px; border-color: #5f2c82; color: #5f2c82;">
                            <i class="fas fa-plus"></i>
                          </button>
                          <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item" href="/work-areas/create?worksiteId=<%= worksite._id %>"><i class="fas fa-map-marked-alt me-2" style="color: #26a69a;"></i>Add Work Area</a></li>
                            <li><a class="dropdown-item" href="/incidents/report?worksiteId=<%= worksite._id %>"><i class="fas fa-flag me-2" style="color: #f44336;"></i>Report Incident</a></li>
                            <li><a class="dropdown-item" href="/safety-talks/generate?worksiteId=<%= worksite._id %>"><i class="fas fa-robot me-2" style="color: #5f2c82;"></i>Generate Talk</a></li>
                          </ul>
                        </div>
                      </div>
                    </td>
                  </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Pagination - Work Area Styled -->
    <% if (pagination && pagination.pages > 1) { %>
    <div class="row mt-5">
      <div class="col-12">
        <nav aria-label="Worksites pagination">
          <ul class="pagination justify-content-center">
            <li class="page-item <%= pagination.page === 1 ? 'disabled' : '' %>">
              <a class="page-link" href="?page=<%= pagination.page - 1 %>&search=<%= search || '' %>&status=<%= status || '' %>" style="border-radius: 40px; color: #26a69a;">
                <i class="fas fa-chevron-left"></i>
              </a>
            </li>
            
            <% for (let i = 1; i <= pagination.pages; i++) { %>
              <% if (i >= pagination.page - 2 && i <= pagination.page + 2) { %>
              <li class="page-item <%= i === pagination.page ? 'active' : '' %>">
                <a class="page-link" href="?page=<%= i %>&search=<%= search || '' %>&status=<%= status || '' %>" 
                   style="border-radius: 40px; <%= i === pagination.page ? 'background: #26a69a; color: white; border-color: #26a69a;' : 'color: #26a69a;' %>">
                  <%= i %>
                </a>
              </li>
              <% } %>
            <% } %>
            
            <li class="page-item <%= pagination.page === pagination.pages ? 'disabled' : '' %>">
              <a class="page-link" href="?page=<%= pagination.page + 1 %>&search=<%= search || '' %>&status=<%= status || '' %>" style="border-radius: 40px; color: #26a69a;">
                <i class="fas fa-chevron-right"></i>
              </a>
            </li>
          </ul>
        </nav>
      </div>
    </div>
    <% } %>
    
    <% } else { %>
    <!-- Empty State - Work Area Styled -->
    <div class="row">
      <div class="col-12">
        <div class="card border-0 bg-light" style="border-radius: 24px;">
          <div class="card-body text-center p-5">
            <div class="mb-4">
              <i class="fas fa-hard-hat fa-4x" style="color: #26a69a;"></i>
            </div>
            <h3 class="fw-bold mb-3" style="color: #1e3c5c;">No Worksites Found</h3>
            <p class="text-muted mb-4">
              <%= search || status ? 'No worksites match your search criteria.' : 'Get started by creating your first worksite.' %>
            </p>
            <% if (search || status) { %>
            <a href="/worksites/my-worksites" class="btn btn-outline-primary btn-lg px-4" style="border-radius: 40px; border-color: #26a69a; color: #26a69a;">
              <i class="fas fa-redo-alt me-2"></i> Clear Filters
            </a>
            <% } else { %>
            <a href="/worksites/create" class="btn btn-lg px-4" style="background: #26a69a; color: white; border: none; border-radius: 40px;">
              <i class="fas fa-plus-circle me-2"></i> Create First Worksite
            </a>
            <% } %>
          </div>
        </div>
      </div>
    </div>
    <% } %>
  </div>
</div>

<style>
  .main-wrapper {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }
  
  .content {
    flex: 1;
  }
  
  .hover-row {
    transition: background-color 0.2s ease;
  }
  .hover-row:hover {
    background-color: #f0f7f5;
  }
  
  .page-link {
    color: #26a69a;
    border-radius: 40px;
    margin: 0 2px;
    border: 1px solid #dee2e6;
  }
  .page-item.active .page-link {
    background: #26a69a;
    border-color: #26a69a;
    color: white;
  }
  .page-item.disabled .page-link {
    color: #6c757d;
  }
  
  .dropdown-menu {
    border: none;
    box-shadow: 0 5px 20px rgba(0,0,0,0.1);
    border-radius: 16px;
    padding: 0.5rem;
  }
  
  .dropdown-item {
    border-radius: 40px;
    padding: 0.5rem 1rem;
    margin: 2px 0;
    font-size: 0.9rem;
  }
  
  .dropdown-item:hover {
    background: #f0f7f5;
  }
  
  .dropdown-item i {
    width: 20px;
  }
  
  .table th {
    font-weight: 600;
    color: #495057;
    font-size: 0.9rem;
  }
  
  .table td {
    font-size: 0.9rem;
  }
  
  .badge {
    font-weight: 500;
    font-size: 0.75rem;
    padding: 0.4rem 0.6rem;
  }
  
  .btn-outline-primary {
    border-color: #26a69a;
    color: #26a69a;
  }
  .btn-outline-primary:hover {
    background-color: #26a69a;
    color: white;
  }
  .btn-outline-info {
    border-color: #5f2c82;
    color: #5f2c82;
  }
  .btn-outline-info:hover {
    background-color: #5f2c82;
    color: white;
  }
  .btn-outline-secondary:hover {
    background-color: #6c757d;
    color: white;
  }
</style>

<%- include('../partials/footer') %>