<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-8">
      <div class="card shadow-lg border-0">
        <div class="card-header bg-transparent border-0 pt-4 px-4">
          <h3 class="fw-bold mb-0" style="color: #2196f3">
            <i class="fas fa-plus-circle me-2"></i>Create New Worksite
          </h3>
          <p class="text-muted">Add a new worksite to your organization</p>
        </div>
        <div class="card-body p-4">
          <form action="/worksites/create" method="POST">
            <!-- Basic Information -->
            <div class="mb-4">
              <h5 class="fw-bold mb-3" style="color: #1e3c5c">Basic Information</h5>
              <div class="row g-3">
                <div class="col-md-6">
                  <label for="name" class="form-label fw-semibold">Worksite Name *</label>
                  <input type="text" class="form-control form-control-lg" id="name" name="name" 
                         placeholder="e.g., Lusaka City Mall Construction" required>
                </div>
                <div class="col-md-6">
                  <label for="location" class="form-label fw-semibold">Location *</label>
                  <input type="text" class="form-control form-control-lg" id="location" name="location" 
                         placeholder="e.g., Lusaka, Zambia" required>
                </div>
                <div class="col-md-6">
                  <label for="siteType" class="form-label fw-semibold">Site Type *</label>
                  <select class="form-select form-select-lg" id="siteType" name="siteType" required>
                    <option value="">Select site type</option>
                    <option value="construction">Construction</option>
                    <option value="mining">Mining</option>
                    <option value="manufacturing">Manufacturing</option>
                    <option value="oil_gas">Oil & Gas</option>
                    <option value="warehouse">Warehouse</option>
                    <option value="office">Office</option>
                    <option value="other">Other</option>
                  </select>
                </div>
                <div class="col-md-6">
                  <label for="clientName" class="form-label fw-semibold">Client Name</label>
                  <input type="text" class="form-control form-control-lg" id="clientName" name="clientName" 
                         placeholder="e.g., Zambia National Construction">
                </div>
                <div class="col-md-6">
                  <label for="clientContact" class="form-label fw-semibold">Client Contact</label>
                  <input type="text" class="form-control form-control-lg" id="clientContact" name="clientContact" 
                         placeholder="e.g., +260977123456">
                </div>
                <div class="col-12">
                  <label for="description" class="form-label fw-semibold">Description</label>
                  <textarea class="form-control" id="description" name="description" rows="3" 
                            placeholder="Brief description of the worksite..."></textarea>
                </div>
              </div>
            </div>

            <!-- Site Context for AI -->
            <div class="mb-4">
              <h5 class="fw-bold mb-3" style="color: #1e3c5c">Site Context <small class="text-muted">(Optional but helpful for AI)</small></h5>
              <div class="row g-3">
                <div class="col-12">
                  <label for="siteOverview" class="form-label fw-semibold">Site Overview</label>
                  <textarea class="form-control" id="siteOverview" name="siteOverview" rows="2" 
                            placeholder="General overview of the site..."></textarea>
                </div>
                <div class="col-12">
                  <label for="knownChallenges" class="form-label fw-semibold">Known Challenges</label>
                  <textarea class="form-control" id="knownChallenges" name="knownChallenges" rows="2" 
                            placeholder="e.g., confined spaces, working at heights, nearby traffic..."></textarea>
                  <small class="text-muted">Separate multiple challenges with commas</small>
                </div>
              </div>
            </div>

            <!-- Shifts Configuration -->
            <div class="mb-4">
              <h5 class="fw-bold mb-3" style="color: #1e3c5c">Shift Configuration</h5>
              <div class="row g-3">
                <div class="col-md-4">
                  <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="shiftMorning" name="shifts[]" value="morning">
                    <label class="form-check-label" for="shiftMorning">
                      <i class="fas fa-sun me-1 text-warning"></i> Morning Shift
                    </label>
                  </div>
                </div>
                <div class="col-md-4">
                  <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="shiftAfternoon" name="shifts[]" value="afternoon">
                    <label class="form-check-label" for="shiftAfternoon">
                      <i class="fas fa-cloud-sun me-1 text-info"></i> Afternoon Shift
                    </label>
                  </div>
                </div>
                <div class="col-md-4">
                  <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="shiftNight" name="shifts[]" value="night">
                    <label class="form-check-label" for="shiftNight">
                      <i class="fas fa-moon me-1 text-secondary"></i> Night Shift
                    </label>
                  </div>
                </div>
              </div>
            </div>

            <% if (safetyOfficers && safetyOfficers.length > 0) { %>
            <!-- Assign Safety Officers -->
            <div class="mb-4">
              <h5 class="fw-bold mb-3" style="color: #1e3c5c">Assign Safety Officers</h5>
              <p class="text-muted small">Select officers to assign to this worksite</p>
              <div class="row g-3">
                <% safetyOfficers.forEach(officer => { %>
                <div class="col-md-6">
                  <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="assignedOfficers[]" value="<%= officer._id %>" id="officer_<%= officer._id %>">
                    <label class="form-check-label" for="officer_<%= officer._id %>">
                      <strong><%= officer.name %></strong><br>
                      <small class="text-muted"><%= officer.email %></small>
                    </label>
                  </div>
                </div>
                <% }) %>
              </div>
            </div>
            <% } %>

            <div class="d-flex gap-2 justify-content-end mt-4">
              <a href="/dashboard/admin" class="btn btn-secondary btn-lg px-4">Cancel</a>
              <button type="submit" class="btn btn-primary btn-lg px-4" style="background: linear-gradient(135deg, #2196f3 0%, #1976d2 100%); border: none;">
                <i class="fas fa-save me-2"></i> Create Worksite
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>