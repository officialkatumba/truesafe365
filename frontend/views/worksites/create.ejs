<!-- frontend/views/worksites/create.ejs -->
<%- include('../partials/header') %> <%- include('../partials/navbar') %>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-10">
      <div class="card shadow-lg border-0">
        <div class="card-header bg-transparent border-0 pt-4 px-4">
          <div class="d-flex justify-content-between align-items-center">
            <div>
              <h3 class="fw-bold mb-0" style="color: #2196f3">
                <i class="fas fa-plus-circle me-2"></i>Create New Worksite
              </h3>
              <p class="text-muted">
                Tell us about your worksite. The more information you provide,
                the better we can help with compliance.
              </p>
            </div>
            <span class="badge bg-info">Step 1 of 5</span>
          </div>
        </div>

        <div class="card-body p-4">
          <form action="/worksites/create" method="POST" id="worksiteForm">
            <!-- ==================== SECTION 1: BASIC INFORMATION ==================== -->
            <div class="form-section mb-5">
              <h5 class="fw-bold mb-3" style="color: #1e3c5c">
                <i class="fas fa-info-circle me-2"></i>1. Basic Information
              </h5>

              <div class="row g-3">
                <div class="col-md-6">
                  <label for="name" class="form-label fw-semibold"
                    >Worksite Name *</label
                  >
                  <input
                    type="text"
                    class="form-control form-control-lg"
                    id="name"
                    name="name"
                    placeholder="e.g., Lusaka City Mall Construction"
                    required
                  />
                </div>

                <div class="col-md-6">
                  <label for="location" class="form-label fw-semibold"
                    >Location *</label
                  >
                  <input
                    type="text"
                    class="form-control form-control-lg"
                    id="location"
                    name="location"
                    placeholder="e.g., Lusaka, Zambia"
                    required
                  />
                </div>

                <div class="col-md-6">
                  <label for="siteType" class="form-label fw-semibold"
                    >Site Type *</label
                  >
                  <select
                    class="form-select form-select-lg"
                    id="siteType"
                    name="siteType"
                    required
                  >
                    <option value="">Select site type</option>
                    <option value="construction">🏗️ Construction</option>
                    <option value="mining">⛏️ Mining</option>
                    <option value="manufacturing">🏭 Manufacturing</option>
                    <option value="oil_gas">🛢️ Oil & Gas</option>
                    <option value="warehouse">📦 Warehouse</option>
                    <option value="office">💼 Office</option>
                    <option value="agriculture">🌾 Agriculture</option>
                    <option value="other">Other</option>
                  </select>
                </div>

                <div class="col-md-6">
                  <label for="clientName" class="form-label fw-semibold"
                    >Client/Company Name</label
                  >
                  <input
                    type="text"
                    class="form-control"
                    id="clientName"
                    name="clientName"
                    placeholder="e.g., Zambia National Construction"
                  />
                </div>

                <div class="col-md-6">
                  <label for="clientEmail" class="form-label fw-semibold"
                    >Client Email</label
                  >
                  <input
                    type="email"
                    class="form-control"
                    id="clientEmail"
                    name="clientEmail"
                    placeholder="client@company.com"
                  />
                </div>

                <div class="col-md-6">
                  <label for="clientContact" class="form-label fw-semibold"
                    >Client Phone</label
                  >
                  <input
                    type="text"
                    class="form-control"
                    id="clientContact"
                    name="clientContact"
                    placeholder="+260 XXX XXX XXX"
                  />
                </div>

                <div class="col-12">
                  <label for="description" class="form-label fw-semibold"
                    >Brief Description</label
                  >
                  <textarea
                    class="form-control"
                    id="description"
                    name="description"
                    rows="2"
                    placeholder="What is the main purpose of this worksite? What will be built/produced?"
                  ></textarea>
                </div>
              </div>
            </div>

            <!-- ==================== SECTION 2: PROJECT TIMELINE & WORKFORCE ==================== -->
            <div class="form-section mb-5">
              <h5 class="fw-bold mb-3" style="color: #1e3c5c">
                <i class="fas fa-calendar-alt me-2"></i>2. Project Timeline &
                Workforce
              </h5>

              <div class="row g-3">
                <div class="col-md-4">
                  <label for="startDate" class="form-label fw-semibold"
                    >Expected Start Date</label
                  >
                  <input
                    type="date"
                    class="form-control"
                    id="startDate"
                    name="startDate"
                  />
                </div>

                <div class="col-md-4">
                  <label for="endDate" class="form-label fw-semibold"
                    >Expected End Date</label
                  >
                  <input
                    type="date"
                    class="form-control"
                    id="endDate"
                    name="endDate"
                  />
                </div>

                <div class="col-md-4">
                  <label for="durationMonths" class="form-label fw-semibold"
                    >Estimated Duration (months)</label
                  >
                  <input
                    type="number"
                    class="form-control"
                    id="durationMonths"
                    name="durationMonths"
                    step="1"
                  />
                </div>
              </div>

              <div class="row g-3 mt-2">
                <div class="col-md-4">
                  <label for="totalWorkers" class="form-label fw-semibold"
                    >Estimated Total Workers</label
                  >
                  <input
                    type="number"
                    class="form-control"
                    id="totalWorkers"
                    name="totalWorkers"
                    placeholder="e.g., 50"
                  />
                </div>

                <div class="col-md-4">
                  <label for="peakWorkers" class="form-label fw-semibold"
                    >Peak Worker Count</label
                  >
                  <input
                    type="number"
                    class="form-control"
                    id="peakWorkers"
                    name="peakWorkers"
                    placeholder="e.g., 100"
                  />
                </div>

                <div class="col-md-4">
                  <label for="contractors" class="form-label fw-semibold"
                    >Number of Contractors</label
                  >
                  <input
                    type="number"
                    class="form-control"
                    id="contractors"
                    name="contractors"
                    placeholder="e.g., 10"
                  />
                </div>
              </div>

              <div class="mt-3">
                <label class="form-label fw-semibold">Shifts</label>
                <div class="row g-3">
                  <div class="col-md-4">
                    <div class="form-check">
                      <input
                        class="form-check-input"
                        type="checkbox"
                        id="shiftMorning"
                        name="shifts"
                        value="morning"
                      />
                      <label class="form-check-label" for="shiftMorning">
                        🌅 Morning Shift (6:00 - 14:00)
                      </label>
                    </div>
                  </div>
                  <div class="col-md-4">
                    <div class="form-check">
                      <input
                        class="form-check-input"
                        type="checkbox"
                        id="shiftAfternoon"
                        name="shifts"
                        value="afternoon"
                      />
                      <label class="form-check-label" for="shiftAfternoon">
                        ☀️ Afternoon Shift (14:00 - 22:00)
                      </label>
                    </div>
                  </div>
                  <div class="col-md-4">
                    <div class="form-check">
                      <input
                        class="form-check-input"
                        type="checkbox"
                        id="shiftNight"
                        name="shifts"
                        value="night"
                      />
                      <label class="form-check-label" for="shiftNight">
                        🌙 Night Shift (22:00 - 6:00)
                      </label>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <!-- ==================== SECTION 3: SITE CHARACTERISTICS ==================== -->
            <div class="form-section mb-5">
              <h5 class="fw-bold mb-3" style="color: #1e3c5c">
                <i class="fas fa-map-marked-alt me-2"></i>3. Site
                Characteristics
              </h5>

              <div class="row g-3">
                <div class="col-md-4">
                  <label for="siteArea" class="form-label fw-semibold"
                    >Site Area (hectares)</label
                  >
                  <input
                    type="number"
                    class="form-control"
                    id="siteArea"
                    name="siteArea"
                    step="0.1"
                    placeholder="e.g., 10.5"
                  />
                </div>

                <div class="col-md-4">
                  <label for="terrain" class="form-label fw-semibold"
                    >Terrain Type</label
                  >
                  <select class="form-select" id="terrain" name="terrain">
                    <option value="flat">Flat</option>
                    <option value="gentle_slope">Gentle Slope</option>
                    <option value="steep_slope">Steep Slope</option>
                    <option value="mountainous">Mountainous</option>
                    <option value="undulating">Undulating</option>
                  </select>
                </div>

                <div class="col-md-4">
                  <label for="soilType" class="form-label fw-semibold"
                    >Soil Type</label
                  >
                  <select class="form-select" id="soilType" name="soilType">
                    <option value="clay">Clay</option>
                    <option value="sandy">Sandy</option>
                    <option value="loamy">Loamy</option>
                    <option value="rocky">Rocky</option>
                    <option value="mixed">Mixed</option>
                    <option value="unknown">Unknown</option>
                  </select>
                </div>
              </div>

              <div class="row g-3 mt-2">
                <div class="col-md-6">
                  <label for="waterProximity" class="form-label fw-semibold"
                    >Proximity to Water Bodies</label
                  >
                  <select
                    class="form-select"
                    id="waterProximity"
                    name="waterProximity"
                  >
                    <option value="none">No water bodies nearby</option>
                    <option value="within_100m">Within 100m</option>
                    <option value="within_500m">Within 500m</option>
                    <option value="within_1km">Within 1km</option>
                    <option value="beyond_1km">Beyond 1km</option>
                    <option value="on_site">On site</option>
                  </select>
                </div>

                <div class="col-md-6">
                  <label for="waterBodyType" class="form-label fw-semibold"
                    >Type of Water Body</label
                  >
                  <select
                    class="form-select"
                    id="waterBodyType"
                    name="waterBodyType"
                  >
                    <option value="not_applicable">Not applicable</option>
                    <option value="river">River</option>
                    <option value="stream">Stream</option>
                    <option value="lake">Lake</option>
                    <option value="dam">Dam</option>
                    <option value="wetland">Wetland</option>
                    <option value="groundwater">Groundwater</option>
                  </select>
                </div>
              </div>

              <div class="mt-3">
                <div class="form-check">
                  <input
                    class="form-check-input"
                    type="checkbox"
                    id="inProtectedArea"
                    name="inProtectedArea"
                    value="true"
                  />
                  <label class="form-check-label" for="inProtectedArea">
                    🏞️ Site is located in or near a protected area (National
                    Park, Game Management Area, Forest Reserve, Wetland)
                  </label>
                </div>
              </div>
            </div>

            <!-- ==================== SECTION 4: ACTIVITIES & OPERATIONS ==================== -->
            <div class="form-section mb-5">
              <h5 class="fw-bold mb-3" style="color: #1e3c5c">
                <i class="fas fa-tools me-2"></i>4. Activities & Operations
              </h5>
              <p class="text-muted small mb-3">
                Tell us about the work that will be done. This helps identify
                relevant compliance requirements.
              </p>

              <!-- Primary Activities -->
              <div class="mb-4">
                <label class="form-label fw-semibold">Primary Activities</label>
                <div class="border rounded p-3 bg-light">
                  <div id="activitiesContainer">
                    <div class="activity-entry mb-2">
                      <div class="row g-2">
                        <div class="col-md-5">
                          <input
                            type="text"
                            class="form-control"
                            name="primaryActivities[]"
                            placeholder="Activity name (e.g., Excavation)"
                          />
                        </div>
                        <div class="col-md-5">
                          <input
                            type="text"
                            class="form-control"
                            name="activityDescriptions[]"
                            placeholder="Brief description"
                          />
                        </div>
                        <div class="col-md-2">
                          <button
                            type="button"
                            class="btn btn-outline-danger w-100"
                            onclick="this.closest('.activity-entry').remove()"
                          >
                            <i class="fas fa-trash"></i>
                          </button>
                        </div>
                      </div>
                    </div>
                  </div>
                  <button
                    type="button"
                    class="btn btn-sm btn-outline-primary mt-2"
                    onclick="addActivity()"
                  >
                    <i class="fas fa-plus me-1"></i> Add Activity
                  </button>
                </div>
              </div>

              <!-- Risk Factors -->
              <div class="row g-3">
                <div class="col-md-6">
                  <div class="form-check">
                    <input
                      class="form-check-input"
                      type="checkbox"
                      id="hasWorkAtHeights"
                      name="hasWorkAtHeights"
                      value="true"
                    />
                    <label class="form-check-label" for="hasWorkAtHeights">
                      🪜 Working at Heights
                    </label>
                    <div
                      id="heightsDetails"
                      class="mt-2 ms-4"
                      style="display: none"
                    >
                      <input
                        type="number"
                        class="form-control form-control-sm mb-2"
                        name="maxHeight"
                        placeholder="Maximum height (meters)"
                      />
                      <input
                        type="text"
                        class="form-control form-control-sm"
                        name="fallProtection"
                        placeholder="Fall protection used (e.g., harness, guardrails)"
                      />
                    </div>
                  </div>
                </div>

                <div class="col-md-6">
                  <div class="form-check">
                    <input
                      class="form-check-input"
                      type="checkbox"
                      id="hasConfinedSpaces"
                      name="hasConfinedSpaces"
                      value="true"
                    />
                    <label class="form-check-label" for="hasConfinedSpaces">
                      📦 Confined Spaces
                    </label>
                    <div
                      id="confinedDetails"
                      class="mt-2 ms-4"
                      style="display: none"
                    >
                      <input
                        type="text"
                        class="form-control form-control-sm"
                        name="confinedSpacesDesc"
                        placeholder="Describe confined spaces (tanks, pits, tunnels)"
                      />
                    </div>
                  </div>
                </div>

                <div class="col-md-6">
                  <div class="form-check">
                    <input
                      class="form-check-input"
                      type="checkbox"
                      id="hasHeavyEquipment"
                      name="hasHeavyEquipment"
                      value="true"
                    />
                    <label class="form-check-label" for="hasHeavyEquipment">
                      🚜 Heavy Equipment
                    </label>
                    <div
                      id="equipmentDetails"
                      class="mt-2 ms-4"
                      style="display: none"
                    >
                      <input
                        type="text"
                        class="form-control form-control-sm"
                        name="equipmentTypes"
                        placeholder="Types: cranes, excavators, bulldozers"
                      />
                    </div>
                  </div>
                </div>

                <div class="col-md-6">
                  <div class="form-check">
                    <input
                      class="form-check-input"
                      type="checkbox"
                      id="hasHazardousSubstances"
                      name="hasHazardousSubstances"
                      value="true"
                    />
                    <label
                      class="form-check-label"
                      for="hasHazardousSubstances"
                    >
                      ⚠️ Hazardous Substances
                    </label>
                    <div
                      id="hazardousDetails"
                      class="mt-2 ms-4"
                      style="display: none"
                    >
                      <input
                        type="text"
                        class="form-control form-control-sm"
                        name="hazardousSubstancesList"
                        placeholder="List: chemicals, fuels, paints, solvents"
                      />
                    </div>
                  </div>
                </div>

                <div class="col-md-6">
                  <div class="form-check">
                    <input
                      class="form-check-input"
                      type="checkbox"
                      id="hasExcavation"
                      name="hasExcavation"
                      value="true"
                    />
                    <label class="form-check-label" for="hasExcavation">
                      ⛏️ Excavation Work
                    </label>
                    <div
                      id="excavationDetails"
                      class="mt-2 ms-4"
                      style="display: none"
                    >
                      <input
                        type="number"
                        class="form-control form-control-sm mb-2"
                        name="excavationDepth"
                        placeholder="Maximum depth (meters)"
                      />
                      <input
                        type="text"
                        class="form-control form-control-sm"
                        name="utilitiesNearby"
                        placeholder="Nearby utilities (water, gas, electrical)"
                      />
                    </div>
                  </div>
                </div>

                <div class="col-md-6">
                  <div class="form-check">
                    <input
                      class="form-check-input"
                      type="checkbox"
                      id="hasElectricalWork"
                      name="hasElectricalWork"
                      value="true"
                    />
                    <label class="form-check-label" for="hasElectricalWork">
                      ⚡ Electrical Work
                    </label>
                    <div
                      id="electricalDetails"
                      class="mt-2 ms-4"
                      style="display: none"
                    >
                      <input
                        type="text"
                        class="form-control form-control-sm"
                        name="voltageLevels"
                        placeholder="Voltage levels (e.g., 240V, 11kV)"
                      />
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <!-- ==================== SECTION 5: HEALTH & SAFETY RESOURCES ==================== -->
            <div class="form-section mb-5">
              <h5 class="fw-bold mb-3" style="color: #1e3c5c">
                <i class="fas fa-ambulance me-2"></i>5. Health & Safety
                Resources
              </h5>

              <div class="row g-3">
                <div class="col-md-4">
                  <label class="form-label fw-semibold">Safety Personnel</label>
                  <div class="form-check">
                    <input
                      class="form-check-input"
                      type="checkbox"
                      id="hasSafetyOfficer"
                      name="hasSafetyOfficer"
                      value="true"
                    />
                    <label class="form-check-label" for="hasSafetyOfficer"
                      >Dedicated Safety Officer</label
                    >
                  </div>
                  <div id="officerCount" class="mt-2" style="display: none">
                    <input
                      type="number"
                      class="form-control"
                      name="safetyOfficerCount"
                      placeholder="Number of safety officers"
                    />
                  </div>
                </div>

                <div class="col-md-4">
                  <label class="form-label fw-semibold">Safety Committee</label>
                  <div class="form-check">
                    <input
                      class="form-check-input"
                      type="checkbox"
                      id="hasSafetyCommittee"
                      name="hasSafetyCommittee"
                      value="true"
                    />
                    <label class="form-check-label" for="hasSafetyCommittee"
                      >Has Safety Committee</label
                    >
                  </div>
                  <div id="committeeMembers" class="mt-2" style="display: none">
                    <input
                      type="number"
                      class="form-control"
                      name="committeeMembers"
                      placeholder="Number of members"
                    />
                  </div>
                </div>

                <div class="col-md-4">
                  <label class="form-label fw-semibold">First Aid</label>
                  <input
                    type="number"
                    class="form-control"
                    name="firstAidBoxes"
                    placeholder="Number of first aid boxes"
                  />
                  <input
                    type="number"
                    class="form-control mt-2"
                    name="trainedFirstAiders"
                    placeholder="Trained first aiders"
                  />
                </div>
              </div>

              <div class="row g-3 mt-2">
                <div class="col-md-6">
                  <label class="form-label fw-semibold"
                    >Medical Facilities</label
                  >
                  <div class="form-check">
                    <input
                      class="form-check-input"
                      type="checkbox"
                      id="hasOnSiteClinic"
                      name="hasOnSiteClinic"
                      value="true"
                    />
                    <label class="form-check-label" for="hasOnSiteClinic"
                      >On-site Clinic</label
                    >
                  </div>
                  <input
                    type="text"
                    class="form-control mt-2"
                    name="nearestHospital"
                    placeholder="Nearest hospital name & distance"
                  />
                  <input
                    type="text"
                    class="form-control mt-2"
                    name="emergencyContact"
                    placeholder="Emergency contact number"
                  />
                </div>

                <div class="col-md-6">
                  <label class="form-label fw-semibold">Fire Safety</label>
                  <div class="row">
                    <div class="col-6">
                      <input
                        type="number"
                        class="form-control"
                        name="fireExtinguishers"
                        placeholder="Extinguishers"
                      />
                    </div>
                    <div class="col-6">
                      <input
                        type="number"
                        class="form-control"
                        name="fireHoses"
                        placeholder="Fire hoses"
                      />
                    </div>
                  </div>
                  <div class="form-check mt-2">
                    <input
                      class="form-check-input"
                      type="checkbox"
                      id="hasEvacuationPlan"
                      name="hasEvacuationPlan"
                      value="true"
                    />
                    <label class="form-check-label" for="hasEvacuationPlan"
                      >Has Evacuation Plan</label
                    >
                  </div>
                  <div class="form-check">
                    <input
                      class="form-check-input"
                      type="checkbox"
                      id="hasAssemblyPoint"
                      name="hasAssemblyPoint"
                      value="true"
                    />
                    <label class="form-check-label" for="hasAssemblyPoint"
                      >Has Assembly Point</label
                    >
                  </div>
                </div>
              </div>
            </div>

            <!-- Submit Buttons -->
            <div class="d-flex gap-2 justify-content-end mt-4 pt-3 border-top">
              <a href="/dashboard/admin" class="btn btn-secondary btn-lg px-4"
                >Cancel</a
              >
              <button
                type="submit"
                class="btn btn-primary btn-lg px-4"
                style="
                  background: linear-gradient(135deg, #2196f3 0%, #1976d2 100%);
                  border: none;
                "
              >
                <i class="fas fa-save me-2"></i> Create Worksite & Continue to
                Compliance
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  // Show/hide conditional fields
  document
    .getElementById("hasWorkAtHeights")
    .addEventListener("change", function () {
      document.getElementById("heightsDetails").style.display = this.checked
        ? "block"
        : "none";
    });
  document
    .getElementById("hasConfinedSpaces")
    .addEventListener("change", function () {
      document.getElementById("confinedDetails").style.display = this.checked
        ? "block"
        : "none";
    });
  document
    .getElementById("hasHeavyEquipment")
    .addEventListener("change", function () {
      document.getElementById("equipmentDetails").style.display = this.checked
        ? "block"
        : "none";
    });
  document
    .getElementById("hasHazardousSubstances")
    .addEventListener("change", function () {
      document.getElementById("hazardousDetails").style.display = this.checked
        ? "block"
        : "none";
    });
  document
    .getElementById("hasExcavation")
    .addEventListener("change", function () {
      document.getElementById("excavationDetails").style.display = this.checked
        ? "block"
        : "none";
    });
  document
    .getElementById("hasElectricalWork")
    .addEventListener("change", function () {
      document.getElementById("electricalDetails").style.display = this.checked
        ? "block"
        : "none";
    });
  document
    .getElementById("hasSafetyOfficer")
    .addEventListener("change", function () {
      document.getElementById("officerCount").style.display = this.checked
        ? "block"
        : "none";
    });
  document
    .getElementById("hasSafetyCommittee")
    .addEventListener("change", function () {
      document.getElementById("committeeMembers").style.display = this.checked
        ? "block"
        : "none";
    });

  // Add activity function
  function addActivity() {
    const container = document.getElementById("activitiesContainer");
    const newEntry = document.createElement("div");
    newEntry.className = "activity-entry mb-2";
    newEntry.innerHTML = `
      <div class="row g-2">
        <div class="col-md-5">
          <input type="text" class="form-control" name="primaryActivities[]" placeholder="Activity name">
        </div>
        <div class="col-md-5">
          <input type="text" class="form-control" name="activityDescriptions[]" placeholder="Brief description">
        </div>
        <div class="col-md-2">
          <button type="button" class="btn btn-outline-danger w-100" onclick="this.closest('.activity-entry').remove()">
            <i class="fas fa-trash"></i>
          </button>
        </div>
      </div>
    `;
    container.appendChild(newEntry);
  }
</script>

