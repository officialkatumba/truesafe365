<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-eye me-2 text-primary"></i>Safety Observations</h2>
    <a href="/dashboard" class="btn btn-outline-secondary">Back to Dashboard</a>
  </div>

  <!-- Stats Cards -->
  <div class="row g-3 mb-4">
    <div class="col-md-2 col-6">
      <div class="card border-0 shadow-sm text-center bg-primary text-white">
        <div class="card-body py-3"><h3 class="mb-0"><%= stats.total %></h3><small>Total</small></div>
      </div>
    </div>
    <div class="col-md-2 col-6">
      <div class="card border-0 shadow-sm text-center bg-warning text-dark">
        <div class="card-body py-3"><h3 class="mb-0"><%= stats.open %></h3><small>Open</small></div>
      </div>
    </div>
    <div class="col-md-2 col-6">
      <div class="card border-0 shadow-sm text-center bg-info text-white">
        <div class="card-body py-3"><h3 class="mb-0"><%= stats.inReview %></h3><small>In Review</small></div>
      </div>
    </div>
    <div class="col-md-2 col-6">
      <div class="card border-0 shadow-sm text-center bg-success text-white">
        <div class="card-body py-3"><h3 class="mb-0"><%= stats.closed %></h3><small>Closed</small></div>
      </div>
    </div>
    <div class="col-md-2 col-6">
      <div class="card border-0 shadow-sm text-center bg-success text-white">
        <div class="card-body py-3"><h3 class="mb-0"><%= stats.positive %></h3><small>Positive</small></div>
      </div>
    </div>
    <div class="col-md-2 col-6">
      <div class="card border-0 shadow-sm text-center bg-danger text-white">
        <div class="card-body py-3"><h3 class="mb-0"><%= stats.atRisk + stats.condition %></h3><small>Issues Found</small></div>
      </div>
    </div>
  </div>

  <!-- Filters -->
  <div class="card shadow-sm mb-4 border-0">
    <div class="card-body">
      <form method="GET" class="row g-3">
        <div class="col-md-4"><select name="status" class="form-select"><option value="all">All Status</option><option value="open">Open</option><option value="in_review">In Review</option><option value="closed">Closed</option></select></div>
        <div class="col-md-4"><select name="type" class="form-select"><option value="all">All Types</option><option value="positive">Positive</option><option value="at_risk">At-Risk Behavior</option><option value="condition">Unsafe Condition</option></select></div>
        <div class="col-md-4"><button type="submit" class="btn btn-primary w-100">Apply Filters</button></div>
      </form>
    </div>
  </div>

  <!-- Observations Table -->
  <div class="card shadow-sm border-0">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover mb-0">
          <thead class="table-light"><tr><th>Date</th><th>Type</th><th>Description</th><th>Work Area</th><th>Status</th><th>Observed By</th><th></th></tr></thead>
          <tbody>
            <% observations.forEach(obs => { %>
            <tr>
              <td><%= new Date(obs.date).toLocaleDateString() %></td>
              <td><span class="badge <%= obs.type === 'positive' ? 'bg-success' : obs.type === 'at_risk' ? 'bg-warning text-dark' : 'bg-danger' %>"><%= obs.type %></span></td>
              <td><%= obs.description.substring(0, 60) %>...</td>
              <td><%= obs.workArea?.name %></td>
              <td><span class="badge <%= obs.status === 'closed' ? 'bg-success' : obs.status === 'in_review' ? 'bg-info' : 'bg-warning text-dark' %>"><%= obs.status %></span></td>
              <td><%= obs.observedBy?.name %></td>
              <td><a href="/safety-observations/<%= obs._id %>" class="btn btn-sm btn-outline-primary">View</a></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>