<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-exclamation-triangle me-2 text-danger"></i>Incident Reports</h2>
    <a href="/dashboard" class="btn btn-outline-secondary">Back to Dashboard</a>
  </div>

  <div class="card shadow-sm">
    <div class="card-body">
      <div class="table-responsive">
        <table class="table table-hover">
          <thead>
            <tr>
              <th>#</th>
              <th>Type</th>
              <th>Severity</th>
              <th>Location</th>
              <th>Date</th>
              <th>Status</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% incidents.forEach(incident => { %>
            <tr>
              <td>INC-<%= incident.incidentNumber %></td>
              <td><span class="badge bg-secondary"><%= incident.type %></span></td>
              <td>
                <span class="badge <%= 
                  incident.severity === 'critical' ? 'bg-danger' : 
                  incident.severity === 'high' ? 'bg-warning' : 
                  incident.severity === 'medium' ? 'bg-info' : 
                  'bg-success' 
                %>"><%= incident.severity %></span>
              </td>
              <td><%= incident.location %></td>
              <td><%= new Date(incident.dateTime).toLocaleDateString() %></td>
              <td><span class="badge bg-secondary"><%= incident.status %></span></td>
              <td><a href="/incidents/<%= incident._id %>" class="btn btn-sm btn-outline-primary">View</a></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>