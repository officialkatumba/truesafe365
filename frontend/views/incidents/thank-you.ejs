<%- include('../partials/header') %>

<div class="container py-5">
  <div class="card shadow-lg border-0 text-center" style="border-radius: 20px; max-width: 600px; margin: 0 auto;">
    <div class="card-body p-5">
      <i class="fas fa-check-circle fa-5x text-success mb-4"></i>
      <h2 class="mb-3">Thank You for Reporting!</h2>
      <p class="text-muted mb-4">Your report has been submitted successfully. A safety officer will review it within 24 hours.</p>
      
      <% if (type === 'incident') { %>
        <div class="alert alert-warning">
          <i class="fas fa-heartbeat me-2"></i>
          <strong>Incident Reported</strong><br>
          If medical attention is needed, please ensure the affected person has received care.
        </div>
      <% } else if (type === 'near_miss') { %>
        <div class="alert alert-info">
          <i class="fas fa-exclamation-triangle me-2"></i>
          <strong>Near Miss Reported</strong><br>
          Thank you for helping us prevent future incidents!
        </div>
      <% } else { %>
        <div class="alert alert-success">
          <i class="fas fa-eye me-2"></i>
          <strong>Hazard Reported</strong><br>
          We'll investigate and take corrective action.
        </div>
      <% } %>
      
      <hr class="my-4">
      <p class="small text-muted">Report Reference: Your report has been logged in our system.</p>
      <a href="/" class="btn btn-primary">
        <i class="fas fa-home me-2"></i>Return to Home
      </a>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>