<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="container py-4">
  <!-- Header Banner -->
  <div class="p-4 mb-4 rounded-3" style="background: linear-gradient(135deg, #e74c3c, #c0392b)">
    <div class="d-flex justify-content-between align-items-center flex-wrap">
      <div>
        <div class="d-flex align-items-center gap-2 mb-2">
          <i class="fas fa-exclamation-triangle fa-2x text-white"></i>
          <h2 class="text-white fw-bold mb-0">Incident Report #INC-<%= incident.incidentNumber %></h2>
        </div>
        <p class="text-white-50 mb-0"><%= incident.workArea?.name %> | Reported on <%= new Date(incident.createdAt).toLocaleDateString() %></p>
      </div>
      <div>
        <span class="badge bg-light text-dark px-3 py-2 fs-6 me-2">
          <i class="fas fa-tag me-1"></i><%= incident.type?.toUpperCase() %>
        </span>
        <span class="badge <%= 
          incident.severity === 'critical' ? 'bg-danger' : 
          incident.severity === 'high' ? 'bg-warning text-dark' : 
          incident.severity === 'medium' ? 'bg-info' : 
          'bg-success' 
        %> px-3 py-2 fs-6">
          <i class="fas fa-chart-line me-1"></i><%= incident.severity?.toUpperCase() %>
        </span>
        <span class="badge <%=
          incident.status === 'closed' ? 'bg-success' :
          incident.status === 'resolved' ? 'bg-primary' :
          incident.status === 'under_investigation' ? 'bg-warning text-dark' :
          'bg-secondary'
        %> px-3 py-2 fs-6 ms-2">
          <i class="fas fa-flag-checkered me-1"></i><%= incident.status?.toUpperCase() %>
        </span>
        <% if (incident.classification?.isLTI) { %>
          <span class="badge bg-danger px-3 py-2 fs-6 ms-2">
            <i class="fas fa-user-injured me-1"></i>LTI
          </span>
        <% } %>
        <% if (incident.classification?.isRecordable) { %>
          <span class="badge bg-dark px-3 py-2 fs-6 ms-2">
            <i class="fas fa-clipboard-list me-1"></i>TRIR RECORDABLE
          </span>
        <% } %>
      </div>
    </div>
  </div>

  <!-- Stats Row -->
  <div class="row g-3 mb-4">
    <div class="col-md-3">
      <div class="card border-0 shadow-sm text-center">
        <div class="card-body">
          <i class="fas fa-calendar fa-2x text-primary mb-2"></i>
          <h6 class="text-muted mb-1">Date & Time</h6>
          <p class="fw-bold mb-0"><%= new Date(incident.dateTime).toLocaleString() %></p>
          <small class="text-muted"><%= incident.shift %> shift</small>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card border-0 shadow-sm text-center">
        <div class="card-body">
          <i class="fas fa-map-marker-alt fa-2x text-danger mb-2"></i>
          <h6 class="text-muted mb-1">Location</h6>
          <p class="fw-bold mb-0"><%= incident.location %></p>
          <small class="text-muted"><%= incident.locationDetails || 'No details' %></small>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card border-0 shadow-sm text-center">
        <div class="card-body">
          <i class="fas fa-user fa-2x text-success mb-2"></i>
          <h6 class="text-muted mb-1">Reported By</h6>
          <p class="fw-bold mb-0"><%= incident.anonymous ? 'Anonymous' : (incident.reporterName || 'Worker') %></p>
          <small class="text-muted"><%= incident.reportedBy %></small>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card border-0 shadow-sm text-center">
        <div class="card-body">
          <i class="fas fa-briefcase fa-2x text-warning mb-2"></i>
          <h6 class="text-muted mb-1">Work Type</h6>
          <p class="fw-bold mb-0"><%= incident.workTypeAtTime || 'Not specified' %></p>
          <small class="text-muted">at time of incident</small>
        </div>
      </div>
    </div>
  </div>

  <!-- Main Content -->
  <div class="row">
    <div class="col-lg-8">
      <!-- Incident Description -->
      <div class="card shadow-sm mb-4 border-0">
        <div class="card-header bg-white border-0 pt-4">
          <h5 class="fw-bold mb-0"><i class="fas fa-file-alt me-2 text-primary"></i>Incident Description</h5>
        </div>
        <div class="card-body">
          <p class="mb-3"><%= incident.description %></p>
          <% if (incident.immediateAction) { %>
            <div class="alert alert-info mt-3">
              <i class="fas fa-first-aid me-2"></i>
              <strong>Immediate Action Taken:</strong><br>
              <%= incident.immediateAction %>
            </div>
          <% } %>
        </div>
      </div>

      <!-- Injuries Section -->
      <% if (incident.injuries?.occurred) { %>
      <div class="card shadow-sm mb-4 border-0">
        <div class="card-header bg-white border-0 pt-4">
          <h5 class="fw-bold mb-0"><i class="fas fa-heartbeat me-2 text-danger"></i>Injury Details</h5>
        </div>
        <div class="card-body">
          <div class="row">
            <div class="col-md-6">
              <div class="mb-3">
                <label class="fw-bold">Injury Type</label>
                <p><%= incident.injuries.injuredPersons?.[0]?.injuryType || 'Not specified' %></p>
              </div>
            </div>
            <div class="col-md-6">
              <div class="mb-3">
                <label class="fw-bold">Body Part Affected</label>
                <p><%= incident.injuries.injuredPersons?.[0]?.bodyPart || 'Not specified' %></p>
              </div>
            </div>
          </div>
          <div class="mb-3">
            <label class="fw-bold">Description</label>
            <p><%= incident.injuries.description || incident.injuries.injuredPersons?.[0]?.treatmentRequired || 'No additional details' %></p>
          </div>
          <div class="d-flex gap-3 flex-wrap">
            <span class="badge <%= incident.injuries.firstAidProvided ? 'bg-success' : 'bg-secondary' %>">
              <i class="fas fa-bandaid me-1"></i> First Aid: <%= incident.injuries.firstAidProvided ? 'Yes' : 'No' %>
            </span>
            <span class="badge <%= incident.injuries.ambulanceCalled ? 'bg-danger' : 'bg-secondary' %>">
              <i class="fas fa-ambulance me-1"></i> Ambulance: <%= incident.injuries.ambulanceCalled ? 'Yes' : 'No' %>
            </span>
            <span class="badge <%= incident.injuries.injuredPersons?.[0]?.hospitalVisit ? 'bg-warning' : 'bg-secondary' %>">
              <i class="fas fa-hospital me-1"></i> Hospital: <%= incident.injuries.injuredPersons?.[0]?.hospitalVisit ? 'Yes' : 'No' %>
            </span>
            <span class="badge <%= incident.injuries.injuredPersons?.[0]?.timeOffWork ? 'bg-info' : 'bg-secondary' %>">
              <i class="fas fa-calendar-times me-1"></i> Time Off: <%= incident.injuries.injuredPersons?.[0]?.daysOff || 0 %> days
            </span>
          </div>
        </div>
      </div>
      <% } %>

      <!-- Near Miss Section -->
      <% if (incident.type === 'near_miss' && incident.potentialConsequences) { %>
      <div class="card shadow-sm mb-4 border-0">
        <div class="card-header bg-white border-0 pt-4">
          <h5 class="fw-bold mb-0"><i class="fas fa-exclamation-triangle me-2 text-warning"></i>Near Miss Analysis</h5>
        </div>
        <div class="card-body">
          <div class="mb-3">
            <label class="fw-bold">What Could Have Happened?</label>
            <p><%= incident.potentialConsequences %></p>
          </div>
          <div class="mb-3">
            <label class="fw-bold">Why Didn't It Cause Harm?</label>
            <p><%= incident.whyDidNotHappen %></p>
          </div>
        </div>
      </div>
      <% } %>

      <!-- Equipment Involved -->
      <% if (incident.equipmentInvolved && incident.equipmentInvolved.length > 0) { %>
      <div class="card shadow-sm mb-4 border-0">
        <div class="card-header bg-white border-0 pt-4">
          <h5 class="fw-bold mb-0"><i class="fas fa-tools me-2 text-secondary"></i>Equipment Involved</h5>
        </div>
        <div class="card-body">
          <div class="table-responsive">
            <table class="table table-sm">
              <thead>
                <tr>
                  <th>Equipment</th>
                  <th>Condition</th>
                  <th>Inspected</th>
                </tr>
              </thead>
              <tbody>
                <% incident.equipmentInvolved.forEach(eq => { %>
                <tr>
                  <td><%= eq.name %></td>
                  <td><%= eq.condition %></td>
                  <td><%= eq.wasInspected ? 'Yes' : 'No' %></td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
      <% } %>

      <!-- Environmental Factors -->
      <% if (incident.aiContext) { %>
      <div class="card shadow-sm mb-4 border-0">
        <div class="card-header bg-white border-0 pt-4">
          <h5 class="fw-bold mb-0"><i class="fas fa-cloud-sun me-2 text-info"></i>Environmental Factors</h5>
        </div>
        <div class="card-body">
          <div class="row">
            <div class="col-md-4">
              <strong>Weather:</strong> <%= incident.aiContext.weatherConditions || 'Not specified' %>
            </div>
            <div class="col-md-4">
              <strong>Lighting:</strong> <%= incident.aiContext.lighting || 'Not specified' %>
            </div>
            <div class="col-md-4">
              <strong>Noise:</strong> <%= incident.aiContext.noise || 'Not specified' %>
            </div>
          </div>
          <% if (incident.aiContext.contributingFactors) { %>
          <div class="mt-3">
            <strong>Contributing Factors:</strong>
            <p class="mt-1"><%= incident.aiContext.contributingFactors %></p>
          </div>
          <% } %>
        </div>
      </div>
      <% } %>

      <!-- Investigation -->
      <% if (incident.investigation?.conducted) { %>
      <div class="card shadow-sm mb-4 border-0">
        <div class="card-header bg-white border-0 pt-4">
          <h5 class="fw-bold mb-0"><i class="fas fa-search me-2 text-primary"></i>Investigation Findings</h5>
        </div>
        <div class="card-body">
          <div class="mb-3">
            <label class="fw-bold">Root Cause</label>
            <p><%= incident.investigation.rootCause %></p>
          </div>
          <div class="mb-3">
            <label class="fw-bold">Contributing Factors</label>
            <ul class="mb-0">
              <% (incident.investigation.contributingFactors || []).forEach(factor => { %>
                <li><%= factor %></li>
              <% }) %>
            </ul>
          </div>
          <div class="mb-3">
            <label class="fw-bold">Findings</label>
            <p><%= incident.investigation.findings %></p>
          </div>
          <div class="mb-3">
            <label class="fw-bold">Recommendations</label>
            <ul class="mb-0">
              <% (incident.investigation.recommendations || []).forEach(rec => { %>
                <li><%= rec %></li>
              <% }) %>
            </ul>
          </div>
          <div class="text-muted small mt-3">
            <i class="fas fa-user-check me-1"></i> Investigated by: <%= incident.investigation.conductedBy?.name || 'Safety Officer' %>
            on <%= new Date(incident.investigation.investigationDate).toLocaleDateString() %>
          </div>
        </div>
      </div>
      <% } %>

      <!-- Corrective Actions -->
      <% if (incident.correctiveActions && incident.correctiveActions.length > 0) { %>
      <div class="card shadow-sm mb-4 border-0">
        <div class="card-header bg-white border-0 pt-4">
          <h5 class="fw-bold mb-0"><i class="fas fa-check-circle me-2 text-success"></i>Corrective Actions</h5>
        </div>
        <div class="card-body">
          <div class="table-responsive">
            <table class="table table-hover">
              <thead>
                <tr>
                  <th>Action</th>
                  <th>Assigned To</th>
                  <th>Deadline</th>
                  <th>Priority</th>
                  <th>Status</th>
                </tr>
              </thead>
              <tbody>
                <% incident.correctiveActions.forEach(action => { %>
                <tr>
                  <td><%= action.action %></td>
                  <td><%= action.assignedToName || 'Not assigned' %></td>
                  <td><%= action.deadline ? new Date(action.deadline).toLocaleDateString() : 'Not set' %></td>
                  <td>
                    <span class="badge <%= 
                      action.priority === 'high' ? 'bg-danger' : 
                      action.priority === 'medium' ? 'bg-warning text-dark' : 
                      'bg-success' 
                    %>"><%= action.priority %></span>
                  </td>
                  <td>
                    <span class="badge <%= action.completed ? 'bg-success' : 'bg-secondary' %>">
                      <%= action.completed ? 'Completed' : 'Pending' %>
                    </span>
                  </td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
      <% } %>

      <!-- Lessons Learned -->
      <% if (incident.lessonsLearned) { %>
      <div class="card shadow-sm mb-4 border-0">
        <div class="card-header bg-white border-0 pt-4">
          <h5 class="fw-bold mb-0"><i class="fas fa-graduation-cap me-2 text-primary"></i>Lessons Learned</h5>
        </div>
        <div class="card-body">
          <p><%= incident.lessonsLearned %></p>
        </div>
      </div>
      <% } %>
    </div>

    <!-- Sidebar -->
    <div class="col-lg-4">
      <!-- Action Buttons -->
      <div class="card shadow-sm mb-4 border-0">
        <div class="card-body">
          <h6 class="fw-bold mb-3"><i class="fas fa-cog me-2 text-primary"></i>Actions</h6>
          <div class="d-grid gap-2">
            <% if (user.role === 'safety_officer') { %>
              <a href="/incidents/<%= incident._id %>/edit" class="btn btn-outline-primary">
                <i class="fas fa-edit me-2"></i>Edit Incident
              </a>
              <% if (!incident.investigation?.conducted) { %>
                <button class="btn btn-outline-info" data-bs-toggle="modal" data-bs-target="#investigationModal">
                  <i class="fas fa-search me-2"></i>Add Investigation
                </button>
              <% } %>
              <% if (incident.injuries?.occurred) { %>
                <button class="btn btn-outline-dark" data-bs-toggle="modal" data-bs-target="#classificationModal">
                  <i class="fas fa-user-injured me-2"></i>Classify Injury (LTI/TRIR)
                </button>
              <% } %>
              <button class="btn btn-outline-success" data-bs-toggle="modal" data-bs-target="#actionModal">
                <i class="fas fa-plus-circle me-2"></i>Add Corrective Action
              </button>
              <% if (incident.status !== 'closed') { %>
                <button class="btn btn-outline-danger" data-bs-toggle="modal" data-bs-target="#closeModal">
                  <i class="fas fa-check-double me-2"></i>Close Incident
                </button>
              <% } %>
            <% } %>
            <button class="btn btn-secondary" onclick="window.print()">
              <i class="fas fa-print me-2"></i>Print Report
            </button>
          </div>
        </div>
      </div>

      <!-- Timeline -->
      <div class="card shadow-sm mb-4 border-0">
        <div class="card-body">
          <h6 class="fw-bold mb-3"><i class="fas fa-history me-2 text-primary"></i>Timeline</h6>
          <div class="timeline">
            <div class="timeline-item">
              <div class="timeline-badge bg-danger"></div>
              <div class="timeline-content">
                <strong>Incident Occurred</strong>
                <p class="small text-muted mb-0"><%= new Date(incident.dateTime).toLocaleString() %></p>
              </div>
            </div>
            <div class="timeline-item">
              <div class="timeline-badge bg-warning"></div>
              <div class="timeline-content">
                <strong>Reported</strong>
                <p class="small text-muted mb-0"><%= new Date(incident.createdAt).toLocaleString() %></p>
              </div>
            </div>
            <% if (incident.investigation?.conducted) { %>
            <div class="timeline-item">
              <div class="timeline-badge bg-info"></div>
              <div class="timeline-content">
                <strong>Investigation Completed</strong>
                <p class="small text-muted mb-0"><%= new Date(incident.investigation.investigationDate).toLocaleString() %></p>
              </div>
            </div>
            <% } %>
            <% if (incident.status === 'closed') { %>
            <div class="timeline-item">
              <div class="timeline-badge bg-success"></div>
              <div class="timeline-content">
                <strong>Closed</strong>
                <p class="small text-muted mb-0"><%= new Date(incident.updatedAt).toLocaleString() %></p>
              </div>
            </div>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Investigation Modal -->
<div class="modal fade" id="investigationModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header bg-info text-white">
        <h5 class="modal-title"><i class="fas fa-search me-2"></i>Add Investigation</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <form method="POST" action="/incidents/<%= incident._id %>/investigation">
        <div class="modal-body">
          <div class="mb-3">
            <label class="form-label fw-bold">Root Cause</label>
            <textarea name="rootCause" class="form-control" rows="3" required></textarea>
          </div>
          <div class="mb-3">
            <label class="form-label fw-bold">Contributing Factors (comma separated)</label>
            <input type="text" name="contributingFactors" class="form-control" placeholder="e.g., Poor lighting, Lack of training, Equipment failure">
          </div>
          <div class="mb-3">
            <label class="form-label fw-bold">Findings</label>
            <textarea name="findings" class="form-control" rows="3"></textarea>
          </div>
          <div class="mb-3">
            <label class="form-label fw-bold">Recommendations</label>
            <textarea name="recommendations" class="form-control" rows="3" placeholder="One per line"></textarea>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-info text-white">Save Investigation</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Injury Classification Modal (LTI/TRIR) -->
<div class="modal fade" id="classificationModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header bg-dark text-white">
        <h5 class="modal-title"><i class="fas fa-user-injured me-2"></i>Classify Injury</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <form method="POST" action="/incidents/<%= incident._id %>/edit">
        <div class="modal-body">
          <p class="text-muted small">
            Classify this injury for Zambian OHS Act No. 16 of 2025 recordkeeping. An LTI (Lost Time Injury) is any work injury that keeps the person off work beyond the day of the incident. A TRIR-recordable injury is any work injury requiring medical treatment beyond first aid, restricted duty, days away, or death.
          </p>
          <div class="form-check mb-3">
            <input type="hidden" name="isLTI" value="no">
            <input class="form-check-input" type="checkbox" name="isLTI" id="isLTI" value="yes" <%= incident.classification?.isLTI ? 'checked' : '' %>>
            <label class="form-check-label fw-bold" for="isLTI">Lost Time Injury (LTI)</label>
          </div>
          <div class="mb-3">
            <label class="form-label fw-bold">Lost Time (days)</label>
            <input type="number" min="0" name="lostTimeDays" class="form-control" value="<%= incident.classification?.lostTimeDays || 0 %>">
          </div>
          <div class="form-check mb-3">
            <input type="hidden" name="isRecordable" value="no">
            <input class="form-check-input" type="checkbox" name="isRecordable" id="isRecordable" value="yes" <%= incident.classification?.isRecordable ? 'checked' : '' %>>
            <label class="form-check-label fw-bold" for="isRecordable">TRIR Recordable Injury</label>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-dark">Save Classification</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Corrective Action Modal -->
<div class="modal fade" id="actionModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header bg-success text-white">
        <h5 class="modal-title"><i class="fas fa-plus-circle me-2"></i>Add Corrective Action</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <form method="POST" action="/incidents/<%= incident._id %>/corrective-action">
        <div class="modal-body">
          <div class="mb-3">
            <label class="form-label fw-bold">Action Item</label>
            <textarea name="action" class="form-control" rows="2" required></textarea>
          </div>
          <div class="mb-3">
            <label class="form-label fw-bold">Assigned To</label>
            <input type="text" name="assignedToName" class="form-control" placeholder="Person or department">
          </div>
          <div class="row">
            <div class="col-md-6 mb-3">
              <label class="form-label fw-bold">Deadline</label>
              <input type="date" name="deadline" class="form-control">
            </div>
            <div class="col-md-6 mb-3">
              <label class="form-label fw-bold">Priority</label>
              <select name="priority" class="form-select">
                <option value="high">High</option>
                <option value="medium">Medium</option>
                <option value="low">Low</option>
              </select>
            </div>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-success">Add Action</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Close Incident Modal -->
<div class="modal fade" id="closeModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header bg-danger text-white">
        <h5 class="modal-title"><i class="fas fa-check-double me-2"></i>Close Incident</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <form method="POST" action="/incidents/<%= incident._id %>/close">
        <div class="modal-body">
          <div class="mb-3">
            <label class="form-label fw-bold">Lessons Learned</label>
            <textarea name="lessonsLearned" class="form-control" rows="4" required></textarea>
            <div class="form-text">What can we learn from this incident to prevent recurrence?</div>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-danger">Close Incident</button>
        </div>
      </form>
    </div>
  </div>
</div>

<style>
  .timeline {
    position: relative;
    padding-left: 30px;
  }
  .timeline-item {
    position: relative;
    margin-bottom: 20px;
  }
  .timeline-badge {
    position: absolute;
    left: -30px;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    top: 5px;
  }
  .timeline-content {
    padding-left: 10px;
  }
  .timeline-item:before {
    content: '';
    position: absolute;
    left: -24px;
    top: 17px;
    width: 2px;
    height: calc(100% + 10px);
    background: #e9ecef;
  }
  .timeline-item:last-child:before {
    display: none;
  }
</style>

<%- include('../partials/footer') %>
