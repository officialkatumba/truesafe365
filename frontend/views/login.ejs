<%- include('partials/header') %> <%- include('partials/navbar') %>

<div class="d-flex align-items-center justify-content-center min-vh-100 py-5">
  <div
    class="card shadow-lg border-0 p-4"
    style="
      max-width: 420px;
      width: 100%;
      border-radius: 12px;
      background: white;
    "
  >
    <div class="text-center mb-4">
      <i class="fas fa-sign-in-alt fa-3x mb-2" style="color: #e67e22"></i>
      <h3 class="fw-bold" style="color: #1e3c5c">Welcome Back</h3>
      <p class="text-muted mb-0">Login to access your TrueSafe dashboard</p>
    </div>

    <form action="/api/users/login" method="POST">
      <div class="mb-3">
        <label for="email" class="form-label fw-semibold">Email *</label>
        <input
          type="email"
          class="form-control form-control-lg"
          id="email"
          name="email"
          placeholder="you@example.com"
          required
        />
      </div>

      <div class="mb-3">
        <label for="password" class="form-label fw-semibold">Password *</label>
        <input
          type="password"
          class="form-control form-control-lg"
          id="password"
          name="password"
          placeholder="Enter your password"
          required
        />
        <div class="mt-2 text-end">
          <a
            href="/users/forgot-password"
            class="small text-decoration-none"
            style="color: #e67e22"
          >
            <i class="fas fa-key me-1"></i>Forgot Password?
          </a>
        </div>
      </div>

      <button
        type="submit"
        class="btn w-100 py-3 fw-bold"
        style="
          background: #dc3545;
          color: white;
          border-radius: 50px;
          border: 2px solid #dc3545;
          font-size: 1.2rem;
          letter-spacing: 1px;
          text-transform: uppercase;
          box-shadow: 0 8px 20px rgba(220, 53, 69, 0.4);
          transition: all 0.3s ease;
          position: relative;
          overflow: hidden;
        "
      >
        <i class="fas fa-sign-in-alt me-2"></i> Login
      </button>
    </form>

    <div class="text-center mt-4">
      <p class="mb-2 text-muted">Don't have an account?</p>
      <div class="d-flex flex-column gap-2">
        <a href="/register/options" class="fw-semibold" style="color: #e67e22">
          <i class="fas fa-shield-alt me-1"></i> Register Now
        </a>
      </div>
    </div>
  </div>
</div>

<style>
  .btn::before {
    content: "";
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 255, 255, 0.2),
      transparent
    );
    transition: left 0.5s ease;
    pointer-events: none;
  }

  .btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 30px rgba(220, 53, 69, 0.6) !important;
    background: #c82333 !important;
    border-color: #c82333 !important;
  }

  .btn:hover::before {
    left: 100%;
  }

  .btn:active {
    transform: translateY(-1px);
    box-shadow: 0 5px 15px rgba(220, 53, 69, 0.4) !important;
  }

  .form-control:focus {
    border-color: #e67e22;
    box-shadow: 0 0 0 0.2rem rgba(230, 126, 34, 0.25);
  }
</style>

<%- include('partials/footer') %>
