<%- include('../partials/header') %> <%- include('../partials/navbar') %>

<div class="d-flex align-items-center justify-content-center min-vh-100 py-5">
  <div
    class="card shadow-lg border-0 p-4"
    style="
      max-width: 500px;
      width: 100%;
      border-radius: 12px;
      background: white;
    "
  >
    <div class="text-center mb-4">
      <div
        class="icon-circle mb-3 mx-auto"
        style="
          background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
          width: 80px;
          height: 80px;
          border-radius: 50%;
          display: flex;
          align-items: center;
          justify-content: center;
        "
      >
        <i class="fas fa-user-tie fa-3x text-white"></i>
      </div>
      <h3 class="fw-bold" style="color: #1e3c5c">
        Solo Practitioner Registration
      </h3>
      <p class="text-muted mb-0">
        Create your account - you'll be both Admin and Safety Officer
      </p>
    </div>

    <form action="/register/solo" method="POST">
      <div class="mb-3">
        <label for="name" class="form-label fw-semibold">Full Name *</label>
        <input
          type="text"
          class="form-control form-control-lg"
          id="name"
          name="name"
          placeholder="Enter your full name"
          required
        />
      </div>

      <div class="mb-3">
        <label for="email" class="form-label fw-semibold">Email *</label>
        <input
          type="email"
          class="form-control form-control-lg"
          id="email"
          name="email"
          placeholder="you@example.com"
          required
        />
      </div>

      <div class="mb-3">
        <label for="phone" class="form-label fw-semibold">Phone Number *</label>
        <input
          type="tel"
          class="form-control form-control-lg"
          id="phone"
          name="phone"
          placeholder="+260971234567"
          required
        />
      </div>

      <div class="mb-3">
        <label for="password" class="form-label fw-semibold">Password *</label>
        <input
          type="password"
          class="form-control form-control-lg"
          id="password"
          name="password"
          placeholder="Create a password"
          required
        />
        <small class="text-muted">Minimum 6 characters</small>
      </div>

      <div class="mb-3">
        <label for="companyName" class="form-label fw-semibold"
          >Company/Business Name</label
        >
        <input
          type="text"
          class="form-control form-control-lg"
          id="companyName"
          name="companyName"
          placeholder="e.g., Katumba Safety Consultants"
        />
        <small class="text-muted"
          >Optional - we'll use this for your default worksite</small
        >
      </div>

      <div class="mb-4">
        <label for="bio" class="form-label fw-semibold"
          >Short Bio / Experience</label
        >
        <textarea
          class="form-control"
          id="bio"
          name="bio"
          rows="3"
          placeholder="Tell us about your safety experience..."
        ></textarea>
      </div>

      <button
        type="submit"
        class="btn w-100 py-3 fw-bold"
        style="
          background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
          color: white;
          border: none;
          border-radius: 50px;
        "
      >
        <i class="fas fa-user-plus me-2"></i> Register as Solo Practitioner
      </button>
    </form>

    <div class="text-center mt-4">
      <p class="mb-1 text-muted">Already have an account?</p>
      <a href="/api/users/login" class="fw-semibold" style="color: #667eea">
        <i class="fas fa-sign-in-alt me-1"></i> Login
      </a>
      <span class="mx-2 text-muted">|</span>
      <a href="/register/options" class="fw-semibold" style="color: #667eea">
        <i class="fas fa-arrow-left me-1"></i> Back to Options
      </a>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
