<%- include('../partials/header') %> <%- include('../partials/navbar') %>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-10">
      <div class="text-center mb-5">
        <h1 class="display-4 fw-bold gradient-text mb-3">Join TrueSafe</h1>
        <p class="lead text-secondary">
          Choose the account type that best fits your needs
        </p>
      </div>

      <div class="row g-4">
        <!-- Solo Practitioner Card -->
        <div class="col-md-6">
          <div class="card h-100 shadow-lg border-0 hover-card">
            <div class="card-body text-center p-5">
              <div
                class="icon-circle mb-4 mx-auto"
                style="
                  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
                  width: 120px;
                  height: 120px;
                  border-radius: 50%;
                  display: flex;
                  align-items: center;
                  justify-content: center;
                "
              >
                <i class="fas fa-user-tie fa-4x text-white"></i>
              </div>
              <h2 class="fw-bold mb-3">Solo Practitioner</h2>
              <p class="text-muted mb-4">
                You are a one-person safety consultant or independent officer
                managing your own worksites.
              </p>

              <div class="text-start mb-4">
                <h6 class="fw-bold mb-3">
                  <i class="fas fa-check-circle text-success me-2"></i>You get:
                </h6>
                <ul class="list-unstyled">
                  <li class="mb-2">
                    <i class="fas fa-check text-success me-2"></i> Full System
                    Admin privileges
                  </li>
                  <li class="mb-2">
                    <i class="fas fa-check text-success me-2"></i> Full Safety
                    Officer privileges
                  </li>
                  <li class="mb-2">
                    <i class="fas fa-check text-success me-2"></i> Create and
                    manage your own worksites
                  </li>
                  <li class="mb-2">
                    <i class="fas fa-check text-success me-2"></i> Add team
                    members
                  </li>
                  <li class="mb-2">
                    <i class="fas fa-check text-success me-2"></i> Share
                    worksites with other officers
                  </li>
                  <li class="mb-2">
                    <i class="fas fa-check text-success me-2"></i> Generate AI
                    safety talks and reports
                  </li>
                </ul>
              </div>

              <div class="bg-light p-3 rounded-3 mb-4">
                <p class="mb-0">
                  <strong>Perfect for:</strong> Independent safety consultants,
                  small business owners, solo officers
                </p>
              </div>

              <a
                href="/register/solo"
                class="btn btn-lg w-100 py-3"
                style="
                  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
                  color: white;
                  border: none;
                "
              >
                <i class="fas fa-user-plus me-2"></i> Register as Solo
              </a>
            </div>
          </div>
        </div>

        <!-- Enterprise Admin Card -->
        <div class="col-md-6">
          <div class="card h-100 shadow-lg border-0 hover-card">
            <div class="card-body text-center p-5">
              <div
                class="icon-circle mb-4 mx-auto"
                style="
                  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
                  width: 120px;
                  height: 120px;
                  border-radius: 50%;
                  display: flex;
                  align-items: center;
                  justify-content: center;
                "
              >
                <i class="fas fa-building fa-4x text-white"></i>
              </div>
              <h2 class="fw-bold mb-3">Enterprise Admin</h2>
              <p class="text-muted mb-4">
                You manage a company with multiple worksites and need to oversee
                a team of safety officers.
              </p>

              <div class="text-start mb-4">
                <h6 class="fw-bold mb-3">
                  <i class="fas fa-check-circle text-success me-2"></i>You get:
                </h6>
                <ul class="list-unstyled">
                  <li class="mb-2">
                    <i class="fas fa-check text-success me-2"></i> System Admin
                    privileges
                  </li>
                  <li class="mb-2">
                    <i class="fas fa-check text-success me-2"></i> Create
                    company worksites
                  </li>
                  <li class="mb-2">
                    <i class="fas fa-check text-success me-2"></i> Create safety
                    officer accounts
                  </li>
                  <li class="mb-2">
                    <i class="fas fa-check text-success me-2"></i> Assign
                    officers to worksites
                  </li>
                  <li class="mb-2">
                    <i class="fas fa-check text-success me-2"></i> Approve
                    documents and reports
                  </li>
                  <li class="mb-2">
                    <i class="fas fa-check text-success me-2"></i> Company-wide
                    compliance tracking
                  </li>
                </ul>
              </div>

              <div class="bg-light p-3 rounded-3 mb-4">
                <p class="mb-0">
                  <strong>Perfect for:</strong> Companies with multiple safety
                  officers, construction firms, mining operations
                </p>
              </div>

              <a
                href="/register/enterprise-admin"
                class="btn btn-lg w-100 py-3"
                style="
                  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
                  color: white;
                  border: none;
                "
              >
                <i class="fas fa-building me-2"></i> Register as Enterprise
                Admin
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Additional Info Row -->
      <div class="row mt-5">
        <div class="col-12">
          <div class="card border-0 bg-light">
            <div class="card-body p-4 text-center">
              <div class="row align-items-center">
                <div class="col-md-8 text-center text-md-start">
                  <h5 class="fw-bold mb-2">
                    <i
                      class="fas fa-question-circle me-2"
                      style="color: var(--secondary)"
                    ></i>
                    Already have an account?
                  </h5>
                  <p class="text-muted mb-0 mb-md-0">
                    Login to access your dashboard and continue your safety
                    work.
                  </p>
                </div>
                <div class="col-md-4 text-center text-md-end mt-3 mt-md-0">
                  <a
                    href="/api/users/login"
                    class="btn btn-outline-primary px-4"
                  >
                    <i class="fas fa-sign-in-alt me-2"></i>Login
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Are you a safety officer? -->
      <div class="row mt-4">
        <div class="col-12">
          <div class="alert alert-info text-center mb-0">
            <i class="fas fa-info-circle me-2"></i>
            <strong>Were you invited by your company?</strong> If your admin
            created an account for you,
            <a href="/api/users/login" class="alert-link">login here</a> with
            the credentials they provided.
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .hover-card {
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease;
  }

  .hover-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15) !important;
  }

  .icon-circle {
    transition: transform 0.3s ease;
  }

  .hover-card:hover .icon-circle {
    transform: scale(1.1);
  }

  .gradient-text {
    background: linear-gradient(135deg, var(--secondary), var(--accent));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .btn {
    transition: all 0.3s ease;
  }

  .btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
  }
</style>

<%- include('../partials/footer') %>
