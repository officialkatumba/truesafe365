<%- include('../partials/header') %> <%- include('../partials/navbar') %>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-8">
      <div class="text-center mb-5">
        <h1 class="display-4 fw-bold gradient-text mb-3">Join TrueSafe</h1>
        <p class="lead text-secondary">
          Register as an Enterprise Admin to manage your company's workplace
          safety
        </p>
      </div>

      <div class="row g-4 justify-content-center">
        <!-- Enterprise Admin Card (Centered) -->
        <div class="col-md-8">
          <div class="card h-100 shadow-lg border-0 hover-card">
            <div class="card-body text-center p-5">
              <div
                class="icon-circle mb-4 mx-auto"
                style="
                  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
                  width: 120px;
                  height: 120px;
                  border-radius: 50%;
                  display: flex;
                  align-items: center;
                  justify-content: center;
                "
              >
                <i class="fas fa-building fa-4x text-white"></i>
              </div>
              <h2 class="fw-bold mb-3">Enterprise Admin</h2>
              <p class="text-muted mb-4">
                Register your company to manage worksites, create safety officer
                accounts, and oversee compliance across your organization.
              </p>

              <div class="text-start mb-4">
                <h6 class="fw-bold mb-3">
                  <i class="fas fa-check-circle text-success me-2"></i>As an
                  Enterprise Admin, you can:
                </h6>
                <ul class="list-unstyled">
                  <li class="mb-2">
                    <i class="fas fa-check text-success me-2"></i> Create and
                    manage company worksites
                  </li>
                  <li class="mb-2">
                    <i class="fas fa-check text-success me-2"></i> Create safety
                    officer accounts with secure credentials
                  </li>
                  <li class="mb-2">
                    <i class="fas fa-check text-success me-2"></i> Assign
                    officers to specific worksites and work areas
                  </li>
                  <li class="mb-2">
                    <i class="fas fa-check text-success me-2"></i> Review and
                    approve safety documents
                  </li>
                  <li class="mb-2">
                    <i class="fas fa-check text-success me-2"></i> Track
                    company-wide compliance and safety metrics
                  </li>
                  <li class="mb-2">
                    <i class="fas fa-check text-success me-2"></i> Generate
                    AI-powered insights and reports
                  </li>
                </ul>
              </div>

              <div class="bg-light p-3 rounded-3 mb-4">
                <p class="mb-0">
                  <strong>Perfect for:</strong> Construction firms, mining
                  operations, manufacturing plants, and any organization with
                  multiple worksites and safety officers.
                </p>
              </div>

              <a
                href="/register/enterprise-admin"
                class="btn btn-lg w-100 py-3"
                style="
                  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
                  color: white;
                  border: none;
                "
              >
                <i class="fas fa-building me-2"></i> Register as Enterprise
                Admin
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Login Option -->
      <div class="row mt-5">
        <div class="col-12">
          <div class="card border-0 bg-light">
            <div class="card-body p-4 text-center">
              <div class="row align-items-center">
                <div class="col-md-8 text-center text-md-start">
                  <h5 class="fw-bold mb-2">
                    <i
                      class="fas fa-question-circle me-2"
                      style="color: var(--secondary)"
                    ></i>
                    Already have an account?
                  </h5>
                  <p class="text-muted mb-0 mb-md-0">
                    Login to access your dashboard and continue managing your
                    safety operations.
                  </p>
                </div>
                <div class="col-md-4 text-center text-md-end mt-3 mt-md-0">
                  <a
                    href="/api/users/login"
                    class="btn btn-outline-primary px-4"
                    style="
                      border-radius: 40px;
                      border-color: #f093fb;
                      color: #f093fb;
                    "
                  >
                    <i class="fas fa-sign-in-alt me-2"></i>Login
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Safety Officer Login Info -->
      <div class="row mt-4">
        <div class="col-12">
          <div
            class="alert alert-info text-center mb-0"
            style="border-radius: 16px; border-left: 5px solid #f093fb"
          >
            <i class="fas fa-info-circle me-2" style="color: #f093fb"></i>
            <strong>Are you a safety officer?</strong> If your company admin
            created an account for you,
            <a href="/api/users/login" class="alert-link" style="color: #f093fb"
              >login here</a
            >
            with the credentials they provided.
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .hover-card {
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease;
    border-radius: 24px;
  }

  .hover-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15) !important;
  }

  .icon-circle {
    transition: transform 0.3s ease;
  }

  .hover-card:hover .icon-circle {
    transform: scale(1.1);
  }

  .gradient-text {
    background: linear-gradient(135deg, #f093fb, #f5576c);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .btn {
    transition: all 0.3s ease;
    border-radius: 40px;
  }

  .btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
  }

  .btn-outline-primary {
    border-color: #f093fb;
    color: #f093fb;
  }

  .btn-outline-primary:hover {
    background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
    border-color: #f5576c;
    color: white;
  }

  .alert-info {
    background-color: #f8f9fa;
    border: none;
  }
</style>

<%- include('../partials/footer') %>
