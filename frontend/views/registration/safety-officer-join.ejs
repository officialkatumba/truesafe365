<%- include('../partials/header') %> <%- include('../partials/navbar') %>

<div class="d-flex align-items-center justify-content-center min-vh-100 py-5">
  <div
    class="card shadow-lg border-0 p-4"
    style="
      max-width: 550px;
      width: 100%;
      border-radius: 12px;
      background: white;
    "
  >
    <div class="text-center mb-4">
      <div
        class="icon-circle mb-3 mx-auto"
        style="
          background: linear-gradient(135deg, #ff9800 0%, #f57c00 100%);
          width: 80px;
          height: 80px;
          border-radius: 50%;
          display: flex;
          align-items: center;
          justify-content: center;
        "
      >
        <i class="fas fa-user-shield fa-3x text-white"></i>
      </div>
      <h3 class="fw-bold" style="color: #1e3c5c">Join as Safety Officer</h3>
      <p class="text-muted mb-0">
        Search for your company and enter the PIN to join
      </p>
    </div>

    <form action="/register/safety-officer/join" method="POST">
      <!-- Searchable Company Dropdown (like student search) -->
      <div class="mb-3">
        <label class="fw-semibold">Company</label>
        <div class="position-relative">
          <input
            type="text"
            id="companySearch"
            class="form-control form-control-lg"
            placeholder="Start typing company name..."
            autocomplete="off"
            style="border-radius: 40px"
          />
          <input
            type="hidden"
            name="companyId"
            id="selectedCompanyId"
            required
          />
          <div
            id="companyDropdown"
            class="dropdown-menu w-100"
            style="display: none; max-height: 250px; overflow-y: auto"
          >
            <!-- Search results will appear here -->
          </div>
        </div>
        <div
          id="selectedCompanyInfo"
          class="mt-2 p-2 border rounded bg-light"
          style="display: none"
        >
          <small class="text-muted">Selected:</small>
          <span id="selectedCompanyText" class="fw-semibold ms-2"></span>
          <button
            type="button"
            id="clearSelection"
            class="btn btn-sm btn-outline-danger float-end"
          >
            ×
          </button>
        </div>
        <div class="form-text">Search by company name</div>
      </div>

      <!-- Company PIN Field - Required (only shows after company selected) -->
      <div class="mb-3" id="pinField" style="display: none">
        <label for="companyPin" class="form-label fw-semibold"
          >Company PIN *</label
        >
        <input
          type="text"
          class="form-control form-control-lg"
          id="companyPin"
          name="companyPin"
          placeholder="Enter 6-digit company PIN"
          style="border-radius: 40px"
          required
        />
        <small class="text-muted"
          >Enter the PIN provided by your company administrator</small
        >
      </div>

      <div class="mb-3">
        <label for="name" class="form-label fw-semibold"
          >Your Full Name *</label
        >
        <input
          type="text"
          class="form-control form-control-lg"
          id="name"
          name="name"
          placeholder="Enter your full name"
          required
          style="border-radius: 40px"
        />
      </div>

      <div class="mb-3">
        <label for="email" class="form-label fw-semibold"
          >Email Address *</label
        >
        <input
          type="email"
          class="form-control form-control-lg"
          id="email"
          name="email"
          placeholder="your@email.com"
          required
          style="border-radius: 40px"
        />
      </div>

      <div class="mb-3">
        <label for="phone" class="form-label fw-semibold">Phone Number *</label>
        <input
          type="tel"
          class="form-control form-control-lg"
          id="phone"
          name="phone"
          placeholder="+260 XXX XXX XXX"
          required
          style="border-radius: 40px"
        />
      </div>

      <!-- Bio Field -->
      <div class="mb-3">
        <label for="bio" class="form-label fw-semibold"
          >Bio / Qualifications</label
        >
        <textarea
          class="form-control"
          id="bio"
          name="bio"
          rows="3"
          placeholder="Brief description of your qualifications, experience, and certifications..."
          style="border-radius: 16px"
        ></textarea>
        <small class="text-muted">Optional: Share your safety background</small>
      </div>

      <div class="mb-3">
        <label for="password" class="form-label fw-semibold">Password *</label>
        <input
          type="password"
          class="form-control form-control-lg"
          id="password"
          name="password"
          placeholder="Create a password"
          required
          style="border-radius: 40px"
        />
        <small class="text-muted">Minimum 6 characters</small>
      </div>

      <div class="mb-4">
        <label for="confirmPassword" class="form-label fw-semibold"
          >Confirm Password *</label
        >
        <input
          type="password"
          class="form-control form-control-lg"
          id="confirmPassword"
          name="confirmPassword"
          placeholder="Confirm password"
          required
          style="border-radius: 40px"
        />
      </div>

      <button
        type="submit"
        class="btn w-100 py-3 fw-bold"
        style="
          background: linear-gradient(135deg, #ff9800 0%, #f57c00 100%);
          color: white;
          border-radius: 50px;
        "
      >
        <i class="fas fa-user-plus me-2"></i> Join Company
      </button>
    </form>

    <div class="text-center mt-4">
      <p class="mb-1 text-muted">Already have an account?</p>
      <a href="/api/users/login" class="fw-semibold" style="color: #ff9800">
        <i class="fas fa-sign-in-alt me-1"></i> Login
      </a>
    </div>
  </div>
</div>

<script>
  // All companies loaded from server
  const allCompanies = <%- JSON.stringify(companies) %>;

  let searchTimeout = null;

  // Company search function (client-side filtering)
  function searchCompanies() {
    const searchTerm = document.getElementById("companySearch").value.toLowerCase().trim();
    const dropdown = document.getElementById("companyDropdown");

    if (searchTerm.length < 2) {
      dropdown.style.display = "none";
      return;
    }

    // Filter companies client-side
    const filteredCompanies = allCompanies.filter(company =>
      company.companyName.toLowerCase().includes(searchTerm)
    );

    if (filteredCompanies.length === 0) {
      dropdown.innerHTML = '<div class="dropdown-item text-muted">No companies found</div>';
      dropdown.style.display = "block";
      return;
    }

    dropdown.innerHTML = filteredCompanies.map(company => `
      <button type="button" class="dropdown-item"
              data-id="${company._id}"
              data-name="${company.companyName}"
              data-size="${company.companySize}">
        <strong>${company.companyName}</strong><br>
        <small class="text-muted">Size: ${company.companySize || "N/A"}</small>
      </button>
    `).join('');

    dropdown.style.display = "block";

    // Add click listeners
    document.querySelectorAll('#companyDropdown .dropdown-item').forEach(item => {
      item.addEventListener('click', function() {
        const companyId = this.getAttribute('data-id');
        const companyName = this.getAttribute('data-name');
        const companySize = this.getAttribute('data-size');

        document.getElementById('selectedCompanyId').value = companyId;
        document.getElementById('selectedCompanyText').innerHTML = `
          <i class="fas fa-building me-2"></i>${companyName}
          <span class="badge bg-secondary ms-2">${companySize}</span>
        `;
        document.getElementById('selectedCompanyInfo').style.display = "block";
        document.getElementById('companySearch').value = "";
        document.getElementById('pinField').style.display = "block";
        dropdown.style.display = "none";

        // Focus on PIN field
        document.getElementById('companyPin').focus();
      });
    });
  }

  // Clear selection
  function clearSelection() {
    document.getElementById('selectedCompanyId').value = "";
    document.getElementById('selectedCompanyInfo').style.display = "none";
    document.getElementById('companySearch').value = "";
    document.getElementById('companySearch').focus();
    document.getElementById('pinField').style.display = "none";
    document.getElementById('companyPin').value = "";
  }

  // Handle click outside
  document.addEventListener('click', function(e) {
    const searchInput = document.getElementById('companySearch');
    const dropdown = document.getElementById('companyDropdown');

    if (!searchInput.contains(e.target) && !dropdown.contains(e.target)) {
      dropdown.style.display = "none";
    }
  });

  // Debounced search
  document.getElementById("companySearch").addEventListener("input", function() {
    clearTimeout(searchTimeout);
    searchTimeout = setTimeout(searchCompanies, 300);
  });

  // Clear selection button
  document.getElementById("clearSelection").addEventListener("click", clearSelection);

  // PIN validation
  const pinInput = document.getElementById("companyPin");
  if (pinInput) {
    pinInput.addEventListener("input", function(e) {
      this.value = this.value
        .toUpperCase()
        .replace(/[^A-Z0-9]/g, "")
        .slice(0, 6);
    });
  }

  // Password confirmation validation
  const password = document.getElementById("password");
  const confirmPassword = document.getElementById("confirmPassword");

  function validatePassword() {
    if (password.value !== confirmPassword.value) {
      confirmPassword.setCustomValidity("Passwords don't match");
    } else {
      confirmPassword.setCustomValidity("");
    }
  }

  password.onchange = validatePassword;
  confirmPassword.onkeyup = validatePassword;
</script>

<style>
  .form-control,
  .form-select {
    border: 1px solid #dee2e6;
    transition: border-color 0.2s ease;
  }

  .form-control:focus,
  .form-select:focus {
    border-color: #ff9800;
    box-shadow: 0 0 0 0.2rem rgba(255, 152, 0, 0.25);
  }

  .alert-success {
    background-color: #e8f5e9;
    border-color: #c8e6c9;
  }

  .dropdown-item:hover,
  .dropdown-item.active {
    background-color: #f8f9fa;
    cursor: pointer;
  }

  .dropdown-item {
    white-space: normal;
    padding: 0.5rem 1rem;
  }
</style>

<%- include('../partials/footer') %>
