<!-- frontend/views/worker/dashboard.ejs -->
<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="main-wrapper">
  <div class="content container py-4">
    <div class="worker-dashboard-container" style="max-width: 900px; margin: 0 auto;">
      <!-- Worker Header -->
      <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
        <div>
          <h3 class="mb-1">
            <i class="fas fa-hard-hat me-2" style="color: #4caf50;"></i>
            Worker Dashboard
          </h3>
          <div class="d-flex gap-2">
            <span class="badge text-bg-secondary">
              <i class="fas fa-id-card me-1"></i> <%= worker.workerNumber || user.workerNumber || 'Not assigned' %>
            </span>
            <span class="badge text-bg-success">
              <i class="fas fa-check-circle me-1"></i> Active
            </span>
            <span class="badge text-bg-info">
              <i class="fas fa-calendar me-1"></i> <%= new Date().toLocaleDateString() %>
            </span>
          </div>
        </div>
        <span class="text-muted small">
          <i class="fas fa-user me-1"></i> Welcome, <strong><%= worker.name || user.name %></strong>
        </span>
      </div>

      <!-- Profile Card -->
      <div class="card border-0 shadow-sm mb-4" style="border-radius: 16px;">
        <div class="card-body p-4">
          <div class="row">
            <div class="col-md-3 text-center text-md-start">
              <div class="mx-auto mb-3" style="width: 100px; height: 100px; background: linear-gradient(135deg, #4caf50 0%, #1e3c5c 100%); border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                <i class="fas fa-hard-hat fa-3x text-white"></i>
              </div>
            </div>
            <div class="col-md-9">
              <h5 class="fw-bold mb-2"><%= worker.name || user.name %></h5>
              <div class="row">
                <div class="col-md-6">
                  <p class="mb-1"><i class="fas fa-envelope me-2 text-muted"></i> <%= worker.email || user.email %></p>
                  <p class="mb-1"><i class="fas fa-phone me-2 text-muted"></i> <%= worker.phone || 'Not provided' %></p>
                </div>
                <div class="col-md-6">
                  <p class="mb-1"><i class="fas fa-building me-2 text-muted"></i> Company: <%= company?.companyName || 'N/A' %></p>
                  <p class="mb-1"><i class="fas fa-map-marker-alt me-2 text-muted"></i> Position: <%= worker.position || 'General Worker' %></p>
                </div>
              </div>
              <div class="mt-2 p-2 rounded-3" style="background: #f8f9fa;">
                <small class="text-muted"><i class="fas fa-shield-alt me-1 text-success"></i> Safety is everyone's responsibility. Report hazards and near misses immediately.</small>
              </div>
            </div>
          </div>
        </div>
      </div>

      <hr />

      <!-- Assigned Work Area Section -->
      <h4 class="text-center mb-4 fw-bold">
        <i class="fas fa-map-marked-alt me-2" style="color: #4caf50;"></i>
        My Assigned Work Area
      </h4>

      <div class="card shadow-sm border-0 mb-4" style="border-radius: 16px;">
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
              <thead style="background: #f8f9fa;">
                <tr>
                  <th class="px-4 py-3">Work Area</th>
                  <th class="py-3">Worksite</th>
                  <th class="py-3">Location</th>
                  <th class="py-3">Shift</th>
                  <th class="py-3 text-end pe-4">Actions</th>
                </tr>
              </thead>
              <tbody>
                <% if (workArea) { %>
                <tr>
                  <td class="px-4 py-3">
                    <div class="d-flex align-items-center">
                      <div class="icon-circle-sm me-2" style="background: linear-gradient(135deg, #4caf50 0%, #1e3c5c 100%); width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                        <i class="fas fa-map-marked-alt text-white" style="font-size: 0.8rem;"></i>
                      </div>
                      <strong><%= workArea.name %></strong>
                    </div>
                   </td>
                  <td class="py-3"><%= workArea.worksite?.name || 'N/A' %></td>
                  <td class="py-3"><%= workArea.location?.zone || workArea.location || 'Not specified' %></td>
                  <td class="py-3">
                    <span class="badge bg-info bg-opacity-10 text-info px-3 py-2 rounded-pill">
                      <i class="fas fa-clock me-1"></i> <%= worker.shift || 'Morning' %>
                    </span>
                  </td>
                  <td class="py-3 text-end pe-4">
                    <a href="/work-areas/<%= workArea._id %>" class="btn btn-sm btn-outline-primary" style="border-radius: 40px;">
                      <i class="fas fa-eye me-1"></i> View Details
                    </a>
                  </td>
                </tr>
                <% } else { %>
                  <tr>
                    <td colspan="5" class="text-center py-5">
                      <i class="fas fa-info-circle fa-2x text-muted mb-2 d-block"></i>
                      <p class="text-muted mb-0">No work area assigned yet.</p>
                      <small class="text-muted">Contact your safety officer to be assigned to a work area.</small>
                    </td>
                  </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .main-wrapper {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }
  
  .content {
    flex: 1;
  }

  .worker-dashboard-container {
    max-width: 900px;
    margin: 0 auto;
  }

  .icon-circle-sm {
    transition: transform 0.3s ease;
  }

  .btn {
    transition: all 0.3s ease;
    border-radius: 40px;
  }

  .btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
  }
  
  .card {
    border-radius: 16px;
  }
  
  .badge {
    font-size: 0.75rem;
    padding: 0.35rem 0.75rem;
    border-radius: 40px;
  }

  .table th {
    font-weight: 600;
    color: #1e3c5c;
    border-bottom: 2px solid #e9ecef;
  }

  .table td {
    vertical-align: middle;
    border-bottom: 1px solid #e9ecef;
  }

  .table tr:hover {
    background-color: #f8f9fa;
  }
</style>

<%- include('../partials/footer') %>