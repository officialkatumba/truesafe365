<!-- Emergency Banner -->
<div class="emergency-banner">
  <div class="container">
    <div class="row align-items-center">
      <div class="col-md-8 text-center text-md-start">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>
        <strong>Emergency? Report immediately:</strong>
        <a href="tel:+260966658181" class="mx-2 text-white">
          <i class="bi bi-telephone-fill me-1"></i>Call
        </a>
        <span class="text-white-50">|</span>
        <a
          href="https://wa.me/260966658181?text=URGENT%20SAFETY%20REPORT%3A%20Please%20assist%20with%20an%20emergency%20at%20our%20worksite"
          class="mx-2 text-white"
          target="_blank"
        >
          <i class="bi bi-whatsapp me-1"></i>WhatsApp
        </a>
      </div>
      <div class="col-md-4 text-center text-md-end mt-2 mt-md-0">
        <i class="bi bi-shield-shaded me-2"></i>
        <span>24/7 Safety Hotline</span>
      </div>
    </div>
  </div>
</div>

<!-- Navbar -->
<nav class="navbar navbar-expand-lg">
  <div class="container">
    <a class="navbar-brand fw-bold" href="/">
      <i class="bi bi-shield-check me-2" style="color: var(--secondary);"></i>
      TrueSafe
    </a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse justify-content-end" id="navbarNav">
      <ul class="navbar-nav">
        <li class="nav-item">
          <a class="nav-link" href="/">Home</a>
        </li>
        <% if (user) { %>
          <% if (user.role === 'system_admin') { %>
            <!-- Enterprise Admin -->
            <li class="nav-item">
              <a class="nav-link" href="/dashboard/admin">Dashboard</a>
            </li>
          <% } else if (user.role === 'safety_officer') { %>
            <!-- Safety Officer -->
            <li class="nav-item">
              <a class="nav-link" href="/dashboard/officer">Dashboard</a>
            </li>
          <% } else if (user.role === 'worker') { %>
            <!-- Worker -->
            <li class="nav-item">
              <a class="nav-link" href="/dashboard/worker">Dashboard</a>
            </li>
          <% } %>
          <li class="nav-item">
            <a class="nav-link" href="/api/users/change-password">Settings</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/api/users/logout">Logout</a>
          </li>
        <% } else { %>
          <li class="nav-item">
            <a class="nav-link" href="/api/users/login">Login</a>
          </li>
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" href="#" id="registerDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
              <i class="bi bi-person-plus-fill me-1"></i>Register
            </a>
            <ul class="dropdown-menu" aria-labelledby="registerDropdown">
              <li>
                <a class="dropdown-item" href="/register/enterprise-admin">
                  <i class="bi bi-building me-2"></i>Enterprise Admin
                  <small class="d-block text-muted">Register your company</small>
                </a>
              </li>
              <li><hr class="dropdown-divider"></li>
              <li>
                <a class="dropdown-item" href="/register/safety-officer/join">
                  <i class="bi bi-shield-check me-2"></i>Safety Officer
                  <small class="d-block text-muted">Join with company PIN</small>
                </a>
              </li>
              <li><hr class="dropdown-divider"></li>
              <li>
                <a class="dropdown-item" href="/register/worker/join">
                  <i class="bi bi-person-badge me-2"></i>Worker
                  <small class="d-block text-muted">Join with company PIN</small>
                </a>
              </li>
            </ul>
          </li>
        <% } %>
      </ul>
    </div>
  </div>
</nav>

<style>
  .emergency-banner {
    background: linear-gradient(135deg, #dc3545 0%, #c82333 100%);
    color: white;
    padding: 8px 0;
    font-size: 0.85rem;
  }
  
  .emergency-banner a {
    text-decoration: none;
    transition: opacity 0.3s ease;
  }
  
  .emergency-banner a:hover {
    opacity: 0.8;
  }
  
  .navbar {
    background: transparent;
    padding: 12px 0;
    box-shadow: none;
    border-bottom: none;
  }
  
  .navbar-brand {
    font-size: 1.5rem;
    color: #1e3c5c !important;
    font-weight: 700;
  }
  
  .navbar-brand i {
    color: #e67e22;
  }
  
  .nav-link {
    color: #4a5568 !important;
    font-weight: 500;
    transition: all 0.3s ease;
    margin: 0 4px;
  }
  
  .nav-link:hover {
    color: #e67e22 !important;
  }
  
  .dropdown-menu {
    border: none;
    border-radius: 8px;
    box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    margin-top: 8px;
    padding: 8px 0;
    background: white;
  }
  
  .dropdown-item {
    padding: 8px 20px;
    transition: all 0.3s ease;
    color: #4a5568;
  }
  
  .dropdown-item:hover {
    background-color: #f8f9fa;
    color: #e67e22;
    padding-left: 25px;
  }
  
  .dropdown-item small {
    font-size: 0.7rem;
    color: #6c757d;
  }
  
  .dropdown-item i {
    width: 20px;
    color: #e67e22;
    margin-right: 8px;
  }
  
  .dropdown-divider {
    margin: 8px 0;
  }
  
  @media (max-width: 768px) {
    .navbar {
      background: transparent;
    }
    
    .dropdown-menu {
      border: none;
      background: rgba(255, 255, 255, 0.95);
      box-shadow: none;
      padding-left: 20px;
    }
    
    .dropdown-item {
      color: #4a5568 !important;
    }
    
    .dropdown-item small {
      color: #6c757d !important;
    }
    
    .dropdown-item i {
      color: #e67e22;
    }
    
    .dropdown-item:hover {
      background: #f8f9fa;
      padding-left: 25px;
    }
  }
</style>