<header class="all-safe-navigation-region" aria-label="TrueSafe365 site navigation">
  <!-- Emergency Banner -->
  <div class="emergency-banner">
  <div class="container emergency-banner-shell">
    <div class="row align-items-center">
      <div class="col-md-8 text-center text-md-start">
        <i class="bi bi-whatsapp me-2"></i>
        <strong>For any enquiry, reach us through WhatsApp:</strong>
        <a
          href="https://wa.me/260977658181?text=Hello%20TrueSafe365%2C%20I%20have%20an%20enquiry."
          class="mx-2 text-white"
          target="_blank"
          rel="noopener noreferrer"
        >
          <i class="bi bi-whatsapp me-1"></i>0977658181
        </a>
      </div>
      <div class="col-md-4 text-center text-md-end mt-2 mt-md-0">
        <i class="bi bi-shield-shaded me-2"></i>
        <span>Safety and support enquiries</span>
      </div>
    </div>
  </div>
</div>

  <!-- Main Navigation Area -->
  <nav class="navbar navbar-expand-lg all-safe-navigation-area" aria-label="Main navigation">
  <div class="container all-safe-navigation-shell">
    <a class="navbar-brand fw-bold" href="/">
      <i class="bi bi-shield-check me-2" style="color: var(--secondary);"></i>
      TrueSafe365
    </a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse justify-content-end" id="navbarNav">
      <ul class="navbar-nav all-safe-navigation-links">
        <li class="nav-item">
          <a class="nav-link" href="/">Home</a>
        </li>
        <% if (user) { %>
          <li class="nav-item">
            <a class="nav-link" href="/dashboard/officer">Dashboard</a>
          </li>
          <li class="nav-item">
            <a class="nav-link <%= hasUrgentAlerts ? 'alert-nav-link' : '' %>" href="/alerts">
              <i class="bi bi-exclamation-triangle-fill me-1"></i>Alerts
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/api/users/change-password">
              <i class="bi bi-key-fill me-1"></i>Change Password
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/api/users/logout">Logout</a>
          </li>
        <% } else { %>
          <li class="nav-item">
            <a class="nav-link" href="/api/users/login">Login</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/register/safety-officer">
              <i class="bi bi-person-plus-fill me-1"></i>Register
            </a>
          </li>
        <% } %>
      </ul>
    </div>
  </div>
</nav>
</header>

<link rel="stylesheet" href="/css/navbar.css" />

