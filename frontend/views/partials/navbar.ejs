<!-- Emergency Banner -->
<div class="emergency-banner">
  <div class="container">
    <div class="row align-items-center">
      <div class="col-md-8 text-center text-md-start">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>
        <strong>Emergency? Report immediately:</strong>
        <a href="tel:+260966658181" class="mx-2 text-white">
          <i class="bi bi-telephone-fill me-1"></i>Call
        </a>
        <span class="text-white-50">|</span>
        <a
          href="https://wa.me/260966658181?text=URGENT%20SAFETY%20REPORT%3A%20Please%20assist%20with%20an%20emergency%20at%20our%20worksite"
          class="mx-2 text-white"
          target="_blank"
        >
          <i class="bi bi-whatsapp me-1"></i>WhatsApp
        </a>
      </div>
      <div class="col-md-4 text-center text-md-end mt-2 mt-md-0">
        <i class="bi bi-shield-shaded me-2"></i>
        <span>24/7 Safety Hotline</span>
      </div>
    </div>
  </div>
</div>

<!-- Navbar -->
<nav class="navbar navbar-expand-lg">
  <div class="container">
    <a class="navbar-brand fw-bold" href="/">
      <i class="bi bi-shield-check me-2" style="color: var(--secondary);"></i>
      TrueSafe
    </a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse justify-content-end" id="navbarNav">
      <ul class="navbar-nav">
        <li class="nav-item">
          <a class="nav-link" href="/">Home</a>
        </li>
        <% if (user) { %>
          <% if (user.isDualRole) { %>
            <!-- Solo Practitioner -->
            <li class="nav-item">
              <a class="nav-link" href="/dashboard/solo">Dashboard</a>
            </li>
          <% } else if (user.role === 'system_admin' && user.accountType === 'enterprise_admin') { %>
            <!-- Enterprise Admin -->
            <li class="nav-item">
              <a class="nav-link" href="/dashboard/admin">Dashboard</a>
            </li>
          <% } else if (user.role === 'safety_officer') { %>
            <!-- Enterprise Safety Officer -->
            <li class="nav-item">
              <a class="nav-link" href="/dashboard/officer">Dashboard</a>
            </li>
          <% } %>
          <li class="nav-item">
            <a class="nav-link" href="/api/users/change-password">Settings</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/api/users/logout">Logout</a>
          </li>
        <% } else { %>
          <li class="nav-item">
            <a class="nav-link" href="/api/users/login">Login</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/register/options">
              <i class="bi bi-person-plus-fill me-1"></i>Register
            </a>
          </li>
        <% } %>
      </ul>
    </div>
  </div>
</nav>