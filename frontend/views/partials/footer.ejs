<footer class="site-footer py-5" style="background: radial-gradient(circle at top left, rgba(225, 29, 72, 0.08), transparent 26rem), linear-gradient(135deg, #ffffff 0%, #fff7f8 100%); position: relative; overflow: hidden;">
  <!-- Animated background elements -->
  <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; opacity: 0.1; pointer-events: none;">
    <div style="position: absolute; top: 10%; left: 5%; width: 200px; height: 200px; border-radius: 50%; background: radial-gradient(circle, #ffffff 0%, transparent 70%); animation: float 8s infinite ease-in-out;"></div>
    <div style="position: absolute; bottom: 10%; right: 5%; width: 300px; height: 300px; border-radius: 50%; background: radial-gradient(circle, #fecdd3 0%, transparent 70%); animation: float 12s infinite ease-in-out reverse;"></div>
  </div>

  <div class="container position-relative">
    <div class="row g-4 align-items-center">
      <!-- Branding -->
      <div class="col-lg-8 mb-4 mb-lg-0">
        <div class="d-flex align-items-center mb-3">
          <div style="background: linear-gradient(135deg, #fff, #fecdd3); width: 50px; height: 50px; border-radius: 15px; display: flex; align-items: center; justify-content: center; margin-right: 15px; box-shadow: 0 10px 20px rgba(255, 255, 255, 0.22);">
            <i class="bi bi-shield-check fs-2" style="color: #be123c;"></i>
          </div>
          <h3 class="fw-bold mb-0" style="background: linear-gradient(135deg, #fff, #ffe4e6); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">TrueSafe365</h3>
        </div>
        <p class="text-white-50 mb-3">AI-powered safety intelligence for professional work-area documentation, review, and prevention.</p>

        <div class="d-flex gap-2">
          <span class="badge px-3 py-2" style="background: linear-gradient(135deg, #fff, #fecdd3); color: #9f1239; box-shadow: 0 8px 22px rgba(190, 18, 60, 0.12);">
            <i class="bi bi-patch-check-fill me-1"></i>ISO 45001
          </span>
          <span class="badge px-3 py-2" style="background: linear-gradient(135deg, #fff1f2, #ffffff); color: #9f1239; box-shadow: 0 8px 22px rgba(190, 18, 60, 0.12);">
            <i class="bi bi-shield-fill-check me-1"></i>OSHA Compliant
          </span>
        </div>
      </div>

      <!-- Social Links -->
      <div class="col-lg-4">
        <div class="footer-socials d-flex justify-content-lg-end justify-content-start gap-2">
          <a href="https://wa.me/260977658181?text=Hello%20TrueSafe365%2C%20I%20have%20an%20enquiry." class="footer-social-link" aria-label="WhatsApp enquiry" target="_blank" rel="noopener noreferrer">
            <i class="bi bi-facebook"></i>
          </a>
          <a href="https://wa.me/260977658181?text=Hello%20TrueSafe365%2C%20I%20have%20an%20enquiry." class="footer-social-link" aria-label="WhatsApp enquiry" target="_blank" rel="noopener noreferrer">
            <i class="bi bi-twitter-x"></i>
          </a>
          <a href="https://wa.me/260977658181?text=Hello%20TrueSafe365%2C%20I%20have%20an%20enquiry." class="footer-social-link" aria-label="WhatsApp enquiry" target="_blank" rel="noopener noreferrer">
            <i class="bi bi-linkedin"></i>
          </a>
          <a href="https://wa.me/260977658181?text=Hello%20TrueSafe365%2C%20I%20have%20an%20enquiry." class="footer-social-link" aria-label="WhatsApp enquiry" target="_blank" rel="noopener noreferrer">
            <i class="bi bi-whatsapp"></i>
          </a>
        </div>
      </div>
    </div>

    <hr class="my-4" style="background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent); height: 2px; border: none;">

    <div class="row">
      <div class="col-12">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-center">
          <p class="mb-3 mb-md-0 text-white-50 small">
            <i class="bi bi-c-circle me-1"></i> <%= new Date().getFullYear() %> TrueSafe365 by Frontline Softwares. All rights reserved.
          </p>
          <div class="mt-3 mt-md-0">
            <span class="badge" style="background: linear-gradient(135deg, #fff, #fecdd3); color: #9f1239; padding: 8px 15px;">
              <i class="bi bi-shield-fill-check me-1"></i> Safety First, Always
            </span>
          </div>
        </div>
      </div>
    </div>
  </div>
</footer>

<button type="button" id="backToTopButton" class="back-to-top-button" aria-label="Back to top">
  <i class="bi bi-arrow-up"></i>
</button>

<div id="submitLockOverlay" class="submit-lock-overlay" aria-live="polite" aria-busy="true" hidden>
  <div class="submit-lock-panel">
    <div class="submit-lock-spinner" aria-hidden="true"></div>
    <h5 class="mb-2">Please wait</h5>
    <p id="submitLockMessage" class="mb-0 text-muted">Submitting your request. Please wait...</p>
  </div>
</div>

<link rel="stylesheet" href="/css/footer.css" />

<!-- Bootstrap Bundle -->
<script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>

<!-- SweetAlert2 -->
<script src="/vendor/sweetalert2/sweetalert2.all.min.js"></script>

<!-- Local form auto-save for long field forms -->
<script src="/js/form-autosave.js"></script>

<!-- Flash message alerts -->
<script>
  <% if (typeof success !== 'undefined' && success.length > 0) { %>
    Swal.fire({
      icon: 'success',
      title: 'Success!',
      text: "<%= success[0] %>",
      timer: 3000,
      showConfirmButton: true,
      customClass: {
        popup: 'all-safe-medical-alert',
        confirmButton: 'all-safe-medical-confirm'
      }
    });
  <% } %>

  <% if (typeof error !== 'undefined' && error.length > 0) { %>
    Swal.fire({
      icon: 'error',
      title: 'Oops!',
      text: "<%= error[0] %>",
      timer: 3000,
      showConfirmButton: true,
      customClass: {
        popup: 'all-safe-medical-alert',
        confirmButton: 'all-safe-medical-confirm'
      }
    });
  <% } %>
</script>

<script>
  window.allSafeCsrfToken = "<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>";
</script>
<script src="/js/app.js"></script>

</body>
</html>


