<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="container py-5">
  <!-- Header with Profile Summary - Matching solo dashboard style -->
  <div class="row mb-4">
    <div class="col-12">
      <div class="card border-0" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);">
        <div class="card-body p-4 text-white">
          <div class="row align-items-center">
            <div class="col-md-8">
              <div class="d-flex align-items-center mb-2">
                <i class="fas fa-building fa-2x me-3"></i>
                <div>
                  <h2 class="display-5 fw-bold mb-0">Enterprise Admin Dashboard</h2>
                  <p class="lead mb-0">Company-wide oversight and compliance management</p>
                </div>
              </div>
              <p class="mb-2 mt-3">
                Welcome back, <strong><%= user.email %></strong>
              </p>
              <div class="mt-2">
                <span class="badge bg-warning text-dark p-2 me-2">
                  <i class="fas fa-crown me-1"></i> System Administrator
                </span>
                <span class="badge bg-info p-2 me-2">
                  <i class="fas fa-chart-line me-1"></i> Enterprise Access
                </span>
                
                <% 
                let currentDate = new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
                %>
                
                <span class="badge bg-secondary p-2">
                  <i class="fas fa-calendar me-1"></i> <%= currentDate %>
                </span>
              </div>
            </div>
            <div class="col-md-4 text-center text-md-end mt-3 mt-md-0">
              <img src="<%= user.profileImage || 'https://cdn.pixabay.com/photo/2015/10/05/22/37/blank-profile-picture-973460_960_720.png' %>" 
                   alt="Profile" 
                   class="rounded-circle border border-3 border-white shadow"
                   style="width: 120px; height: 120px; object-fit: cover;">
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Company Performance Overview - Quick Stats (matching solo dashboard style) -->
  <div class="row mb-5">
    <div class="col-12">
      <div class="card shadow-sm border-0">
        <div class="card-body p-4">
          <h4 class="fw-bold mb-4" style="color: #1e3c5c">
            <i class="fas fa-chart-line me-2"></i>Company Performance Overview
          </h4>
          <div class="row g-3">
            <!-- Total Worksites -->
            <div class="col-md-3 col-6">
              <div class="d-flex align-items-center p-3 rounded" style="background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);">
                <div class="rounded-circle p-3 me-3" style="background: linear-gradient(135deg, #2196f3 0%, #1976d2 100%);">
                  <i class="fas fa-hard-hat fa-2x text-white"></i>
                </div>
                <div>
                  <h3 class="fw-bold mb-0">0</h3>
                  <small class="text-muted">Total Worksites</small>
                </div>
              </div>
            </div>

            <!-- Safety Officers -->
            <div class="col-md-3 col-6">
              <div class="d-flex align-items-center p-3 rounded" style="background: linear-gradient(135deg, #e8eaf6 0%, #c5cae9 100%);">
                <div class="rounded-circle p-3 me-3" style="background: linear-gradient(135deg, #3f51b5 0%, #3949ab 100%);">
                  <i class="fas fa-user-tie fa-2x text-white"></i>
                </div>
                <div>
                  <h3 class="fw-bold mb-0">0</h3>
                  <small class="text-muted">Safety Officers</small>
                </div>
              </div>
            </div>

            <!-- Pending Approvals -->
            <div class="col-md-3 col-6">
              <div class="d-flex align-items-center p-3 rounded" style="background: linear-gradient(135deg, #fff3e0 0%, #ffe0b2 100%);">
                <div class="rounded-circle p-3 me-3" style="background: linear-gradient(135deg, #ff9800 0%, #f57c00 100%);">
                  <i class="fas fa-clock fa-2x text-white"></i>
                </div>
                <div>
                  <h3 class="fw-bold mb-0">0</h3>
                  <small class="text-muted">Pending Approvals</small>
                </div>
              </div>
            </div>

            <!-- Company Safety Score -->
            <div class="col-md-3 col-6">
              <div class="d-flex align-items-center p-3 rounded" style="background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%);">
                <div class="rounded-circle p-3 me-3" style="background: linear-gradient(135deg, #4caf50 0%, #388e3c 100%);">
                  <i class="fas fa-shield-alt fa-2x text-white"></i>
                </div>
                <div>
                  <h3 class="fw-bold mb-0">98%</h3>
                  <small class="text-muted">Safety Score</small>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Worksite Management Section -->
  <div class="row mb-4">
    <div class="col-12">
      <h3 class="fw-bold mb-4" style="color: #f093fb">
        <i class="fas fa-hard-hat me-2"></i>Worksite Management
      </h3>
    </div>
  </div>

  <div class="row g-4 mb-5">
    <!-- Create Worksite Card -->
    <div class="col-lg-4 col-md-6">
      <div class="card h-100 shadow-lg border-0 hover-card">
        <div class="card-body text-center p-4">
          <div class="icon-circle mb-3 mx-auto" style="background: linear-gradient(135deg, #2196f3 0%, #1976d2 100%); width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
            <i class="fas fa-plus-circle fa-3x text-white"></i>
          </div>
          <h4 class="fw-bold mb-2">Create Worksite</h4>
          <p class="text-muted mb-3">Add a new company worksite with location, site type, and safety parameters.</p>
          <div class="bg-light p-3 rounded-3 mb-3">
            <small class="text-muted">Create unlimited company worksites</small>
          </div>
          <a href="/admin/worksites/create" class="btn w-100 py-2" style="background: linear-gradient(135deg, #2196f3 0%, #1976d2 100%); color: white; border-radius: 30px;">
            <i class="fas fa-plus-circle me-2"></i> Create Worksite
          </a>
        </div>
      </div>
    </div>

    <!-- Manage Worksites Card -->
    <div class="col-lg-4 col-md-6">
      <div class="card h-100 shadow-lg border-0 hover-card">
        <div class="card-body text-center p-4">
          <div class="icon-circle mb-3 mx-auto" style="background: linear-gradient(135deg, #3f51b5 0%, #3949ab 100%); width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
            <i class="fas fa-list fa-3x text-white"></i>
          </div>
          <h4 class="fw-bold mb-2">Manage Worksites</h4>
          <p class="text-muted mb-3">View and manage all company worksites, track performance and compliance.</p>
          <div class="bg-light p-3 rounded-3 mb-3">
            <strong class="d-block fs-2">0</strong>
            <small class="text-muted">Active Worksites</small>
          </div>
          <a href="/admin/worksites" class="btn w-100 py-2" style="background: linear-gradient(135deg, #3f51b5 0%, #3949ab 100%); color: white; border-radius: 30px;">
            <i class="fas fa-arrow-right me-2"></i> View All
          </a>
        </div>
      </div>
    </div>

    <!-- Worksite Analytics Card -->
    <div class="col-lg-4 col-md-6">
      <div class="card h-100 shadow-lg border-0 hover-card">
        <div class="card-body text-center p-4">
          <div class="icon-circle mb-3 mx-auto" style="background: linear-gradient(135deg, #5f2c82 0%, #49a09d 100%); width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
            <i class="fas fa-chart-line fa-3x text-white"></i>
          </div>
          <h4 class="fw-bold mb-2">Worksite Analytics</h4>
          <p class="text-muted mb-3">View performance metrics across all worksites. Identify trends and improvements.</p>
          <div class="bg-light p-3 rounded-3 mb-3">
            <div class="row">
              <div class="col-6">
                <strong class="d-block fs-4">0</strong>
                <small class="text-muted">Incidents</small>
              </div>
              <div class="col-6">
                <strong class="d-block fs-4">0</strong>
                <small class="text-muted">Actions</small>
              </div>
            </div>
          </div>
          <a href="/admin/analytics" class="btn w-100 py-2" style="background: linear-gradient(135deg, #5f2c82 0%, #49a09d 100%); color: white; border-radius: 30px;">
            <i class="fas fa-chart-pie me-2"></i> View Analytics
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Work Areas Section -->
<div class="row mb-4">
  <div class="col-12">
    <h3 class="fw-bold mb-4" style="color: #f093fb">
      <i class="fas fa-map-marked-alt me-2"></i>Work Area Management
    </h3>
  </div>
</div>

<div class="row g-4 mb-5">
  <!-- Create Work Area Card -->
  <div class="col-lg-4 col-md-6">
    <div class="card h-100 shadow-lg border-0 hover-card">
      <div class="card-body text-center p-4">
        <div class="icon-circle mb-3 mx-auto" style="background: linear-gradient(135deg, #26a69a 0%, #00897b 100%); width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
          <i class="fas fa-plus-circle fa-3x text-white"></i>
        </div>
        <h4 class="fw-bold mb-2">Create Work Area</h4>
        <p class="text-muted mb-3">Add new work areas to existing worksites. Define zones, hazards, and safety requirements.</p>
        <div class="bg-light p-3 rounded-3 mb-3">
          <small class="text-muted">Assign to specific worksites and shifts</small>
        </div>
        <a href="/work-areas/create" class="btn w-100 py-2" style="background: linear-gradient(135deg, #26a69a 0%, #00897b 100%); color: white; border-radius: 30px;">
          <i class="fas fa-plus-circle me-2"></i> Create Work Area
        </a>
      </div>
    </div>
  </div>

  <!-- Manage Work Areas Card -->
  <div class="col-lg-4 col-md-6">
    <div class="card h-100 shadow-lg border-0 hover-card">
      <div class="card-body text-center p-4">
        <div class="icon-circle mb-3 mx-auto" style="background: linear-gradient(135deg, #00897b 0%, #00695c 100%); width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
          <i class="fas fa-list fa-3x text-white"></i>
        </div>
        <h4 class="fw-bold mb-2">Manage Work Areas</h4>
        <p class="text-muted mb-3">View and manage all work areas. Track hazards, incidents, and assigned officers.</p>
        <div class="bg-light p-3 rounded-3 mb-3">
          <strong class="d-block fs-2">0</strong>
          <small class="text-muted">Active Work Areas</small>
        </div>
        <a href="/work-areas" class="btn w-100 py-2" style="background: linear-gradient(135deg, #00897b 0%, #00695c 100%); color: white; border-radius: 30px;">
          <i class="fas fa-arrow-right me-2"></i> View All
        </a>
      </div>
    </div>
  </div>

  <!-- Area Analytics Card -->
  <div class="col-lg-4 col-md-6">
    <div class="card h-100 shadow-lg border-0 hover-card">
      <div class="card-body text-center p-4">
        <div class="icon-circle mb-3 mx-auto" style="background: linear-gradient(135deg, #4db6ac 0%, #009688 100%); width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
          <i class="fas fa-chart-pie fa-3x text-white"></i>
        </div>
        <h4 class="fw-bold mb-2">Area Analytics</h4>
        <p class="text-muted mb-3">View safety performance metrics by work area. Identify high-risk zones.</p>
        <div class="bg-light p-3 rounded-3 mb-3">
          <div class="row">
            <div class="col-6">
              <strong class="d-block fs-4">0</strong>
              <small class="text-muted">Incidents</small>
            </div>
            <div class="col-6">
              <strong class="d-block fs-4">0</strong>
              <small class="text-muted">Hazards</small>
            </div>
          </div>
        </div>
        <a href="/work-areas/analytics" class="btn w-100 py-2" style="background: linear-gradient(135deg, #4db6ac 0%, #009688 100%); color: white; border-radius: 30px;">
          <i class="fas fa-chart-line me-2"></i> View Analytics
        </a>
      </div>
    </div>
  </div>
</div>

  <!-- Safety Officer Management Section -->
  <div class="row mb-4">
    <div class="col-12">
      <h3 class="fw-bold mb-4" style="color: #f093fb">
        <i class="fas fa-users me-2"></i>Safety Officer Management
      </h3>
    </div>
  </div>

  <div class="row g-4 mb-5">
    <!-- Add Safety Officer Card -->
    <div class="col-lg-4 col-md-6">
      <div class="card h-100 shadow-lg border-0 hover-card">
        <div class="card-body text-center p-4">
          <div class="icon-circle mb-3 mx-auto" style="background: linear-gradient(135deg, #ff9800 0%, #f57c00 100%); width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
            <i class="fas fa-user-plus fa-3x text-white"></i>
          </div>
          <h4 class="fw-bold mb-2">Add Safety Officer</h4>
          <p class="text-muted mb-3">Create new safety officer accounts and assign initial permissions.</p>
          <div class="bg-light p-3 rounded-3 mb-3">
            <small class="text-muted">Send email with login credentials</small>
          </div>
          <a href="/admin/safety-officers/create" class="btn w-100 py-2" style="background: linear-gradient(135deg, #ff9800 0%, #f57c00 100%); color: white; border-radius: 30px;">
            <i class="fas fa-user-plus me-2"></i> Add Officer
          </a>
        </div>
      </div>
    </div>

    <!-- Manage Officers Card -->
    <div class="col-lg-4 col-md-6">
      <div class="card h-100 shadow-lg border-0 hover-card">
        <div class="card-body text-center p-4">
          <div class="icon-circle mb-3 mx-auto" style="background: linear-gradient(135deg, #9c27b0 0%, #7b1fa2 100%); width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
            <i class="fas fa-users-cog fa-3x text-white"></i>
          </div>
          <h4 class="fw-bold mb-2">Manage Officers</h4>
          <p class="text-muted mb-3">View all safety officers, update roles, permissions, and assignments.</p>
          <div class="bg-light p-3 rounded-3 mb-3">
            <strong class="d-block fs-2">0</strong>
            <small class="text-muted">Active Officers</small>
          </div>
          <a href="/admin/safety-officers" class="btn w-100 py-2" style="background: linear-gradient(135deg, #9c27b0 0%, #7b1fa2 100%); color: white; border-radius: 30px;">
            <i class="fas fa-cog me-2"></i> Manage
          </a>
        </div>
      </div>
    </div>

    <!-- Assign Officers Card -->
    <div class="col-lg-4 col-md-6">
      <div class="card h-100 shadow-lg border-0 hover-card">
        <div class="card-body text-center p-4">
          <div class="icon-circle mb-3 mx-auto" style="background: linear-gradient(135deg, #03a9f4 0%, #0288d1 100%); width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
            <i class="fas fa-user-tie fa-3x text-white"></i>
          </div>
          <h4 class="fw-bold mb-2">Assign Officers</h4>
          <p class="text-muted mb-3">Assign safety officers to specific worksites and work areas.</p>
          <div class="bg-light p-3 rounded-3 mb-3">
            <small class="text-muted">Match officers to worksites</small>
          </div>
          <a href="/admin/assign-officers" class="btn w-100 py-2" style="background: linear-gradient(135deg, #03a9f4 0%, #0288d1 100%); color: white; border-radius: 30px;">
            <i class="fas fa-exchange-alt me-2"></i> Assign
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Corporate Compliance & Oversight Section - 3 New Cards -->
  <div class="row mb-4">
    <div class="col-12">
      <h3 class="fw-bold mb-4" style="color: #f093fb">
        <i class="fas fa-shield-alt me-2"></i>Corporate Compliance & Oversight
      </h3>
    </div>
  </div>

  <div class="row g-4 mb-5">
    <!-- Company-wide Safety Performance Card -->
    <div class="col-lg-4 col-md-6">
      <div class="card h-100 shadow-lg border-0 hover-card">
        <div class="card-body text-center p-4">
          <div class="icon-circle mb-3 mx-auto" style="background: linear-gradient(135deg, #4caf50 0%, #388e3c 100%); width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
            <i class="fas fa-chart-bar fa-3x text-white"></i>
          </div>
          <h4 class="fw-bold mb-2">Company-wide Safety</h4>
          <p class="text-muted mb-3">View consolidated safety metrics across all worksites and departments.</p>
          <div class="bg-light p-3 rounded-3 mb-3">
            <div class="progress mb-2" style="height: 8px;">
              <div class="progress-bar bg-success" style="width: 98%"></div>
            </div>
            <small class="text-muted">Overall Safety Rating: 98%</small>
          </div>
          <a href="/admin/company-safety" class="btn w-100 py-2" style="background: linear-gradient(135deg, #4caf50 0%, #388e3c 100%); color: white; border-radius: 30px;">
            <i class="fas fa-chart-line me-2"></i> View Dashboard
          </a>
        </div>
      </div>
    </div>

    <!-- Environmental Performance Card -->
    <div class="col-lg-4 col-md-6">
      <div class="card h-100 shadow-lg border-0 hover-card">
        <div class="card-body text-center p-4">
          <div class="icon-circle mb-3 mx-auto" style="background: linear-gradient(135deg, #26c6da 0%, #00acc1 100%); width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
            <i class="fas fa-leaf fa-3x text-white"></i>
          </div>
          <h4 class="fw-bold mb-2">Environmental Performance</h4>
          <p class="text-muted mb-3">Track environmental compliance, emissions, waste management, and sustainability.</p>
          <div class="bg-light p-3 rounded-3 mb-3">
            <div class="row">
              <div class="col-6">
                <strong class="d-block fs-5">0</strong>
                <small class="text-muted">Incidents</small>
              </div>
              <div class="col-6">
                <strong class="d-block fs-5">100%</strong>
                <small class="text-muted">Compliance</small>
              </div>
            </div>
          </div>
          <a href="/admin/environmental" class="btn w-100 py-2" style="background: linear-gradient(135deg, #26c6da 0%, #00acc1 100%); color: white; border-radius: 30px;">
            <i class="fas fa-leaf me-2"></i> View Reports
          </a>
        </div>
      </div>
    </div>

    <!-- Safety Act Compliance Card -->
    <div class="col-lg-4 col-md-6">
      <div class="card h-100 shadow-lg border-0 hover-card">
        <div class="card-body text-center p-4">
          <div class="icon-circle mb-3 mx-auto" style="background: linear-gradient(135deg, #f44336 0%, #d32f2f 100%); width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
            <i class="fas fa-gavel fa-3x text-white"></i>
          </div>
          <h4 class="fw-bold mb-2">Safety Act Compliance</h4>
          <p class="text-muted mb-3">Monitor compliance with Zambian Factories Act, OSHA, and ISO 45001 standards.</p>
          <div class="bg-light p-3 rounded-3 mb-3">
            <div class="d-flex justify-content-between mb-1">
              <small>OSHA</small>
              <small>98%</small>
            </div>
            <div class="progress mb-2" style="height: 5px;">
              <div class="progress-bar bg-danger" style="width: 98%"></div>
            </div>
            <div class="d-flex justify-content-between mb-1">
              <small>ISO 45001</small>
              <small>95%</small>
            </div>
            <div class="progress mb-2" style="height: 5px;">
              <div class="progress-bar bg-warning" style="width: 95%"></div>
            </div>
          </div>
          <a href="/admin/compliance" class="btn w-100 py-2" style="background: linear-gradient(135deg, #f44336 0%, #d32f2f 100%); color: white; border-radius: 30px;">
            <i class="fas fa-check-circle me-2"></i> View Compliance
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Second Row of Corporate Cards - 3 More Cards -->
  <div class="row g-4 mb-5">
    <!-- Incident Trends Card -->
    <div class="col-lg-4 col-md-6">
      <div class="card h-100 shadow-lg border-0 hover-card">
        <div class="card-body text-center p-4">
          <div class="icon-circle mb-3 mx-auto" style="background: linear-gradient(135deg, #ff7043 0%, #f4511e 100%); width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
            <i class="fas fa-exclamation-triangle fa-3x text-white"></i>
          </div>
          <h4 class="fw-bold mb-2">Incident Trends</h4>
          <p class="text-muted mb-3">Analyze incident patterns across the organization. Identify high-risk areas.</p>
          <div class="bg-light p-3 rounded-3 mb-3">
            <div class="row">
              <div class="col-4 text-center">
                <strong class="d-block">0</strong>
                <small>This Month</small>
              </div>
              <div class="col-4 text-center">
                <strong class="d-block">0</strong>
                <small>Last Month</small>
              </div>
              <div class="col-4 text-center">
                <strong class="d-block text-success">0%</strong>
                <small>Change</small>
              </div>
            </div>
          </div>
          <a href="/admin/incident-trends" class="btn w-100 py-2" style="background: linear-gradient(135deg, #ff7043 0%, #f4511e 100%); color: white; border-radius: 30px;">
            <i class="fas fa-chart-line me-2"></i> View Trends
          </a>
        </div>
      </div>
    </div>

    <!-- Training & Competency Card -->
    <div class="col-lg-4 col-md-6">
      <div class="card h-100 shadow-lg border-0 hover-card">
        <div class="card-body text-center p-4">
          <div class="icon-circle mb-3 mx-auto" style="background: linear-gradient(135deg, #7e57c2 0%, #5e35b1 100%); width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
            <i class="fas fa-graduation-cap fa-3x text-white"></i>
          </div>
          <h4 class="fw-bold mb-2">Training & Competency</h4>
          <p class="text-muted mb-3">Track safety training completion, certifications, and competency records.</p>
          <div class="bg-light p-3 rounded-3 mb-3">
            <strong class="d-block fs-2">0</strong>
            <small class="text-muted">Certifications Active</small>
          </div>
          <a href="/admin/training" class="btn w-100 py-2" style="background: linear-gradient(135deg, #7e57c2 0%, #5e35b1 100%); color: white; border-radius: 30px;">
            <i class="fas fa-graduation-cap me-2"></i> Manage Training
          </a>
        </div>
      </div>
    </div>

    <!-- Audit & Inspection Card -->
    <div class="col-lg-4 col-md-6">
