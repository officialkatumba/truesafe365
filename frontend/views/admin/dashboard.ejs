<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="container py-5">
  <!-- Header with Profile Summary -->
  <div class="row mb-4">
    <div class="col-12">
      <div class="card border-0" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);">
        <div class="card-body p-4 text-white">
          <div class="row align-items-center">
            <div class="col-md-8">
              <div class="d-flex align-items-center mb-2">
                <i class="fas fa-building fa-2x me-3"></i>
                <div>
                  <h2 class="display-5 fw-bold mb-0">Enterprise Admin Dashboard</h2>
                  <p class="lead mb-0">Company-wide oversight and compliance management</p>
                </div>
              </div>
              <p class="mb-2 mt-3">
                Welcome back, <strong><%= user.email %></strong>
              </p>
              <div class="mt-2">
                <span class="badge bg-warning text-dark p-2 me-2">
                  <i class="fas fa-crown me-1"></i> System Administrator
                </span>
                <span class="badge bg-info p-2 me-2">
                  <i class="fas fa-chart-line me-1"></i> Enterprise Access
                </span>
                
                <% 
                let currentDate = new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
                %>
                
                <span class="badge bg-secondary p-2">
                  <i class="fas fa-calendar me-1"></i> <%= currentDate %>
                </span>
              </div>
            </div>
            <div class="col-md-4 text-center text-md-end mt-3 mt-md-0">
              <img src="<%= user.profileImage || 'https://cdn.pixabay.com/photo/2015/10/05/22/37/blank-profile-picture-973460_960_720.png' %>" 
                   alt="Profile" 
                   class="rounded-circle border border-3 border-white shadow"
                   style="width: 120px; height: 120px; object-fit: cover;">
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Critical Alerts Banner -->
  <% 
    // Sample data - replace with actual data from your backend
    const criticalAlerts = [
      { type: 'incident', count: 2, message: 'Unresolved critical incidents requiring investigation', severity: 'critical', link: '/incidents?severity=critical' },
      { type: 'approval', count: 5, message: 'Pending approvals overdue', severity: 'high', link: '/admin/approvals' }
    ];
    
    const totalCritical = criticalAlerts.reduce((sum, alert) => sum + alert.count, 0);
  %>

  <% if (totalCritical > 0) { %>
  <div class="row mb-4">
    <div class="col-12">
      <div class="alert alert-danger border-0 shadow-lg" role="alert" style="background: linear-gradient(135deg, #dc3545 0%, #b02a37 100%); color: white; border-radius: 12px; padding: 1rem 1.5rem;">
        <div class="d-flex align-items-center">
          <div class="flex-shrink-0 me-3">
            <i class="fas fa-exclamation-triangle fa-3x"></i>
          </div>
          <div class="flex-grow-1">
            <h4 class="fw-bold mb-1">⚠️ Critical Actions Required</h4>
            <p class="mb-0"><%= totalCritical %> urgent items need your immediate attention</p>
          </div>
          <div class="flex-shrink-0 ms-3">
            <button class="btn btn-light" type="button" data-bs-toggle="collapse" data-bs-target="#criticalAlertsList">
              <i class="fas fa-chevron-down me-1"></i> View Details
            </button>
          </div>
        </div>
        
        <!-- Collapsible details -->
        <div class="collapse mt-3" id="criticalAlertsList">
          <div class="bg-white bg-opacity-10 p-3 rounded-3">
            <% criticalAlerts.forEach(alert => { %>
              <a href="<%= alert.link %>" class="text-white text-decoration-none">
                <div class="d-flex align-items-center justify-content-between mb-2 p-2 rounded" style="background: rgba(255,255,255,0.1);">
                  <div>
                    <% if (alert.severity === 'critical') { %>
                      <span class="badge bg-danger me-2">CRITICAL</span>
                    <% } else if (alert.severity === 'high') { %>
                      <span class="badge bg-warning text-dark me-2">HIGH</span>
                    <% } %>
                    <span><%= alert.count %>x <%= alert.message %></span>
                  </div>
                  <i class="fas fa-arrow-right"></i>
                </div>
              </a>
            <% }); %>
          </div>
        </div>
      </div>
    </div>
  </div>
  <% } %>

  <!-- Company Performance Overview - Quick Stats -->
  <div class="row mb-5">
    <div class="col-12">
      <div class="card shadow-sm border-0">
        <div class="card-body p-4">
          <h4 class="fw-bold mb-4" style="color: #1e3c5c">
            <i class="fas fa-chart-line me-2"></i>Company Performance Overview
          </h4>
          <div class="row g-3">
            <!-- Total Worksites -->
            <div class="col-md-3 col-6">
              <div class="d-flex align-items-center p-3 rounded" style="background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);">
                <div class="rounded-circle p-3 me-3" style="background: linear-gradient(135deg, #2196f3 0%, #1976d2 100%);">
                  <i class="fas fa-hard-hat fa-2x text-white"></i>
                </div>
                <div>
                  <h3 class="fw-bold mb-0">0</h3>
                  <small class="text-muted">Worksites</small>
                </div>
              </div>
            </div>

            <!-- Work Areas -->
            <div class="col-md-3 col-6">
              <div class="d-flex align-items-center p-3 rounded" style="background: linear-gradient(135deg, #b2ebf2 0%, #80deea 100%);">
                <div class="rounded-circle p-3 me-3" style="background: linear-gradient(135deg, #00acc1 0%, #00838f 100%);">
                  <i class="fas fa-map-marked-alt fa-2x text-white"></i>
                </div>
                <div>
                  <h3 class="fw-bold mb-0">0</h3>
                  <small class="text-muted">Work Areas</small>
                </div>
              </div>
            </div>

            <!-- Safety Officers -->
            <div class="col-md-3 col-6">
              <div class="d-flex align-items-center p-3 rounded" style="background: linear-gradient(135deg, #e8eaf6 0%, #c5cae9 100%);">
                <div class="rounded-circle p-3 me-3" style="background: linear-gradient(135deg, #3f51b5 0%, #3949ab 100%);">
                  <i class="fas fa-user-tie fa-2x text-white"></i>
                </div>
                <div>
                  <h3 class="fw-bold mb-0">0</h3>
                  <small class="text-muted">Officers</small>
                </div>
              </div>
            </div>

            <!-- Pending Approvals -->
            <div class="col-md-3 col-6">
              <div class="d-flex align-items-center p-3 rounded" style="background: linear-gradient(135deg, #fff3e0 0%, #ffe0b2 100%);">
                <div class="rounded-circle p-3 me-3" style="background: linear-gradient(135deg, #ff9800 0%, #f57c00 100%);">
                  <i class="fas fa-clock fa-2x text-white"></i>
                </div>
                <div>
                  <h3 class="fw-bold mb-0">0</h3>
                  <small class="text-muted">Approvals</small>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- SECTION 1: Worksite & Work Area Management (3 cards) -->
  <div class="row mb-4">
    <div class="col-12">
      <h3 class="fw-bold mb-4" style="color: #f093fb">
        <i class="fas fa-hard-hat me-2"></i>Site Management
      </h3>
    </div>
  </div>

  <div class="row g-4 mb-5">
   <div class="row g-4 mb-5">
    <!-- Create Worksite Card -->
    <div class="col-lg-4 col-md-6">
      <div class="card h-100 shadow-lg border-0 hover-card">
        <div class="card-body text-center p-4">
          <div class="icon-circle mb-3 mx-auto" style="background: linear-gradient(135deg, #2196f3 0%, #1976d2 100%); width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
            <i class="fas fa-plus-circle fa-3x text-white"></i>
          </div>
          <h4 class="fw-bold mb-2">Create Worksite</h4>
          <p class="text-muted mb-3">Add new company worksites. Each worksite will have its own work areas and safety data.</p>
          <div class="bg-light p-3 rounded-3 mb-3">
            <small class="text-muted">Create unlimited worksites</small>
          </div>
          <a href="/worksites/create" class="btn w-100 py-2" style="background: linear-gradient(135deg, #2196f3 0%, #1976d2 100%); color: white; border-radius: 30px;">
            <i class="fas fa-plus-circle me-2"></i> Create
          </a>
        </div>
      </div>
    </div>
    
    <!-- All Worksites Card -->
    <div class="col-lg-4 col-md-6">
      <div class="card h-100 shadow-lg border-0 hover-card">
        <div class="card-body text-center p-4">
          <div class="icon-circle mb-3 mx-auto" style="background: linear-gradient(135deg, #3f51b5 0%, #3949ab 100%); width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
            <i class="fas fa-list fa-3x text-white"></i>
          </div>
          <h4 class="fw-bold mb-2">All Worksites</h4>
          <p class="text-muted mb-3">View all company worksites. Click any worksite to manage its details, work areas, and safety data.</p>
          <div class="bg-light p-3 rounded-3 mb-3">
            <strong class="d-block fs-2">0</strong>
            <small class="text-muted">Total Worksites</small>
          </div>
          <a href="/worksites/my-worksites" class="btn w-100 py-2" style="background: linear-gradient(135deg, #3f51b5 0%, #3949ab 100%); color: white; border-radius: 30px;">
            <i class="fas fa-arrow-right me-2"></i> View All
          </a>
        </div>
      </div>
    </div>
    <!-- All Work Areas Card (Gateway to individual work areas) -->
    <div class="col-lg-4 col-md-6">
      <div class="card h-100 shadow-lg border-0 hover-card">
        <div class="card-body text-center p-4">
          <div class="icon-circle mb-3 mx-auto" style="background: linear-gradient(135deg, #26a69a 0%, #00897b 100%); width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
            <i class="fas fa-map-marked-alt fa-3x text-white"></i>
          </div>
          <h4 class="fw-bold mb-2">All Work Areas</h4>
          <p class="text-muted mb-3">View all work areas across worksites. Click any area to manage hazards, incidents, and safety talks.</p>
          <div class="bg-light p-3 rounded-3 mb-3">
            <strong class="d-block fs-2">0</strong>
            <small class="text-muted">Active Areas</small>
          </div>
          <a href="/work-areas" class="btn w-100 py-2" style="background: linear-gradient(135deg, #26a69a 0%, #00897b 100%); color: white; border-radius: 30px;">
            <i class="fas fa-arrow-right me-2"></i> View All
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- SECTION 2: Safety Officer Management (3 cards) -->
  <div class="row mb-4">
    <div class="col-12">
      <h3 class="fw-bold mb-4" style="color: #f093fb">
        <i class="fas fa-users me-2"></i>Personnel Management
      </h3>
    </div>
  </div>

  <div class="row g-4 mb-5">
    <!-- Add Safety Officer Card -->
    <div class="col-lg-4 col-md-6">
      <div class="card h-100 shadow-lg border-0 hover-card">
        <div class="card-body text-center p-4">
          <div class="icon-circle mb-3 mx-auto" style="background: linear-gradient(135deg, #ff9800 0%, #f57c00 100%); width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
            <i class="fas fa-user-plus fa-3x text-white"></i>
          </div>
          <h4 class="fw-bold mb-2">Add Officer</h4>
          <p class="text-muted mb-3">Create new safety officer accounts. They can then be assigned to worksites and work areas.</p>
          <div class="bg-light p-3 rounded-3 mb-3">
            <small class="text-muted">Send email with login credentials</small>
          </div>
          <a href="/admin/safety-officers/create" class="btn w-100 py-2" style="background: linear-gradient(135deg, #ff9800 0%, #f57c00 100%); color: white; border-radius: 30px;">
            <i class="fas fa-user-plus me-2"></i> Add Officer
          </a>
        </div>
      </div>
    </div>

    <!-- All Officers Card -->
    <div class="col-lg-4 col-md-6">
      <div class="card h-100 shadow-lg border-0 hover-card">
        <div class="card-body text-center p-4">
          <div class="icon-circle mb-3 mx-auto" style="background: linear-gradient(135deg, #9c27b0 0%, #7b1fa2 100%); width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
            <i class="fas fa-users-cog fa-3x text-white"></i>
          </div>
          <h4 class="fw-bold mb-2">All Officers</h4>
          <p class="text-muted mb-3">View all safety officers. Manage their profiles, permissions, and assignments.</p>
          <div class="bg-light p-3 rounded-3 mb-3">
            <strong class="d-block fs-2">0</strong>
            <small class="text-muted">Active Officers</small>
          </div>
          <a href="/admin/safety-officers" class="btn w-100 py-2" style="background: linear-gradient(135deg, #9c27b0 0%, #7b1fa2 100%); color: white; border-radius: 30px;">
            <i class="fas fa-arrow-right me-2"></i> View All
          </a>
        </div>
      </div>
    </div>

  <!-- Training & Competency Card (Replaces Assign Officers) -->
<div class="col-lg-4 col-md-6">
  <div class="card h-100 shadow-lg border-0 hover-card">
    <div class="card-body text-center p-4">
      <div class="icon-circle mb-3 mx-auto" style="background: linear-gradient(135deg, #7e57c2 0%, #5e35b1 100%); width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
        <i class="fas fa-graduation-cap fa-3x text-white"></i>
      </div>
      <h4 class="fw-bold mb-2">Training & Certifications</h4>
      <p class="text-muted mb-3">Track safety training completion, expiring certifications, and competency records across all personnel.</p>
      <div class="bg-light p-3 rounded-3 mb-3">
        <div class="row">
          <div class="col-6">
            <strong class="d-block fs-4">0</strong>
            <small class="text-muted">Expiring Soon</small>
          </div>
          <div class="col-6">
            <strong class="d-block fs-4">0</strong>
            <small class="text-muted">Overdue</small>
          </div>
        </div>
      </div>
      <a href="/admin/training" class="btn w-100 py-2" style="background: linear-gradient(135deg, #7e57c2 0%, #5e35b1 100%); color: white; border-radius: 30px;">
        <i class="fas fa-graduation-cap me-2"></i> Manage Training
      </a>
    </div>
  </div>
</div>
</div>

  <!-- SECTION 3: Compliance & Oversight (3 cards) -->
  <div class="row mb-4">
    <div class="col-12">
      <h3 class="fw-bold mb-4" style="color: #f093fb">
        <i class="fas fa-shield-alt me-2"></i>Compliance & Oversight
      </h3>
    </div>
  </div>

  <div class="row g-4 mb-5">
    <!-- Pending Approvals Card -->
    <div class="col-lg-4 col-md-6">
      <div class="card h-100 shadow-lg border-0 hover-card">
        <div class="card-body text-center p-4">
          <div class="icon-circle mb-3 mx-auto" style="background: linear-gradient(135deg, #ff9800 0%, #f57c00 100%); width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
            <i class="fas fa-clock fa-3x text-white"></i>
          </div>
          <h4 class="fw-bold mb-2">Pending Approvals</h4>
          <p class="text-muted mb-3">Review and approve safety documents, incident reports, and permit requests from officers.</p>
          <div class="bg-light p-3 rounded-3 mb-3">
            <strong class="d-block fs-2">0</strong>
            <small class="text-muted">Awaiting Review</small>
          </div>
          <a href="/admin/approvals" class="btn w-100 py-2" style="background: linear-gradient(135deg, #ff9800 0%, #f57c00 100%); color: white; border-radius: 30px;">
            <i class="fas fa-check-circle me-2"></i> Review
          </a>
        </div>
      </div>
    </div>

    <!-- Safety Reports Card (Window to all reports) -->
    <div class="col-lg-4 col-md-6">
      <div class="card h-100 shadow-lg border-0 hover-card">
        <div class="card-body text-center p-4">
          <div class="icon-circle mb-3 mx-auto" style="background: linear-gradient(135deg, #4caf50 0%, #388e3c 100%); width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
            <i class="fas fa-file-alt fa-3x text-white"></i>
          </div>
          <h4 class="fw-bold mb-2">Safety Reports</h4>
          <p class="text-muted mb-3">View all incident reports, risk assessments, and safety talks across the company.</p>
          <div class="bg-light p-3 rounded-3 mb-3">
            <small class="text-muted">Incidents • Assessments • Talks</small>
          </div>
          <a href="/admin/reports" class="btn w-100 py-2" style="background: linear-gradient(135deg, #4caf50 0%, #388e3c 100%); color: white; border-radius: 30px;">
            <i class="fas fa-file-alt me-2"></i> View Reports
          </a>
        </div>
      </div>
    </div>

    <!-- Compliance Dashboard Card -->
    <div class="col-lg-4 col-md-6">
      <div class="card h-100 shadow-lg border-0 hover-card">
        <div class="card-body text-center p-4">
          <div class="icon-circle mb-3 mx-auto" style="background: linear-gradient(135deg, #f44336 0%, #d32f2f 100%); width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
            <i class="fas fa-gavel fa-3x text-white"></i>
          </div>
          <h4 class="fw-bold mb-2">Compliance Dashboard</h4>
          <p class="text-muted mb-3">Monitor regulatory compliance, track standards adherence, and identify gaps.</p>
          <div class="bg-light p-3 rounded-3 mb-3">
            <div class="d-flex justify-content-between mb-1">
              <small>OSHA</small>
              <small>98%</small>
            </div>
            <div class="progress mb-2" style="height: 5px;">
              <div class="progress-bar bg-danger" style="width: 98%"></div>
            </div>
          </div>
          <a href="/admin/compliance" class="btn w-100 py-2" style="background: linear-gradient(135deg, #f44336 0%, #d32f2f 100%); color: white; border-radius: 30px;">
            <i class="fas fa-check-circle me-2"></i> View Compliance
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Quick Actions -->
  <div class="row mt-4">
    <div class="col-12">
      <div class="card border-0 shadow-sm">
        <div class="card-body p-4">
          <h5 class="fw-bold mb-3" style="color: #1e3c5c">
            <i class="fas fa-bolt me-2"></i>Quick Actions
          </h5>
          <div class="row g-2">
            <div class="col-md-3 col-6">
              <a href="/admin/worksites/create" class="btn btn-outline-primary w-100">
                <i class="fas fa-plus-circle me-1"></i> New Worksite
              </a>
            </div>
            <div class="col-md-3 col-6">
              <a href="/work-areas/create" class="btn btn-outline-success w-100">
                <i class="fas fa-map-marked-alt me-1"></i> New Work Area
              </a>
            </div>
            <div class="col-md-3 col-6">
              <a href="/admin/safety-officers/create" class="btn btn-outline-warning w-100">
                <i class="fas fa-user-plus me-1"></i> Add Officer
              </a>
            </div>
            <div class="col-md-3 col-6">
              <a href="/admin/approvals" class="btn btn-outline-danger w-100">
                <i class="fas fa-check-circle me-1"></i> Approvals
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Info Banner -->
  <div class="row mt-4">
    <div class="col-12">
      <div class="alert alert-info text-center mb-0">
        <i class="fas fa-info-circle me-2"></i>
        <strong>Enterprise Admin Portal:</strong> Click any worksite or work area from the list views to manage detailed safety data.
        <a href="#" class="alert-link">Learn more</a>
      </div>
    </div>
  </div>
</div>

    </div>


<style>
  .hover-card {
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .hover-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15) !important;
  }

  .icon-circle {
    transition: transform 0.3s ease;
  }

  .hover-card:hover .icon-circle {
    transform: scale(1.1);
  }

  .btn {
    transition: all 0.3s ease;
  }

  .btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
  }
  
  .card {
    border-radius: 16px;
  }
  
  .badge {
    font-size: 0.8rem;
    padding: 0.4rem 0.6rem;
  }
  
  .progress {
    border-radius: 10px;
  }
</style>

<%- include('../partials/footer') %>