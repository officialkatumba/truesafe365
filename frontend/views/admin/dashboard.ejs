<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="main-wrapper">
  <div class="content container py-4">
    <div class="admin-dashboard-container" style="max-width: 900px; margin: 0 auto;">
      <!-- Admin Header -->
      <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
        <div>
          <h3 class="mb-1">
            <i class="fas fa-building me-2" style="color: #f093fb;"></i>
            Enterprise Admin Dashboard
          </h3>
          <div class="d-flex gap-2">
            <span class="badge text-bg-secondary">
              <i class="fas fa-crown me-1"></i> System Administrator
            </span>
            <span class="badge text-bg-info">
              <i class="fas fa-chart-line me-1"></i> Enterprise Access
            </span>
            <span class="badge text-bg-secondary">
              <i class="fas fa-calendar me-1"></i> <%= new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %>
            </span>
          </div>
        </div>
        <span class="text-muted small">
          <i class="fas fa-user me-1"></i> Welcome back, <strong><%= user.email %></strong>
        </span>
      </div>

      <!-- Company PIN Card -->
      <div class="card border-0 shadow-sm mb-4" style="border-radius: 16px;">
        <div class="card-body p-4">
          <h5 class="fw-bold mb-3" style="color: #1e3c5c;">
            <i class="fas fa-building me-2" style="color: #e67e22;"></i>
            Company Information
          </h5>
          <div class="row">
            <div class="col-md-6">
              <p class="mb-2"><strong>Company Name:</strong> <%= user.companyName || 'Not set' %></p>
              <p class="mb-2">
                <strong>Company PIN:</strong> 
                <span class="badge bg-primary fs-6 p-2"><%= user.companyPin || 'Not generated' %></span>
                <% if (user.companyPin) { %>
                <button class="btn btn-sm btn-outline-secondary ms-2" onclick="copyPIN()">
                  <i class="fas fa-copy"></i> Copy
                </button>
                <% } %>
              </p>
            </div>
            <div class="col-md-6">
              <% if (user.companyPinExpiresAt) { %>
              <p class="mb-2"><strong>PIN Expires:</strong> <%= new Date(user.companyPinExpiresAt).toLocaleDateString() %></p>
              <p class="mb-2"><strong>PIN Uses Left:</strong> <%= (user.maxPinUses || 1) - ((user.companyPinUsedBy && user.companyPinUsedBy.length) || 0) %></p>
              <% } else { %>
              <p class="mb-2 text-muted"><i class="fas fa-info-circle me-1"></i> No PIN generated yet</p>
              <% } %>
            </div>
          </div>
          <div class="mt-3 p-3 rounded-3" style="background: #f8f9fa;">
            <small class="text-muted">
              <i class="fas fa-info-circle me-1" style="color: #e67e22;"></i>
              Share this PIN with safety officers and workers to join your company. Each PIN can be used up to <%= user.maxPinUses || 1 %> time(s).
            </small>
          </div>
        </div>
      </div>

      <!-- Critical Alerts Banner -->
      <% 
        const criticalAlerts = [
          { type: 'incident', count: 2, message: 'Unresolved critical incidents requiring investigation', severity: 'critical', link: '/incidents?severity=critical' },
          { type: 'approval', count: 5, message: 'Pending approvals overdue', severity: 'high', link: '/admin/approvals' }
        ];
        
        const totalCritical = criticalAlerts.reduce((sum, alert) => sum + alert.count, 0);
      %>

      <% if (totalCritical > 0) { %>
      <div class="safety-talk-container text-center mb-4" style="border-left-color: #dc3545;">
        <div class="timer-label" style="color: #dc3545;">⚠️ CRITICAL ACTIONS REQUIRED</div>
        <div class="safety-talk-content" style="border-left: 3px solid #dc3545;">
          <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
            <span><%= totalCritical %> urgent items need your immediate attention</span>
            <button class="btn btn-sm btn-outline-danger" type="button" data-bs-toggle="collapse" data-bs-target="#criticalAlertsList">
              View Details <i class="fas fa-chevron-down ms-1"></i>
            </button>
          </div>
          
          <div class="collapse mt-3 text-start" id="criticalAlertsList">
            <div class="bg-light p-3 rounded-3">
              <% criticalAlerts.forEach(alert => { %>
                <a href="<%= alert.link %>" class="text-decoration-none">
                  <div class="d-flex align-items-center justify-content-between mb-2 p-2 rounded" style="background: <%= alert.severity === 'critical' ? '#dc3545' : '#ffc107' %>; color: <%= alert.severity === 'critical' ? 'white' : 'black' %>;">
                    <div>
                      <span class="badge bg-<%= alert.severity === 'critical' ? 'light text-dark' : 'dark' %> me-2"><%= alert.severity.toUpperCase() %></span>
                      <span><%= alert.count %>x <%= alert.message %></span>
                    </div>
                    <i class="fas fa-arrow-right"></i>
                  </div>
                </a>
              <% }); %>
            </div>
          </div>
        </div>
      </div>
      <% } %>

      <!-- Company Performance Overview Stats Row -->
      <div class="row g-3 mb-4">
        <div class="col-md-3 col-6">
          <div class="d-flex align-items-center p-2 rounded bg-light">
            <div class="rounded-circle d-flex align-items-center justify-content-center me-2" style="background: linear-gradient(135deg, #2196f3 0%, #1976d2 100%); width: 35px; height: 35px;">
              <i class="fas fa-hard-hat text-white" style="font-size: 0.9rem;"></i>
            </div>
            <div>
              <strong>0</strong>
              <small class="text-muted d-block">Worksites</small>
            </div>
          </div>
        </div>
        <div class="col-md-3 col-6">
          <div class="d-flex align-items-center p-2 rounded bg-light">
            <div class="rounded-circle d-flex align-items-center justify-content-center me-2" style="background: linear-gradient(135deg, #26a69a 0%, #00897b 100%); width: 35px; height: 35px;">
              <i class="fas fa-map-marked-alt text-white" style="font-size: 0.9rem;"></i>
            </div>
            <div>
              <strong>0</strong>
              <small class="text-muted d-block">Work Areas</small>
            </div>
          </div>
        </div>
        <div class="col-md-3 col-6">
          <div class="d-flex align-items-center p-2 rounded bg-light">
            <div class="rounded-circle d-flex align-items-center justify-content-center me-2" style="background: linear-gradient(135deg, #ff9800 0%, #f57c00 100%); width: 35px; height: 35px;">
              <i class="fas fa-user-tie text-white" style="font-size: 0.9rem;"></i>
            </div>
            <div>
              <strong>0</strong>
              <small class="text-muted d-block">Officers</small>
            </div>
          </div>
        </div>
        <div class="col-md-3 col-6">
          <div class="d-flex align-items-center p-2 rounded bg-light">
            <div class="rounded-circle d-flex align-items-center justify-content-center me-2" style="background: linear-gradient(135deg, #f44336 0%, #d32f2f 100%); width: 35px; height: 35px;">
              <i class="fas fa-clock text-white" style="font-size: 0.9rem;"></i>
            </div>
            <div>
              <strong>0</strong>
              <small class="text-muted d-block">Pending</small>
            </div>
          </div>
        </div>
      </div>

      <!-- Quick Actions Row -->
      <div class="d-flex gap-2 justify-content-center flex-wrap mb-4">
        <a href="/worksites/create" class="btn btn-outline-primary btn-sm">
          <i class="fas fa-plus-circle me-1"></i> New Worksite
        </a>
        <!-- <a href="/work-areas/create" class="btn btn-outline-success btn-sm">
          <i class="fas fa-map-marked-alt me-1"></i> New Work Area
        </a> -->
        <a href="/admin/safety-officers/create" class="btn btn-outline-warning btn-sm">
          <i class="fas fa-user-plus me-1"></i> Add Officer
        </a>
        <a href="/admin/approvals" class="btn btn-outline-danger btn-sm">
          <i class="fas fa-check-circle me-1"></i> Approvals
        </a>
      </div>

      <hr />
      <!-- SECTION 1: Site Management Cards -->
      <h4 class="text-center mb-4 fw-bold">
        <i class="fas fa-hard-hat me-2" style="color: #f093fb;"></i>
        Site Management
      </h4>

      <div class="row g-4 mb-5">
        <div class="col-lg-4 col-md-6">
          <div class="card shadow-sm border-0 h-100 hover-card">
            <div class="card-body text-center p-4">
              <div class="icon-circle mb-3 mx-auto" style="background: linear-gradient(135deg, #2196f3 0%, #1976d2 100%); width: 70px; height: 70px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                <i class="fas fa-plus-circle fa-2x text-white"></i>
              </div>
              <h5 class="fw-bold mb-2">Create Worksite</h5>
              <p class="text-muted small mb-3">Add new company worksites. Each worksite will have its own work areas and needed safety data.</p>
              <a href="/worksites/create" class="btn w-100" style="background: linear-gradient(135deg, #2196f3 0%, #1976d2 100%); color: white; border-radius: 40px;">
                <i class="fas fa-plus-circle me-2"></i> Create
              </a>
            </div>
          </div>
        </div>
        
        <div class="col-lg-4 col-md-6">
          <div class="card shadow-sm border-0 h-100 hover-card">
            <div class="card-body text-center p-4">
              <div class="icon-circle mb-3 mx-auto" style="background: linear-gradient(135deg, #3f51b5 0%, #3949ab 100%); width: 70px; height: 70px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                <i class="fas fa-list fa-2x text-white"></i>
              </div>
              <h5 class="fw-bold mb-2">All Worksites</h5>
              <p class="text-muted small mb-3">View all company worksites. Click any worksite to manage its details, work areas, and safety data.</p>
              <a href="/worksites/my-worksites" class="btn w-100" style="background: linear-gradient(135deg, #3f51b5 0%, #3949ab 100%); color: white; border-radius: 40px;">
                <i class="fas fa-arrow-right me-2"></i> View All
              </a>
            </div>
          </div>
        </div>

        <div class="col-lg-4 col-md-6">
          <div class="card shadow-sm border-0 h-100 hover-card">
            <div class="card-body text-center p-4">
              <div class="icon-circle mb-3 mx-auto" style="background: linear-gradient(135deg, #ff9800 0%, #f57c00 100%); width: 70px; height: 70px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                <i class="fas fa-file-signature fa-2x text-white"></i>
              </div>
              <h5 class="fw-bold mb-2">Worksite Permits</h5>
              <p class="text-muted small mb-3">View and manage all worksite permits. Track permit status, expiry dates, and compliance requirements.</p>
              <a href="/admin/permits" class="btn w-100" style="background: linear-gradient(135deg, #ff9800 0%, #f57c00 100%); color: white; border-radius: 40px;">
                <i class="fas fa-arrow-right me-2"></i> View Permits
              </a>
            </div>
          </div>
        </div>
      </div>
      <!-- SECTION 2: Personnel Management Cards -->
      <h4 class="text-center mb-4 fw-bold">
        <i class="fas fa-users me-2" style="color: #f093fb;"></i>
        Personnel Management
      </h4>

      <div class="row g-4 mb-5">
        <!-- All Safety Officers Card -->
        <div class="col-lg-4 col-md-6">
          <div class="card shadow-sm border-0 h-100 hover-card">
            <div class="card-body text-center p-4">
              <div class="icon-circle mb-3 mx-auto" style="background: linear-gradient(135deg, #9c27b0 0%, #7b1fa2 100%); width: 70px; height: 70px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                <i class="fas fa-users-cog fa-2x text-white"></i>
              </div>
              <h5 class="fw-bold mb-2">All Safety Officers</h5>
              <p class="text-muted small mb-3">View all safety officers. Manage their profiles, permissions, and assignments.</p>
              <a href="/admin/safety-officers" class="btn w-100" style="background: linear-gradient(135deg, #9c27b0 0%, #7b1fa2 100%); color: white; border-radius: 40px;">
                <i class="fas fa-arrow-right me-2"></i> View All
              </a>
            </div>
          </div>
        </div>

        <!-- All Workers Card -->
        <div class="col-lg-4 col-md-6">
          <div class="card shadow-sm border-0 h-100 hover-card">
            <div class="card-body text-center p-4">
              <div class="icon-circle mb-3 mx-auto" style="background: linear-gradient(135deg, #2196f3 0%, #1976d2 100%); width: 70px; height: 70px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                <i class="fas fa-users fa-2x text-white"></i>
              </div>
              <h5 class="fw-bold mb-2">All Workers</h5>
              <p class="text-muted small mb-3">View all workers across all worksites. Manage assignments and track safety records.</p>
              <a href="/admin/workers" class="btn w-100" style="background: linear-gradient(135deg, #2196f3 0%, #1976d2 100%); color: white; border-radius: 40px;">
                <i class="fas fa-arrow-right me-2"></i> View All
              </a>
            </div>
          </div>
        </div>

        <!-- Certifications Card -->
        <div class="col-lg-4 col-md-6">
          <div class="card shadow-sm border-0 h-100 hover-card">
            <div class="card-body text-center p-4">
              <div class="icon-circle mb-3 mx-auto" style="background: linear-gradient(135deg, #7e57c2 0%, #5e35b1 100%); width: 70px; height: 70px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                <i class="fas fa-graduation-cap fa-2x text-white"></i>
              </div>
              <h5 class="fw-bold mb-2">Certifications</h5>
              <p class="text-muted small mb-3">Track safety training completion, expiring certifications and competency.</p>
              <a href="/admin/training" class="btn w-100" style="background: linear-gradient(135deg, #7e57c2 0%, #5e35b1 100%); color: white; border-radius: 40px;">
                <i class="fas fa-graduation-cap me-2"></i> Manage Training
              </a>
            </div>
          </div>
        </div>
      </div>


       
            <!-- SECTION 3: Compliance & Oversight Cards -->
      <h4 class="text-center mb-4 fw-bold">
        <i class="fas fa-shield-alt me-2" style="color: #f093fb;"></i>
        Compliance & Oversight
      </h4>

      <div class="row g-4 mb-5">
        <!-- Safety & Health Compliance Card -->
        <div class="col-lg-4 col-md-6">
          <div class="card shadow-sm border-0 h-100 hover-card">
            <div class="card-body text-center p-4">
              <div class="icon-circle mb-3 mx-auto" style="background: linear-gradient(135deg, #4caf50 0%, #388e3c 100%); width: 70px; height: 70px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                <i class="fas fa-chart-line fa-2x text-white"></i>
              </div>
              <h5 class="fw-bold mb-2">Safety & Health Compliance</h5>
              <p class="text-muted small mb-3">Monitor regulatory compliance, track standards adherence, identify gaps, and view comprehensive safety metrics.</p>
              <a href="/admin/compliance" class="btn w-100" style="background: linear-gradient(135deg, #4caf50 0%, #388e3c 100%); color: white; border-radius: 40px;">
                <i class="fas fa-chart-line me-2"></i> View Dashboard
              </a>
            </div>
          </div>
        </div>

        <!-- Actions Needed Card -->
        <div class="col-lg-4 col-md-6">
          <div class="card shadow-sm border-0 h-100 hover-card">
            <div class="card-body text-center p-4">
              <div class="icon-circle mb-3 mx-auto" style="background: linear-gradient(135deg, #f44336 0%, #d32f2f 100%); width: 70px; height: 70px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                <i class="fas fa-bell fa-2x text-white"></i>
              </div>
              <h5 class="fw-bold mb-2">Immediate Actions Needed</h5>
              <p class="text-muted small mb-3">Review pending approvals, address overdue tasks, respond to urgent safety requests, and manage critical issues.</p>
              <a href="/admin/actions" class="btn w-100" style="background: linear-gradient(135deg, #f44336 0%, #d32f2f 100%); color: white; border-radius: 40px;">
                <i class="fas fa-tasks me-2"></i> View Actions
              </a>
            </div>
          </div>
        </div>

        <!-- Enhanced Safety Reports Card -->
        <div class="col-lg-4 col-md-6">
          <div class="card shadow-sm border-0 h-100 hover-card">
            <div class="card-body text-center p-4">
              <div class="icon-circle mb-3 mx-auto" style="background: linear-gradient(135deg, #ff9800 0%, #f57c00 100%); width: 70px; height: 70px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                <i class="fas fa-chart-pie fa-2x text-white"></i>
              </div>
              <h5 class="fw-bold mb-2">Safety Reports & Analytics</h5>
              <p class="text-muted small mb-3">Comprehensive incident reports, risk assessments, safety talks, trends analysis, and performance metrics.</p>
              <a href="/admin/reports" class="btn w-100" style="background: linear-gradient(135deg, #ff9800 0%, #f57c00 100%); color: white; border-radius: 40px;">
                <i class="fas fa-chart-pie me-2"></i> View Reports
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Info Banner -->
      <div class="alert alert-info text-center mb-0" style="border-radius: 8px; border-left: 5px solid #26a69a; background-color: #f8f9fa;">
        <i class="fas fa-info-circle me-2" style="color: #26a69a;"></i>
        <strong>Enterprise Admin Portal:</strong> Click any worksite or work area from the list views to manage detailed safety data.
        <a href="#" class="alert-link">Learn more</a>
      </div>
    </div>
  </div>
</div>

<script>
function copyPIN() {
  navigator.clipboard.writeText('<%= user.companyPin %>');
  Swal.fire({
    icon: 'success',
    title: 'Copied!',
    text: 'Company PIN copied to clipboard',
    timer: 1500,
    showConfirmButton: false
  });
}
</script>

<style>
  .main-wrapper {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }
  
  .content {
    flex: 1;
  }

  .admin-dashboard-container {
    max-width: 900px;
    margin: 0 auto;
  }

  .hover-card {
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    border-radius: 16px;
  }

  .hover-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15) !important;
  }

  .icon-circle {
    transition: transform 0.3s ease;
  }

  .hover-card:hover .icon-circle {
    transform: scale(1.1);
  }

  .btn {
    transition: all 0.3s ease;
    border-radius: 40px;
  }

  .btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
  }
  
  .card {
    border-radius: 16px;
  }
  
  .badge {
    font-size: 0.8rem;
    padding: 0.4rem 0.6rem;
    border-radius: 40px;
  }

  .safety-talk-container {
    background-color: #f8f9fa;
    padding: 1rem;
    border-radius: 8px;
    border-left: 5px solid #26a69a;
  }

  .safety-talk-content {
    font-size: 1rem;
    color: #343a40;
    background-color: white;
    padding: 0.75rem 1rem;
    border-radius: 6px;
    margin-top: 0.5rem;
    border: 1px solid #e9ecef;
  }

  .timer-label {
    font-size: 0.9rem;
    color: #6c757d;
    letter-spacing: 1px;
    font-weight: 600;
  }

  .btn-outline-primary {
    color: #26a69a;
    border-color: #26a69a;
  }
  .btn-outline-primary:hover {
    background-color: #26a69a;
    color: white;
  }
  .btn-outline-success {
    color: #4caf50;
    border-color: #4caf50;
  }
  .btn-outline-success:hover {
    background-color: #4caf50;
    color: white;
  }
  .btn-outline-warning {
    color: #ff9800;
    border-color: #ff9800;
  }
  .btn-outline-warning:hover {
    background-color: #ff9800;
    color: white;
  }
  .btn-outline-danger {
    color: #f44336;
    border-color: #f44336;
  }
  .btn-outline-danger:hover {
    background-color: #f44336;
    color: white;
  }
</style>

<%- include('../partials/footer') %>