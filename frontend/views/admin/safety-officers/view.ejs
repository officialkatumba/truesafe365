<%- include('../../partials/header') %>
<%- include('../../partials/navbar') %>

<div class="main-wrapper">
  <div class="content container py-4">
    <div class="officer-details-container" style="max-width: 900px; margin: 0 auto;">
      <!-- Officer Header with Status Badge -->
      <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
        <div>
          <h3 class="mb-1">
            <i class="fas fa-user-shield me-2" style="color: #26a69a;"></i>
            <%= officer.name %>
          </h3>
          <div class="d-flex gap-2">
            <span class="badge text-bg-secondary">
              <%= officer.officerNumber %>
            </span>
            <% if (officer.verificationStatus === 'verified') { %>
              <span class="badge text-bg-success">
                <i class="fas fa-check-circle me-1"></i>VERIFIED
              </span>
            <% } else if (officer.verificationStatus === 'suspended') { %>
              <span class="badge text-bg-danger">
                <i class="fas fa-ban me-1"></i>SUSPENDED
              </span>
            <% } else { %>
              <span class="badge text-bg-warning">
                <i class="fas fa-clock me-1"></i>PENDING
              </span>
            <% } %>
          </div>
        </div>
        <span class="text-muted small">
          <i class="fas fa-calendar-alt me-1"></i> Joined: <%= officer.createdAt ? new Date(officer.createdAt).toLocaleDateString() : 'N/A' %>
        </span>
      </div>

      <!-- Daily Safety Talk Section (like timer section) - Personal Message -->
      <div class="safety-talk-container text-center mb-4">
        <div class="timer-label" id="safetyTalkLabel">OFFICER'S DAILY SAFETY COMMITMENT</div>
        <div class="safety-talk-content" id="safetyTalkContent">
          "I commit to leading by example, enforcing safety protocols, and ensuring every worker goes home safe today."
        </div>
        <div class="timer-meta mt-2">
          <small>
            <i class="fas fa-robot me-1" style="color: #26a69a;"></i>
            Auto-generated | Updated: <%= new Date().toLocaleDateString() %>
          </small>
        </div>
      </div>

      <!-- Compact Action Buttons Row (like voting buttons) -->
      <div class="d-flex gap-2 justify-content-center flex-wrap mb-4">
        <a href="/admin/safety-officers" class="btn btn-outline-secondary btn-sm">
          <i class="fas fa-arrow-left me-1"></i> Back to Officers
        </a>
        <a href="/admin/safety-officers/<%= officer._id %>/edit" class="btn btn-outline-primary btn-sm">
          <i class="fas fa-edit me-1"></i> Edit Officer
        </a>
        <button class="btn btn-outline-danger btn-sm" onclick="confirmSuspend('<%= officer._id %>')">
          <i class="fas fa-ban me-1"></i> Suspend
        </button>
        <a href="/admin/worksites/create?assignOfficer=<%= officer._id %>" class="btn btn-outline-success btn-sm">
          <i class="fas fa-plus-circle me-1"></i> Create Worksite
        </a>
        <button class="btn btn-outline-info btn-sm" data-bs-toggle="modal" data-bs-target="#assignWorksiteModal">
          <i class="fas fa-hard-hat me-1"></i> Assign to Worksite
        </button>
      </div>

      <hr />

      <!-- Officer Details Section (Full Width) -->
      <h4 class="text-center mb-4 fw-bold">
        <i class="fas fa-info-circle me-2" style="color: #26a69a;"></i>
        Officer Information
      </h4>

      <div class="d-flex justify-content-center">
        <div class="details-panel shadow-sm border rounded p-4" style="max-width: 800px; width: 100%;">
          <!-- Profile Row -->
          <div class="row mb-3">
            <div class="col-md-4 text-center">
              <div class="mx-auto mb-2 d-flex align-items-center justify-content-center" 
                   style="width: 100px; height: 100px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 50%;">
                <i class="fas fa-user-tie fa-3x text-white"></i>
              </div>
            </div>
            <div class="col-md-8">
              <h6 class="fw-bold"><i class="fas fa-id-card me-2 text-secondary"></i>Contact Information</h6>
              <div class="row">
                <div class="col-6">
                  <p class="mb-1"><i class="fas fa-envelope me-2 text-muted"></i><%= officer.email %></p>
                  <p class="mb-1"><i class="fas fa-phone me-2 text-muted"></i><%= officer.phone || 'Not provided' %></p>
                </div>
                <div class="col-6">
                  <p class="mb-1"><i class="fas fa-user-check me-2 text-muted"></i>Verified: <%= officer.verifiedBy ? 'Yes' : 'Auto' %></p>
                  <p class="mb-1"><i class="fas fa-briefcase me-2 text-muted"></i>Worksites: <%= officer.worksites?.length || 0 %></p>
                </div>
              </div>
            </div>
          </div>

          <!-- Bio Section -->
          <div class="mb-3">
            <h6 class="fw-bold"><i class="fas fa-align-left me-2 text-secondary"></i>Bio / Qualifications</h6>
            <p class="text-muted"><%= officer.bio || 'No bio provided' %></p>
          </div>

          <!-- Certifications (if any) -->
          <% if (officer.certifications && officer.certifications.length > 0) { %>
          <div class="mb-3">
            <h6 class="fw-bold"><i class="fas fa-certificate me-2 text-secondary"></i>Certifications</h6>
            <div class="d-flex flex-wrap gap-2">
              <% officer.certifications.slice(0, 5).forEach(cert => { %>
                <span class="badge bg-info p-2">
                  <i class="fas fa-check-circle me-1"></i><%= cert.name %>
                  <% if (cert.expiryDate) { %>
                    <span class="ms-1">(<%= new Date(cert.expiryDate).toLocaleDateString() %>)</span>
                  <% } %>
                </span>
              <% }) %>
            </div>
          </div>
          <% } %>

          <!-- Stats Row (compact) -->
          <div class="row mt-3 pt-3 border-top">
            <div class="col-3 text-center">
              <h5 class="fw-bold text-primary"><%= officer.worksitesManaged || 0 %></h5>
              <small class="text-muted">Worksites</small>
            </div>
            <div class="col-3 text-center">
              <h5 class="fw-bold text-danger"><%= officer.incidentsReported || 0 %></h5>
              <small class="text-muted">Incidents</small>
            </div>
            <div class="col-3 text-center">
              <h5 class="fw-bold text-success"><%= officer.safetyTalksConducted || 0 %></h5>
              <small class="text-muted">Safety Talks</small>
            </div>
            <div class="col-3 text-center">
              <h5 class="fw-bold text-warning"><%= officer.workAreas ? officer.workAreas.length : 0 %></h5>
              <small class="text-muted">Work Areas</small>
            </div>
          </div>
        </div>
      </div>

      <!-- Assigned Worksites Section -->
      <h4 class="text-center mt-5 mb-4 fw-bold">
        <i class="fas fa-hard-hat me-2" style="color: #26a69a;"></i>
        Assigned Worksites
      </h4>

      <div class="d-flex justify-content-center">
        <div class="worksites-panel shadow-sm border rounded p-4" style="max-width: 800px; width: 100%;">
          <% if (assignedWorksites && assignedWorksites.length > 0) { %>
            <div class="row g-3">
              <% assignedWorksites.forEach(worksite => { %>
                <div class="col-md-6">
                  <div class="d-flex align-items-center p-3 rounded bg-light">
                    <div class="rounded-circle bg-primary d-flex align-items-center justify-content-center me-3" style="width: 45px; height: 45px;">
                      <i class="fas fa-hard-hat text-white" style="font-size: 1.2rem;"></i>
                    </div>
                    <div class="flex-grow-1">
                      <strong><%= worksite.name %></strong>
                      <div class="small">
                        <span class="text-muted"><%= worksite.location %></span>
                        <span class="badge <%= worksite.status === 'active' ? 'bg-success' : 'bg-secondary' %> ms-2">
                          <%= worksite.status %>
                        </span>
                      </div>
                      <div class="mt-1">
                        <a href="/admin/worksites/<%= worksite._id %>" class="btn btn-sm btn-outline-primary" style="border-radius: 40px;">
                          <i class="fas fa-eye me-1"></i> View
                        </a>
                      </div>
                    </div>
                  </div>
                </div>
              <% }) %>
            </div>
          <% } else { %>
            <p class="text-muted text-center py-4">No worksites assigned yet.</p>
            <div class="text-center">
              <button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#assignWorksiteModal">
                <i class="fas fa-plus-circle me-1"></i> Assign to Worksite
              </button>
            </div>
          <% } %>
        </div>
      </div>

      <!-- Work Areas Section -->
      <h4 class="text-center mt-5 mb-4 fw-bold">
        <i class="fas fa-layer-group me-2" style="color: #26a69a;"></i>
        Monitored Work Areas
      </h4>

      <div class="d-flex justify-content-center">
        <div class="workareas-panel shadow-sm border rounded p-4" style="max-width: 800px; width: 100%;">
          <% if (workAreas && workAreas.length > 0) { %>
            <div class="table-responsive">
              <table class="table table-hover align-middle">
                <thead>
                  <tr>
                    <th>Area Name</th>
                    <th>Worksite</th>
                    <th>Status</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% workAreas.forEach(area => { %>
                    <tr>
                      <td><%= area.name %></td>
                      <td><%= area.worksite ? area.worksite.name : 'N/A' %></td>
                      <td>
                        <span class="badge <%= area.status === 'active' ? 'bg-success' : 'bg-warning' %>">
                          <%= area.status || 'active' %>
                        </span>
                      </td>
                      <td>
                        <a href="/admin/work-areas/<%= area._id %>" class="btn btn-sm btn-outline-secondary" style="border-radius: 40px;">
                          <i class="fas fa-eye me-1"></i> View
                        </a>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } else { %>
            <p class="text-muted text-center py-4">No work areas assigned yet.</p>
          <% } %>
        </div>
      </div>

      <!-- Documents Section with Tabs -->
      <div class="row mt-5">
        <div class="col-12">
          <h4 class="fw-bold mb-3" style="color: #26a69a;">
            <i class="fas fa-folder-open me-2"></i>Activity & Documents
          </h4>
          
          <!-- Tabs Navigation -->
          <ul class="nav nav-tabs" id="documentTabs" role="tablist">
            <li class="nav-item" role="presentation">
              <button class="nav-link active" id="incidents-tab" data-bs-toggle="tab" data-bs-target="#incidents" type="button" role="tab">
                <i class="fas fa-exclamation-triangle me-1"></i> Incidents 
                <span class="badge bg-secondary ms-1"><%= recentIncidents?.length || 0 %></span>
              </button>
            </li>
            <li class="nav-item" role="presentation">
              <button class="nav-link" id="assessments-tab" data-bs-toggle="tab" data-bs-target="#assessments" type="button" role="tab">
                <i class="fas fa-chart-pie me-1"></i> Risk Assessments
                <span class="badge bg-secondary ms-1"><%= recentAssessments?.length || 0 %></span>
              </button>
            </li>
            <li class="nav-item" role="presentation">
              <button class="nav-link" id="talks-tab" data-bs-toggle="tab" data-bs-target="#talks" type="button" role="tab">
                <i class="fas fa-chalkboard-teacher me-1"></i> Safety Talks
                <span class="badge bg-secondary ms-1"><%= officer.safetyTalksConducted || 0 %></span>
              </button>
            </li>
          </ul>

          <!-- Tabs Content -->
          <div class="tab-content p-4 border border-top-0 rounded-bottom shadow-sm" style="background-color: white;">
            
            <!-- Incidents Tab -->
            <div class="tab-pane fade show active" id="incidents" role="tabpanel">
              <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="fw-bold mb-0"><i class="fas fa-exclamation-triangle me-2" style="color: #f44336;"></i>Reported Incidents</h5>
                <a href="/incidents/report?officerId=<%= officer._id %>" class="btn btn-sm" style="background: #f44336; color: white; border-radius: 40px;">
                  <i class="fas fa-flag me-1"></i> Report Incident
                </a>
              </div>
              
              <% if (recentIncidents && recentIncidents.length > 0) { %>
                <div class="list-group">
                  <% recentIncidents.slice(0, 3).forEach(incident => { %>
                    <a href="/incidents/<%= incident._id %>" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                      <div>
                        <strong><%= incident.type || incident.title %></strong>
                        <span class="badge <%= 
                          incident.severity === 'critical' ? 'bg-danger' : 
                          incident.severity === 'high' ? 'bg-warning text-dark' : 
                          incident.severity === 'medium' ? 'bg-info' : 
                          'bg-success' 
                        %> ms-2"><%= incident.severity %></span>
                        <div class="small text-muted">
                          <i class="fas fa-calendar me-1"></i> <%= new Date(incident.dateTime || incident.createdAt).toLocaleDateString() %>
                          | <%= incident.workArea?.name || 'N/A' %>
                        </div>
                      </div>
                      <i class="fas fa-chevron-right text-muted"></i>
                    </a>
                  <% }) %>
                </div>
                <% if (recentIncidents.length > 3) { %>
                  <div class="text-center mt-3">
                    <a href="/incidents?officerId=<%= officer._id %>" class="btn btn-sm btn-outline-secondary">
                      View All <%= recentIncidents.length %> Incidents
                    </a>
                  </div>
                <% } %>
              <% } else { %>
                <p class="text-muted text-center py-4">No incidents reported by this officer.</p>
              <% } %>
            </div>

            <!-- Risk Assessments Tab -->
            <div class="tab-pane fade" id="assessments" role="tabpanel">
              <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="fw-bold mb-0"><i class="fas fa-chart-pie me-2" style="color: #26a69a;"></i>Risk Assessments</h5>
                <a href="/risk-assessments/new?officerId=<%= officer._id %>" class="btn btn-sm" style="background: #26a69a; color: white; border-radius: 40px;">
                  <i class="fas fa-plus-circle me-1"></i> New Assessment
                </a>
              </div>
              
              <% if (recentAssessments && recentAssessments.length > 0) { %>
                <div class="list-group">
                  <% recentAssessments.slice(0, 3).forEach(assessment => { %>
                    <a href="/risk-assessments/<%= assessment._id %>" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                      <div>
                        <strong><%= assessment.title %></strong>
                        <span class="badge <%= 
                          assessment.status === 'active' ? 'bg-success' : 
                          assessment.status === 'draft' ? 'bg-secondary' : 
                          'bg-info' 
                        %> ms-2"><%= assessment.status %></span>
                        <div class="small text-muted">
                          <i class="fas fa-calendar me-1"></i> <%= new Date(assessment.createdAt).toLocaleDateString() %>
                          | Hazards: <%= assessment.hazards?.length || 0 %>
                        </div>
                      </div>
                      <i class="fas fa-chevron-right text-muted"></i>
                    </a>
                  <% }) %>
                </div>
                <% if (recentAssessments.length > 3) { %>
                  <div class="text-center mt-3">
                    <a href="/risk-assessments?officerId=<%= officer._id %>" class="btn btn-sm btn-outline-secondary">
                      View All <%= recentAssessments.length %> Assessments
                    </a>
                  </div>
                <% } %>
              <% } else { %>
                <p class="text-muted text-center py-4">No risk assessments created by this officer.</p>
              <% } %>
            </div>

            <!-- Safety Talks Tab -->
            <div class="tab-pane fade" id="talks" role="tabpanel">
              <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="fw-bold mb-0"><i class="fas fa-chalkboard-teacher me-2" style="color: #5f2c82;"></i>Safety Talks</h5>
                <a href="/safety-talks/generate?officerId=<%= officer._id %>" class="btn btn-sm" style="background: #5f2c82; color: white; border-radius: 40px;">
                  <i class="fas fa-robot me-1"></i> Generate Talk
                </a>
              </div>
              
              <p class="text-muted text-center py-4">Total talks conducted: <strong><%= officer.safetyTalksConducted || 0 %></strong></p>
              
              <div class="text-center mt-2">
                <a href="/safety-talks/history?officerId=<%= officer._id %>" class="btn btn-sm btn-outline-secondary">
                  View Talk History
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Back Button -->
      <div class="text-center mt-4">
        <a href="/admin/safety-officers" class="btn btn-outline-secondary btn-sm">
          <i class="fas fa-arrow-left me-1"></i> Back to Safety Officers
        </a>
      </div>
    </div>
  </div>
</div>

<!-- Assign Worksite Modal -->
<div class="modal fade" id="assignWorksiteModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content" style="border-radius: 16px;">
      <div class="modal-header border-0">
        <h5 class="modal-title fw-bold">Assign to Worksite</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form action="/admin/worksites/assign-officer" method="POST" id="assignWorksiteForm">
        <div class="modal-body">
          <input type="hidden" name="officerId" value="<%= officer._id %>">
          <div class="mb-3">
            <label class="form-label fw-semibold">Select Worksite</label>
            <select class="form-select" name="worksiteId" required style="border-radius: 40px;">
              <option value="">Choose worksite...</option>
              <% if (availableWorksites) { %>
                <% availableWorksites.forEach(worksite => { %>
                <option value="<%= worksite._id %>"><%= worksite.name %> - <%= worksite.location %></option>
                <% }) %>
              <% } %>
            </select>
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold">Role</label>
            <select class="form-select" name="role" style="border-radius: 40px;">
              <option value="lead">Lead Officer</option>
              <option value="assistant" selected>Assistant Officer</option>
              <option value="trainee">Trainee</option>
            </select>
          </div>
        </div>
        <div class="modal-footer border-0">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal" style="border-radius: 40px;">Cancel</button>
          <button type="submit" class="btn" style="background: #26a69a; color: white; border-radius: 40px;">Assign</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  function confirmSuspend(officerId) {
    Swal.fire({
      title: 'Suspend Safety Officer?',
      text: "This officer will lose access to all worksites and work areas!",
      icon: 'warning',
      showCancelButton: true,
      confirmButtonColor: '#d33',
      cancelButtonColor: '#6c757d',
      confirmButtonText: 'Yes, suspend',
      cancelButtonText: 'Cancel'
    }).then((result) => {
      if (result.isConfirmed) {
        fetch(`/admin/safety-officers/${officerId}/suspend`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          }
        })
        .then(response => response.json())
        .then(data => {
          if (data.success) {
            Swal.fire({
              icon: 'success',
              title: 'Suspended!',
              text: 'Safety officer has been suspended.',
              timer: 2000
            }).then(() => {
              location.reload();
            });
          } else {
            Swal.fire({
              icon: 'error',
              title: 'Error!',
              text: data.message || 'Failed to suspend officer'
            });
          }
        })
        .catch(error => {
          Swal.fire({
            icon: 'error',
            title: 'Error!',
            text: 'An error occurred'
          });
        });
      }
    });
  }
</script>

<style>
  .officer-details-container {
    max-width: 900px;
    margin: 0 auto;
  }

  .safety-talk-container {
    background-color: #f8f9fa;
    padding: 1rem;
    border-radius: 8px;
    border-left: 5px solid #26a69a;
  }

  .safety-talk-content {
    font-size: 1rem;
    font-style: italic;
    color: #343a40;
    background-color: white;
    padding: 0.75rem 1rem;
    border-radius: 6px;
    margin-top: 0.5rem;
    border: 1px solid #e9ecef;
  }

  .details-panel,
  .worksites-panel,
  .workareas-panel {
    background-color: #ffffff;
  }

  .btn-outline-primary {
    color: #26a69a;
    border-color: #26a69a;
  }
  .btn-outline-primary:hover {
    background-color: #26a69a;
    color: white;
  }
  .btn-outline-info {
    color: #5f2c82;
    border-color: #5f2c82;
  }
  .btn-outline-info:hover {
    background-color: #5f2c82;
    color: white;
  }
  .btn-outline-success {
    color: #27ae60;
    border-color: #27ae60;
  }
  .btn-outline-success:hover {
    background-color: #27ae60;
    color: white;
  }

  @media (max-width: 768px) {
    .btn-sm {
      font-size: 0.75rem;
    }
  }
</style>

<%- include('../../partials/footer') %>