<%- include('../../partials/header') %>
<%- include('../../partials/navbar') %>

<div class="main-wrapper">
  <div class="content container py-4">
    <div class="officer-details-container" style="max-width: 900px; margin: 0 auto;">
      <!-- Officer Header with Status Badge -->
      <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
        <div>
          <h3 class="mb-1">
            <i class="fas fa-user-shield me-2" style="color: #26a69a;"></i>
            <%= officer.name %>
          </h3>
          <div class="d-flex gap-2">
            <span class="badge text-bg-secondary">
              <%= officer.officerNumber %>
            </span>
            <% if (officer.verificationStatus === 'verified') { %>
              <span class="badge text-bg-success">
                <i class="fas fa-check-circle me-1"></i>VERIFIED
              </span>
            <% } else if (officer.verificationStatus === 'suspended') { %>
              <span class="badge text-bg-danger">
                <i class="fas fa-ban me-1"></i>SUSPENDED
              </span>
            <% } else { %>
              <span class="badge text-bg-warning">
                <i class="fas fa-clock me-1"></i>PENDING
              </span>
            <% } %>
          </div>
        </div>
        <div class="text-end">
          <span class="text-muted small d-block">
            <i class="fas fa-calendar-alt me-1"></i> Joined: <%= officer.createdAt ? new Date(officer.createdAt).toLocaleDateString() : 'N/A' %>
          </span>
          <span class="text-muted small mt-1 d-block">
            <i class="fas fa-user me-1"></i> Welcome back, <strong><%= user.email %></strong>
            <span class="badge <%= user.role === 'system_admin' ? 'bg-warning text-dark' : (user.role === 'safety_officer' ? 'bg-success' : 'bg-info') %> ms-2">
              <i class="fas fa-<%= user.role === 'system_admin' ? 'crown' : (user.role === 'safety_officer' ? 'user-shield' : 'user') %> me-1"></i>
              <%= user.role === 'system_admin' ? 'System Admin' : (user.role === 'safety_officer' ? 'Safety Officer' : (user.role === 'supervisor' ? 'Supervisor' : 'Worker')) %>
            </span>
          </span>
        </div>
      </div>

      <!-- Compact Action Buttons Row -->
      <div class="d-flex gap-2 justify-content-center flex-wrap mb-4">
        <button class="btn btn-outline-danger btn-sm" onclick="confirmSuspend('<%= officer._id %>')">
          <i class="fas fa-ban me-1"></i> Suspend
        </button>
      </div>

      <hr />

      <!-- Officer Details Section -->
      <h4 class="text-center mb-4 fw-bold">
        <i class="fas fa-info-circle me-2" style="color: #26a69a;"></i>
        Officer Information
      </h4>

      <div class="d-flex justify-content-center">
        <div class="details-panel shadow-sm border rounded p-4" style="max-width: 800px; width: 100%;">
          <!-- Profile Row -->
          <div class="row mb-3">
            <div class="col-md-4 text-center">
              <div class="mx-auto mb-2 d-flex align-items-center justify-content-center" 
                   style="width: 100px; height: 100px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 50%;">
                <i class="fas fa-user-tie fa-3x text-white"></i>
              </div>
            </div>
            <div class="col-md-8">
              <h6 class="fw-bold"><i class="fas fa-id-card me-2 text-secondary"></i>Contact Information</h6>
              <div class="row">
                <div class="col-6">
                  <p class="mb-1"><i class="fas fa-envelope me-2 text-muted"></i><%= officer.email %></p>
                  <p class="mb-1"><i class="fas fa-phone me-2 text-muted"></i><%= officer.phone || 'Not provided' %></p>
                </div>
                <div class="col-6">
                  <p class="mb-1"><i class="fas fa-user-check me-2 text-muted"></i>Verified: <%= officer.verifiedBy ? 'Yes' : 'Auto' %></p>
                  <p class="mb-1"><i class="fas fa-briefcase me-2 text-muted"></i>Worksites: <%= officer.worksites?.length || 0 %></p>
                </div>
              </div>
            </div>
          </div>

          <!-- Bio Section -->
          <div class="mb-3">
            <h6 class="fw-bold"><i class="fas fa-align-left me-2 text-secondary"></i>Bio / Qualifications</h6>
            <p class="text-muted"><%= officer.bio || 'No bio provided' %></p>
          </div>

          <!-- Certifications (if any) -->
          <% if (officer.certifications && officer.certifications.length > 0) { %>
          <div class="mb-3">
            <h6 class="fw-bold"><i class="fas fa-certificate me-2 text-secondary"></i>Certifications</h6>
            <div class="d-flex flex-wrap gap-2">
              <% officer.certifications.slice(0, 5).forEach(cert => { %>
                <span class="badge bg-info p-2">
                  <i class="fas fa-check-circle me-1"></i><%= cert.name %>
                  <% if (cert.expiryDate) { %>
                    <span class="ms-1">(<%= new Date(cert.expiryDate).toLocaleDateString() %>)</span>
                  <% } %>
                </span>
              <% }) %>
            </div>
          </div>
          <% } %>

          <!-- Stats Row -->
          <div class="row mt-3 pt-3 border-top">
            <div class="col-3 text-center">
              <h5 class="fw-bold text-primary"><%= officer.worksitesManaged || 0 %></h5>
              <small class="text-muted">Worksites</small>
            </div>
            <div class="col-3 text-center">
              <h5 class="fw-bold text-danger"><%= officer.incidentsReported || 0 %></h5>
              <small class="text-muted">Incidents</small>
            </div>
            <div class="col-3 text-center">
              <h5 class="fw-bold text-success"><%= officer.safetyTalksConducted || 0 %></h5>
              <small class="text-muted">Safety Talks</small>
            </div>
            <div class="col-3 text-center">
              <h5 class="fw-bold text-warning"><%= officer.workAreas ? officer.workAreas.length : 0 %></h5>
              <small class="text-muted">Work Areas</small>
            </div>
          </div>
        </div>
      </div>

      <!-- Assigned Worksites Section -->
      <h4 class="text-center mt-5 mb-4 fw-bold">
        <i class="fas fa-hard-hat me-2" style="color: #26a69a;"></i>
        Assigned Worksites
      </h4>

      <div class="d-flex justify-content-center">
        <div class="worksites-panel shadow-sm border rounded p-4" style="max-width: 800px; width: 100%;">
          <% if (assignedWorksites && assignedWorksites.length > 0) { %>
            <div class="row g-3">
              <% assignedWorksites.forEach(worksite => { %>
                <div class="col-md-6">
                  <div class="d-flex align-items-center p-3 rounded bg-light">
                    <div class="rounded-circle bg-primary d-flex align-items-center justify-content-center me-3" style="width: 45px; height: 45px;">
                      <i class="fas fa-hard-hat text-white" style="font-size: 1.2rem;"></i>
                    </div>
                    <div class="flex-grow-1">
                      <strong><%= worksite.name %></strong>
                      <div class="small">
                        <span class="text-muted"><%= worksite.location %></span>
                        <span class="badge <%= worksite.status === 'active' ? 'bg-success' : 'bg-secondary' %> ms-2">
                          <%= worksite.status %>
                        </span>
                      </div>
                      <div class="mt-1">
                        <a href="/admin/worksites/<%= worksite._id %>" class="btn btn-sm btn-outline-primary" style="border-radius: 40px;">
                          <i class="fas fa-eye me-1"></i> View
                        </a>
                      </div>
                    </div>
                  </div>
                </div>
              <% }) %>
            </div>
          <% } else { %>
            <p class="text-muted text-center py-4">No worksites assigned yet.</p>
          <% } %>
        </div>
      </div>

      <!-- Work Areas Section with Assign Button -->
      <div class="d-flex justify-content-between align-items-center mt-5 mb-4">
        <h4 class="fw-bold mb-0">
          <i class="fas fa-layer-group me-2" style="color: #26a69a;"></i>
          Monitored Work Areas
        </h4>
        <button class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#assignWorkAreaModal" style="border-radius: 40px;">
          <i class="fas fa-plus-circle me-1"></i> Assign Work Area
        </button>
      </div>

      <div class="d-flex justify-content-center">
        <div class="workareas-panel shadow-sm border rounded p-4" style="max-width: 800px; width: 100%;">
          <% if (workAreas && workAreas.length > 0) { %>
            <div class="table-responsive">
              <table class="table table-hover align-middle">
                <thead>
                  <tr>
                    <th>Area Name</th>
                    <th>Worksite</th>
                    <th>Location</th>
                    <th>Status</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% workAreas.forEach(area => { %>
                    <tr>
                      <td><strong><%= area.name %></strong></td>
                      <td><%= area.worksite ? area.worksite.name : 'N/A' %></td>
                      <td><%= area.location?.zone || area.location || 'Not specified' %></td>
                      <td>
                        <span class="badge <%= area.status === 'active' ? 'bg-success' : 'bg-warning' %>">
                          <%= area.status || 'active' %>
                        </span>
                      </td>
                      <td>
                        <div class="d-flex gap-2">
                          <a href="/work-areas/<%= area._id %>" class="btn btn-sm btn-outline-primary" style="border-radius: 40px;">
                            <i class="fas fa-eye me-1"></i> View
                          </a>
                          <button class="btn btn-sm btn-outline-danger" onclick="removeWorkArea('<%= officer._id %>', '<%= area._id %>')" style="border-radius: 40px;">
                            <i class="fas fa-trash me-1"></i> Remove
                          </button>
                        </div>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } else { %>
            <p class="text-muted text-center py-4">No work areas assigned yet.</p>
            <div class="text-center">
              <button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#assignWorkAreaModal">
                <i class="fas fa-plus-circle me-1"></i> Assign Work Area
              </button>
            </div>
          <% } %>
        </div>
      </div>

      <!-- Back Button -->
      <div class="text-center mt-4">
        <a href="/admin/safety-officers" class="btn btn-outline-secondary btn-sm">
          <i class="fas fa-arrow-left me-1"></i> Back to Safety Officers
        </a>
      </div>
    </div>
  </div>
</div>

<!-- Assign Work Area Modal -->
<div class="modal fade" id="assignWorkAreaModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content" style="border-radius: 16px;">
      <div class="modal-header border-0">
        <h5 class="modal-title fw-bold">Assign to Work Area</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form action="/admin/safety-officers/<%= officer._id %>/assign-work-area" method="POST" id="assignWorkAreaForm">
        <div class="modal-body">
          <div class="mb-3">
            <label class="form-label fw-semibold">Select Work Area</label>
            <select class="form-select" name="workAreaId" required style="border-radius: 40px;">
              <option value="">Choose work area...</option>
              <% if (availableWorkAreas && availableWorkAreas.length > 0) { %>
                <% availableWorkAreas.forEach(area => { %>
                <option value="<%= area._id %>"><%= area.name %> - <%= area.worksite?.name || 'No worksite' %></option>
                <% }) %>
              <% } else { %>
                <option value="">No available work areas</option>
              <% } %>
            </select>
            <small class="text-muted">Work areas not already assigned to this officer</small>
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold">Shift</label>
            <select class="form-select" name="shift" style="border-radius: 40px;">
              <option value="morning">Morning Shift</option>
              <option value="afternoon">Afternoon Shift</option>
              <option value="night">Night Shift</option>
            </select>
          </div>
          <div class="form-check mb-3">
            <input class="form-check-input" type="checkbox" name="isPrimary" value="true" id="isPrimary">
            <label class="form-check-label" for="isPrimary">
              Make this officer the primary contact for this work area
            </label>
          </div>
        </div>
        <div class="modal-footer border-0">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal" style="border-radius: 40px;">Cancel</button>
          <button type="submit" class="btn" style="background: #26a69a; color: white; border-radius: 40px;">Assign</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  function confirmSuspend(officerId) {
    Swal.fire({
      title: 'Suspend Safety Officer?',
      text: "This officer will lose access to all worksites and work areas!",
      icon: 'warning',
      showCancelButton: true,
      confirmButtonColor: '#d33',
      cancelButtonColor: '#6c757d',
      confirmButtonText: 'Yes, suspend',
      cancelButtonText: 'Cancel'
    }).then((result) => {
      if (result.isConfirmed) {
        fetch(`/admin/safety-officers/${officerId}/suspend`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          }
        })
        .then(response => response.json())
        .then(data => {
          if (data.success) {
            Swal.fire({
              icon: 'success',
              title: 'Suspended!',
              text: 'Safety officer has been suspended.',
              timer: 2000
            }).then(() => {
              location.reload();
            });
          } else {
            Swal.fire({
              icon: 'error',
              title: 'Error!',
              text: data.message || 'Failed to suspend officer'
            });
          }
        })
        .catch(error => {
          Swal.fire({
            icon: 'error',
            title: 'Error!',
            text: 'An error occurred'
          });
        });
      }
    });
  }

  function removeWorkArea(officerId, workAreaId) {
    Swal.fire({
      title: 'Remove from Work Area?',
      text: "This officer will no longer have access to this work area.",
      icon: 'warning',
      showCancelButton: true,
      confirmButtonColor: '#d33',
      cancelButtonColor: '#6c757d',
      confirmButtonText: 'Yes, remove',
      cancelButtonText: 'Cancel'
    }).then((result) => {
      if (result.isConfirmed) {
        fetch(`/admin/safety-officers/${officerId}/work-areas/${workAreaId}/remove`, {
          method: 'DELETE',
          headers: {
            'Content-Type': 'application/json',
          }
        })
        .then(response => response.json())
        .then(data => {
          if (data.success) {
            Swal.fire({
              icon: 'success',
              title: 'Removed!',
              text: 'Officer removed from work area.',
              timer: 2000
            }).then(() => {
              location.reload();
            });
          } else {
            Swal.fire({
              icon: 'error',
              title: 'Error!',
              text: data.message || 'Failed to remove officer'
            });
          }
        })
        .catch(error => {
          Swal.fire({
            icon: 'error',
            title: 'Error!',
            text: 'An error occurred'
          });
        });
      }
    });
  }
</script>

<style>
  .officer-details-container {
    max-width: 900px;
    margin: 0 auto;
  }

  .safety-talk-container {
    background-color: #f8f9fa;
    padding: 1rem;
    border-radius: 8px;
    border-left: 5px solid #26a69a;
  }

  .safety-talk-content {
    font-size: 1rem;
    font-style: italic;
    color: #343a40;
    background-color: white;
    padding: 0.75rem 1rem;
    border-radius: 6px;
    margin-top: 0.5rem;
    border: 1px solid #e9ecef;
  }

  .details-panel,
  .worksites-panel,
  .workareas-panel {
    background-color: #ffffff;
  }

  .btn-outline-primary {
    color: #26a69a;
    border-color: #26a69a;
  }
  .btn-outline-primary:hover {
    background-color: #26a69a;
    color: white;
  }
  .btn-outline-info {
    color: #5f2c82;
    border-color: #5f2c82;
  }
  .btn-outline-info:hover {
    background-color: #5f2c82;
    color: white;
  }
  .btn-outline-success {
    color: #27ae60;
    border-color: #27ae60;
  }
  .btn-outline-success:hover {
    background-color: #27ae60;
    color: white;
  }

  @media (max-width: 768px) {
    .btn-sm {
      font-size: 0.75rem;
    }
  }
</style>

<%- include('../../partials/footer') %>