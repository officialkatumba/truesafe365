<%- include('../../partials/header') %>
<%- include('../../partials/navbar') %>

<div class="main-wrapper">
  <div class="content container py-4">
    <div class="officers-list-container" style="max-width: 1000px; margin: 0 auto;">
      <!-- Header -->
      <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <div>
          <h3 class="mb-1">
            <i class="fas fa-users-cog me-2" style="color: #f093fb;"></i>
            Safety Officers
          </h3>
          <p class="text-muted small">Manage all safety officers in the company</p>
        </div>
        <a href="/admin/safety-officers/create" class="btn" style="background: #26a69a; color: white; border-radius: 40px;">
          <i class="fas fa-user-plus me-2"></i>Add New Officer
        </a>
      </div>

      <!-- Search Bar -->
      <div class="row mb-4">
        <div class="col-12">
          <div class="card border-0 shadow-sm" style="border-radius: 16px;">
            <div class="card-body p-3">
              <form method="GET" class="row g-2">
                <div class="col-md-8">
                  <div class="input-group">
                    <span class="input-group-text bg-light border-0">
                      <i class="fas fa-search text-muted"></i>
                    </span>
                    <input type="text" class="form-control border-0 bg-light" name="search" 
                           placeholder="Search by name or email..." value="<%= typeof search !== 'undefined' ? search : '' %>" style="border-radius: 40px;">
                  </div>
                </div>
                <div class="col-md-4">
                  <button type="submit" class="btn w-100" style="background: #26a69a; color: white; border: none; border-radius: 40px;">
                    <i class="fas fa-search me-1"></i> Search
                  </button>
                </div>
              </form>
            </div>
          </div>
        </div>
      </div>

      <!-- Officers Table -->
      <% if (officers && officers.length > 0) { %>
      <div class="row">
        <div class="col-12">
          <div class="card border-0 shadow-sm" style="border-radius: 16px;">
            <div class="card-body p-0">
              <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                  <thead class="bg-light">
                    <tr>
                      <th class="px-4 py-3" style="border-radius: 16px 0 0 0;">Officer</th>
                      <th class="py-3">Contact</th>
                      <th class="py-3 text-center">Status</th>
                      <th class="py-3 text-center">Worksites</th>
                      <th class="py-3 text-center" style="border-radius: 0 16px 0 0;">Actions</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% officers.forEach(officer => { %>
                    <tr class="hover-row">
                      <td class="px-4">
                        <div class="d-flex align-items-center">
                          <div class="rounded-circle d-flex align-items-center justify-content-center me-3" 
                               style="background: linear-gradient(135deg, #ff9800 0%, #f57c00 100%); width: 40px; height: 40px;">
                            <i class="fas fa-user-tie text-white" style="font-size: 1rem;"></i>
                          </div>
                          <div>
                            <strong class="fs-6"><%= officer.name %></strong>
                            <div>
                              <span class="badge bg-light text-dark" style="border-radius: 40px; font-size: 0.65rem;">
                                <i class="fas fa-id-card me-1"></i> #<%= officer.officerNumber %>
                              </span>
                            </div>
                          </div>
                        </div>
                      </td>
                      <td>
                        <div><i class="fas fa-envelope me-1" style="color: #f093fb;"></i> <%= officer.email %></div>
                        <small><i class="fas fa-phone me-1" style="color: #26a69a;"></i> <%= officer.phone %></small>
                      </td>
                      <td class="text-center">
                        <span class="badge <%= officer.isActive ? 'bg-success' : 'bg-secondary' %>" style="border-radius: 40px;">
                          <%= officer.isActive ? 'Active' : 'Inactive' %>
                        </span>
                      </td>
                      <td class="text-center">
                        <span class="badge" style="background: #2196f3; color: white; border-radius: 40px;">
                          <%= officer.worksites?.length || 0 %> worksites
                        </span>
                      </td>
                      <td class="text-center">
                        <div class="d-flex gap-2 justify-content-center">
                          <a href="/admin/safety-officers/<%= officer._id %>" class="btn btn-sm btn-outline-primary" title="View" style="border-radius: 40px; border-color: #26a69a; color: #26a69a;">
                            <i class="fas fa-eye"></i>
                          </a>
                          <button class="btn btn-sm btn-outline-danger" title="Suspend" style="border-radius: 40px;" onclick="confirmSuspend('<%= officer._id %>')">
                            <i class="fas fa-ban"></i>
                          </button>
                        </div>
                      </td>
                    </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Pagination -->
      <% if (pagination && pagination.pages > 1) { %>
      <div class="row mt-4">
        <div class="col-12">
          <nav aria-label="Officers pagination">
            <ul class="pagination justify-content-center">
              <li class="page-item <%= pagination.page === 1 ? 'disabled' : '' %>">
                <a class="page-link" href="?page=<%= pagination.page - 1 %>&search=<%= search || '' %>" style="border-radius: 40px; color: #26a69a;">
                  <i class="fas fa-chevron-left"></i>
                </a>
              </li>
              
              <% for (let i = 1; i <= pagination.pages; i++) { %>
                <% if (i >= pagination.page - 2 && i <= pagination.page + 2) { %>
                <li class="page-item <%= i === pagination.page ? 'active' : '' %>">
                  <a class="page-link" href="?page=<%= i %>&search=<%= search || '' %>" 
                     style="border-radius: 40px; <%= i === pagination.page ? 'background: #26a69a; color: white; border-color: #26a69a;' : 'color: #26a69a;' %>">
                    <%= i %>
                  </a>
                </li>
                <% } %>
              <% } %>
              
              <li class="page-item <%= pagination.page === pagination.pages ? 'disabled' : '' %>">
                <a class="page-link" href="?page=<%= pagination.page + 1 %>&search=<%= search || '' %>" style="border-radius: 40px; color: #26a69a;">
                  <i class="fas fa-chevron-right"></i>
                </a>
              </li>
            </ul>
          </nav>
        </div>
      </div>
      <% } %>
      
      <% } else { %>
      <!-- Empty State -->
      <div class="row">
        <div class="col-12">
          <div class="card border-0 bg-light" style="border-radius: 24px;">
            <div class="card-body text-center p-5">
              <div class="mb-4">
                <i class="fas fa-users fa-4x" style="color: #26a69a;"></i>
              </div>
              <h4 class="fw-bold mb-3" style="color: #1e3c5c;">No Safety Officers Found</h4>
              <p class="text-muted mb-4">
                <%= search ? 'No officers match your search criteria.' : 'Get started by creating your first safety officer.' %>
              </p>
              <% if (search) { %>
              <a href="/admin/safety-officers" class="btn btn-outline-primary px-4" style="border-radius: 40px; border-color: #26a69a; color: #26a69a;">
                <i class="fas fa-redo-alt me-2"></i> Clear Search
              </a>
              <% } else { %>
              <a href="/admin/safety-officers/create" class="btn px-4" style="background: #26a69a; color: white; border: none; border-radius: 40px;">
                <i class="fas fa-user-plus me-2"></i> Create First Officer
              </a>
              <% } %>
            </div>
          </div>
        </div>
      </div>
      <% } %>
    </div>
  </div>
</div>

<!-- SweetAlert2 for confirmations -->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
function confirmSuspend(officerId) {
  Swal.fire({
    title: 'Suspend Officer?',
    text: 'This officer will no longer be able to access the system.',
    icon: 'warning',
    showCancelButton: true,
    confirmButtonColor: '#f44336',
    cancelButtonColor: '#6c757d',
    confirmButtonText: 'Yes, suspend',
    cancelButtonText: 'Cancel'
  }).then((result) => {
    if (result.isConfirmed) {
      // Add suspend functionality here
      Swal.fire({
        icon: 'success',
        title: 'Suspended',
        text: 'Officer has been suspended',
        confirmButtonColor: '#26a69a'
      });
    }
  });
}
</script>

<style>
  .main-wrapper {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }
  
  .content {
    flex: 1;
  }
  
  .hover-row {
    transition: background-color 0.2s ease;
  }
  .hover-row:hover {
    background-color: #f0f7f5;
  }
  
  .page-link {
    color: #26a69a;
    border-radius: 40px;
    margin: 0 2px;
    border: 1px solid #dee2e6;
  }
  .page-item.active .page-link {
    background: #26a69a;
    border-color: #26a69a;
    color: white;
  }
  .page-item.disabled .page-link {
    color: #6c757d;
  }
  
  .btn-outline-primary:hover {
    background-color: #26a69a;
    color: white;
  }
</style>

<%- include('../../partials/footer') %>