<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>TrueSafe365 | AI-Powered Hazard Pattern Discovery &amp; Safety Talks</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Plus+Jakarta+Sans:wght@500;600;700;800&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet">

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" />
</head>

<body>

<main class="truesafe365-landing" data-landing>
  <!-- HERO SCREEN -->
  <section class="ts-screen ts-screen-hero is-active" id="welcome" aria-labelledby="TrueSafe365-title">
    <div class="ts-orb ts-orb-one"></div>
    <div class="ts-orb ts-orb-two"></div>
    <div class="ts-orb ts-orb-three"></div>

    <nav class="ts-topbar" aria-label="Landing navigation">
      <a class="ts-mini-brand" href="/" aria-label="TrueSafe365 home">
        <span class="ts-mark"><i class="bi bi-shield-check"></i></span>
        <span>TrueSafe365</span>
      </a>

      <button class="ts-menu-toggle" type="button" data-menu-toggle aria-label="Open navigation">
        <i class="bi bi-list"></i>
      </button>

      <div class="ts-nav-links" data-mobile-menu>
        <a class="ts-incident-nav" href="#staff-incident-report" data-incident-jump>Incident</a>
        <% if (user) { %>
          <a href="/dashboard/officer">Dashboard</a>
          <a href="/api/users/logout">Sign out</a>
        <% } else { %>
          <a href="/api/users/login">Sign in</a>
          <a href="/register/safety-officer">Register</a>
        <% } %>
      </div>
    </nav>

    <div class="ts-hero-center">
      <p class="ts-eyebrow">PREDICTIVE PROTECTION &amp; DAILY TEAM ALIGNMENT</p>
      <h1 id="TrueSafe365-title">Expose Hidden Risks. Get Real Time Safety Insights</h1>

      <p class="ts-hero-copy">
        Isolated near-misses and scattered field logs hide deadly patterns that human eyes overlook. <strong>TrueSafe365</strong> uses AI to instantly turn your real-time site data into high-value safety insights and hyper-relevant, localized daily safety talk topics that keep your entire team safer every single shift.
      </p>

      <button class="ts-primary-action" type="button" data-go-onboarding>
        See How It Works
        <i class="bi bi-arrow-right-short"></i>
      </button>
    </div>

    <div class="ts-home-video">
      <div class="ts-video-frame">
        <iframe
          src="https://www.youtube-nocookie.com/embed/s6XWkHzuJ2g?rel=0&modestbranding=1&playsinline=1"
          title="Safety video"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          allowfullscreen
          referrerpolicy="strict-origin-when-cross-origin"
        ></iframe>
      </div>
    </div>

    <form id="staff-incident-report" class="ts-staff-report-card" action="/incidents/access-code" method="POST">
      <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
      <div>
        <span>Staff incident reporting</span>
        <strong>Have a work-area code?</strong>
        <small>Report an incident, near miss, or hazard without creating an account.</small>
      </div>
      <label class="visually-hidden" for="incidentAccessCode">Work-area incident code</label>
      <input id="incidentAccessCode" name="incidentAccessCode" type="text" placeholder="Enter code e.g. TS-ABC123" required autocomplete="off" />
      <button type="submit">Report Now</button>
    </form>

    <div class="ts-floating-note ts-note-left">
      <span>Daily Safety Talks</span>
      Instant Topic Briefs Derived From Real Site Hazards
    </div>

    <div class="ts-floating-note ts-note-right">
      <span>Valuable Insights</span>
      Uncover Deep Predictive Trends Humans Overlook
    </div>

    <footer class="ts-legal-links" aria-label="Legal links">
      <button type="button" class="ts-legal-trigger" data-legal-target="privacy">Privacy Notice</button>
      <button type="button" class="ts-legal-trigger" data-legal-target="terms">Terms &amp; Privacy</button>
      <button type="button" class="ts-legal-trigger" data-legal-target="disclosures">Compliance Disclosures</button>
    </footer>
  </section>

  <!-- ONBOARDING/HOW IT WORKS SCREEN -->
  <section class="ts-screen ts-screen-onboarding" id="onboarding" aria-labelledby="onboarding-title">
    <div class="ts-orb ts-orb-four"></div>
    <div class="ts-orb ts-orb-five"></div>

    <nav class="ts-topbar" aria-label="Onboarding navigation">
      <a class="ts-mini-brand" href="/" aria-label="TrueSafe365 home">
        <span class="ts-mark"><i class="bi bi-shield-check"></i></span>
        <span>TrueSafe365</span>
      </a>

      <button class="ts-menu-toggle" type="button" data-menu-toggle aria-label="Open navigation">
        <i class="bi bi-list"></i>
      </button>

      <div class="ts-nav-links" data-mobile-menu>
        <a href="/">Home</a>
        <a class="ts-incident-nav" href="/#staff-incident-report">Incident</a>
        <% if (user) { %>
          <a href="/dashboard/officer">Dashboard</a>
          <a href="/api/users/logout">Sign out</a>
        <% } else { %>
          <a href="/api/users/login">Sign in</a>
          <a href="/register/safety-officer">Register</a>
        <% } %>
      </div>
    </nav>

    <div class="ts-onboarding-wrap">
      <div class="ts-onboarding-intro">
        <p class="ts-eyebrow">The Predictive Safety Blueprint</p>
        <h2 id="onboarding-title">
          Human intuition gathers data. AI generates daily briefs. You protect the site. <span aria-hidden="true">📊</span>
        </h2>
      </div>

      <div class="ts-path-panel" aria-label="TrueSafe365 system operational steps">
        <a class="ts-path-action" href="/register/safety-officer">
          Deploy Your Shield Now
          <i class="bi bi-arrow-up-right"></i>
        </a>

        <ol class="ts-path-list">
          <li>
            <span>01</span>
            <div>
              <strong>Secure Your Officer Command Portal</strong>
              <p>Create your exclusive Safety Officer profile. You have absolute standalone control over your projects, workspace parameters, and data logs with zero corporate friction.</p>
            </div>
          </li>

          <li>
            <span>02</span>
            <div>
              <strong>Map Active Environments &amp; Equipment</strong>
              <p>Define your specific dynamic operating locations and assets—such as excavation sectors, high-voltage spaces, or processing facilities where environmental risks change by the hour.</p>
            </div>
          </li>

          <li>
            <span>03</span>
            <div>
              <strong>Feed Continuous Raw Incident Data</strong>
              <p>Dump real-time field information directly into your terminal—including verbal worker updates, minor slips, near-miss entries, or messy site WhatsApp logs. Nothing gets lost.</p>
            </div>
          </li>

          <li>
            <span>04</span>
            <div>
              <strong>Extract High-Value Safety Insights</strong>
              <p>The AI runs advanced cross-pattern processing over historical logs, flagging escalating risk combinations and surfacing valuable, predictive behavioral insights before an incident can manifest.</p>
            </div>
          </li>

          <li>
            <span>05</span>
            <div>
              <strong>Generate Contextual Daily Safety Talks</strong>
              <p>No more generic templates. Instantly generate highly relevant, custom daily safety talk topics engineered around your site’s real-time raw data to keep your team actively engaged and safer.</p>
            </div>
          </li>

          <li>
            <span>06</span>
            <div>
              <strong>Human Sign-Off: Edit, Approve &amp; Deploy</strong>
              <p>You are the ultimate authority. Tweak, edit, or append the generated insights and risk parameters right on your screen to match localized requirements, then export clean, editable documents.</p>
            </div>
          </li>
        </ol>
      </div>
    </div>
  </section>
</main>

<!-- LEGAL MODALS OVERLAYS -->
<div class="ts-modal-overlay" id="legal-modal" aria-hidden="true">
  <div class="ts-modal-container">
    <button type="button" class="ts-modal-close" id="close-modal-btn" aria-label="Close document panel">
      <i class="bi bi-x-lg"></i>
    </button>
    <div class="ts-modal-body" id="modal-content-area">
      <!-- Injected Document content populated via JS -->
    </div>
  </div>
</div>

<style>
  :root {
    --ts-ink: #0f172a;
    --ts-muted: #475569;
    --ts-surface: rgba(255, 255, 255, 0.74);
    --ts-line: rgba(225, 29, 72, 0.15);
    --ts-blue: #1d4ed8;
    --ts-green: #047857;
    --ts-orange: #d97706;
    --ts-red: #dc2626;
    --ts-red-dark: #991b1b;
    --ts-clinical: #fef2f2;
    --ts-shadow: 0 28px 80px rgba(220, 38, 38, 0.1);
  }

  body {
    background: #fffcfc;
    overflow-x: hidden;
  }

  .truesafe365-landing {
    color: var(--ts-ink);
    font-family: "Plus Jakarta Sans", "Inter", system-ui, sans-serif;
    min-height: 100vh;
  }

  .ts-screen {
    display: none;
    isolation: isolate;
    min-height: 100vh;
    overflow: hidden;
    padding: clamp(1.2rem, 3vw, 2rem);
    position: relative;
  }

  .ts-screen.is-active {
    animation: tsScreenIn 0.55s ease both;
    display: block;
  }

  .ts-screen-hero {
    background:
      radial-gradient(circle at 16% 18%, rgba(220, 38, 38, 0.12), transparent 27rem),
      radial-gradient(circle at 82% 22%, rgba(255, 255, 255, 0.95), transparent 30rem),
      linear-gradient(135deg, #ffffff 0%, #fff5f5 48%, #f8faff 100%);
  }

  .ts-screen-onboarding {
    background:
      radial-gradient(circle at 12% 12%, rgba(220, 38, 38, 0.12), transparent 22rem),
      radial-gradient(circle at 90% 20%, rgba(255, 255, 255, 0.9), transparent 24rem),
      linear-gradient(135deg, #fff 0%, #fff8f8 100%);
  }

  .ts-topbar {
    align-items: center;
    display: flex;
    justify-content: space-between;
    margin: 0 auto;
    max-width: 1180px;
    position: relative;
    z-index: 20;
  }

  .ts-mini-brand,
  .ts-nav-links a {
    align-items: center;
    color: var(--ts-ink);
    display: inline-flex;
    font-weight: 800;
    gap: 0.55rem;
    text-decoration: none;
  }

  .ts-nav-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    justify-content: flex-end;
  }

  .ts-mark {
    align-items: center;
    background: #fff;
    border: 1px solid var(--ts-line);
    border-radius: 1rem;
    box-shadow: 0 12px 34px rgba(220, 38, 38, 0.1);
    color: var(--ts-red);
    display: inline-flex;
    height: 2.7rem;
    justify-content: center;
    width: 2.7rem;
    font-size: 1.3rem;
  }

  .ts-nav-links a {
    background: rgba(255, 255, 255, 0.75);
    border: 1px solid var(--ts-line);
    border-radius: 999px;
    box-shadow: 0 10px 30px rgba(23, 32, 51, 0.05);
    padding: 0.8rem 1.4rem;
    font-size: 0.95rem;
    font-weight: 700;
    transition: all 0.2s ease;
  }


  .ts-nav-links a.ts-incident-nav {
    background: linear-gradient(135deg, var(--ts-red), var(--ts-red-dark));
    border-color: rgba(220, 38, 38, 0.38);
    color: #fff;
    box-shadow: 0 12px 28px rgba(220, 38, 38, 0.2);
  }
  .ts-nav-links a.ts-incident-nav:hover {
    background: var(--ts-red-dark);
    border-color: var(--ts-red-dark);
    color: #fff;
  }
  .ts-nav-links a:hover {
    background: var(--ts-red);
    color: #fff;
    border-color: var(--ts-red);
  }

  .ts-menu-toggle {
    align-items: center;
    background: #fff;
    border: 1px solid var(--ts-line);
    border-radius: 0.9rem;
    box-shadow: 0 10px 30px rgba(23, 32, 51, 0.08);
    color: var(--ts-red);
    cursor: pointer;
    display: none;
    font-size: 1.7rem;
    height: 2.8rem;
    justify-content: center;
    width: 2.8rem;
  }

  .ts-hero-center {
    align-items: center;
    display: flex;
    flex-direction: column;
    margin: clamp(4rem, 10vh, 7rem) auto 0;
    max-width: 1050px;
    min-height: 52vh;
    position: relative;
    text-align: center;
    z-index: 2;
  }

  .ts-eyebrow {
    background: #fff0f0;
    border: 1px solid rgba(220, 38, 38, 0.2);
    border-radius: 999px;
    box-shadow: 0 14px 40px rgba(220, 38, 38, 0.06);
    color: var(--ts-red-dark);
    display: inline-flex;
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    margin-bottom: 1.5rem;
    padding: 0.62rem 1.2rem;
    text-transform: uppercase;
  }

  .ts-hero-center h1 {
    font-family: "Space Grotesk", "Plus Jakarta Sans", sans-serif;
    font-size: clamp(2.3rem, 7.5vw, 5.5rem);
    font-weight: 800;
    letter-spacing: -0.05em;
    line-height: 1.05;
    margin: 0;
    padding-right: 0.1em;
    text-wrap: balance;
  }

  .ts-hero-copy {
    color: var(--ts-muted);
    font-size: clamp(1.05rem, 1.8vw, 1.35rem);
    line-height: 1.6;
    margin: 2rem auto 2.2rem;
    max-width: 820px;
  }

  .ts-primary-action {
    align-items: center;
    background: var(--ts-red);
    border: 0;
    border-radius: 999px;
    box-shadow: 0 18px 45px rgba(220, 38, 38, 0.25);
    color: #fff;
    display: inline-flex;
    font-size: 1.1rem;
    font-weight: 800;
    gap: 0.4rem;
    padding: 1.1rem 1.7rem 1.1rem 2rem;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .ts-primary-action:hover {
    box-shadow: 0 24px 60px rgba(220, 38, 38, 0.35);
    transform: translateY(-3px);
    background: var(--ts-red-dark);
  }

  .ts-primary-action i {
    font-size: 1.6rem;
  }

  .ts-orb {
    border-radius: 999px;
    filter: blur(2px);
    opacity: 0.85;
    position: absolute;
    z-index: 0;
  }

  .ts-orb-one {
    animation: tsFloat 8s ease-in-out infinite;
    background: #ffe4e6;
    height: 12rem;
    left: 6%;
    top: 20%;
    width: 12rem;
  }

  .ts-orb-two {
    animation: tsFloat 10s ease-in-out infinite reverse;
    background: #ffffff;
    height: 16rem;
    right: 8%;
    top: 15%;
    width: 16rem;
  }

  .ts-orb-three {
    animation: tsFloat 12s ease-in-out infinite;
    background: #fee2e2;
    bottom: 8%;
    height: 18rem;
    left: 28%;
    width: 18rem;
  }

  .ts-orb-four {
    background: #fee2e2;
    height: 22rem;
    left: -8rem;
    top: 12rem;
    width: 22rem;
  }

  .ts-orb-five {
    background: #ffedd5;
    bottom: -7rem;
    right: -7rem;
    height: 24rem;
    width: 24rem;
  }

  .ts-floating-note {
    backdrop-filter: blur(18px);
    background: rgba(255, 255, 255, 0.75);
    border: 1px solid rgba(220, 38, 38, 0.2);
    border-radius: 1.5rem;
    box-shadow: var(--ts-shadow);
    color: var(--ts-ink);
    font-weight: 700;
    max-width: 260px;
    padding: 1.1rem 1.3rem;
    position: absolute;
    z-index: 2;
    font-size: 0.95rem;
  }

  .ts-floating-note span {
    color: var(--ts-red);
    display: block;
    font-family: "Space Grotesk", sans-serif;
    font-size: 1.4rem;
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: 0.25rem;
  }

  .ts-note-left {
    bottom: 18%;
    left: 5%;
    transform: rotate(-3deg);
  }

  .ts-note-right {
    right: 5%;
    top: 42%;
    transform: rotate(3deg);
  }

  .ts-staff-report-card {
    align-items: stretch;
    background: rgba(255, 255, 255, 0.88);
    border: 1px solid rgba(220, 38, 38, 0.18);
    border-radius: 28px;
    box-shadow: 0 22px 60px rgba(190, 18, 60, 0.12);
    display: grid;
    gap: 0.85rem;
    grid-template-columns: minmax(0, 1.15fr) minmax(180px, 0.75fr) auto;
    margin: 1.5rem auto 0;
    max-width: 780px;
    padding: 0.9rem;
    position: relative;
    scroll-margin-top: 7rem;
    text-align: left;
    z-index: 30;
  }

  .ts-staff-report-card span {
    color: var(--ts-red-dark);
    display: block;
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .ts-staff-report-card strong {
    display: block;
    font-size: 1rem;
  }

  .ts-staff-report-card small {
    color: var(--ts-muted);
    display: block;
    font-size: 0.78rem;
    line-height: 1.45;
  }

  .ts-staff-report-card input {
    border: 1px solid rgba(148, 163, 184, 0.45);
    border-radius: 999px;
    color: var(--ts-ink);
    font-weight: 800;
    letter-spacing: 0.04em;
    padding: 0.85rem 1rem;
    text-transform: uppercase;
  }

  .ts-staff-report-card button {
    background: linear-gradient(135deg, var(--ts-red), var(--ts-red-dark));
    border: 0;
    border-radius: 999px;
    color: white;
    font-weight: 900;
    padding: 0.85rem 1.2rem;
    white-space: nowrap;
  }
  .ts-home-video {
    background: #fff;
    border: 1px solid var(--ts-line);
    border-radius: 2.2rem;
    box-shadow: 0 30px 90px rgba(220, 38, 38, 0.15);
    margin: clamp(3rem, 8vh, 6rem) auto 3rem;
    max-width: 980px;
    overflow: hidden;
    padding: clamp(0.65rem, 1.8vw, 1rem);
    position: relative;
    z-index: 2;
  }

  .ts-video-frame {
    aspect-ratio: 16 / 9;
    background: #0f172a;
    border-radius: 1.55rem;
    overflow: hidden;
    width: 100%;
  }

  .ts-video-frame iframe {
    border: 0;
    height: 100%;
    width: 100%;
  }

  .ts-legal-links {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: 1.8rem;
    justify-content: center;
    margin: 2rem auto 0;
    max-width: 720px;
    padding: 1rem 0 0.25rem;
    position: relative;
    z-index: 2;
  }

  .ts-legal-trigger {
    background: transparent;
    border: 0;
    color: var(--ts-muted);
    font-size: 0.9rem;
    font-weight: 700;
    padding: 0;
    transition: color 0.2s ease;
  }

  .ts-legal-trigger:hover {
    color: var(--ts-red);
  }

  .ts-onboarding-wrap {
    margin: clamp(3rem, 7vh, 5.5rem) auto 0;
    max-width: 1180px;
    position: relative;
    z-index: 2;
  }

  .ts-onboarding-intro {
    max-width: 820px;
  }

  .ts-onboarding-intro h2 {
    font-family: "Space Grotesk", "Plus Jakarta Sans", sans-serif;
    font-size: clamp(2.1rem, 5.2vw, 4rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1.1;
    margin-bottom: 1.3rem;
  }

  .ts-path-panel {
    background: rgba(255, 255, 255, 0.75);
    border: 1px solid rgba(255, 255, 255, 0.92);
    border-radius: 2rem;
    box-shadow: 0 24px 75px rgba(220, 38, 38, 0.08);
    margin: 2rem 0;
    overflow: hidden;
    padding: clamp(1rem, 3vw, 1.6rem);
    position: relative;
  }

  .ts-path-action {
    align-items: center;
    background: var(--ts-red);
    border-radius: 999px;
    color: #fff;
    display: inline-flex;
    font-weight: 800;
    gap: 0.35rem;
    margin-bottom: 1.5rem;
    padding: 1rem 1.5rem;
    text-decoration: none;
    box-shadow: 0 10px 25px rgba(220, 38, 38, 0.2);
    transition: all 0.2s ease;
  }

  .ts-path-action:hover {
    color: #fff;
    transform: translateY(-2px);
    background: var(--ts-red-dark);
    box-shadow: 0 12px 30px rgba(220, 38, 38, 0.3);
  }

  .ts-path-list {
    display: grid;
    gap: 0.95rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .ts-path-list li {
    align-items: flex-start;
    background: rgba(255, 255, 255, 0.8);
    border: 1px solid rgba(220, 38, 38, 0.08);
    border-radius: 1.35rem;
    display: grid;
    gap: 1.2rem;
    grid-template-columns: auto 1fr;
    padding: 1.2rem;
    transition: all 0.2s ease;
  }

  .ts-path-list li:hover {
    background: #fff;
    box-shadow: 0 16px 44px rgba(220, 38, 38, 0.08);
    transform: translateX(6px);
    border-color: rgba(220, 38, 38, 0.2);
  }

  .ts-path-list span {
    align-items: center;
    background: linear-gradient(135deg, var(--ts-red), var(--ts-red-dark));
    border-radius: 999px;
    color: #fff;
    display: inline-flex;
    font-family: "Space Grotesk", sans-serif;
    font-weight: 700;
    height: 3rem;
    justify-content: center;
    width: 3rem;
  }

  .ts-path-list strong {
    display: block;
    font-family: "Space Grotesk", sans-serif;
    font-size: 1.3rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 0.35rem;
  }

  .ts-path-list p {
    color: var(--ts-muted);
    font-size: 0.98rem;
    line-height: 1.6;
    margin: 0;
  }

  /* MODAL ARCHITECTURE STYLING */
  .ts-modal-overlay {
    align-items: center;
    backdrop-filter: blur(12px);
    background: rgba(15, 23, 42, 0.45);
    display: flex;
    height: 100%;
    justify-content: center;
    left: 0;
    opacity: 0;
    padding: 1.5rem;
    pointer-events: none;
    position: fixed;
    top: 0;
    transition: opacity 0.3s ease;
    width: 100%;
    z-index: 2000;
  }

  .ts-modal-overlay.is-visible {
    opacity: 1;
    pointer-events: auto;
  }

  .ts-modal-container {
    background: #ffffff;
    border: 1px solid rgba(15, 23, 42, 0.08);
    border-radius: 1.8rem;
    box-shadow: 0 35px 90px rgba(15, 23, 42, 0.25);
    max-height: 85vh;
    max-width: 720px;
    overflow-y: auto;
    padding: clamp(1.5rem, 4vw, 3rem);
    position: relative;
    transform: translateY(20px) scale(0.98);
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    width: 100%;
  }

  .ts-modal-overlay.is-visible .ts-modal-container {
    transform: translateY(0) scale(1);
  }

  .ts-modal-close {
    align-items: center;
    background: #f1f5f9;
    border: 0;
    border-radius: 50%;
    color: var(--ts-muted);
    display: inline-flex;
    height: 2.5rem;
    justify-content: center;
    position: absolute;
    right: 1.5rem;
    top: 1.5rem;
    width: 2.5rem;
    transition: background 0.2s;
  }

  .ts-modal-close:hover {
    background: #e2e8f0;
    color: var(--ts-ink);
  }

  .ts-modal-body h3 {
    font-family: "Space Grotesk", sans-serif;
    font-size: 1.8rem;
    font-weight: 800;
    margin-bottom: 1.2rem;
    color: var(--ts-ink);
  }

  .ts-modal-body h4 {
    font-family: "Space Grotesk", sans-serif;
    font-size: 1.15rem;
    font-weight: 700;
    margin-top: 1.6rem;
    margin-bottom: 0.45rem;
  }

  .ts-modal-body p, .ts-modal-body li {
    color: var(--ts-muted);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .ts-modal-body ul {
    padding-left: 1.25rem;
    margin-bottom: 1rem;
  }

  @keyframes tsFloat {
    0%, 100% { transform: translate3d(0, 0, 0) scale(1); }
    50% { transform: translate3d(0, -15px, 0) scale(1.03); }
  }

  @keyframes tsScreenIn {
    from { opacity: 0; transform: translateY(12px) scale(0.995); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }

  @media (max-width: 992px) {
    .ts-floating-note { display: none; }
  }

  @media (max-width: 768px) {
    .ts-menu-toggle { display: inline-flex; }
    .ts-nav-links {
      background: rgba(255, 255, 255, 0.98);
      border: 1px solid var(--ts-line);
      border-radius: 1.2rem;
      box-shadow: 0 24px 70px rgba(220, 38, 38, 0.15);
      display: none;
      flex-direction: column;
      min-width: 220px;
      padding: 0.85rem;
      position: absolute;
      right: 0;
      top: calc(100% + 0.75rem);
      z-index: 999;
    }
    .ts-staff-report-card {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .ts-nav-links.show { display: flex; }
    .ts-nav-links a { justify-content: center; width: 100%; }
  }

  @media (max-width: 640px) {
    .ts-screen { padding: 1rem; }
    .ts-hero-center { margin-top: 3.5rem; min-height: auto; }
    .ts-hero-center h1 { font-size: clamp(2.2rem, 12vw, 3.8rem); letter-spacing: -0.04em; }
    .ts-hero-copy { font-size: 1rem; }
    .ts-onboarding-intro h2 { font-size: clamp(1.9rem, 10vw, 3rem); }
  }

  .swal2-popup.all-safe-medical-alert {
    border-radius: 1.25rem;
    border-top: 5px solid var(--ts-red);
    box-shadow: 0 24px 70px rgba(190, 18, 60, 0.18);
  }

  .swal2-confirm.all-safe-medical-confirm {
    background: linear-gradient(135deg, var(--ts-red), var(--ts-red-dark)) !important;
    border-radius: 999px !important;
    box-shadow: 0 12px 28px rgba(190, 18, 60, 0.2) !important;
    padding-left: 1.4rem !important;
    padding-right: 1.4rem !important;
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const hero = document.querySelector(".ts-screen-hero");
    const onboarding = document.querySelector(".ts-screen-onboarding");
    const goOnboardingButton = document.querySelector("[data-go-onboarding]");


    const incidentJumpLinks = document.querySelectorAll("[data-incident-jump]");
    incidentJumpLinks.forEach((link) => {
      link.addEventListener("click", (event) => {
        const target = document.querySelector("#staff-incident-report");
        if (!target) return;
        event.preventDefault();
        showScreen(hero, "welcome");
        target.scrollIntoView({ behavior: "smooth", block: "center" });
      });
    });

    // Screen navigation logic
    const showScreen = function (screen, hash) {
      hero.classList.remove("is-active");
      onboarding.classList.remove("is-active");
      screen.classList.add("is-active");
      window.history.replaceState(null, "", hash || window.location.pathname);
      window.scrollTo({ top: 0, behavior: "smooth" });
    };

    const showOnboarding = function () { showScreen(onboarding, "#onboarding"); };
    const showHero = function () { showScreen(hero, window.location.pathname); };

    const syncScreenFromHash = function () {
      if (window.location.hash === "#onboarding") {
        showOnboarding();
      } else {
        showHero();
      }
    };

    document.querySelectorAll("[data-menu-toggle]").forEach(function (toggle) {
      toggle.addEventListener("click", function () {
        const nav = toggle.closest(".ts-topbar").querySelector("[data-mobile-menu]");
        nav.classList.toggle("show");
      });
    });

    document.addEventListener("click", function (event) {
      document.querySelectorAll(".ts-topbar").forEach(function (topbar) {
        if (!topbar.contains(event.target)) {
          const nav = topbar.querySelector("[data-mobile-menu]");
          nav?.classList.remove("show");
        }
      });
    });

    syncScreenFromHash();
    goOnboardingButton?.addEventListener("click", showOnboarding);
    window.addEventListener("hashchange", syncScreenFromHash);

    // Dynamic Legal Content Strategy
    const legalDocuments = {
      privacy: `
        <h3>Privacy Notice</h3>
        <p><strong>Effective Date:</strong> June 2026</p>
        <p>At TrueSafe365, we prioritize protecting the operational, spatial, and hazardous trend data handled by safety officers across dynamic environments. This document explains how raw environmental updates, near-miss profiles, and site parameters are managed inside your standalone terminal ecosystem.</p>
        <h4>1. Information Capture & Bounds</h4>
        <p>We process data fields provided voluntarily under your administrative authorization. This includes structural equipment layouts, local operational footprints, custom worker observations, and incident histories. This specific raw material is localized strictly to run predictive cross-pattern risk assessments and compile your dedicated Daily Safety Talks.</p>
        <h4>2. Data Control and Sovereignty</h4>
        <p>TrueSafe365 honors complete human-in-the-loop validation. Your parsed site information, workspace variables, and exported Word materials belong exclusively to your administrative portal dashboard. Data logs are never sold or pooled outside your structural node parameters.</p>
        <h4>3. Structural Security Architecture</h4>
        <p>We leverage industry-grade programmatic protocols and secure session parameters to safeguard tactical infrastructure notes and field profiles against unintended external visibility.</p>
      `,
      terms: `
        <h3>Terms &amp; Privacy</h3>
        <p><strong>Last Updated:</strong> June 2026</p>
        <p>Welcome to TrueSafe365. By establishing your exclusive safety management account portal, tracking dynamic site configurations, or processing real-time workspace entries, you confirm complete adherence to these core operational terms.</p>
        <h4>1. Scope of Safety Automation Assets</h4>
        <p>TrueSafe365 functions strictly as an analytical tool to assist localized safety officers. The platform cross-references raw field feedback to draft Risk Assessments, compliance checklists, and localized safety talk scripts. The final text layouts require ultimate human verification, sign-off, and configuration prior to deployment.</p>
        <h4>2. Account Portal Governance</h4>
        <p>Safety administrators maintain full ownership of workspace settings, verification credentials, and analytical document repositories. Users are strictly responsible for checking generated materials against local compliance standards.</p>
        <h4>3. Limitations of Liability</h4>
        <p>TrueSafe365 acts as a predictive insight generator based exclusively on user-supplied parameter inputs. Operational safety enforcement, protective validation, and site monitoring protocols rest entirely on the supervising entities.</p>
      `,
      disclosures: `
        <h3>Compliance &amp; Disclosures</h3>
        <p>TrueSafe365 operates in strict alignment with regional corporate registrations and standardized workspace oversight guidelines. We remain focused on delivering robust toolsets for self-employed professionals, independent safety auditors, and enterprise field engineers alike.</p>
        <h4>1. Advisory Notice &amp; Human Sign-Off</h4>
        <p>All output text structures—including analytical insight summaries, hazard correlation vectors, and tool topic lists—are designed to augment your safety blueprint. They do not substitute for official on-site safety validation practices.</p>
        <h4>2. Technical and Core Integrity Updates</h4>
        <p>The system baseline and predictive mapping frameworks receive continuous iterations to address dynamic risk environments. For registration records, infrastructure queries, or specific portal support access, contact our technical team via your verified profile dashboard.</p>
      `
    };

    const modalOverlay = document.getElementById("legal-modal");
    const modalContent = document.getElementById("modal-content-area");
    const closeModalBtn = document.getElementById("close-modal-btn");

    document.querySelectorAll("[data-legal-target]").forEach(button => {
      button.addEventListener("click", function() {
        const docKey = this.getAttribute("data-legal-target");
        if(legalDocuments[docKey]) {
          modalContent.innerHTML = legalDocuments[docKey];
          modalOverlay.classList.add("is-visible");
          modalOverlay.setAttribute("aria-hidden", "false");
          document.body.style.overflow = "hidden"; // Prevent background scroll
        }
      });
    });

    const hideModal = function() {
      modalOverlay.classList.remove("is-visible");
      modalOverlay.setAttribute("aria-hidden", "true");
      document.body.style.overflow = "";
    };

    closeModalBtn?.addEventListener("click", hideModal);
    modalOverlay?.addEventListener("click", function(e) {
      if(e.target === modalOverlay) hideModal();
    });
    document.addEventListener("keydown", function(e) {
      if(e.key === "Escape" && modalOverlay.classList.contains("is-visible")) hideModal();
    });
  });
</script>


<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
  <% if (typeof success !== 'undefined' && success.length > 0) { %>
    Swal.fire({
      icon: 'success',
      title: 'Success!',
      text: "<%= success[0] %>",
      timer: 3000,
      showConfirmButton: true,
      customClass: {
        popup: 'all-safe-medical-alert',
        confirmButton: 'all-safe-medical-confirm'
      }
    });
  <% } %>

  <% if (typeof error !== 'undefined' && error.length > 0) { %>
    Swal.fire({
      icon: 'error',
      title: 'Oops!',
      text: "<%= error[0] %>",
      timer: 3000,
      showConfirmButton: true,
      customClass: {
        popup: 'all-safe-medical-alert',
        confirmButton: 'all-safe-medical-confirm'
      }
    });
  <% } %>
</script>
</body>
</html>