<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="main-wrapper">
  <div class="content container py-4">
    <div class="manage-officers-container" style="max-width: 1000px; margin: 0 auto;">
      <!-- Work Area Style Header -->
      <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
        <div>
          <h3 class="mb-1">
            <i class="fas fa-user-cog me-2" style="color: #26a69a;"></i>
            Manage Safety Officers
          </h3>
          <div class="d-flex gap-2">
            <span class="badge text-bg-secondary">
              <i class="fas fa-map-marked-alt me-1"></i> <%= workArea.name %>
            </span>
          </div>
        </div>
        <a href="/work-areas/<%= workArea._id %>" class="btn btn-outline-secondary btn-sm" style="border-radius: 40px;">
          <i class="fas fa-arrow-left me-2"></i>Back to Work Area
        </a>
      </div>

      <!-- Two Column Layout -->
      <div class="row g-4">
        <!-- Currently Assigned -->
        <div class="col-lg-5">
          <div class="card border-0 shadow-sm h-100" style="border-radius: 16px;">
            <div class="card-header bg-transparent border-0 pt-4 px-4">
              <h4 class="fw-bold mb-0" style="color: #26a69a">
                <i class="fas fa-user-check me-2"></i>Currently Assigned
              </h4>
            </div>
            <div class="card-body p-4">
              <% if (workArea.assignedSafetyOfficers && workArea.assignedSafetyOfficers.filter(a => a.isActive !== false).length > 0) { %>
                <div class="list-group">
                  <% workArea.assignedSafetyOfficers.filter(a => a.isActive !== false).forEach(assignment => { %>
                  <div class="list-group-item border-0 bg-light mb-2 rounded-3">
                    <div class="d-flex justify-content-between align-items-center">
                      <div class="d-flex align-items-center">
                        <div class="rounded-circle d-flex align-items-center justify-content-center me-2" 
                             style="background: linear-gradient(135deg, #26a69a 0%, #00897b 100%); width: 35px; height: 35px;">
                          <i class="fas fa-user-tie text-white" style="font-size: 0.9rem;"></i>
                        </div>
                        <div>
                          <h6 class="fw-bold mb-1"><%= assignment.officer?.name || 'Unknown' %></h6>
                          <div class="d-flex gap-2 align-items-center">
                            <span class="badge" style="background: #26a69a; color: white; border-radius: 40px;">
                              <i class="fas fa-clock me-1"></i> <%= assignment.shift || 'Not set' %>
                            </span>
                            <% if (assignment.isPrimary) { %>
                            <span class="badge" style="background: #ffc107; color: #212529; border-radius: 40px;">
                              <i class="fas fa-crown me-1"></i> Primary
                            </span>
                            <% } %>
                          </div>
                        </div>
                      </div>
                      <button class="btn btn-sm btn-outline-danger remove-officer" data-assignment-id="<%= assignment._id %>" style="border-radius: 40px;">
                        <i class="fas fa-times"></i>
                      </button>
                    </div>
                  </div>
                  <% }) %>
                </div>
              <% } else { %>
                <div class="text-center py-5">
                  <i class="fas fa-user-slash fa-3x text-muted mb-3"></i>
                  <p class="text-muted">No safety officers assigned yet</p>
                </div>
              <% } %>
            </div>
          </div>
        </div>

        <!-- Assignment Form -->
        <div class="col-lg-7">
          <div class="card border-0 shadow-sm" style="border-radius: 16px;">
            <div class="card-header bg-transparent border-0 pt-4 px-4">
              <h4 class="fw-bold mb-0" style="color: #26a69a">
                <i class="fas fa-user-plus me-2"></i>Assign New Officer
              </h4>
            </div>
            <div class="card-body p-4">
              <form id="assignOfficerForm">
                <div class="row g-4">
                  <div class="col-md-7">
                    <label class="form-label fw-semibold">Select Officer</label>
                    <select class="form-select" id="officerSelect" required style="border-radius: 40px; padding: 0.5rem 1rem;">
                      <option value="">Choose officer...</option>
                      <% availableOfficers.forEach(officer => { %>
                      <option value="<%= officer._id %>"><%= officer.name %> (<%= officer.officerNumber %>)</option>
                      <% }) %>
                    </select>
                  </div>
                  <div class="col-md-5">
                    <label class="form-label fw-semibold">Shift</label>
                    <select class="form-select" id="shiftSelect" required style="border-radius: 40px; padding: 0.5rem 1rem;">
                      <option value="morning">Morning</option>
                      <option value="afternoon">Afternoon</option>
                      <option value="night">Night</option>
                    </select>
                  </div>
                  <div class="col-12">
                    <div class="form-check">
                      <input class="form-check-input" type="checkbox" id="isPrimaryCheck" style="border-radius: 4px;">
                      <label class="form-check-label" for="isPrimaryCheck">
                        Set as Primary Officer for this shift
                      </label>
                    </div>
                  </div>
                  <div class="col-12">
                    <button type="submit" class="btn w-100 py-2" style="background: #26a69a; color: white; border: none; border-radius: 40px;">
                      <i class="fas fa-user-plus me-2"></i>Assign Officer
                    </button>
                  </div>
                </div>
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- SweetAlert2 -->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const workAreaId = '<%= workArea._id %>';

  // Handle assign officer
  document.getElementById('assignOfficerForm').addEventListener('submit', function(e) {
    e.preventDefault();
    
    const officerId = document.getElementById('officerSelect').value;
    const shift = document.getElementById('shiftSelect').value;
    const isPrimary = document.getElementById('isPrimaryCheck').checked;

    if (!officerId) {
      Swal.fire({
        icon: 'warning',
        title: 'No Officer Selected',
        text: 'Please select an officer to assign',
        confirmButtonColor: '#26a69a',
        confirmButtonText: 'OK'
      });
      return;
    }

    fetch(`/work-areas/${workAreaId}/assign-officer`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ officerId, shift, isPrimary })
    })
    .then(res => res.json())
    .then(data => {
      if (data.success) {
        Swal.fire({
          icon: 'success',
          title: 'Success!',
          text: 'Officer assigned successfully',
          confirmButtonColor: '#26a69a',
          timer: 1500,
          showConfirmButton: false
        }).then(() => {
          window.location.reload();
        });
      } else {
        Swal.fire({
          icon: 'error',
          title: 'Error',
          text: data.message || 'Failed to assign officer',
          confirmButtonColor: '#26a69a'
        });
      }
    })
    .catch(err => {
      console.error('Error assigning officer:', err);
      Swal.fire({
        icon: 'error',
        title: 'Error',
        text: 'An unexpected error occurred',
        confirmButtonColor: '#26a69a'
      });
    });
  });

  // Handle remove officer
  document.querySelectorAll('.remove-officer').forEach(btn => {
    btn.addEventListener('click', function() {
      const assignmentId = this.dataset.assignmentId;
      
      Swal.fire({
        title: 'Remove Officer?',
        text: 'Are you sure you want to remove this officer from the work area?',
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#f44336',
        cancelButtonColor: '#6c757d',
        confirmButtonText: 'Yes, remove',
        cancelButtonText: 'Cancel'
      }).then((result) => {
        if (result.isConfirmed) {
          fetch(`/work-areas/${workAreaId}/assignments/${assignmentId}`, {
            method: 'DELETE'
          })
          .then(res => res.json())
          .then(data => {
            if (data.success) {
              Swal.fire({
                icon: 'success',
                title: 'Removed!',
                text: 'Officer has been removed',
                confirmButtonColor: '#26a69a',
                timer: 1500,
                showConfirmButton: false
              }).then(() => {
                window.location.reload();
              });
            } else {
              Swal.fire({
                icon: 'error',
                title: 'Error',
                text: data.message || 'Failed to remove officer',
                confirmButtonColor: '#26a69a'
              });
            }
          })
          .catch(err => {
            console.error('Error removing officer:', err);
            Swal.fire({
              icon: 'error',
              title: 'Error',
              text: 'An unexpected error occurred',
              confirmButtonColor: '#26a69a'
            });
          });
        }
      });
    });
  });
});
</script>

<style>
  .main-wrapper {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }
  
  .content {
    flex: 1;
  }

  .card {
    border-radius: 16px;
  }
  
  .badge {
    font-weight: 500;
    font-size: 0.75rem;
    padding: 0.3rem 0.6rem;
  }
  
  .btn {
    transition: all 0.2s ease;
  }
  
  .btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
  }
  
  .form-select {
    border: 1px solid #dee2e6;
    transition: border-color 0.2s ease;
  }
  
  .form-select:focus {
    border-color: #26a69a;
    box-shadow: 0 0 0 0.2rem rgba(38, 166, 154, 0.25);
  }
  
  .form-check-input:checked {
    background-color: #26a69a;
    border-color: #26a69a;
  }
  
  .list-group-item {
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  
  .list-group-item:hover {
    transform: translateX(5px);
    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05);
  }
  
  .btn-outline-danger {
    border-color: #f44336;
    color: #f44336;
  }
  .btn-outline-danger:hover {
    background-color: #f44336;
    color: white;
  }
  
  .btn-outline-secondary {
    border-color: #6c757d;
    color: #6c757d;
  }
  .btn-outline-secondary:hover {
    background-color: #6c757d;
    color: white;
  }
</style>

<%- include('../partials/footer') %>