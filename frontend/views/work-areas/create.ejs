<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<%
  const controls = [
    ['barricades_installed', 'Barricades installed'],
    ['warning_signs_placed', 'Warning signs placed'],
    ['ppe_issued', 'PPE issued'],
    ['toolbox_talk_done', 'Toolbox talk done'],
    ['equipment_inspected', 'Equipment inspected'],
    ['supervisor_assigned', 'Supervisor assigned'],
    ['permit_issued', 'Permit issued'],
    ['fire_extinguisher_placed', 'Fire extinguisher placed'],
    ['first_aider_nearby', 'First aider nearby'],
    ['area_isolated', 'Area isolated'],
    ['lockout_tagout_done', 'Lockout/tagout done'],
    ['ventilation_provided', 'Ventilation provided'],
    ['dust_suppression_used', 'Dust suppression used'],
  ];

  const hazards = [
    ['fire_risk', 'Fire risk'],
    ['smoke_inhalation', 'Smoke inhalation'],
    ['dust_exposure', 'Dust exposure'],
    ['chemical_exposure', 'Chemical exposure'],
    ['biological_infection', 'Biological infection'],
    ['electricity_high_voltage', 'Electricity or high voltage'],
    ['radiation', 'Radiation'],
    ['noise', 'Noise'],
    ['vibration', 'Vibration'],
    ['heat_stress', 'Heat stress'],
    ['working_at_height', 'Working at height'],
    ['excavation', 'Excavation'],
    ['confined_space', 'Confined space'],
    ['lifting_operations', 'Lifting operations'],
    ['moving_machinery', 'Moving machinery'],
    ['vehicles_mobile_equipment', 'Vehicles/mobile equipment'],
    ['falling_objects', 'Falling objects'],
    ['slips_trips_falls', 'Slips, trips, and falls'],
    ['manual_handling', 'Manual handling'],
    ['poor_lighting', 'Poor lighting'],
    ['weather_exposure', 'Weather exposure'],
    ['water_flooding', 'Water/flooding'],
    ['explosive_flammable_substances', 'Explosive or flammable substances'],
  ];

  const ppeOptions = [
    ['hard_hat', 'Hard hats'],
    ['steel_toe_boots', 'Safety boots'],
    ['gloves', 'Gloves'],
    ['safety_glasses', 'Safety glasses/goggles'],
    ['face_shield', 'Face shield'],
    ['respirator', 'Respirator/mask'],
    ['ear_plugs', 'Ear plugs'],
    ['ear_muffs', 'Ear muffs'],
    ['high_vis_vest', 'High visibility clothing'],
    ['fall_arrest', 'Fall arrest harness'],
    ['welding_helmet', 'Welding helmet'],
    ['chemical_suit', 'Chemical apron/suit'],
    ['life_jacket', 'Life jacket'],
    ['dust_mask', 'Dust mask'],
    ['heat_resistant_ppe', 'Heat-resistant PPE'],
  ];

  const documents = [
    ['safety_talk', 'Safety Talk'],
    ['risk_assessment', 'Risk Assessment'],
    ['job_safety_analysis', 'Job Safety Analysis'],
    ['incident_report', 'Incident Report'],
    ['near_miss_report', 'Near-Miss Report'],
    ['ppe_checklist', 'PPE Checklist'],
    ['emergency_response_plan', 'Emergency Response Plan'],
    ['training_requirement', 'Training Requirement'],
    ['permit_to_work_guidance', 'Permit-to-Work Guidance'],
    ['chemical_material_safety_handling_guide', 'Chemical / Material Safety Handling Guide'],
    ['environmental_risk_assessment', 'Environmental Risk Assessment'],
    ['ohs_compliance_audit', 'OHS Compliance Audit'],
  ];
%>

<div class="container-fluid py-4 work-area-create">
  <div class="row justify-content-center">
    <div class="col-12 col-lg-8">
      <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-end gap-3 mb-4">
        <div>
          <p class="text-uppercase text-muted fw-semibold small mb-1">Safety officer intake</p>
          <h1 class="h3 fw-bold mb-1" style="color: #1e3c5c;">Create Work Area</h1>
          <p class="text-muted mb-0">Capture the facts TrueSafe365 needs to prepare useful safety documents.</p>
        </div>
      </div>

      <form action="/work-areas/create" method="POST" id="workAreaForm" data-autosave="work-area-create">
        <div class="wizard-panel mb-3" aria-label="Work area creation steps">
          <div class="d-flex justify-content-between align-items-center gap-3 mb-3">
            <span class="fw-semibold text-muted" id="wizardStepLabel">Step 1 of 11</span>
            <span class="fw-semibold" id="wizardSectionLabel" style="color: #1e3c5c;">Work Area Basics</span>
          </div>
          <div class="step-strip" id="wizardStepStrip" aria-label="Numbered form steps">
            <button type="button" class="step-dot is-active" data-step-index="0" aria-label="Step 1">1</button>
            <button type="button" class="step-dot" data-step-index="1" aria-label="Step 2">2</button>
            <button type="button" class="step-dot" data-step-index="2" aria-label="Step 3">3</button>
            <button type="button" class="step-dot" data-step-index="3" aria-label="Step 4">4</button>
            <button type="button" class="step-dot" data-step-index="4" aria-label="Step 5">5</button>
            <button type="button" class="step-dot" data-step-index="5" aria-label="Step 6">6</button>
            <button type="button" class="step-dot" data-step-index="6" aria-label="Step 7">7</button>
            <button type="button" class="step-dot" data-step-index="7" aria-label="Step 8">8</button>
            <button type="button" class="step-dot" data-step-index="8" aria-label="Step 9">9</button>
            <button type="button" class="step-dot" data-step-index="9" aria-label="Step 10">10</button>
            <button type="button" class="step-dot" data-step-index="10" aria-label="Step 11">11</button>
          </div>
        </div>

        <section class="intake-section wizard-step" data-step-title="Work Area Basics">
          <div class="section-heading">
            <span>1</span>
            <div>
              <h2>Work Area Basics</h2>
              <p>Work area name and location are optional. You may use a simple reference such as "Kitwe" or "Workshop area" instead of the exact site name or precise location. If you leave them blank, TrueSafe365 will create a default reference for you.</p>
            </div>
          </div>

          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label fw-semibold" for="name">Work area name</label>
              <input class="form-control" id="name" name="name" type="text" placeholder="Optional">
              <small class="text-muted">Any memorable name is fine. It does not need to be the official or exact site name.</small>
            </div>
            <div class="col-md-6">
              <label class="form-label fw-semibold" for="location">Location</label>
              <input class="form-control" id="location" name="location" type="text" placeholder="Optional, e.g., Kitwe">
              <small class="text-muted">A town or general area is enough. The precise location can be added manually in the final document.</small>
            </div>
            <div class="col-md-6">
              <label class="form-label fw-semibold" for="mainActivity">Main activity or job being done</label>
              <input class="form-control" id="mainActivity" name="mainActivity" type="text" required placeholder="e.g., Excavation, welding, lifting, cleaning">
            </div>
            <div class="col-md-3">
              <label class="form-label fw-semibold" for="plannedStart">Expected start date</label>
              <input class="form-control" id="plannedStart" name="plannedStart" type="date">
            </div>
            <div class="col-md-3">
              <label class="form-label fw-semibold" for="plannedEnd">Expected end date</label>
              <input class="form-control" id="plannedEnd" name="plannedEnd" type="date">
            </div>
            <div class="col-md-6">
              <label class="form-label fw-semibold" for="shiftOrWorkingTime">Shift or working time</label>
              <input class="form-control" id="shiftOrWorkingTime" name="shiftOrWorkingTime" type="text" placeholder="e.g., 07:00 - 17:00, night shift">
            </div>
            <div class="col-md-6">
              <label class="form-label fw-semibold" for="numberOfPeopleInvolved">Number of people involved</label>
              <input class="form-control" id="numberOfPeopleInvolved" name="numberOfPeopleInvolved" type="number" min="0">
            </div>
            <div class="col-12">
              <label class="form-label fw-semibold" for="description">Short description of the work</label>
              <textarea class="form-control" id="description" name="description" rows="3" placeholder="Describe what will be done, where the work starts and ends, and anything unusual about the job."></textarea>
            </div>
            <div class="col-12">
              <label class="form-label fw-semibold">Type of workers involved</label>
              <div class="option-grid">
                <label class="check-tile"><input type="checkbox" name="workerEmployees"> Employees</label>
                <label class="check-tile"><input type="checkbox" name="workerContractors"> Contractors</label>
                <label class="check-tile"><input type="checkbox" name="workerVisitors"> Visitors</label>
                <label class="check-tile"><input type="checkbox" name="workerPublicNearby"> Public nearby</label>
              </div>
            </div>
          </div>
        </section>

        <section class="intake-section wizard-step" data-step-title="Personal Risks">
          <div class="section-heading">
            <span>2</span>
            <div>
              <h2>What Risks Have You Personally Identified?</h2>
              <p>Write what you have seen, heard from workers, or collected from WhatsApp/verbal reports.</p>
            </div>
          </div>
          <div class="row g-3">
            <div class="col-md-6"><label class="form-label fw-semibold" for="riskPeople">Risk to people</label><textarea class="form-control" id="riskPeople" name="riskPeople" rows="3"></textarea></div>
            <div class="col-md-6"><label class="form-label fw-semibold" for="riskEquipment">Risk to equipment</label><textarea class="form-control" id="riskEquipment" name="riskEquipment" rows="3"></textarea></div>
            <div class="col-md-6"><label class="form-label fw-semibold" for="riskEnvironment">Risk to environment</label><textarea class="form-control" id="riskEnvironment" name="riskEnvironment" rows="3"></textarea></div>
            <div class="col-md-6"><label class="form-label fw-semibold" for="riskNearbyWorkersPublic">Risk to nearby workers/public</label><textarea class="form-control" id="riskNearbyWorkersPublic" name="riskNearbyWorkersPublic" rows="3"></textarea></div>
            <div class="col-md-6"><label class="form-label fw-semibold" for="riskPropertyMaterials">Risk to property/materials</label><textarea class="form-control" id="riskPropertyMaterials" name="riskPropertyMaterials" rows="3"></textarea></div>
            <div class="col-md-6"><label class="form-label fw-semibold" for="riskOperationsProduction">Risk to operations or production</label><textarea class="form-control" id="riskOperationsProduction" name="riskOperationsProduction" rows="3"></textarea></div>
          </div>
        </section>

        <section class="intake-section wizard-step" data-step-title="Controls Taken">
          <div class="section-heading">
            <span>3</span>
            <div>
              <h2>What Measures Have You Already Taken?</h2>
              <p>Select the controls already in place and add anything specific the AI should know.</p>
            </div>
          </div>
          <div class="option-grid">
            <% controls.forEach(([value, label]) => { %>
              <label class="check-tile"><input type="checkbox" name="existingControls" value="<%= value %>"> <%= label %></label>
            <% }) %>
          </div>
          <label class="form-label fw-semibold mt-3" for="existingControlsNotes">Control notes</label>
          <textarea class="form-control" id="existingControlsNotes" name="existingControlsNotes" rows="3" placeholder="Explain what has been done, where it is placed, who checked it, and any gaps still open."></textarea>
        </section>

        <section class="intake-section wizard-step" data-step-title="Emergency Preparedness">
          <div class="section-heading">
            <span>4</span>
            <div>
              <h2>Emergency Preparedness</h2>
              <p>Record what is ready to protect people, equipment, and lives if something goes wrong.</p>
            </div>
          </div>
          <div class="row g-3">
            <div class="col-md-6"><label class="form-label fw-semibold" for="emergencyContactPerson">Emergency contact person</label><input class="form-control" id="emergencyContactPerson" name="emergencyContactPerson" type="text"></div>
            <div class="col-md-6"><label class="form-label fw-semibold" for="nearestClinicHospital">Nearest clinic/hospital</label><input class="form-control" id="nearestClinicHospital" name="nearestClinicHospital" type="text"></div>
            <div class="col-md-6"><label class="form-label fw-semibold" for="healthFacilityDistanceTime">Distance or travel time to health facility</label><input class="form-control" id="healthFacilityDistanceTime" name="healthFacilityDistanceTime" type="text"></div>
            <div class="col-md-6"><label class="form-label fw-semibold" for="trainedFirstAiders">Number of trained first aiders</label><input class="form-control" id="trainedFirstAiders" name="trainedFirstAiders" type="number" min="0"></div>
            <div class="col-md-6"><label class="form-label fw-semibold" for="emergencyExitRoutes">Emergency exit routes</label><input class="form-control" id="emergencyExitRoutes" name="emergencyExitRoutes" type="text"></div>
            <div class="col-md-6"><label class="form-label fw-semibold" for="assemblyPoint">Assembly point</label><input class="form-control" id="assemblyPoint" name="assemblyPoint" type="text"></div>
            <div class="col-md-6"><label class="form-label fw-semibold" for="rescueEquipment">Rescue equipment</label><input class="form-control" id="rescueEquipment" name="rescueEquipment" type="text"></div>
            <div class="col-md-6">
              <label class="form-label fw-semibold">Communication method</label>
              <div class="option-grid compact">
                <label class="check-tile"><input type="checkbox" name="communicationMethods" value="phone"> Phone</label>
                <label class="check-tile"><input type="checkbox" name="communicationMethods" value="radio"> Radio</label>
                <label class="check-tile"><input type="checkbox" name="communicationMethods" value="whatsapp"> WhatsApp</label>
              </div>
            </div>
            <div class="col-12">
              <div class="option-grid">
                <label class="check-tile"><input type="checkbox" name="ambulanceAvailable"> Ambulance availability confirmed</label>
                <label class="check-tile"><input type="checkbox" name="firstAidBoxAvailable"> First aid box available</label>
                <label class="check-tile"><input type="checkbox" name="fireExtinguishersAvailable"> Fire extinguishers available</label>
                <label class="check-tile"><input type="checkbox" name="evacuationPlan"> Evacuation plan available</label>
                <label class="check-tile"><input type="checkbox" name="spillKitAvailable"> Spill kit available</label>
                <label class="check-tile"><input type="checkbox" name="emergencyShowerEyewashAvailable"> Emergency shower/eye wash available</label>
              </div>
            </div>
            <div class="col-12"><label class="form-label fw-semibold" for="emergencyPreparednessNotes">Emergency notes</label><textarea class="form-control" id="emergencyPreparednessNotes" name="emergencyPreparednessNotes" rows="3"></textarea></div>
          </div>
        </section>

        <section class="intake-section wizard-step" data-step-title="People Exposure">
          <div class="section-heading">
            <span>5</span>
            <div>
              <h2>People Exposure</h2>
              <p>Show who may be exposed and whether supervision or extra protection is needed.</p>
            </div>
          </div>
          <div class="row g-3">
            <div class="col-md-6"><label class="form-label fw-semibold" for="workersInArea">How many people will work in this area?</label><input class="form-control" id="workersInArea" name="workersInArea" type="number" min="0"></div>
            <div class="col-md-6"><label class="form-label fw-semibold" for="peoplePassingNearby">How many may pass nearby?</label><input class="form-control" id="peoplePassingNearby" name="peoplePassingNearby" type="number" min="0"></div>
            <div class="col-12">
              <div class="option-grid">
                <label class="check-tile"><input type="checkbox" name="inexperiencedWorkers"> Inexperienced workers involved</label>
                <label class="check-tile"><input type="checkbox" name="contractorsInvolved"> Contractors involved</label>
                <label class="check-tile"><input type="checkbox" name="workingAlone"> Workers working alone</label>
                <label class="check-tile"><input type="checkbox" name="supervisionAvailable"> Supervision available</label>
                <label class="check-tile"><input type="checkbox" name="vulnerablePersonsExposed"> Vulnerable persons exposed</label>
              </div>
            </div>
            <div class="col-12"><label class="form-label fw-semibold" for="peopleExposureNotes">People exposure notes</label><textarea class="form-control" id="peopleExposureNotes" name="peopleExposureNotes" rows="3"></textarea></div>
          </div>
        </section>

        <section class="intake-section wizard-step" data-step-title="Hazard Categories">
          <div class="section-heading">
            <span>6</span>
            <div>
              <h2>Hazard Categories</h2>
              <p>Select each hazard that applies. For every selected hazard, add what could happen, likelihood, severity, current controls, and controls still needed.</p>
            </div>
          </div>

          <div class="hazard-list">
            <% hazards.forEach(([value, label], index) => { %>
              <div class="hazard-row">
                <label class="check-tile hazard-check">
                  <input type="checkbox" name="hazardCategories" value="<%= value %>" data-hazard-toggle="<%= value %>">
                  <%= label %>
                </label>
                <div class="hazard-detail" data-hazard-detail="<%= value %>">
                  <div class="row g-3">
                    <div class="col-md-6"><label class="form-label" for="hazardWhatCouldHappen<%= index %>">What could happen?</label><textarea class="form-control hazard-input" id="hazardWhatCouldHappen<%= index %>" name="hazardWhatCouldHappen" rows="2" disabled></textarea></div>
                    <div class="col-md-3"><label class="form-label" for="hazardLikelihood<%= index %>">How likely is it?</label><select class="form-select hazard-input" id="hazardLikelihood<%= index %>" name="hazardLikelihood" disabled><option value="rare">Rare</option><option value="unlikely">Unlikely</option><option value="possible" selected>Possible</option><option value="likely">Likely</option><option value="almost_certain">Almost certain</option></select></div>
                    <div class="col-md-3"><label class="form-label" for="hazardSeverity<%= index %>">How severe could it be?</label><select class="form-select hazard-input" id="hazardSeverity<%= index %>" name="hazardSeverity" disabled><option value="minor">Minor</option><option value="moderate" selected>Moderate</option><option value="major">Major</option><option value="catastrophic">Catastrophic</option></select></div>
                    <div class="col-md-6"><label class="form-label" for="hazardExistingControls<%= index %>">Controls already in place</label><textarea class="form-control hazard-input" id="hazardExistingControls<%= index %>" name="hazardExistingControls" rows="2" disabled></textarea></div>
                    <div class="col-md-6"><label class="form-label" for="hazardControlsStillNeeded<%= index %>">Controls still needed</label><textarea class="form-control hazard-input" id="hazardControlsStillNeeded<%= index %>" name="hazardControlsStillNeeded" rows="2" disabled></textarea></div>
                  </div>
                </div>
              </div>
            <% }) %>
          </div>
        </section>

        <section class="intake-section wizard-step" data-step-title="PPE Assessment">
          <div class="section-heading">
            <span>7</span>
            <div>
              <h2>PPE Assessment</h2>
              <p>Record what has been obtained and whether it is adequate for the work.</p>
            </div>
          </div>
          <div class="option-grid">
            <% ppeOptions.forEach(([value, label]) => { %>
              <label class="check-tile"><input type="checkbox" name="ppeItems" value="<%= value %>"> <%= label %></label>
            <% }) %>
          </div>
          <div class="row g-3 mt-1">
            <div class="col-md-6"><label class="form-label fw-semibold" for="ppeAdequacy">Is the PPE adequate?</label><select class="form-select" id="ppeAdequacy" name="ppeAdequacy"><option value="">Select</option><option value="adequate">Adequate</option><option value="partly_adequate">Partly adequate</option><option value="not_adequate">Not adequate</option><option value="unknown">Unknown</option></select></div>
            <div class="col-md-6"><label class="form-label fw-semibold" for="ppeCondition">PPE condition</label><input class="form-control" id="ppeCondition" name="ppeCondition" type="text" placeholder="e.g., good, damaged items removed, needs inspection"></div>
            <div class="col-12">
              <div class="option-grid">
                <label class="check-tile"><input type="checkbox" name="ppeEnoughForAllWorkers"> Enough for all workers</label>
                <label class="check-tile"><input type="checkbox" name="ppeInspected"> PPE inspected</label>
                <label class="check-tile"><input type="checkbox" name="ppeWorkersKnowHowToUse"> Workers know how to use it</label>
                <label class="check-tile"><input type="checkbox" name="ppeReplacementAvailable"> Replacement PPE available</label>
              </div>
            </div>
            <div class="col-12"><label class="form-label fw-semibold" for="ppeNotes">PPE notes</label><textarea class="form-control" id="ppeNotes" name="ppeNotes" rows="3"></textarea></div>
            <div class="col-12"><label class="form-label fw-semibold" for="customPPE">Additional PPE</label><textarea class="form-control" id="customPPE" name="customPPE" rows="2" placeholder="One item per line"></textarea></div>
          </div>
        </section>

        <section class="intake-section wizard-step" data-step-title="Equipment and Tools">
          <div class="section-heading">
            <span>8</span>
            <div>
              <h2>Equipment and Tools</h2>
              <p>Capture equipment condition, authority to operate, guarding, emergency stops, and failure risks.</p>
            </div>
          </div>
          <div class="row g-3">
            <div class="col-12"><label class="form-label fw-semibold" for="equipmentUsed">What equipment will be used?</label><textarea class="form-control" id="equipmentUsed" name="equipmentUsed" rows="3"></textarea></div>
            <div class="col-md-6"><label class="form-label fw-semibold" for="authorizedOperators">Who is allowed to operate it?</label><input class="form-control" id="authorizedOperators" name="authorizedOperators" type="text"></div>
            <div class="col-12">
              <div class="option-grid">
                <label class="check-tile"><input type="checkbox" name="equipmentInspected"> Equipment inspected</label>
                <label class="check-tile"><input type="checkbox" name="equipmentCertified"> Certified where required</label>
                <label class="check-tile"><input type="checkbox" name="guardsInPlace"> Guards in place</label>
                <label class="check-tile"><input type="checkbox" name="emergencyStopsWorking"> Emergency stops working</label>
                <label class="check-tile"><input type="checkbox" name="maintenanceUpToDate"> Maintenance up to date</label>
              </div>
            </div>
            <div class="col-12">
              <label class="form-label fw-semibold">Equipment failure risks</label>
              <div class="option-grid compact">
                <label class="check-tile"><input type="checkbox" name="equipmentFailureRisks" value="breakdown"> Breakdown</label>
                <label class="check-tile"><input type="checkbox" name="equipmentFailureRisks" value="fire"> Fire</label>
                <label class="check-tile"><input type="checkbox" name="equipmentFailureRisks" value="leakage"> Leakage</label>
                <label class="check-tile"><input type="checkbox" name="equipmentFailureRisks" value="collapse"> Collapse</label>
                <label class="check-tile"><input type="checkbox" name="equipmentFailureRisks" value="electrocution"> Electrocution</label>
              </div>
            </div>
            <div class="col-12"><label class="form-label fw-semibold" for="equipmentNotes">Equipment notes</label><textarea class="form-control" id="equipmentNotes" name="equipmentNotes" rows="3"></textarea></div>
          </div>
        </section>

        <section class="intake-section wizard-step" data-step-title="Materials and Substances">
          <div class="section-heading">
            <span>9</span>
            <div>
              <h2>Materials and Substances</h2>
              <p>Include chemicals, dust-producing materials, storage, spill response, PPE, and first aid after exposure.</p>
            </div>
          </div>
          <div class="row g-3">
            <div class="col-12"><label class="form-label fw-semibold" for="materialsOrChemicalsUsed">What materials or chemicals are being used?</label><textarea class="form-control" id="materialsOrChemicalsUsed" name="materialsOrChemicalsUsed" rows="3"></textarea></div>
            <div class="col-12">
              <div class="option-grid">
                <label class="check-tile"><input type="checkbox" name="safetyDataSheetsAvailable"> Safety Data Sheets available</label>
                <label class="check-tile"><input type="checkbox" name="substanceHazards" value="flammable"> Flammable</label>
                <label class="check-tile"><input type="checkbox" name="substanceHazards" value="toxic"> Toxic</label>
                <label class="check-tile"><input type="checkbox" name="substanceHazards" value="corrosive"> Corrosive</label>
                <label class="check-tile"><input type="checkbox" name="substanceHazards" value="explosive"> Explosive</label>
                <label class="check-tile"><input type="checkbox" name="substanceHazards" value="dusty"> Dusty</label>
              </div>
            </div>
            <div class="col-md-6"><label class="form-label fw-semibold" for="storageMethod">How are they stored?</label><textarea class="form-control" id="storageMethod" name="storageMethod" rows="3"></textarea></div>
            <div class="col-md-6"><label class="form-label fw-semibold" for="spillHandling">How are spills handled?</label><textarea class="form-control" id="spillHandling" name="spillHandling" rows="3"></textarea></div>
            <div class="col-md-6"><label class="form-label fw-semibold" for="materialRequiredPPE">What PPE is required?</label><textarea class="form-control" id="materialRequiredPPE" name="materialRequiredPPE" rows="3"></textarea></div>
            <div class="col-md-6"><label class="form-label fw-semibold" for="firstAidAfterExposure">What first aid is required after exposure?</label><textarea class="form-control" id="firstAidAfterExposure" name="firstAidAfterExposure" rows="3"></textarea></div>
          </div>
        </section>

        <section class="intake-section wizard-step" data-step-title="Incident History">
          <div class="section-heading">
            <span>10</span>
            <div>
              <h2>Incident and Near-Miss History</h2>
              <p>Tell TrueSafe365 whether this area or activity has already shown warning signs.</p>
            </div>
          </div>
          <div class="option-grid">
            <label class="check-tile"><input type="checkbox" name="similarHappenedBefore"> Similar incident happened before</label>
            <label class="check-tile"><input type="checkbox" name="workersComplained"> Workers complained about this area</label>
            <label class="check-tile"><input type="checkbox" name="nearMisses"> Near-misses reported</label>
            <label class="check-tile"><input type="checkbox" name="equipmentFailedBefore"> Equipment failed before</label>
            <label class="check-tile"><input type="checkbox" name="injuriesFiresSpillsFallsShocksExposure"> Injuries, fires, spills, falls, shocks, or exposure incidents</label>
          </div>
          <label class="form-label fw-semibold mt-3" for="incidentHistoryNotes">History notes</label>
          <textarea class="form-control" id="incidentHistoryNotes" name="incidentHistoryNotes" rows="3"></textarea>
        </section>

        <section class="intake-section wizard-step" data-step-title="AI Document Intent">
          <div class="section-heading">
            <span>11</span>
            <div>
              <h2>AI Document Intent</h2>
              <p>Select the documents you want TrueSafe365 to generate from this work area information.</p>
            </div>
          </div>
          <div class="option-grid">
            <% documents.forEach(([value, label]) => { %>
              <label class="check-tile"><input type="checkbox" name="documentIntent" value="<%= value %>"> <%= label %></label>
            <% }) %>
          </div>
        </section>

        <div class="submit-bar">
          <a href="/dashboard/officer" class="btn btn-outline-secondary btn-lg px-4">Cancel</a>
          <button class="btn btn-outline-primary btn-lg px-4" id="wizardPrev" type="button">
            <i class="fas fa-arrow-left me-2"></i>Previous
          </button>
          <button class="btn btn-primary btn-lg px-4" id="wizardNext" type="button">
            Next<i class="fas fa-arrow-right ms-2"></i>
          </button>
          <button class="btn btn-primary btn-lg px-4 d-none" id="wizardSubmit" type="submit">
            <i class="fas fa-save me-2"></i>Create Work Area
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  const wizardSteps = Array.from(document.querySelectorAll('.wizard-step'));
  const wizardPrev = document.getElementById('wizardPrev');
  const wizardNext = document.getElementById('wizardNext');
  const wizardSubmit = document.getElementById('wizardSubmit');
  const wizardStepLabel = document.getElementById('wizardStepLabel');
  const wizardSectionLabel = document.getElementById('wizardSectionLabel');
  const wizardStepDots = Array.from(document.querySelectorAll('.step-dot'));
  let currentWizardStep = 0;

  function updateWizard() {
    const totalSteps = wizardSteps.length;
    wizardSteps.forEach(function (step, index) {
      step.classList.toggle('is-active', index === currentWizardStep);
    });

    const visibleStep = wizardSteps[currentWizardStep];
    wizardStepLabel.textContent = 'Step ' + (currentWizardStep + 1) + ' of ' + totalSteps;
    wizardSectionLabel.textContent = visibleStep.dataset.stepTitle || '';
    wizardStepDots.forEach(function (dot, index) {
      dot.classList.toggle('is-active', index === currentWizardStep);
      dot.classList.toggle('is-complete', index < currentWizardStep);
      dot.setAttribute('aria-current', index === currentWizardStep ? 'step' : 'false');
    });

    wizardPrev.disabled = currentWizardStep === 0;
    wizardNext.classList.toggle('d-none', currentWizardStep === totalSteps - 1);
    wizardSubmit.classList.toggle('d-none', currentWizardStep !== totalSteps - 1);
  }

  function validateCurrentStep() {
    const controls = Array.from(wizardSteps[currentWizardStep].querySelectorAll('input, select, textarea'));
    const invalidControl = controls.find(function (control) {
      return !control.disabled && !control.checkValidity();
    });

    if (invalidControl) {
      invalidControl.reportValidity();
      return false;
    }

    return true;
  }

  wizardPrev.addEventListener('click', function () {
    if (currentWizardStep === 0) return;
    currentWizardStep -= 1;
    updateWizard();
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });

  wizardNext.addEventListener('click', function () {
    if (!validateCurrentStep()) return;
    if (currentWizardStep >= wizardSteps.length - 1) return;
    currentWizardStep += 1;
    updateWizard();
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });

  wizardStepDots.forEach(function (dot) {
    dot.addEventListener('click', function () {
      const requestedStep = Number(dot.dataset.stepIndex);
      if (Number.isNaN(requestedStep) || requestedStep === currentWizardStep) return;
      if (requestedStep > currentWizardStep && !validateCurrentStep()) return;
      currentWizardStep = requestedStep;
      updateWizard();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  });

  document.querySelectorAll('[data-hazard-toggle]').forEach(function (toggle) {
    const detail = document.querySelector('[data-hazard-detail="' + toggle.dataset.hazardToggle + '"]');
    const inputs = detail ? detail.querySelectorAll('.hazard-input') : [];
    const sync = function () {
      if (!detail) return;
      detail.classList.toggle('is-open', toggle.checked);
      inputs.forEach(function (input) {
        input.disabled = !toggle.checked;
      });
    };
    toggle.addEventListener('change', sync);
    sync();
  });

  document.getElementById('workAreaForm').addEventListener('submit', function () {
    const customPPE = document.getElementById('customPPE').value;
    customPPE.split('\n').map(function (line) {
      return line.trim();
    }).filter(Boolean).forEach(function (item) {
      const input = document.createElement('input');
      input.type = 'hidden';
      input.name = 'ppeItems';
      input.value = item;
      this.appendChild(input);
    }, this);
  });

  updateWizard();
</script>

<style>
