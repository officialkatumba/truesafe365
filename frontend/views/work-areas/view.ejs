<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="main-wrapper">
  <div class="content container py-4">
    <div class="workarea-details-container" style="max-width: 900px; margin: 0 auto;">
      <!-- Work Area Header -->
      <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
        <div>
          <h3 class="mb-1">
            <i class="fas fa-map-marked-alt me-2" style="color: #26a69a;"></i>
            <%= workArea.name %>
          </h3>
          <div class="d-flex gap-2">
            <span class="badge text-bg-secondary">
              #<%= workArea.workAreaNumber || 'N/A' %>
            </span>
            <span class="badge <%= 
              workArea.status === 'active' ? 'text-bg-success' : 
              workArea.status === 'planned' ? 'text-bg-warning' : 
              workArea.status === 'on_hold' ? 'text-bg-danger' : 
              workArea.status === 'completed' ? 'text-bg-info' : 
              'text-bg-secondary' 
            %>">
              <%= (workArea.status || 'unknown').toUpperCase() %>
            </span>
          </div>
        </div>
        <div class="text-end">
          <span class="text-muted small d-block">
            <i class="fas fa-calendar-alt me-1"></i> Created: <%= workArea.createdAt ? new Date(workArea.createdAt).toLocaleDateString() : 'N/A' %>
          </span>
          <span class="text-muted small mt-1 d-block">
            <i class="fas fa-user me-1"></i> Welcome back, <strong><%= user.email %></strong>
            <span class="badge <%= user.role === 'system_admin' ? 'bg-warning text-dark' : (user.role === 'safety_officer' ? 'bg-success' : 'bg-info') %> ms-2">
              <i class="fas fa-<%= user.role === 'system_admin' ? 'crown' : (user.role === 'safety_officer' ? 'user-shield' : 'user') %> me-1"></i>
              <%= user.role === 'system_admin' ? 'System Admin' : (user.role === 'safety_officer' ? 'Safety Officer' : (user.role === 'supervisor' ? 'Supervisor' : 'Worker')) %>
            </span>
          </span>
        </div>
      </div>

     


      <!-- Daily Safety Talk Section -->
<div class="safety-talk-container mb-4">
  <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
    <div class="timer-label" id="safetyTalkLabel">
      <i class="fas fa-chalkboard-teacher me-2" style="color: #5f2c82;"></i>
      TODAY'S SAFETY TALK
    </div>
    <% if (todaySafetyTalk) { %>
      <a href="/safety-talks/<%= todaySafetyTalk._id %>" class="btn btn-sm btn-outline-primary">
        <i class="fas fa-eye me-1"></i> View Full Talk
      </a>
    <% } else if (user.role === 'safety_officer') { %>
      <form method="POST" action="/safety-talks/generate/<%= workArea._id %>" class="d-inline">
        <button type="submit" class="btn btn-sm" style="background: #5f2c82; color: white; border-radius: 40px;">
          <i class="fas fa-robot me-1"></i> Generate Today's Talk
        </button>
      </form>
    <% } %>
  </div>
  
  <div class="safety-talk-content mt-3 p-3 rounded" style="background: #f8f9fa; border-left: 4px solid #5f2c82;">
    <% if (todaySafetyTalk) { %>
      <!-- Display excerpt from today's safety talk -->
      <div class="mb-2">
        <strong class="text-primary"><%= todaySafetyTalk.title %></strong>
      </div>
      
      <!-- Opening statement excerpt -->
      <% if (todaySafetyTalk.sections?.opening) { %>
        <p class="mb-2"><%= todaySafetyTalk.sections.opening.substring(0, 150) %><%= todaySafetyTalk.sections.opening.length > 150 ? '...' : '' %></p>
      <% } else if (todaySafetyTalk.content) { %>
        <p class="mb-2"><%= todaySafetyTalk.content.substring(0, 200) %><%= todaySafetyTalk.content.length > 200 ? '...' : '' %></p>
      <% } %>
      
      <!-- Main points preview -->
      <% if (todaySafetyTalk.sections?.mainPoints && todaySafetyTalk.sections.mainPoints.length > 0) { %>
        <div class="small text-muted mt-2">
          <i class="fas fa-list-check me-1"></i> Key points: 
          <%= todaySafetyTalk.sections.mainPoints.slice(0, 2).join(' • ') %>
          <% if (todaySafetyTalk.sections.mainPoints.length > 2) { %> • +<%= todaySafetyTalk.sections.mainPoints.length - 2 %> more<% } %>
        </div>
      <% } %>
      
      <div class="timer-meta mt-2 pt-2 border-top">
        <small class="text-muted">
          <i class="fas fa-clock me-1"></i> <%= todaySafetyTalk.duration || 5 %> min read
          | <i class="fas fa-calendar me-1"></i> <%= new Date(todaySafetyTalk.date || todaySafetyTalk.createdAt).toLocaleDateString() %>
          | <i class="fas fa-robot me-1" style="color: #5f2c82;"></i> AI-Generated
        </small>
      </div>
      
    <% } else { %>
      <!-- No safety talk for today -->
      <div class="text-center py-3">
        <i class="fas fa-chalkboard-teacher fa-2x text-muted mb-2"></i>
        <p class="text-muted mb-0">No safety talk generated for today.</p>
        <% if (user.role === 'safety_officer') { %>
          <form method="POST" action="/safety-talks/generate/<%= workArea._id %>" class="mt-2">
            <button type="submit" class="btn btn-sm" style="background: #5f2c82; color: white;">
              <i class="fas fa-robot me-1"></i> Generate Safety Talk
            </button>
          </form>
        <% } else { %>
          <p class="small text-muted mt-2">Check back later for daily safety briefing.</p>
        <% } %>
      </div>
    <% } %>
  </div>
</div>

<style>
  .safety-talk-container {
    background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
    border-radius: 12px;
    padding: 1rem;
  }
  .timer-label {
    font-weight: bold;
    color: #5f2c82;
    letter-spacing: 1px;
  }
  .safety-talk-content {
    transition: all 0.3s ease;
  }
  .safety-talk-content:hover {
    background: #fff !important;
    box-shadow: 0 2px 8px rgba(0,0,0,0.05);
  }
</style>

