<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="main-wrapper workarea-view-page">
  <div class="content container py-4">
    <div class="workarea-details-container" style="max-width: 1080px; margin: 0 auto;">
      <%
        const locationText = workArea.location?.zone || workArea.location || 'Location not specified';
        const workTypeText = workArea.currentWorkTypes && workArea.currentWorkTypes.length
          ? workArea.currentWorkTypes.map(wt => wt.workType || wt).join(', ')
          : 'general';
        const shiftText = workArea.intake?.shiftOrWorkingTime || (workArea.activeShifts && workArea.activeShifts.length
          ? workArea.activeShifts.map(shift => shift.name).join(', ')
          : 'No shift configured');
        const hazardList = (workArea.identifiedHazards || []).slice(0, 10);
      %>

      <section class="workarea-hero mb-4">
        <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap">
          <div>
            <p class="text-uppercase text-muted fw-semibold small mb-1">Work Area</p>
            <h3 class="mb-2">
              <i class="fas fa-map-marked-alt me-2" style="color: #26a69a;"></i>
              <%= workArea.name %>
            </h3>
            <div class="d-flex flex-wrap gap-2 align-items-center">
              <span class="status-pill neutral">#<%= workArea.workAreaNumber || 'N/A' %></span>
              <span class="status-pill <%= 
                workArea.status === 'active' ? 'success' : 
                workArea.status === 'planned' ? 'warning' : 
                workArea.status === 'on_hold' ? 'danger' : 
                workArea.status === 'completed' ? 'info' : 
                'neutral' 
              %>">
                <%= (workArea.status || 'unknown').toUpperCase() %>
              </span>
              <a href="/work-areas/<%= workArea._id %>/edit" class="status-pill edit-link">
                <i class="fas fa-pen me-1"></i>EDIT WORK AREA
              </a>
              <% hazardList.forEach(hazard => { %>
                <span class="status-pill hazard">
                  <i class="fas fa-exclamation-triangle me-1"></i><%= hazard.hazard %>
                </span>
              <% }) %>
              <% if ((workArea.identifiedHazards || []).length > hazardList.length) { %>
                <span class="status-pill neutral">+<%= workArea.identifiedHazards.length - hazardList.length %> more hazards</span>
              <% } %>
            </div>
          </div>
          <div class="text-lg-end small text-muted">
            <div><i class="fas fa-calendar-alt me-1"></i>Created: <%= workArea.createdAt ? new Date(workArea.createdAt).toLocaleDateString() : 'N/A' %></div>
            <div class="mt-1"><i class="fas fa-user-shield me-1"></i><%= user.email %></div>
          </div>
        </div>

        <div class="d-flex flex-wrap gap-2 align-items-center mt-3">
          <span class="status-pill location">
            <i class="fas fa-map-marker-alt me-1"></i>Location: <%= locationText %>
          </span>
          <span class="status-pill work-type">
            <i class="fas fa-briefcase me-1"></i>Work: <%= workTypeText %>
          </span>
          <span class="status-pill dates">
            <i class="fas fa-calendar-alt me-1"></i><%= workArea.plannedStart ? new Date(workArea.plannedStart).toLocaleDateString() : 'Not set' %> - <%= workArea.plannedEnd ? new Date(workArea.plannedEnd).toLocaleDateString() : 'Not set' %>
          </span>
          <span class="status-pill shifts">
            <i class="fas fa-clock me-1"></i><%= shiftText %>
          </span>
        </div>

        <p class="hero-description mb-0 mt-3"><%= workArea.description || workArea.intake?.mainActivity || 'No description provided yet.' %></p>

        <div class="d-flex flex-wrap gap-2 align-items-center mt-3">
          <span class="status-pill metric-incident">
            <i class="fas fa-exclamation-circle me-1"></i><%= workArea.statistics?.incidents || 0 %> Incidents
          </span>
          <span class="status-pill metric-nearmiss">
            <i class="fas fa-exclamation-triangle me-1"></i><%= workArea.statistics?.nearMisses || 0 %> Near Misses
          </span>
          <span class="status-pill metric-score">
            <i class="fas fa-shield-alt me-1"></i><%= workArea.statistics?.safetyScore || 100 %>% Safety Score
          </span>
          <span class="status-pill metric-days">
            <i class="fas fa-calendar-check me-1"></i><%= workArea.statistics?.daysWithoutIncident || 0 %> Days Safe
          </span>
        </div>
      </section>

      <section class="incident-share-panel mb-4">
        <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
          <div>
            <p class="text-uppercase text-muted fw-semibold small mb-1">Staff Reporting Access</p>
            <h5 class="fw-bold mb-2"><i class="fas fa-qrcode me-2"></i>Shared work-area incident code</h5>
            <p class="text-muted mb-0">Give this code to staff assigned to this work area. They can report incidents, near misses, and hazards from the homepage without logging in. The code stays active until you manually rotate it.</p>
          </div>
          <form method="POST" action="/work-areas/<%= workArea._id %>/incident-share-code/regenerate" class="d-inline">
            <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
            <button type="submit" class="btn btn-outline-danger rounded-pill fw-semibold">
              <i class="fas fa-rotate me-1"></i> Rotate Code
            </button>
          </form>
        </div>
        <div class="row g-3 mt-2 align-items-stretch">
          <div class="col-lg-4">
            <div class="share-code-box h-100">
              <span>Current Code</span>
              <strong><%= workArea.publicIncidentShare?.code || 'Generating...' %></strong>
              <small>Used <%= workArea.publicIncidentShare?.useCount || 0 %> time(s)</small>
            </div>
          </div>
          <div class="col-lg-8">
            <div class="share-link-box h-100">
              <label class="form-label small text-muted fw-semibold" for="staffReportLink">Staff reporting link</label>
              <div class="input-group">
                <input id="staffReportLink" class="form-control" readonly value="/incidents/public/<%= workArea.publicIncidentShare?.code || '' %>">
                <button class="btn btn-outline-secondary" type="button" data-copy-target="staffReportLink"><i class="fas fa-copy me-1"></i>Copy</button>
              </div>
              <div class="mt-2 d-flex flex-wrap gap-2">
                <a class="btn btn-success btn-sm rounded-pill" href="https://wa.me/?text=Report%20a%20TrueSafe365%20incident%20for%20<%= encodeURIComponent(workArea.name || 'this work area') %>%20using%20code%20<%= encodeURIComponent(workArea.publicIncidentShare?.code || '') %>%20at%20https%3A%2F%2Fwww.safety365.work" target="_blank" rel="noopener noreferrer">
                  <i class="fab fa-whatsapp me-1"></i>Share on WhatsApp
                </a>
                <span class="small text-muted align-self-center">Rotate only if the code is abused or exposed outside the work area.</span>
              </div>
            </div>
          </div>
        </div>
      </section>
      <% if (workArea.automation?.safetyInsightNeedsRefresh || workArea.automation?.safetyTalkNeedsRefresh || (workArea.automation?.suggestedDocuments || []).length) { %>
        <section class="automation-refresh-panel mb-4">
          <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
            <div>
              <p class="text-uppercase fw-semibold small mb-1">Automation Triggered</p>
              <h5 class="fw-bold mb-2"><i class="fas fa-bolt me-2"></i>New incident data changed this work area</h5>
              <p class="mb-0">TrueSafe365 has marked the safety insight and safety talk as needing review because a new incident, near miss, or hazard report was submitted for this work area.</p>
            </div>
            <div class="d-flex flex-wrap gap-2">
              <form method="POST" action="/safety-insights/generate/<%= workArea._id %>">
                <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                <button type="submit" class="btn btn-light btn-sm rounded-pill fw-semibold"><i class="fas fa-brain me-1"></i>Refresh Insight</button>
              </form>
              <form method="POST" action="/safety-talks/generate/<%= workArea._id %>">
                <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                <button type="submit" class="btn btn-light btn-sm rounded-pill fw-semibold"><i class="fas fa-chalkboard-teacher me-1"></i>Refresh Talk</button>
              </form>
            </div>
          </div>
          <% const pendingSuggestions = (workArea.automation?.suggestedDocuments || []).filter(item => item.status === 'pending').slice(-6).reverse(); %>
          <% if (pendingSuggestions.length) { %>
            <div class="automation-suggestion-list mt-3">
              <% pendingSuggestions.forEach(item => { %>
                <span class="automation-suggestion-pill <%= item.priority || 'medium' %>">
                  <strong><%= (item.documentType || 'document').replace(/_/g, ' ') %></strong>
                  <small><%= item.reason %></small>
                </span>
              <% }) %>
            </div>
          <% } %>
        </section>
      <% } %>
      <!-- Daily Safety Talk Section -->
      <div class="safety-talk-container mb-4">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
          <div class="timer-label" id="safetyTalkLabel">
            <i class="fas fa-chalkboard-teacher me-2" style="color: #5f2c82;"></i>
            TODAY'S SAFETY TALK
          </div>
          <% if (todaySafetyTalk) { %>
            <a href="/safety-talks/<%= todaySafetyTalk._id %>" class="btn btn-sm btn-outline-primary">
              <i class="fas fa-eye me-1"></i> View Full Talk
            </a>
          <% } else if (user.role === 'safety_officer') { %>
            <form method="POST" action="/safety-talks/generate/<%= workArea._id %>" class="d-inline">
              <button type="submit" class="btn btn-sm" style="background: #5f2c82; color: white; border-radius: 40px;">
                <i class="fas fa-robot me-1"></i> Generate Today's Talk
              </button>
            </form>
          <% } %>
        </div>
        
        <div class="safety-talk-content mt-3 p-3 rounded" style="background: #f8f9fa; border-left: 4px solid #5f2c82;">
          <% if (todaySafetyTalk) { %>
            <div class="mb-2">
              <strong class="text-primary"><%= todaySafetyTalk.title %></strong>
            </div>
            <% if (todaySafetyTalk.sections?.opening) { %>
              <p class="mb-2"><%= todaySafetyTalk.sections.opening.substring(0, 150) %><%= todaySafetyTalk.sections.opening.length > 150 ? '...' : '' %></p>
            <% } else if (todaySafetyTalk.content) { %>
              <p class="mb-2"><%= todaySafetyTalk.content.substring(0, 200) %><%= todaySafetyTalk.content.length > 200 ? '...' : '' %></p>
            <% } %>
            <% if (todaySafetyTalk.sections?.mainPoints && todaySafetyTalk.sections.mainPoints.length > 0) { %>
              <div class="small text-muted mt-2">
                <i class="fas fa-list-check me-1"></i> Key points: 
                <%= todaySafetyTalk.sections.mainPoints.slice(0, 2).join(' • ') %>
                <% if (todaySafetyTalk.sections.mainPoints.length > 2) { %> • +<%= todaySafetyTalk.sections.mainPoints.length - 2 %> more<% } %>
              </div>
            <% } %>
            <div class="timer-meta mt-2 pt-2 border-top">
              <small class="text-muted">
                <i class="fas fa-clock me-1"></i> <%= todaySafetyTalk.duration || 5 %> min read
                | <i class="fas fa-calendar me-1"></i> <%= new Date(todaySafetyTalk.date || todaySafetyTalk.createdAt).toLocaleDateString() %>
                | <i class="fas fa-robot me-1" style="color: #5f2c82;"></i> AI-Generated
              </small>
            </div>
          <% } else { %>
            <div class="text-center py-3">
              <i class="fas fa-chalkboard-teacher fa-2x text-muted mb-2"></i>
              <p class="text-muted mb-0">No safety talk generated for today.</p>
              <% if (user.role === 'safety_officer') { %>
                <form method="POST" action="/safety-talks/generate/<%= workArea._id %>" class="mt-2">
                  <button type="submit" class="btn btn-sm" style="background: #5f2c82; color: white;">
                    <i class="fas fa-robot me-1"></i> Generate Safety Talk
                  </button>
                </form>
              <% } else { %>
                <p class="small text-muted mt-2">Check back later for daily safety briefing.</p>
              <% } %>
            </div>
          <% } %>
        </div>
      </div>

      <style>
        .incident-share-panel {
          background: rgba(255, 255, 255, 0.92);
          border: 1px solid rgba(225, 29, 72, 0.16);
          border-radius: 22px;
          box-shadow: 0 18px 45px rgba(190, 18, 60, 0.09);
          padding: 1.25rem;
        }
        .share-code-box,
        .share-link-box {
          background: #fff7f8;
          border: 1px solid rgba(225, 29, 72, 0.14);
          border-radius: 18px;
          padding: 1rem;
        }
        .share-code-box span {
          color: #be123c;
          display: block;
          font-size: 0.75rem;
          font-weight: 800;
          letter-spacing: 0.12em;
          text-transform: uppercase;
        }
        .share-code-box strong {
          color: #111827;
          display: block;
          font-size: clamp(1.7rem, 4vw, 2.5rem);
          letter-spacing: 0.08em;
          line-height: 1.1;
          margin: 0.35rem 0;
        }
        .automation-refresh-panel {
          background: linear-gradient(135deg, #be123c, #7f1d1d);
          border-radius: 22px;
          box-shadow: 0 20px 55px rgba(127, 29, 29, 0.22);
          color: #fff;
          padding: 1.25rem;
        }
        .automation-refresh-panel p {
          color: rgba(255, 255, 255, 0.86);
        }
        .automation-suggestion-list {
          display: flex;
          flex-wrap: wrap;
          gap: 0.65rem;
        }
        .automation-suggestion-pill {
          background: rgba(255, 255, 255, 0.12);
          border: 1px solid rgba(255, 255, 255, 0.22);
          border-radius: 16px;
          display: inline-flex;
          flex-direction: column;
          gap: 0.2rem;
          max-width: 260px;
          padding: 0.75rem 0.9rem;
        }
        .automation-suggestion-pill strong {
          text-transform: capitalize;
        }
        .automation-suggestion-pill small {
          color: rgba(255, 255, 255, 0.78);
          line-height: 1.35;
        }        .safety-talk-container {
          background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
          border-radius: 12px;
          padding: 1rem;
        }
        .timer-label {
          font-weight: bold;
          color: #5f2c82;
          letter-spacing: 1px;
        }
        .safety-talk-content {
          transition: all 0.3s ease;
        }
        .safety-talk-content:hover {
          background: #fff !important;
          box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        }
      </style>

      <!-- Documents Section with Tabs -->
      <div class="row mt-5">
        <div class="col-12">
          <h4 class="fw-bold mb-3 control-panel-title">
            <i class="fas fa-sliders-h me-2"></i>SAFETY OFFICER CONTROL PANEL
          </h4>
          
          <div class="control-panel-grid" id="documentTabs" role="tablist">
            <button class="control-tile active risk" id="risk-tab" data-bs-toggle="tab" data-bs-target="#risk" type="button" role="tab">
              <i class="fas fa-chart-pie"></i><span>Risk Assessments</span><strong><%= riskAssessments?.length || 0 %></strong>
            </button>
            <button class="control-tile incident" id="incidents-tab" data-bs-toggle="tab" data-bs-target="#incidents" type="button" role="tab">
              <i class="fas fa-exclamation-triangle"></i><span>Incidents</span><strong><%= recentIncidents?.length || 0 %></strong>
            </button>
            <button class="control-tile insights" id="safety-insights-tab" data-bs-toggle="tab" data-bs-target="#insights" type="button" role="tab">
              <i class="fas fa-brain"></i><span>Safety Insights</span><strong><%= safetyInsights?.length || 0 %></strong>
            </button>
            <button class="control-tile talks" id="safety-talks-tab" data-bs-toggle="tab" data-bs-target="#safety-talks" type="button" role="tab">
              <i class="fas fa-chalkboard-teacher"></i><span>Safety Talks</span><strong><%= safetyTalks?.length || 0 %></strong>
            </button>
            <button class="control-tile emergency" id="emergency-protocols-tab" data-bs-toggle="tab" data-bs-target="#emergency-protocols" type="button" role="tab">
              <i class="fas fa-truck-medical"></i><span>Emergency Plans</span><strong><%= emergencyProtocols?.length || 0 %></strong>
            </button>
            <button class="control-tile environmental" id="environmental-tab" data-bs-toggle="tab" data-bs-target="#environmental" type="button" role="tab">
              <i class="fas fa-leaf"></i><span>Environmental</span><strong><%= environmentalAssessments?.length || 0 %></strong>
            </button>
            <button class="control-tile permits" id="permits-tab" data-bs-toggle="tab" data-bs-target="#permits" type="button" role="tab">
              <i class="fas fa-file-signature"></i><span>Permits</span><strong><%= permits?.length || 0 %></strong>
            </button>
            <button class="control-tile jsa" id="jsa-tab" data-bs-toggle="tab" data-bs-target="#jsa" type="button" role="tab">
              <i class="fas fa-tasks"></i><span>JSA</span><strong><%= jsa?.length || 0 %></strong>
            </button>
            <button class="control-tile compliance" id="ohs-compliance-tab" data-bs-toggle="tab" data-bs-target="#ohs-compliance" type="button" role="tab">
              <i class="fas fa-scale-balanced"></i><span>OHS Compliance</span><strong><%= ohsComplianceAudits?.length || 0 %></strong>
            </button>
            <button class="control-tile ppe" id="ppe-tab" data-bs-toggle="tab" data-bs-target="#ppe" type="button" role="tab">
              <i class="fas fa-helmet-safety"></i><span>PPE Checklists</span><strong><%= ppeChecklists?.length || 0 %></strong>
            </button>
            <button class="control-tile training" id="training-tab" data-bs-toggle="tab" data-bs-target="#training" type="button" role="tab">
              <i class="fas fa-graduation-cap"></i><span>Training</span><strong><%= trainingRequirements?.length || 0 %></strong>
            </button>
            <button class="control-tile audits" id="safety-audits-tab" data-bs-toggle="tab" data-bs-target="#safety-audits" type="button" role="tab">
              <i class="fas fa-gauge-high"></i><span>Safety Audits</span><strong><%= safetyAudits?.length || 0 %></strong>
            </button>
            <button class="control-tile observations" id="observations-tab" data-bs-toggle="tab" data-bs-target="#observations" type="button" role="tab">
              <i class="fas fa-eye"></i><span>Observations</span><strong><%= safetyObservations?.length || 0 %></strong>
            </button>
            <button class="control-tile compliance" id="governance-tab" data-bs-toggle="tab" data-bs-target="#governance" type="button" role="tab">
              <i class="fas fa-landmark"></i><span>Governance Docs</span><strong><%= governanceDocuments?.length || 0 %></strong>
            </button>
            <button class="control-tile permits" id="transport-tab" data-bs-toggle="tab" data-bs-target="#transport" type="button" role="tab">
              <i class="fas fa-truck"></i><span>Transport Checklists</span><strong><%= transportChecklists?.length || 0 %></strong>
            </button>
          </div>

          <div class="tab-content p-4 border rounded shadow-sm mt-3" style="background-color: white;">
            
            <!-- Risk Assessments Tab -->
            <div class="tab-pane fade show active" id="risk" role="tabpanel">
              <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="fw-bold mb-0"><i class="fas fa-chart-pie me-2" style="color: #26a69a;"></i>Risk Assessments</h5>
                <% if (user.role === 'safety_officer') { %>
                  <a href="/risk-assessments/new/<%= workArea._id %>" class="btn btn-sm" style="background: #26a69a; color: white; border-radius: 40px;">                         
                    <i class="fas fa-plus-circle me-1"></i> New Assessment
                  </a>
                <% } %>
              </div>
              
              <% if (riskAssessments && riskAssessments.length > 0) { %>
                <div class="list-group">
                  <% riskAssessments.slice(0, 3).forEach(assessment => { %>
                    <a href="/risk-assessments/<%= assessment._id %>" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                      <div>
                        <strong><%= assessment.title %></strong>
                        <span class="badge <%= 
                          assessment.status === 'approved' ? 'bg-success' : 
                          assessment.status === 'draft' ? 'bg-secondary' : 
                          assessment.status === 'under_review' ? 'bg-warning text-dark' : 
                          'bg-info' 
                        %> ms-2"><%= assessment.status || 'draft' %></span>
                        <div class="small text-muted">
                          <i class="fas fa-calendar me-1"></i> <%= new Date(assessment.createdAt).toLocaleDateString() %>
                          | <%= assessment.aiGenerated ? 'AI-Generated' : 'Manual' %>
                        </div>
                      </div>
                      <i class="fas fa-chevron-right text-muted"></i>
                    </a>
                  <% }) %>
                </div>
                <% if (riskAssessments.length > 3) { %>
                  <div class="text-center mt-3">
                    <a href="/risk-assessments?workAreaId=<%= workArea._id %>" class="btn btn-sm btn-outline-secondary">
                      View All <%= riskAssessments.length %> Assessments
                    </a>
                  </div>
                <% } %>
              <% } else { %>
                <p class="text-muted text-center py-4">No risk assessments yet. Click "New Assessment" to create one.</p>
              <% } %>
            </div>

            <!-- Incidents Tab -->
            <div class="tab-pane fade" id="incidents" role="tabpanel">
              <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="fw-bold mb-0"><i class="fas fa-exclamation-triangle me-2" style="color: #f44336;"></i>Incidents</h5>
                <% if (user.role === 'safety_officer') { %>
                  <a href="/incidents/report/<%= workArea._id %>" class="btn btn-sm" style="background: #f44336; color: white; border-radius: 40px;">
                    <i class="fas fa-flag me-1"></i> Report Incident
                  </a>
                <% } %>
              </div>
              
              <% if (recentIncidents && recentIncidents.length > 0) { %>
                <div class="list-group">
                  <% recentIncidents.slice(0, 3).forEach(incident => { %>
                    <a href="/incidents/<%= incident._id %>" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                      <div>
                        <strong><%= incident.type %></strong>
                        <span class="badge <%= 
                          incident.severity === 'critical' ? 'bg-danger' : 
                          incident.severity === 'high' ? 'bg-warning text-dark' : 
                          incident.severity === 'medium' ? 'bg-info' : 
                          'bg-success' 
                        %> ms-2"><%= incident.severity %></span>
                        <div class="small text-muted">
                          <i class="fas fa-calendar me-1"></i> <%= new Date(incident.dateTime).toLocaleDateString() %>
                          | Status: <%= incident.status %>
                        </div>
                      </div>
                      <i class="fas fa-chevron-right text-muted"></i>
                    </a>
                  <% }) %>
                </div>
                <% if (recentIncidents.length > 3) { %>
                  <div class="text-center mt-3">
                    <a href="/incidents?workAreaId=<%= workArea._id %>" class="btn btn-sm btn-outline-secondary">
                      View All <%= recentIncidents.length %> Incidents
                    </a>
                  </div>
                <% } %>
              <% } else { %>
                <p class="text-muted text-center py-4">No incidents reported. Keep up the good work!</p>
              <% } %>
            </div>

            <!-- AI Safety Insights Tab -->
            <div class="tab-pane fade" id="insights" role="tabpanel">
              <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="fw-bold mb-0">
                  <i class="fas fa-brain me-2" style="color: #6f42c1;"></i>
                  AI Safety Insights
                </h5>
                <% if (user.role === 'safety_officer') { %>
                  <form method="POST" action="/safety-insights/generate/<%= workArea._id %>" class="d-inline">
                    <button type="submit" class="btn btn-sm" style="background: #6f42c1; color: white; border-radius: 40px;">
                      <i class="fas fa-robot me-1"></i> Generate AI Insight
                    </button>
