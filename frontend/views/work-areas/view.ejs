                          </span>

                          <% if (score !== undefined && score !== null) { %>
                            <span class="badge bg-primary ms-1">
                              Score: <%= score %>/100
                            </span>
                          <% } %>

                          <div class="small text-muted mt-1">
                            <i class="fas fa-calendar me-1"></i>
                            <%= new Date(audit.createdAt).toLocaleDateString() %>
                            |
                            <i class="fas fa-database me-1"></i>
                            <%= audit.auditPeriod?.label || 'Recent safety data' %>
                          </div>

                          <% if (audit.finalScore?.scoreSummary) { %>
                            <div class="small text-muted mt-2">
                              <%= audit.finalScore.scoreSummary.substring(0, 180) %><%= audit.finalScore.scoreSummary.length > 180 ? '...' : '' %>
                            </div>
                          <% } %>
                        </div>

                        <i class="fas fa-chevron-right text-muted mt-2"></i>
                      </div>
                    </a>
                  <% }) %>
                </div>
              <% } else { %>
                <div class="text-center py-4">
                  <i class="fas fa-gauge-high fa-3x text-muted mb-3"></i>
                  <p class="text-muted">
                    No AI safety score audits generated yet.
                  </p>

                  <% if (user.role === 'safety_officer') { %>
                    <form method="POST" action="/safety-audits/generate/<%= workArea._id %>">
                      <button type="submit" class="btn btn-primary btn-sm">
                        <i class="fas fa-robot me-1"></i>
                        Initiate First Safety Score Audit
                      </button>
                    </form>
                  <% } %>
                </div>
              <% } %>
            </div>

            <!-- Safety Observations Tab -->
            <div class="tab-pane fade" id="observations" role="tabpanel">
              <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="fw-bold mb-0"><i class="fas fa-eye me-2" style="color: #9c27b0;"></i>Safety Observations</h5>
                <% if (user.role === 'safety_officer' || user.role === 'worker') { %>
                  <a href="/safety-observations/create/<%= workArea._id %>" class="btn btn-sm" style="background: #9c27b0; color: white; border-radius: 40px;">
                    <i class="fas fa-plus-circle me-1"></i> New Observation
                  </a>
                <% } %>
              </div>
              
              <% if (safetyObservations && safetyObservations.length > 0) { %>
                <div class="list-group">
                  <% safetyObservations.slice(0, 5).forEach(obs => { %>
                    <a href="/safety-observations/<%= obs._id %>" class="list-group-item list-group-item-action">
                      <div class="d-flex justify-content-between align-items-center">
                        <div>
                          <span class="badge <%= obs.type === 'positive' ? 'bg-success' : obs.type === 'at_risk' ? 'bg-warning text-dark' : 'bg-danger' %> me-2"><%= obs.type %></span>
                          <strong><%= obs.description.substring(0, 80) %>...</strong>
                          <div class="small text-muted"><i class="fas fa-calendar me-1"></i><%= new Date(obs.date).toLocaleDateString() %> | Status: <%= obs.status %></div>
                        </div>
                        <i class="fas fa-chevron-right text-muted"></i>
                      </div>
                    </a>
                  <% }) %>
                </div>
              <% } else { %>
                <p class="text-muted text-center py-4">No safety observations recorded yet.</p>
              <% } %>
            </div>

            <!-- Governance Documents Tab -->
            <div class="tab-pane fade" id="governance" role="tabpanel">
              <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="fw-bold mb-0"><i class="fas fa-landmark me-2" style="color: #1e3c5c;"></i>Governance Documents</h5>
              </div>
              <p class="text-muted small">
                Draft the workplace documents mandated by the Occupational Health and Safety Act No. 16 of 2025: the Health and Safety Committee formation (Section 9) and the CEO-signed Health and Safety Policy (Section 14).
              </p>
              <div class="d-flex gap-2 mb-3">
                <a href="/governance-documents/new/<%= workArea._id %>/committee_formation" class="btn btn-sm" style="background: #1e3c5c; color: white; border-radius: 40px;">
                  <i class="fas fa-users me-1"></i> New Committee Formation
                </a>
                <a href="/governance-documents/new/<%= workArea._id %>/hs_policy" class="btn btn-sm" style="background: #2f5597; color: white; border-radius: 40px;">
                  <i class="fas fa-file-signature me-1"></i> New H&S Policy
                </a>
              </div>

              <% if (governanceDocuments && governanceDocuments.length > 0) { %>
                <div class="list-group">
                  <% governanceDocuments.forEach(doc => { %>
                    <a href="/governance-documents/<%= doc._id %>" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                      <div>
                        <span class="badge <%= doc.docType === 'committee_formation' ? 'bg-primary' : 'bg-info text-dark' %> me-2">
                          <%= doc.docType === 'committee_formation' ? 'Committee' : 'Policy' %>
                        </span>
                        <strong><%= doc.title %></strong>
                        <div class="small text-muted"><i class="fas fa-calendar me-1"></i><%= new Date(doc.createdAt).toLocaleDateString() %></div>
                      </div>
                      <i class="fas fa-chevron-right text-muted"></i>
                    </a>
                  <% }) %>
                </div>
              <% } else { %>
                <p class="text-muted text-center py-4">No governance documents generated yet.</p>
              <% } %>
            </div>

            <!-- Transport Checklists Tab -->
            <div class="tab-pane fade" id="transport" role="tabpanel">
              <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="fw-bold mb-0"><i class="fas fa-truck me-2" style="color: #f093fb;"></i>Transport Checklists</h5>
              </div>
              <p class="text-muted small">
                Simple pre-trip and pre-start checklists for drivers and vehicles on hauling routes.
              </p>
              <div class="d-flex gap-2 mb-3">
                <a href="/transport-checklists/new/<%= workArea._id %>/pre_trip_fatigue" class="btn btn-sm" style="background: #f093fb; color: white; border-radius: 40px;">
                  <i class="fas fa-user-clock me-1"></i> Driver Fatigue Checklist
                </a>
                <a href="/transport-checklists/new/<%= workArea._id %>/pre_start_inspection" class="btn btn-sm" style="background: #667eea; color: white; border-radius: 40px;">
                  <i class="fas fa-truck-monster me-1"></i> Vehicle Pre-Start Inspection
                </a>
              </div>

              <% if (transportChecklists && transportChecklists.length > 0) { %>
                <div class="list-group">
                  <% transportChecklists.forEach(cl => { %>
                    <a href="/transport-checklists/<%= cl._id %>" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                      <div>
                        <span class="badge <%= cl.overallResult === 'pass' ? 'bg-success' : 'bg-danger' %> me-2"><%= cl.overallResult %></span>
                        <strong><%= cl.checklistType === 'pre_trip_fatigue' ? 'Driver Fatigue' : 'Vehicle Pre-Start' %></strong> - <%= cl.driverName %>
                        <div class="small text-muted"><i class="fas fa-calendar me-1"></i><%= new Date(cl.date).toLocaleDateString() %></div>
                      </div>
                      <i class="fas fa-chevron-right text-muted"></i>
                    </a>
                  <% }) %>
                </div>
              <% } else { %>
                <p class="text-muted text-center py-4">No transport checklists submitted yet.</p>
              <% } %>
            </div>
          </div>
        </div>
      </div></div>
  </div>
</div>

