<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="main-wrapper">
  <div class="content container py-4">
    <div class="manage-workers-container" style="max-width: 1000px; margin: 0 auto;">
      <!-- Work Area Style Header -->
      <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
        <div>
          <h3 class="mb-1">
            <i class="fas fa-users me-2" style="color: #4caf50;"></i>
            Manage Workers
          </h3>
          <div class="d-flex gap-2">
            <span class="badge text-bg-secondary">
              <i class="fas fa-map-marked-alt me-1"></i> <%= workArea.name %>
            </span>
          </div>
        </div>
        <a href="/work-areas/<%= workArea._id %>" class="btn btn-outline-secondary btn-sm" style="border-radius: 40px;">
          <i class="fas fa-arrow-left me-2"></i>Back to Work Area
        </a>
      </div>

      <!-- Two Column Layout -->
      <div class="row g-4">
        <!-- Currently Assigned Workers -->
        <div class="col-lg-5">
          <div class="card border-0 shadow-sm h-100" style="border-radius: 16px;">
            <div class="card-header bg-transparent border-0 pt-4 px-4">
              <h4 class="fw-bold mb-0" style="color: #4caf50">
                <i class="fas fa-user-check me-2"></i>Currently Assigned
              </h4>
            </div>
            <div class="card-body p-4">
              <% const assignedWorkers = workArea.assignedWorkers || []; %>
              <% if (assignedWorkers.filter(a => a.isActive !== false).length > 0) { %>
                <div class="list-group">
                  <% assignedWorkers.filter(a => a.isActive !== false).forEach(assignment => { %>
                  <div class="list-group-item border-0 bg-light mb-2 rounded-3">
                    <div class="d-flex justify-content-between align-items-center">
                      <div class="d-flex align-items-center">
                        <div class="rounded-circle d-flex align-items-center justify-content-center me-2" 
                             style="background: linear-gradient(135deg, #4caf50 0%, #388e3c 100%); width: 35px; height: 35px;">
                          <i class="fas fa-hard-hat text-white" style="font-size: 0.9rem;"></i>
                        </div>
                        <div>
                          <h6 class="fw-bold mb-1"><%= assignment.worker?.name || 'Unknown' %></h6>
                          <div class="d-flex gap-2 align-items-center flex-wrap">
                            <span class="badge" style="background: #4caf50; color: white; border-radius: 40px;">
                              <i class="fas fa-clock me-1"></i> <%= assignment.shift || 'Morning' %>
                            </span>
                            <% if (assignment.isTeamLead) { %>
                            <span class="badge" style="background: #ffc107; color: #212529; border-radius: 40px;">
                              <i class="fas fa-crown me-1"></i> Team Lead
                            </span>
                            <% } %>
                            <% if (assignment.department) { %>
                            <span class="badge" style="background: #6c757d; color: white; border-radius: 40px;">
                              <i class="fas fa-building me-1"></i> <%= assignment.department %>
                            </span>
                            <% } %>
                          </div>
                          <div class="small text-muted mt-1">
                            <i class="fas fa-envelope me-1"></i> <%= assignment.worker?.email || 'No email' %>
                            <% if (assignment.worker?.workerNumber) { %>
                            | <i class="fas fa-id-card me-1"></i> <%= assignment.worker.workerNumber %>
                            <% } %>
                          </div>
                        </div>
                      </div>
                      <button class="btn btn-sm btn-outline-danger remove-worker" data-assignment-id="<%= assignment._id %>" style="border-radius: 40px;">
                        <i class="fas fa-times"></i>
                      </button>
                    </div>
                  </div>
                  <% }) %>
                </div>
              <% } else { %>
                <div class="text-center py-5">
                  <i class="fas fa-user-slash fa-3x text-muted mb-3"></i>
                  <p class="text-muted">No workers assigned yet</p>
                </div>
              <% } %>
            </div>
          </div>
        </div>

        <!-- Assignment Form -->
        <div class="col-lg-7">
          <div class="card border-0 shadow-sm" style="border-radius: 16px;">
            <div class="card-header bg-transparent border-0 pt-4 px-4">
              <h4 class="fw-bold mb-0" style="color: #4caf50">
                <i class="fas fa-user-plus me-2"></i>Assign New Worker
              </h4>
            </div>
            <div class="card-body p-4">
              <form id="assignWorkerForm">
                <div class="row g-4">
                  <div class="col-md-12">
                    <label class="form-label fw-semibold">Select Worker</label>
                    <select class="form-select" id="workerSelect" required style="border-radius: 40px; padding: 0.5rem 1rem;">
                      <option value="">Choose worker...</option>
                      <% availableWorkers.forEach(worker => { %>
                      <option value="<%= worker._id %>"><%= worker.name %> (<%= worker.workerNumber || 'No ID' %>) - <%= worker.position || 'Worker' %></option>
                      <% }) %>
                    </select>
                  </div>
                  <div class="col-md-6">
                    <label class="form-label fw-semibold">Shift</label>
                    <select class="form-select" id="shiftSelect" required style="border-radius: 40px; padding: 0.5rem 1rem;">
                      <option value="morning">Morning</option>
                      <option value="afternoon">Afternoon</option>
                      <option value="night">Night</option>
                    </select>
                  </div>
                  <div class="col-md-6">
                    <label class="form-label fw-semibold">Department</label>
                    <input type="text" class="form-control" id="departmentInput" placeholder="e.g., Maintenance, Operations" style="border-radius: 40px;">
                  </div>
                  <div class="col-12">
                    <div class="form-check">
                      <input class="form-check-input" type="checkbox" id="isTeamLeadCheck" style="border-radius: 4px;">
                      <label class="form-check-label" for="isTeamLeadCheck">
                        Set as Team Lead
                      </label>
                    </div>
                  </div>
                  <div class="col-12">
                    <button type="submit" class="btn w-100 py-2" style="background: #4caf50; color: white; border: none; border-radius: 40px;">
                      <i class="fas fa-user-plus me-2"></i>Assign Worker
                    </button>
                  </div>
                </div>
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const workAreaId = '<%= workArea._id %>';

  // Handle assign worker
  document.getElementById('assignWorkerForm').addEventListener('submit', function(e) {
    e.preventDefault();
    
    const workerId = document.getElementById('workerSelect').value;
    const shift = document.getElementById('shiftSelect').value;
    const department = document.getElementById('departmentInput').value;
    const isTeamLead = document.getElementById('isTeamLeadCheck').checked;

    if (!workerId) {
      Swal.fire({
        icon: 'warning',
        title: 'No Worker Selected',
        text: 'Please select a worker to assign',
        confirmButtonColor: '#4caf50',
        confirmButtonText: 'OK'
      });
      return;
    }

    fetch(`/work-areas/${workAreaId}/assign-worker`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ workerId, shift, isTeamLead, department })
    })
    .then(res => res.json())
    .then(data => {
      if (data.success) {
        Swal.fire({
          icon: 'success',
          title: 'Success!',
          text: 'Worker assigned successfully',
          confirmButtonColor: '#4caf50',
          timer: 1500,
          showConfirmButton: false
        }).then(() => {
          window.location.reload();
        });
      } else {
        Swal.fire({
          icon: 'error',
          title: 'Error',
          text: data.message || 'Failed to assign worker',
          confirmButtonColor: '#4caf50'
        });
      }
    })
    .catch(err => {
      console.error('Error assigning worker:', err);
      Swal.fire({
        icon: 'error',
        title: 'Error',
        text: 'An unexpected error occurred',
        confirmButtonColor: '#4caf50'
      });
    });
  });

  // Handle remove worker
  document.querySelectorAll('.remove-worker').forEach(btn => {
    btn.addEventListener('click', function() {
      const assignmentId = this.dataset.assignmentId;
      
      Swal.fire({
        title: 'Remove Worker?',
        text: 'Are you sure you want to remove this worker from the work area?',
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#f44336',
        cancelButtonColor: '#6c757d',
        confirmButtonText: 'Yes, remove',
        cancelButtonText: 'Cancel'
      }).then((result) => {
        if (result.isConfirmed) {
          fetch(`/work-areas/${workAreaId}/workers/${assignmentId}`, {
            method: 'DELETE'
          })
          .then(res => res.json())
          .then(data => {
            if (data.success) {
              Swal.fire({
                icon: 'success',
                title: 'Removed!',
                text: 'Worker has been removed',
                confirmButtonColor: '#4caf50',
                timer: 1500,
                showConfirmButton: false
              }).then(() => {
                window.location.reload();
              });
            } else {
              Swal.fire({
                icon: 'error',
                title: 'Error',
                text: data.message || 'Failed to remove worker',
                confirmButtonColor: '#4caf50'
              });
            }
          })
          .catch(err => {
            console.error('Error removing worker:', err);
            Swal.fire({
              icon: 'error',
              title: 'Error',
              text: 'An unexpected error occurred',
              confirmButtonColor: '#4caf50'
            });
          });
        }
      });
    });
  });
});
</script>

<style>
  .main-wrapper {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }
  
  .content {
    flex: 1;
  }

  .card {
    border-radius: 16px;
  }
  
  .badge {
    font-weight: 500;
    font-size: 0.75rem;
    padding: 0.3rem 0.6rem;
  }
  
  .btn {
    transition: all 0.2s ease;
  }
  
  .btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
  }
  
  .form-select, .form-control {
    border: 1px solid #dee2e6;
    transition: border-color 0.2s ease;
  }
  
  .form-select:focus, .form-control:focus {
    border-color: #4caf50;
    box-shadow: 0 0 0 0.2rem rgba(76, 175, 80, 0.25);
  }
  
  .form-check-input:checked {
    background-color: #4caf50;
    border-color: #4caf50;
  }
  
  .list-group-item {
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  
  .list-group-item:hover {
    transform: translateX(5px);
    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05);
  }
  
  .btn-outline-danger {
    border-color: #f44336;
    color: #f44336;
  }
  .btn-outline-danger:hover {
    background-color: #f44336;
    color: white;
  }
  
  .btn-outline-secondary {
    border-color: #6c757d;
    color: #6c757d;
  }
  .btn-outline-secondary:hover {
    background-color: #6c757d;
    color: white;
  }
</style>

<%- include('../partials/footer') %>