<%- include('partials/header') %> <%- include('partials/navbar') %>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-10">
      <h2 class="text-center fw-bold mb-4">Choose Your Account Type</h2>

      <div class="row g-4">
        <!-- Solo Practitioner Card -->
        <div class="col-md-6">
          <div class="card h-100 shadow-lg border-0 hover-card">
            <div class="card-body text-center p-5">
              <div
                class="icon-circle mb-4 mx-auto"
                style="
                  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
                  width: 100px;
                  height: 100px;
                  border-radius: 50%;
                  display: flex;
                  align-items: center;
                  justify-content: center;
                "
              >
                <i class="fas fa-user-tie fa-3x text-white"></i>
              </div>
              <h3 class="fw-bold mb-3">Solo Practitioner</h3>
              <p class="text-muted mb-4">
                You are a one-person safety consultant. You'll have both Admin
                and Safety Officer powers in one account.
              </p>
              <ul class="text-start list-unstyled mb-4">
                <li class="mb-2">
                  <i class="fas fa-check-circle text-success me-2"></i> Create
                  your own worksites
                </li>
                <li class="mb-2">
                  <i class="fas fa-check-circle text-success me-2"></i> Full
                  admin privileges
                </li>
                <li class="mb-2">
                  <i class="fas fa-check-circle text-success me-2"></i> Full
                  safety officer privileges
                </li>
                <li class="mb-2">
                  <i class="fas fa-check-circle text-success me-2"></i> Add team
                  members later
                </li>
              </ul>
              <a
                href="/register/solo"
                class="btn btn-lg w-100"
                style="
                  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
                  color: white;
                "
              >
                <i class="fas fa-user-plus me-2"></i> Register as Solo
              </a>
            </div>
          </div>
        </div>

        <!-- Enterprise Admin Card -->
        <div class="col-md-6">
          <div class="card h-100 shadow-lg border-0 hover-card">
            <div class="card-body text-center p-5">
              <div
                class="icon-circle mb-4 mx-auto"
                style="
                  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
                  width: 100px;
                  height: 100px;
                  border-radius: 50%;
                  display: flex;
                  align-items: center;
                  justify-content: center;
                "
              >
                <i class="fas fa-building fa-3x text-white"></i>
              </div>
              <h3 class="fw-bold mb-3">Enterprise Admin</h3>
              <p class="text-muted mb-4">
                You manage a company with multiple safety officers. You'll
                create worksites and assign officers.
              </p>
              <ul class="text-start list-unstyled mb-4">
                <li class="mb-2">
                  <i class="fas fa-check-circle text-success me-2"></i> Create
                  company worksites
                </li>
                <li class="mb-2">
                  <i class="fas fa-check-circle text-success me-2"></i> Create
                  safety officer accounts
                </li>
                <li class="mb-2">
                  <i class="fas fa-check-circle text-success me-2"></i> Assign
                  officers to worksites
                </li>
                <li class="mb-2">
                  <i class="fas fa-check-circle text-success me-2"></i> Approve
                  documents & reports
                </li>
              </ul>
              <a
                href="/register/enterprise-admin"
                class="btn btn-lg w-100"
                style="
                  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
                  color: white;
                "
              >
                <i class="fas fa-building me-2"></i> Register as Enterprise
                Admin
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Note about existing safety officers -->
      <div class="row mt-4">
        <div class="col-12">
          <div class="alert alert-info text-center">
            <i class="fas fa-info-circle me-2"></i>
            Are you a safety officer invited by your company?
            <a href="/api/users/login" class="alert-link">Login here</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .hover-card {
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease;
  }

  .hover-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15) !important;
  }

  .icon-circle {
    transition: transform 0.3s ease;
  }

  .hover-card:hover .icon-circle {
    transform: scale(1.1);
  }
</style>

<%- include('partials/footer') %>
