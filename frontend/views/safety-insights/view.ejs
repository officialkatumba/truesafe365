<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="container py-4">
  <div class="p-4 mb-4 rounded-3" style="background: linear-gradient(135deg, #6f42c1, #20c997);">
    <div class="d-flex justify-content-between align-items-center flex-wrap">
      <div>
        <h2 class="text-white fw-bold mb-2">
          <i class="fas fa-brain me-2"></i>
          AI Safety Insight #<%= insight.insightNumber %>
        </h2>
        <p class="text-white-50 mb-0">
          <%= insight.title %>
        </p>
      </div>

      <div class="text-end">
        <span class="badge <%= 
          insight.priorityLevel === 'critical' ? 'bg-danger' :
          insight.priorityLevel === 'high' ? 'bg-warning text-dark' :
          insight.priorityLevel === 'medium' ? 'bg-info' :
          'bg-secondary'
        %> px-3 py-2">
          <%= insight.priorityLevel?.toUpperCase() || 'MEDIUM' %>
        </span>

        <p class="text-white-50 small mt-2 mb-0">
          <i class="fas fa-calendar me-1"></i>
          <%= new Date(insight.createdAt).toLocaleDateString() %>
        </p>
      </div>
    </div>
  </div>

  <div class="card shadow-sm border-0 mb-4">
    <div class="card-body">
      <h5 class="fw-bold text-primary">
        <i class="fas fa-info-circle me-2"></i>
        Executive Summary
      </h5>

      <p class="mb-0">
        <%= insight.summary || 'No summary provided.' %>
      </p>
    </div>
  </div>

  <div class="row g-3 mb-4">
    <div class="col-md-3">
      <div class="card border-0 shadow-sm text-center">
        <div class="card-body">
          <h4 class="fw-bold text-danger"><%= insight.dataCounts?.incidents || 0 %></h4>
          <small class="text-muted">Incidents / Near Misses</small>
        </div>
      </div>
    </div>

    <div class="col-md-3">
      <div class="card border-0 shadow-sm text-center">
        <div class="card-body">
          <h4 class="fw-bold text-warning"><%= insight.dataCounts?.observations || 0 %></h4>
          <small class="text-muted">Observations</small>
        </div>
      </div>
    </div>

    <div class="col-md-3">
      <div class="card border-0 shadow-sm text-center">
        <div class="card-body">
          <h4 class="fw-bold text-primary"><%= insight.dataCounts?.riskAssessments || 0 %></h4>
          <small class="text-muted">Risk Assessments</small>
        </div>
      </div>
    </div>

    <div class="col-md-3">
      <div class="card border-0 shadow-sm text-center">
        <div class="card-body">
          <h4 class="fw-bold text-success"><%= insight.dataCounts?.jsas || 0 %></h4>
          <small class="text-muted">JSAs</small>
        </div>
      </div>
    </div>
  </div>

  <div class="card shadow-sm border-0 mb-4">
    <div class="card-header text-white" style="background: #6f42c1;">
      <h5 class="mb-0">
        <i class="fas fa-eye me-2"></i>
        Part 1: Comprehensive Site-Wide Safety Concerns and Observations
      </h5>
    </div>

    <div class="card-body">
      <div style="white-space: pre-wrap; line-height: 1.7;">
        <%= insight.safetyConcernsAndObservations %>
      </div>
    </div>
  </div>

  <div class="card shadow-sm border-0 mb-4">
    <div class="card-header text-white" style="background: #198754;">
      <h5 class="mb-0">
        <i class="fas fa-list-check me-2"></i>
        Part 2: Actionable Recommendations
      </h5>
    </div>

    <div class="card-body">
      <div style="white-space: pre-wrap; line-height: 1.7;">
        <%= insight.actionableRecommendations %>
      </div>
    </div>
  </div>

  <div class="card shadow-sm border-0 mb-4">
    <div class="card-header bg-dark text-white">
      <h5 class="mb-0">
        <i class="fas fa-bullseye me-2"></i>
        Recommended Areas of Attention
      </h5>
    </div>

    <div class="card-body">
      <% if (insight.recommendedFocusAreas && insight.recommendedFocusAreas.length > 0) { %>
        <div class="d-flex flex-wrap gap-2">
          <% insight.recommendedFocusAreas.forEach(area => { %>
            <span class="badge bg-light text-dark border p-2">
              <i class="fas fa-bullseye me-1"></i>
              <%= area %>
            </span>
          <% }) %>
        </div>
      <% } else { %>
        <p class="text-muted mb-0">No specific focus areas identified.</p>
      <% } %>
    </div>
  </div>

  <div class="card shadow-sm border-0 mb-4">
    <div class="card-header bg-light">
      <h5 class="mb-0">
        <i class="fas fa-file-alt me-2"></i>
        Suggested Document Actions
      </h5>
    </div>

    <div class="card-body">
      <div class="row g-2">
        <div class="col-md-6">
          <span class="badge <%= insight.recommendedDocumentActions?.regenerateRiskAssessment ? 'bg-danger' : 'bg-secondary' %> p-2 w-100">
            Regenerate Risk Assessment:
            <%= insight.recommendedDocumentActions?.regenerateRiskAssessment ? 'YES' : 'NO' %>
          </span>
        </div>

        <div class="col-md-6">
          <span class="badge <%= insight.recommendedDocumentActions?.reviewRiskAssessment ? 'bg-warning text-dark' : 'bg-secondary' %> p-2 w-100">
            Review Risk Assessment:
            <%= insight.recommendedDocumentActions?.reviewRiskAssessment ? 'YES' : 'NO' %>
          </span>
        </div>

        <div class="col-md-6">
          <span class="badge <%= insight.recommendedDocumentActions?.generateOrReviewJSA ? 'bg-primary' : 'bg-secondary' %> p-2 w-100">
            Generate / Review JSA:
            <%= insight.recommendedDocumentActions?.generateOrReviewJSA ? 'YES' : 'NO' %>
          </span>
        </div>

        <div class="col-md-6">
          <span class="badge <%= insight.recommendedDocumentActions?.generateSafetyTalk ? 'bg-success' : 'bg-secondary' %> p-2 w-100">
            Generate Safety Talk:
            <%= insight.recommendedDocumentActions?.generateSafetyTalk ? 'YES' : 'NO' %>
          </span>
        </div>

        <div class="col-md-6">
          <span class="badge <%= insight.recommendedDocumentActions?.reviewCorrectiveActions ? 'bg-info' : 'bg-secondary' %> p-2 w-100">
            Review Corrective Actions:
            <%= insight.recommendedDocumentActions?.reviewCorrectiveActions ? 'YES' : 'NO' %>
          </span>
        </div>
      </div>
    </div>
  </div>

  <div class="text-center">
    <a href="/work-areas/<%= insight.workArea?._id || insight.workArea %>#insights" class="btn btn-outline-secondary">
      <i class="fas fa-arrow-left me-1"></i>
      Back to Work Area
    </a>
  </div>
</div>

<%- include('../partials/footer') %>