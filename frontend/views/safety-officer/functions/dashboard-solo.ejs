<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="container py-5">
  <!-- Header with Profile Summary -->
  <div class="row mb-4">
    <div class="col-12">
      <div class="card border-0" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
        <div class="card-body p-4 text-white">
          <div class="row align-items-center">
            <div class="col-md-8">
              <div class="d-flex align-items-center mb-2">
                <i class="fas fa-crown fa-2x me-3"></i>
                <div>
                  <h2 class="display-5 fw-bold mb-0">Solo Practitioner Dashboard</h2>
                  <p class="lead mb-0">You have full admin + safety officer privileges</p>
                </div>
              </div>
              <p class="mb-2 mt-3">
                Welcome back, <strong><%= user.safetyOfficer?.name || user.email %></strong>
              </p>
              <div class="mt-2">
                <span class="badge bg-warning text-dark p-2 me-2">
                  <i class="fas fa-crown me-1"></i> System Admin
                </span>
                <span class="badge bg-info p-2 me-2">
                  <i class="fas fa-hard-hat me-1"></i> Safety Officer
                </span>
                <span class="badge bg-secondary p-2">
                  <i class="fas fa-id-card me-1"></i> #<%= user.safetyOfficer?.officerNumber || 'N/A' %>
                </span>
                
                <% 
                let verificationBadge = '⏳ Pending Verification';
                let badgeClass = 'bg-warning text-dark';
                if (user.safetyOfficer?.verificationStatus === 'verified') {
                  verificationBadge = '✓ Verified';
                  badgeClass = 'bg-success';
                }
                %>
                
                <span class="badge <%= badgeClass %> p-2">
                  <i class="fas fa-certificate me-1"></i> <%= verificationBadge %>
                </span>
              </div>
            </div>
            <div class="col-md-4 text-center text-md-end mt-3 mt-md-0">
              <img src="<%= user.safetyOfficer?.profileImage || 'https://cdn.pixabay.com/photo/2015/10/05/22/37/blank-profile-picture-973460_960_720.png' %>" 
                   alt="Profile" 
                   class="rounded-circle border border-3 border-white shadow"
                   style="width: 120px; height: 120px; object-fit: cover;">
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Safety Summary Cards - Quick Stats -->
  <div class="row mb-5">
    <div class="col-12">
      <div class="card shadow-sm border-0">
        <div class="card-body p-4">
          <h4 class="fw-bold mb-4" style="color: #1e3c5c">
            <i class="fas fa-chart-line me-2"></i>Safety Performance Overview
          </h4>
          <div class="row g-3">
            <!-- Worksites -->
            <div class="col-md-3 col-6">
              <div class="d-flex align-items-center p-3 rounded" style="background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);">
                <div class="rounded-circle p-3 me-3" style="background: linear-gradient(135deg, #2196f3 0%, #1976d2 100%);">
                  <i class="fas fa-hard-hat fa-2x text-white"></i>
                </div>
                <div>
                  <h3 class="fw-bold mb-0"><%= user.safetyOfficer?.worksites?.length || 0 %></h3>
                  <small class="text-muted">Worksites</small>
                </div>
              </div>
            </div>

            <!-- Incidents -->
            <div class="col-md-3 col-6">
              <div class="d-flex align-items-center p-3 rounded" style="background: linear-gradient(135deg, #ffebee 0%, #ffcdd2 100%);">
                <div class="rounded-circle p-3 me-3" style="background: linear-gradient(135deg, #f44336 0%, #d32f2f 100%);">
                  <i class="fas fa-exclamation-triangle fa-2x text-white"></i>
                </div>
                <div>
                  <h3 class="fw-bold mb-0"><%= user.safetyOfficer?.incidentsReported || 0 %></h3>
                  <small class="text-muted">Incidents</small>
                </div>
              </div>
            </div>

            <!-- Safety Talks -->
            <div class="col-md-3 col-6">
              <div class="d-flex align-items-center p-3 rounded" style="background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%);">
                <div class="rounded-circle p-3 me-3" style="background: linear-gradient(135deg, #4caf50 0%, #388e3c 100%);">
                  <i class="fas fa-chalkboard-teacher fa-2x text-white"></i>
                </div>
                <div>
                  <h3 class="fw-bold mb-0"><%= user.safetyOfficer?.safetyTalksConducted || 0 %></h3>
                  <small class="text-muted">Safety Talks</small>
                </div>
              </div>
            </div>

            <!-- Team Members -->
            <div class="col-md-3 col-6">
              <div class="d-flex align-items-center p-3 rounded" style="background: linear-gradient(135deg, #fff3e0 0%, #ffe0b2 100%);">
                <div class="rounded-circle p-3 me-3" style="background: linear-gradient(135deg, #ff9800 0%, #f57c00 100%);">
                  <i class="fas fa-users fa-2x text-white"></i>
                </div>
                <div>
                  <h3 class="fw-bold mb-0">0</h3>
                  <small class="text-muted">Team Members</small>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Two Column Functional Layout - Admin and Safety Officer Main Cards -->
  <div class="row g-4">
    <!-- Left Column: Admin Functions Main Card -->
    <div class="col-lg-6">
      <div class="card h-100 shadow-lg border-0 hover-card">
        <div class="card-body p-5">
          <div class="text-center mb-4">
            <div class="icon-circle mb-4 mx-auto" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); width: 100px; height: 100px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
              <i class="fas fa-crown fa-3x text-white"></i>
            </div>
            <h2 class="fw-bold mb-2" style="color: #667eea">Admin Functions</h2>
            <p class="text-muted">Manage your worksite structure and team</p>
          </div>

          <div class="text-start mb-4">
            <h6 class="fw-bold mb-3">
              <i class="fas fa-check-circle text-success me-2"></i>You can:
            </h6>
            <ul class="list-unstyled">
              <li class="mb-3">
                <i class="fas fa-check text-success me-2"></i> 
                <strong>Create worksites</strong> - Add new worksites to your portfolio
              </li>
              <li class="mb-3">
                <i class="fas fa-check text-success me-2"></i> 
                <strong>Manage worksites</strong> - View and edit all your worksites
              </li>
              <li class="mb-3">
                <i class="fas fa-check text-success me-2"></i> 
                <strong>Add team members</strong> - Invite workers and supervisors
              </li>
              <li class="mb-3">
                <i class="fas fa-check text-success me-2"></i> 
                <strong>Share worksites</strong> - Collaborate with other officers
              </li>
              <li class="mb-3">
                <i class="fas fa-check text-success me-2"></i> 
                <strong>Assign safety officers</strong> - Delegate responsibilities
              </li>
              <li class="mb-3">
                <i class="fas fa-check text-success me-2"></i> 
                <strong>Company-wide compliance</strong> - Track overall performance
              </li>
            </ul>
          </div>

          <div class="bg-light p-3 rounded-3 mt-3 mb-4">
            <p class="mb-0">
              <strong>Quick Stats:</strong> <%= user.safetyOfficer?.worksites?.length || 0 %> worksites | 0 team members
            </p>
          </div>

          <!-- Button to Admin Functions Page -->
          <div class="d-grid">
            <!-- <a href="/admin/functions" class="btn btn-lg py-3" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; border: none; border-radius: 50px;">
              <i class="fas fa-arrow-right me-2"></i> Go to Admin Functions
            </a> -->

            <!-- In the Admin Functions card -->
<a href="/functions/admin-functions" class="btn btn-lg py-3" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; border: none; border-radius: 50px;">
  <i class="fas fa-arrow-right me-2"></i> Go to Admin Functions
</a>
          </div>
        </div>
      </div>
    </div>

    <!-- Right Column: Safety Officer Functions Main Card -->
    <div class="col-lg-6">
      <div class="card h-100 shadow-lg border-0 hover-card">
        <div class="card-body p-5">
          <div class="text-center mb-4">
            <div class="icon-circle mb-4 mx-auto" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); width: 100px; height: 100px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
              <i class="fas fa-hard-hat fa-3x text-white"></i>
            </div>
            <h2 class="fw-bold mb-2" style="color: #f093fb">Safety Officer Functions</h2>
            <p class="text-muted">Daily safety operations and documentation</p>
          </div>

          <div class="text-start mb-4">
            <h6 class="fw-bold mb-3">
              <i class="fas fa-check-circle text-success me-2"></i>You can:
            </h6>
            <ul class="list-unstyled">
              <li class="mb-3">
                <i class="fas fa-check text-success me-2"></i> 
                <strong>Report incidents</strong> - Log new incidents or near-misses
              </li>
              <li class="mb-3">
                <i class="fas fa-check text-success me-2"></i> 
                <strong>Generate safety talks</strong> - Create AI-powered briefings
              </li>
              <li class="mb-3">
                <i class="fas fa-check text-success me-2"></i> 
                <strong>Risk assessments</strong> - Create and manage assessments
              </li>
              <li class="mb-3">
                <i class="fas fa-check text-success me-2"></i> 
                <strong>PPE compliance</strong> - Run compliance checks
              </li>
              <li class="mb-3">
                <i class="fas fa-check text-success me-2"></i> 
                <strong>View all talks</strong> - Browse safety briefings
              </li>
              <li class="mb-3">
                <i class="fas fa-check text-success me-2"></i> 
                <strong>Compliance reports</strong> - Generate audit documentation
              </li>
            </ul>
          </div>

          <div class="bg-light p-3 rounded-3 mt-3 mb-4">
            <p class="mb-0">
              <strong>Recent Activity:</strong> <%= user.safetyOfficer?.incidentsReported || 0 %> incidents | <%= user.safetyOfficer?.safetyTalksConducted || 0 %> talks
            </p>
          </div>

          <!-- Button to Safety Officer Functions Page -->

           
          <div class="d-grid">
            <!-- <a href="/safety-officer/functions" class="btn btn-lg py-3" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); color: white; border: none; border-radius: 50px;">
              <i class="fas fa-arrow-right me-2"></i> Go to Safety Officer Functions
            </a> -->
            <!-- In the Safety Officer Functions card -->
<a href="/functions/safety-officer-functions" class="btn btn-lg py-3" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); color: white; border: none; border-radius: 50px;">
  <i class="fas fa-arrow-right me-2"></i> Go to Safety Officer Functions
</a>
          </div>
        </div>
      </div>
    </div>
  </div>


  <!-- Info Banner -->
  <div class="row mt-5">
    <div class="col-12">
      <div class="alert alert-info text-center mb-0">
        <i class="fas fa-info-circle me-2"></i>
        <strong>Need help?</strong> Visit our <a href="#" class="alert-link">documentation</a> or 
        <a href="#" class="alert-link">contact support</a>.
      </div>
    </div>
  </div>
</div>

<style>
  .hover-card {
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .hover-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15) !important;
  }

  .icon-circle {
    transition: transform 0.3s ease;
  }

  .hover-card:hover .icon-circle {
    transform: scale(1.1);
  }

  .btn {
    transition: all 0.3s ease;
  }

  .btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
  }
  
  .card {
    border-radius: 16px;
  }
  
  .badge {
    font-size: 0.8rem;
    padding: 0.4rem 0.6rem;
  }
  
  ul.list-unstyled li {
    border-bottom: 1px solid #f0f0f0;
    padding-bottom: 0.75rem;
  }
  
  ul.list-unstyled li:last-child {
    border-bottom: none;
  }
</style>

<%- include('../partials/footer') %>