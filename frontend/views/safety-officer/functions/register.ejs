<%- include('../partials/header') %> <%- include('../partials/navbar') %>

<div class="d-flex align-items-center justify-content-center min-vh-100 py-5">
  <div
    class="card shadow-lg border-0 p-4"
    style="
      max-width: 500px;
      width: 100%;
      border-radius: 12px;
      background: white;
    "
  >
    <div class="text-center mb-4">
      <i
        class="fas fa-shield-alt fa-3x mb-2"
        style="color: var(--secondary)"
      ></i>
      <h3 class="fw-bold" style="color: var(--primary)">
        Safety Officer Registration
      </h3>
      <p class="text-muted mb-0">
        Register to manage worksite safety and protect your team
      </p>
    </div>

    <form action="/safety-officers/register" method="POST">
      <div class="mb-3">
        <label for="name" class="form-label fw-semibold">Full Name *</label>
        <input
          type="text"
          name="name"
          id="name"
          class="form-control form-control-lg"
          placeholder="Enter your full name"
          required
        />
      </div>

      <div class="mb-3">
        <label for="phone" class="form-label fw-semibold">Phone Number *</label>
        <input
          type="tel"
          name="phone"
          id="phone"
          class="form-control form-control-lg"
          required
          placeholder="e.g. +260971234567"
        />
      </div>

      <div class="mb-3">
        <label for="email" class="form-label fw-semibold">Email *</label>
        <input
          type="email"
          name="email"
          id="email"
          class="form-control form-control-lg"
          placeholder="you@example.com"
          required
        />
      </div>

      <div class="mb-3">
        <label for="password" class="form-label fw-semibold">Password *</label>
        <input
          type="password"
          name="password"
          id="password"
          class="form-control form-control-lg"
          placeholder="Enter your password"
          required
        />
      </div>

      <div class="mb-3">
        <label for="bio" class="form-label fw-semibold"
          >Safety Experience & Qualifications (50-150 words) *</label
        >
        <textarea
          name="bio"
          id="bio"
          rows="4"
          class="form-control form-control-lg"
          required
          placeholder="Describe your safety experience, training, and qualifications..."
        ></textarea>
        <small id="wordCount" class="form-text text-muted">0 / 150 words</small>

        <div
          id="wordCountAlert"
          class="alert alert-danger mt-2 d-none"
          role="alert"
        >
          Please ensure your experience statement is between 50 and 150 words.
        </div>
      </div>

      <!-- Hidden fields -->
      <div class="mb-3 d-none">
        <label for="profileImage" class="form-label">Profile Image URL</label>
        <input
          type="url"
          name="profileImage"
          id="profileImage"
          class="form-control"
          value="https://cdn.pixabay.com/photo/2015/10/05/22/37/blank-profile-picture-973460_960_720.png"
          readonly
        />
      </div>

      <button
        type="submit"
        class="btn w-100 py-3 fw-bold"
        style="
          background: #dc3545;
          color: white;
          border-radius: 50px;
          border: 2px solid #dc3545;
          font-size: 1.2rem;
          letter-spacing: 1px;
          text-transform: uppercase;
          box-shadow: 0 8px 20px rgba(220, 53, 69, 0.4);
          transition: all 0.3s ease;
          position: relative;
          overflow: hidden;
        "
      >
        <i class="fas fa-shield-alt me-2"></i> Register as Safety Officer
      </button>
    </form>

    <div class="text-center mt-4">
      <p class="mb-1 text-muted">Already have an account?</p>
      <a
        href="/api/users/login"
        class="fw-semibold"
        style="color: var(--secondary)"
      >
        <i class="fas fa-sign-in-alt me-1"></i> Login Here
      </a>
    </div>
  </div>
</div>

<style>
  .btn::before {
    content: "";
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 255, 255, 0.2),
      transparent
    );
    transition: left 0.5s ease;
    pointer-events: none;
  }

  .btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 30px rgba(220, 53, 69, 0.6) !important;
    background: #c82333 !important;
    border-color: #c82333 !important;
  }

  .btn:hover::before {
    left: 100%;
  }

  .btn:active {
    transform: translateY(-1px);
    box-shadow: 0 5px 15px rgba(220, 53, 69, 0.4) !important;
  }

  .form-control:focus {
    border-color: #e67e22;
    box-shadow: 0 0 0 0.2rem rgba(230, 126, 34, 0.25);
  }
</style>

<%- include('../partials/footer') %>

<script>
  const textarea = document.getElementById("bio");
  const wordCountDisplay = document.getElementById("wordCount");
  const alertBox = document.getElementById("wordCountAlert");

  function countWords(text) {
    return text
      .trim()
      .split(/\s+/)
      .filter((word) => word.length > 0).length;
  }

  textarea.addEventListener("input", () => {
    const words = countWords(textarea.value);
    wordCountDisplay.textContent = `${words} / 150 words`;

    if (words < 50) {
      wordCountDisplay.style.color = "red";
      alertBox.textContent = `Please enter at least 50 words. You have entered ${words}.`;
      alertBox.classList.remove("d-none");
      alertBox.classList.remove("alert-success");
      alertBox.classList.add("alert-danger");
    } else if (words > 150) {
      wordCountDisplay.style.color = "red";
      alertBox.textContent = `You have exceeded the 150-word limit by ${
        words - 150
      } word${words - 150 === 1 ? "" : "s"}.`;
      alertBox.classList.remove("d-none");
      alertBox.classList.remove("alert-success");
      alertBox.classList.add("alert-danger");
    } else {
      wordCountDisplay.style.color = "green";
      alertBox.textContent = "Word count is good! (50-150 words)";
      alertBox.classList.remove("d-none");
      alertBox.classList.remove("alert-danger");
      alertBox.classList.add("alert-success");
    }
  });

  const form = textarea.closest("form");
  form.addEventListener("submit", (e) => {
    const words = countWords(textarea.value);
    if (words < 50 || words > 150) {
      e.preventDefault();
      if (words < 50) {
        alertBox.textContent = `Please enter at least 50 words. You have entered ${words}.`;
      } else {
        alertBox.textContent = `You have exceeded the 150-word limit by ${
          words - 150
        } word${words - 150 === 1 ? "" : "s"}.`;
      }
      alertBox.classList.remove("d-none");
      alertBox.classList.remove("alert-success");
      alertBox.classList.add("alert-danger");
      textarea.focus();
    }
  });
</script>
