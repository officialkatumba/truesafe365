<%- include('../partials/header') %> <%- include('../partials/navbar') %>

<div class="container my-5">
  <!-- Header with Profile Summary (your existing dashboard) -->
  <div class="row mb-4">
    <div class="col-12">
      <div
        class="card border-0 bg-gradient-primary text-white"
        style="background: linear-gradient(135deg, #1e3c5c 0%, #2c5a82 100%)"
      >
        <div class="card-body p-4">
          <div class="row align-items-center">
            <div class="col-md-8">
              <h2 class="display-5 fw-bold mb-2">
                <i class="fas fa-shield-alt me-2"></i>Safety Officer Dashboard
              </h2>
              <p class="lead mb-0">
                Welcome back,
                <strong><%= user.safetyOfficer?.name || user.email %></strong>
              </p>
              <p class="mb-0 mt-2">
                <span class="badge bg-warning text-dark p-2">
                  <i class="fas fa-id-card me-1"></i> Officer #<%=
                  user.safetyOfficer?.officerNumber || 'N/A' %>
                </span>
                <span class="badge bg-info ms-2 p-2">
                  <i class="fas fa-building me-1"></i> Enterprise Officer
                </span>
              </p>
            </div>
            <div class="col-md-4 text-center text-md-end">
              <div class="profile-image-container">
                <img
                  src="<%= user.safetyOfficer?.profileImage || 'https://cdn.pixabay.com/photo/2015/10/05/22/37/blank-profile-picture-973460_960_720.png' %>"
                  alt="Profile"
                  class="rounded-circle border border-3 border-white shadow"
                  style="width: 120px; height: 120px; object-fit: cover"
                />
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Safety Summary Cards (your existing cards) -->
  <div class="row mb-5">
    <div class="col-12">
      <div class="card shadow-sm border-0">
        <div class="card-body p-4">
          <h4 class="fw-bold mb-4" style="color: #1e3c5c">
            <i class="fas fa-chart-line me-2"></i>My Safety Performance Overview
          </h4>
          <div class="row g-3">
            <div class="col-md-3 col-6">
              <div
                class="d-flex align-items-center p-3 rounded"
                style="
                  background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);
                "
              >
                <div
                  class="rounded-circle p-3 me-3"
                  style="
                    background: linear-gradient(
                      135deg,
                      #2196f3 0%,
                      #1976d2 100%
                    );
                  "
                >
                  <i class="fas fa-hard-hat fa-2x text-white"></i>
                </div>
                <div>
                  <h3 class="fw-bold mb-0">
                    <%= user.safetyOfficer?.worksitesManaged || 0 %>
                  </h3>
                  <small class="text-muted">Assigned Worksites</small>
                </div>
              </div>
            </div>
            <div class="col-md-3 col-6">
              <div
                class="d-flex align-items-center p-3 rounded"
                style="
                  background: linear-gradient(135deg, #ffebee 0%, #ffcdd2 100%);
                "
              >
                <div
                  class="rounded-circle p-3 me-3"
                  style="
                    background: linear-gradient(
                      135deg,
                      #f44336 0%,
                      #d32f2f 100%
                    );
                  "
                >
                  <i class="fas fa-exclamation-triangle fa-2x text-white"></i>
                </div>
                <div>
                  <h3 class="fw-bold mb-0">
                    <%= user.safetyOfficer?.incidentsReported || 0 %>
                  </h3>
                  <small class="text-muted">Incidents</small>
                </div>
              </div>
            </div>
            <div class="col-md-3 col-6">
              <div
                class="d-flex align-items-center p-3 rounded"
                style="
                  background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%);
                "
              >
                <div
                  class="rounded-circle p-3 me-3"
                  style="
                    background: linear-gradient(
                      135deg,
                      #4caf50 0%,
                      #388e3c 100%
                    );
                  "
                >
                  <i class="fas fa-chalkboard-teacher fa-2x text-white"></i>
                </div>
                <div>
                  <h3 class="fw-bold mb-0">
                    <%= user.safetyOfficer?.safetyTalksConducted || 0 %>
                  </h3>
                  <small class="text-muted">Safety Talks</small>
                </div>
              </div>
            </div>
            <div class="col-md-3 col-6">
              <div
                class="d-flex align-items-center p-3 rounded"
                style="
                  background: linear-gradient(135deg, #fff3e0 0%, #ffe0b2 100%);
                "
              >
                <div
                  class="rounded-circle p-3 me-3"
                  style="
                    background: linear-gradient(
                      135deg,
                      #ff9800 0%,
                      #f57c00 100%
                    );
                  "
                >
                  <i class="fas fa-shield-alt fa-2x text-white"></i>
                </div>
                <div>
                  <h3 class="fw-bold mb-0">98%</h3>
                  <small class="text-muted">Compliance</small>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Action Cards (your existing 6 cards) -->
  <div class="row g-4">
    <!-- Worksite Management -->
    <div class="col-lg-4 col-md-6">
      <div class="card shadow-sm border-0 h-100 hover-card">
        <div class="card-body text-center p-4">
          <div
            class="icon-circle mb-3 mx-auto"
            style="
              background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
              width: 80px;
              height: 80px;
              border-radius: 50%;
              display: flex;
              align-items: center;
              justify-content: center;
            "
          >
            <i class="fas fa-hard-hat fa-3x text-white"></i>
          </div>
          <h5 class="card-title fw-bold">Worksites</h5>
          <p class="card-text text-muted mb-4">
            View and manage your assigned worksites
          </p>
          <a
            href="/worksites/my-worksites"
            class="btn w-100"
            style="
              background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
              color: white;
            "
          >
            <i class="fas fa-list me-1"></i> View Worksites
          </a>
        </div>
      </div>
    </div>
    <!-- Incident Reporting -->
    <div class="col-lg-4 col-md-6">
      <div class="card shadow-sm border-0 h-100 hover-card">
        <div class="card-body text-center p-4">
          <div
            class="icon-circle mb-3 mx-auto"
            style="
              background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
              width: 80px;
              height: 80px;
              border-radius: 50%;
              display: flex;
              align-items: center;
              justify-content: center;
            "
          >
            <i class="fas fa-exclamation-circle fa-3x text-white"></i>
          </div>
          <h5 class="card-title fw-bold">Incidents</h5>
          <p class="card-text text-muted mb-4">
            Track and manage incident reports
          </p>
          <a
            href="/incidents"
            class="btn w-100"
            style="
              background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
              color: white;
            "
          >
            <i class="fas fa-list-alt me-1"></i> View Incidents
          </a>
        </div>
      </div>
    </div>
    <!-- Safety Talks -->
    <div class="col-lg-4 col-md-6">
      <div class="card shadow-sm border-0 h-100 hover-card">
        <div class="card-body text-center p-4">
          <div
            class="icon-circle mb-3 mx-auto"
            style="
              background: linear-gradient(135deg, #5f2c82 0%, #49a09d 100%);
              width: 80px;
              height: 80px;
              border-radius: 50%;
              display: flex;
              align-items: center;
              justify-content: center;
            "
          >
            <i class="fas fa-chalkboard-teacher fa-3x text-white"></i>
          </div>
          <h5 class="card-title fw-bold">Safety Talks</h5>
          <p class="card-text text-muted mb-4">
            Generate and manage safety briefings
          </p>
          <a
            href="/safety-talks"
            class="btn w-100"
            style="
              background: linear-gradient(135deg, #5f2c82 0%, #49a09d 100%);
              color: white;
            "
          >
            <i class="fas fa-calendar-alt me-1"></i> View Talks
          </a>
        </div>
      </div>
    </div>
    <!-- PPE Compliance -->
    <div class="col-lg-4 col-md-6">
      <div class="card shadow-sm border-0 h-100 hover-card">
        <div class="card-body text-center p-4">
          <div
            class="icon-circle mb-3 mx-auto"
            style="
              background: linear-gradient(135deg, #ff9a9e 0%, #fad0c4 100%);
              width: 80px;
              height: 80px;
              border-radius: 50%;
              display: flex;
              align-items: center;
              justify-content: center;
            "
          >
            <i class="fas fa-helmet-safety fa-3x text-white"></i>
          </div>
          <h5 class="card-title fw-bold">PPE Compliance</h5>
          <p class="card-text text-muted mb-4">Monitor PPE requirements</p>
          <a
            href="/ppe"
            class="btn w-100"
            style="
              background: linear-gradient(135deg, #ff9a9e 0%, #fad0c4 100%);
              color: white;
            "
          >
            <i class="fas fa-clipboard-check me-1"></i> View PPE
          </a>
        </div>
      </div>
    </div>
    <!-- Risk Assessment -->
    <div class="col-lg-4 col-md-6">
      <div class="card shadow-sm border-0 h-100 hover-card">
        <div class="card-body text-center p-4">
          <div
            class="icon-circle mb-3 mx-auto"
            style="
              background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%);
              width: 80px;
              height: 80px;
              border-radius: 50%;
              display: flex;
              align-items: center;
              justify-content: center;
            "
          >
            <i class="fas fa-chart-pie fa-3x text-white"></i>
          </div>
          <h5 class="card-title fw-bold">Risk Assessments</h5>
          <p class="card-text text-muted mb-4">Analyze and track risks</p>
          <a
            href="/risk-assessments"
            class="btn w-100"
            style="
              background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%);
              color: #1e3c5c;
            "
          >
            <i class="fas fa-chart-bar me-1"></i> View Assessments
          </a>
        </div>
      </div>
    </div>
    <!-- Compliance Reports -->
    <div class="col-lg-4 col-md-6">
      <div class="card shadow-sm border-0 h-100 hover-card">
        <div class="card-body text-center p-4">
          <div
            class="icon-circle mb-3 mx-auto"
            style="
              background: linear-gradient(135deg, #fbc2eb 0%, #a6c1ee 100%);
              width: 80px;
              height: 80px;
              border-radius: 50%;
              display: flex;
              align-items: center;
              justify-content: center;
            "
          >
            <i class="fas fa-file-pdf fa-3x text-white"></i>
          </div>
          <h5 class="card-title fw-bold">Compliance</h5>
          <p class="card-text text-muted mb-4">Generate audit reports</p>
          <a
            href="/compliance"
            class="btn w-100"
            style="
              background: linear-gradient(135deg, #fbc2eb 0%, #a6c1ee 100%);
              color: #1e3c5c;
            "
          >
            <i class="fas fa-file-alt me-1"></i> View Reports
          </a>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .hover-card {
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease;
  }
  .hover-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15) !important;
  }
  .icon-circle {
    transition: transform 0.3s ease;
  }
  .hover-card:hover .icon-circle {
    transform: scale(1.1);
  }
</style>

<%- include('../partials/footer') %>
