<%- include('../../partials/header') %> <%- include('../../partials/navbar') %>

<div class="container py-5">
  <!-- Header -->
  <div class="row mb-4">
    <div class="col-12">
      <div
        class="card border-0"
        style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%)"
      >
        <div class="card-body p-4 text-white">
          <div class="row align-items-center">
            <div class="col-md-8">
              <div class="d-flex align-items-center mb-2">
                <i class="fas fa-hard-hat fa-2x me-3"></i>
                <div>
                  <h2 class="display-5 fw-bold mb-0">
                    Safety Officer Functions
                  </h2>
                  <p class="lead mb-0">
                    Daily safety operations and documentation
                  </p>
                </div>
              </div>
              <p class="mb-2 mt-3">
                Welcome back,
                <strong><%= user.safetyOfficer?.name || user.email %></strong>
              </p>
              <div class="mt-2">
                <a href="/dashboard/solo" class="btn btn-light btn-sm me-2">
                  <i class="fas fa-arrow-left me-1"></i> Back to Dashboard
                </a>
                <span class="badge bg-warning text-dark p-2">
                  <i class="fas fa-hard-hat me-1"></i> Safety Officer Access
                </span>
              </div>
            </div>
            <div class="col-md-4 text-center text-md-end mt-3 mt-md-0">
              <img
                src="<%= user.safetyOfficer?.profileImage || 'https://cdn.pixabay.com/photo/2015/10/05/22/37/blank-profile-picture-973460_960_720.png' %>"
                alt="Profile"
                class="rounded-circle border border-3 border-white shadow"
                style="width: 100px; height: 100px; object-fit: cover"
              />
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Incident Management Section -->
  <div class="row mb-4">
    <div class="col-12">
      <h3 class="fw-bold mb-4" style="color: #f093fb">
        <i class="fas fa-exclamation-triangle me-2"></i>Incident Management
      </h3>
    </div>
  </div>

  <div class="row g-4 mb-5">
    <!-- Report Incident Card -->
    <div class="col-lg-4 col-md-6">
      <div class="card h-100 shadow-lg border-0 hover-card">
        <div class="card-body text-center p-4">
          <div
            class="icon-circle mb-3 mx-auto"
            style="
              background: linear-gradient(135deg, #f44336 0%, #d32f2f 100%);
              width: 80px;
              height: 80px;
              border-radius: 50%;
              display: flex;
              align-items: center;
              justify-content: center;
            "
          >
            <i class="fas fa-flag fa-3x text-white"></i>
          </div>
          <h4 class="fw-bold mb-2">Report Incident</h4>
          <p class="text-muted mb-3">
            Log new incidents, near-misses, or unsafe conditions. Include
            details, media, and immediate actions taken.
          </p>
          <div class="bg-light p-3 rounded-3 mb-3">
            <small class="text-muted"
              >Anonymous reporting available for workers</small
            >
          </div>
          <a
            href="/incidents/report"
            class="btn w-100 py-2"
            style="
              background: linear-gradient(135deg, #f44336 0%, #d32f2f 100%);
              color: white;
              border-radius: 30px;
            "
          >
            <i class="fas fa-flag me-2"></i> Report Incident
          </a>
        </div>
      </div>
    </div>

    <!-- View Incidents Card -->
    <div class="col-lg-4 col-md-6">
      <div class="card h-100 shadow-lg border-0 hover-card">
        <div class="card-body text-center p-4">
          <div
            class="icon-circle mb-3 mx-auto"
            style="
              background: linear-gradient(135deg, #ff7043 0%, #f4511e 100%);
              width: 80px;
              height: 80px;
              border-radius: 50%;
              display: flex;
              align-items: center;
              justify-content: center;
            "
          >
            <i class="fas fa-list-alt fa-3x text-white"></i>
          </div>
          <h4 class="fw-bold mb-2">View Incidents</h4>
          <p class="text-muted mb-3">
            Review all reported incidents, track investigations, and monitor
            corrective actions.
          </p>
          <div class="bg-light p-3 rounded-3 mb-3">
            <strong class="d-block fs-2"
              ><%= user.safetyOfficer?.incidentsReported || 0 %></strong
            >
            <small class="text-muted">Total Incidents</small>
          </div>
          <a
            href="/incidents"
            class="btn w-100 py-2"
            style="
              background: linear-gradient(135deg, #ff7043 0%, #f4511e 100%);
              color: white;
              border-radius: 30px;
            "
          >
            <i class="fas fa-arrow-right me-2"></i> View All Incidents
          </a>
        </div>
      </div>
    </div>

    <!-- Incident Investigation Card -->
    <div class="col-lg-4 col-md-6">
      <div class="card h-100 shadow-lg border-0 hover-card">
        <div class="card-body text-center p-4">
          <div
            class="icon-circle mb-3 mx-auto"
            style="
              background: linear-gradient(135deg, #ffb74d 0%, #ff9800 100%);
              width: 80px;
              height: 80px;
              border-radius: 50%;
              display: flex;
              align-items: center;
              justify-content: center;
            "
          >
            <i class="fas fa-search fa-3x text-white"></i>
          </div>
          <h4 class="fw-bold mb-2">Incident Investigation</h4>
          <p class="text-muted mb-3">
            Conduct investigations, document root causes, and track corrective
            action completion.
          </p>
          <div class="bg-light p-3 rounded-3 mb-3">
            <small class="text-muted">Pending investigations: 0</small>
          </div>
          <a
            href="/incidents/investigations"
            class="btn w-100 py-2"
            style="
              background: linear-gradient(135deg, #ffb74d 0%, #ff9800 100%);
              color: white;
              border-radius: 30px;
            "
          >
            <i class="fas fa-microscope me-2"></i> Manage Investigations
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Safety Talks Section -->
  <div class="row mb-4">
    <div class="col-12">
      <h3 class="fw-bold mb-4" style="color: #f093fb">
        <i class="fas fa-chalkboard-teacher me-2"></i>Safety Talks
      </h3>
    </div>
  </div>

  <div class="row g-4 mb-5">
    <!-- Generate Talk Card -->
    <div class="col-lg-4 col-md-6">
      <div class="card h-100 shadow-lg border-0 hover-card">
        <div class="card-body text-center p-4">
          <div
            class="icon-circle mb-3 mx-auto"
            style="
              background: linear-gradient(135deg, #4caf50 0%, #388e3c 100%);
              width: 80px;
              height: 80px;
              border-radius: 50%;
              display: flex;
              align-items: center;
              justify-content: center;
            "
          >
            <i class="fas fa-robot fa-3x text-white"></i>
          </div>
          <h4 class="fw-bold mb-2">Generate Safety Talk</h4>
          <p class="text-muted mb-3">
            Create AI-powered daily safety briefings based on recent incidents,
            hazards, and site conditions.
          </p>
          <div class="bg-light p-3 rounded-3 mb-3">
            <small class="text-muted"
              >Customizable for specific work areas</small
            >
          </div>
          <a
            href="/safety-talks/generate"
            class="btn w-100 py-2"
            style="
              background: linear-gradient(135deg, #4caf50 0%, #388e3c 100%);
              color: white;
              border-radius: 30px;
            "
          >
            <i class="fas fa-robot me-2"></i> Generate New Talk
          </a>
        </div>
      </div>
    </div>

    <!-- View All Talks Card -->
    <div class="col-lg-4 col-md-6">
      <div class="card h-100 shadow-lg border-0 hover-card">
        <div class="card-body text-center p-4">
          <div
            class="icon-circle mb-3 mx-auto"
            style="
              background: linear-gradient(135deg, #66bb6a 0%, #43a047 100%);
              width: 80px;
              height: 80px;
              border-radius: 50%;
              display: flex;
              align-items: center;
              justify-content: center;
            "
          >
            <i class="fas fa-calendar-alt fa-3x text-white"></i>
          </div>
          <h4 class="fw-bold mb-2">View All Talks</h4>
          <p class="text-muted mb-3">
            Browse all generated safety talks, track which have been conducted,
            and review feedback.
          </p>
          <div class="bg-light p-3 rounded-3 mb-3">
            <strong class="d-block fs-2"
              ><%= user.safetyOfficer?.safetyTalksConducted || 0 %></strong
            >
            <small class="text-muted">Talks Conducted</small>
          </div>
          <a
            href="/safety-talks"
            class="btn w-100 py-2"
            style="
              background: linear-gradient(135deg, #66bb6a 0%, #43a047 100%);
              color: white;
              border-radius: 30px;
            "
          >
            <i class="fas fa-arrow-right me-2"></i> View All Talks
          </a>
        </div>
      </div>
    </div>

    <!-- Talk Templates Card -->
    <div class="col-lg-4 col-md-6">
      <div class="card h-100 shadow-lg border-0 hover-card">
        <div class="card-body text-center p-4">
          <div
            class="icon-circle mb-3 mx-auto"
            style="
              background: linear-gradient(135deg, #26c6da 0%, #00acc1 100%);
              width: 80px;
              height: 80px;
              border-radius: 50%;
              display: flex;
              align-items: center;
              justify-content: center;
            "
          >
            <i class="fas fa-file-alt fa-3x text-white"></i>
          </div>
          <h4 class="fw-bold mb-2">Talk Templates</h4>
          <p class="text-muted mb-3">
            Browse and manage reusable safety talk templates for common topics
            and situations.
          </p>
          <div class="bg-light p-3 rounded-3 mb-3">
            <small class="text-muted">Create consistent safety messaging</small>
          </div>
          <a
            href="/safety-talks/templates"
            class="btn w-100 py-2"
            style="
              background: linear-gradient(135deg, #26c6da 0%, #00acc1 100%);
              color: white;
              border-radius: 30px;
            "
          >
            <i class="fas fa-template me-2"></i> Manage Templates
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Risk & Compliance Section -->
  <div class="row mb-4">
    <div class="col-12">
      <h3 class="fw-bold mb-4" style="color: #f093fb">
        <i class="fas fa-shield-alt me-2"></i>Risk & Compliance
      </h3>
    </div>
  </div>

  <div class="row g-4">
    <!-- Risk Assessment Card -->
    <div class="col-lg-4 col-md-6">
      <div class="card h-100 shadow-lg border-0 hover-card">
        <div class="card-body text-center p-4">
          <div
            class="icon-circle mb-3 mx-auto"
            style="
              background: linear-gradient(135deg, #009688 0%, #00796b 100%);
              width: 80px;
              height: 80px;
              border-radius: 50%;
              display: flex;
              align-items: center;
              justify-content: center;
            "
          >
            <i class="fas fa-chart-pie fa-3x text-white"></i>
          </div>
          <h4 class="fw-bold mb-2">Risk Assessment</h4>
          <p class="text-muted mb-3">
            Create and manage comprehensive risk assessments for work areas and
            specific tasks.
          </p>
          <div class="bg-light p-3 rounded-3 mb-3">
            <small class="text-muted"
              >Identify hazards and implement controls</small
            >
          </div>
          <a
            href="/risk-assessments/new"
            class="btn w-100 py-2"
            style="
              background: linear-gradient(135deg, #009688 0%, #00796b 100%);
              color: white;
              border-radius: 30px;
            "
          >
            <i class="fas fa-plus-circle me-2"></i> New Assessment
          </a>
        </div>
      </div>
    </div>

    <!-- View Assessments Card -->
    <div class="col-lg-4 col-md-6">
      <div class="card h-100 shadow-lg border-0 hover-card">
        <div class="card-body text-center p-4">
          <div
            class="icon-circle mb-3 mx-auto"
            style="
              background: linear-gradient(135deg, #26a69a 0%, #00897b 100%);
              width: 80px;
              height: 80px;
              border-radius: 50%;
              display: flex;
              align-items: center;
              justify-content: center;
            "
          >
            <i class="fas fa-chart-bar fa-3x text-white"></i>
          </div>
          <h4 class="fw-bold mb-2">View Assessments</h4>
          <p class="text-muted mb-3">
            Review all risk assessments, track mitigation progress, and schedule
            reviews.
          </p>
          <div class="bg-light p-3 rounded-3 mb-3">
            <strong class="d-block fs-2">0</strong>
            <small class="text-muted">Active Assessments</small>
          </div>
          <a
            href="/risk-assessments"
            class="btn w-100 py-2"
            style="
              background: linear-gradient(135deg, #26a69a 0%, #00897b 100%);
              color: white;
              border-radius: 30px;
            "
          >
            <i class="fas fa-arrow-right me-2"></i> View All
          </a>
        </div>
      </div>
    </div>

    <!-- PPE Compliance Card -->
    <div class="col-lg-4 col-md-6">
      <div class="card h-100 shadow-lg border-0 hover-card">
        <div class="card-body text-center p-4">
          <div
            class="icon-circle mb-3 mx-auto"
            style="
              background: linear-gradient(135deg, #ff9800 0%, #f57c00 100%);
              width: 80px;
              height: 80px;
              border-radius: 50%;
              display: flex;
              align-items: center;
              justify-content: center;
            "
          >
            <i class="fas fa-helmet-safety fa-3x text-white"></i>
          </div>
          <h4 class="fw-bold mb-2">PPE Compliance</h4>
          <p class="text-muted mb-3">
            Create and manage PPE checklists, track compliance, and conduct
            inspections.
          </p>
          <div class="bg-light p-3 rounded-3 mb-3">
            <small class="text-muted"
              >Ensure worker safety with proper PPE</small
            >
          </div>
          <a
            href="/ppe/checklist"
            class="btn w-100 py-2"
            style="
              background: linear-gradient(135deg, #ff9800 0%, #f57c00 100%);
              color: white;
              border-radius: 30px;
            "
          >
            <i class="fas fa-clipboard-check me-2"></i> Manage PPE
          </a>
        </div>
      </div>
    </div>

    <!-- Permits Card -->
    <div class="col-lg-4 col-md-6 mt-4">
      <div class="card h-100 shadow-lg border-0 hover-card">
        <div class="card-body text-center p-4">
          <div
            class="icon-circle mb-3 mx-auto"
            style="
              background: linear-gradient(135deg, #7e57c2 0%, #5e35b1 100%);
              width: 80px;
              height: 80px;
              border-radius: 50%;
              display: flex;
              align-items: center;
              justify-content: center;
            "
          >
            <i class="fas fa-file-signature fa-3x text-white"></i>
          </div>
          <h4 class="fw-bold mb-2">Permit Management</h4>
          <p class="text-muted mb-3">
            Create and manage permits for high-risk activities like hot work,
            confined space, and work at height.
          </p>
          <div class="bg-light p-3 rounded-3 mb-3">
            <small class="text-muted">Track approvals and expirations</small>
          </div>
          <a
            href="/permits"
            class="btn w-100 py-2"
            style="
              background: linear-gradient(135deg, #7e57c2 0%, #5e35b1 100%);
              color: white;
              border-radius: 30px;
            "
          >
            <i class="fas fa-file-signature me-2"></i> Manage Permits
          </a>
        </div>
      </div>
    </div>

    <!-- JSA Card -->
    <div class="col-lg-4 col-md-6 mt-4">
      <div class="card h-100 shadow-lg border-0 hover-card">
        <div class="card-body text-center p-4">
          <div
            class="icon-circle mb-3 mx-auto"
            style="
              background: linear-gradient(135deg, #ec407a 0%, #d81b60 100%);
              width: 80px;
              height: 80px;
              border-radius: 50%;
              display: flex;
              align-items: center;
              justify-content: center;
            "
          >
            <i class="fas fa-tasks fa-3x text-white"></i>
          </div>
          <h4 class="fw-bold mb-2">Job Safety Analysis</h4>
          <p class="text-muted mb-3">
            Create step-by-step job safety analyses for specific tasks and work
            activities.
          </p>
          <div class="bg-light p-3 rounded-3 mb-3">
            <small class="text-muted"
              >Break down tasks and identify hazards</small
            >
          </div>
          <a
            href="/jsa"
            class="btn w-100 py-2"
            style="
              background: linear-gradient(135deg, #ec407a 0%, #d81b60 100%);
              color: white;
              border-radius: 30px;
            "
          >
            <i class="fas fa-tasks me-2"></i> Manage JSA
          </a>
        </div>
      </div>
    </div>

    <!-- Compliance Reports Card -->
    <div class="col-lg-4 col-md-6 mt-4">
      <div class="card h-100 shadow-lg border-0 hover-card">
        <div class="card-body text-center p-4">
          <div
            class="icon-circle mb-3 mx-auto"
            style="
              background: linear-gradient(135deg, #fbc2eb 0%, #a6c1ee 100%);
              width: 80px;
              height: 80px;
              border-radius: 50%;
              display: flex;
              align-items: center;
              justify-content: center;
            "
          >
            <i class="fas fa-file-pdf fa-3x text-white"></i>
          </div>
          <h4 class="fw-bold mb-2">Compliance Reports</h4>
          <p class="text-muted mb-3">
            Generate and download compliance documentation, incident reports,
            and safety statistics.
          </p>
          <div class="bg-light p-3 rounded-3 mb-3">
            <small class="text-muted">Audit-ready documentation</small>
          </div>
          <a
            href="/compliance/reports"
            class="btn w-100 py-2"
            style="
              background: linear-gradient(135deg, #fbc2eb 0%, #a6c1ee 100%);
              color: #1e3c5c;
              border-radius: 30px;
            "
          >
            <i class="fas fa-download me-2"></i> Generate Reports
          </a>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .hover-card {
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease;
  }

  .hover-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15) !important;
  }

  .icon-circle {
    transition: transform 0.3s ease;
  }

  .hover-card:hover .icon-circle {
    transform: scale(1.1);
  }

  .btn {
    transition: all 0.3s ease;
  }

  .btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
  }

  .card {
    border-radius: 16px;
  }
</style>

<%- include('../../partials/footer') %>
