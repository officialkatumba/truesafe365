<%- include('../../partials/header') %> <%- include('../../partials/navbar') %>

<div class="container py-5">
  <!-- Header -->
  <div class="row mb-4">
    <div class="col-12">
      <div
        class="card border-0"
        style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%)"
      >
        <div class="card-body p-4 text-white">
          <div class="row align-items-center">
            <div class="col-md-8">
              <div class="d-flex align-items-center mb-2">
                <i class="fas fa-crown fa-2x me-3"></i>
                <div>
                  <h2 class="display-5 fw-bold mb-0">Admin Functions</h2>
                  <p class="lead mb-0">
                    Manage your worksite structure and team
                  </p>
                </div>
              </div>
              <p class="mb-2 mt-3">
                Welcome back,
                <strong><%= user.safetyOfficer?.name || user.email %></strong>
              </p>
              <div class="mt-2">
                <a href="/dashboard/solo" class="btn btn-light btn-sm me-2">
                  <i class="fas fa-arrow-left me-1"></i> Back to Dashboard
                </a>
                <span class="badge bg-warning text-dark p-2">
                  <i class="fas fa-crown me-1"></i> Admin Access
                </span>
              </div>
            </div>
            <div class="col-md-4 text-center text-md-end mt-3 mt-md-0">
              <img
                src="<%= user.safetyOfficer?.profileImage || 'https://cdn.pixabay.com/photo/2015/10/05/22/37/blank-profile-picture-973460_960_720.png' %>"
                alt="Profile"
                class="rounded-circle border border-3 border-white shadow"
                style="width: 100px; height: 100px; object-fit: cover"
              />
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Worksite Management Section -->
  <div class="row mb-4">
    <div class="col-12">
      <h3 class="fw-bold mb-4" style="color: #667eea">
        <i class="fas fa-hard-hat me-2"></i>Worksite Management
      </h3>
    </div>
  </div>

  <div class="row g-4 mb-5">
    <!-- Create Worksite Card -->
    <div class="col-lg-4 col-md-6">
      <div class="card h-100 shadow-lg border-0 hover-card">
        <div class="card-body text-center p-4">
          <div
            class="icon-circle mb-3 mx-auto"
            style="
              background: linear-gradient(135deg, #2196f3 0%, #1976d2 100%);
              width: 80px;
              height: 80px;
              border-radius: 50%;
              display: flex;
              align-items: center;
              justify-content: center;
            "
          >
            <i class="fas fa-plus-circle fa-3x text-white"></i>
          </div>
          <h4 class="fw-bold mb-2">Create Worksite</h4>
          <p class="text-muted mb-3">
            Add a new worksite to your portfolio. Set up location, site type,
            and initial safety parameters.
          </p>
          <div class="bg-light p-3 rounded-3 mb-3">
            <small class="text-muted"
              >Create unlimited worksites as a solo practitioner</small
            >
          </div>
          <a
            href="/worksites/create"
            class="btn w-100 py-2"
            style="
              background: linear-gradient(135deg, #2196f3 0%, #1976d2 100%);
              color: white;
              border-radius: 30px;
            "
          >
            <i class="fas fa-plus-circle me-2"></i> Create New Worksite
          </a>
        </div>
      </div>
    </div>

    <!-- My Worksites Card -->
    <div class="col-lg-4 col-md-6">
      <div class="card h-100 shadow-lg border-0 hover-card">
        <div class="card-body text-center p-4">
          <div
            class="icon-circle mb-3 mx-auto"
            style="
              background: linear-gradient(135deg, #3f51b5 0%, #3949ab 100%);
              width: 80px;
              height: 80px;
              border-radius: 50%;
              display: flex;
              align-items: center;
              justify-content: center;
            "
          >
            <i class="fas fa-list fa-3x text-white"></i>
          </div>
          <h4 class="fw-bold mb-2">My Worksites</h4>
          <p class="text-muted mb-3">
            View and manage all your worksites. Track hazards, compliance, and
            safety performance.
          </p>
          <div class="bg-light p-3 rounded-3 mb-3">
            <strong class="d-block fs-2"
              ><%= user.safetyOfficer?.worksites?.length || 0 %></strong
            >
            <small class="text-muted">Total Worksites</small>
          </div>
          <a
            href="/worksites/my-worksites"
            class="btn w-100 py-2"
            style="
              background: linear-gradient(135deg, #3f51b5 0%, #3949ab 100%);
              color: white;
              border-radius: 30px;
            "
          >
            <i class="fas fa-arrow-right me-2"></i> View All Worksites
          </a>
        </div>
      </div>
    </div>

    <!-- Worksite Analytics Card -->
    <div class="col-lg-4 col-md-6">
      <div class="card h-100 shadow-lg border-0 hover-card">
        <div class="card-body text-center p-4">
          <div
            class="icon-circle mb-3 mx-auto"
            style="
              background: linear-gradient(135deg, #5f2c82 0%, #49a09d 100%);
              width: 80px;
              height: 80px;
              border-radius: 50%;
              display: flex;
              align-items: center;
              justify-content: center;
            "
          >
            <i class="fas fa-chart-line fa-3x text-white"></i>
          </div>
          <h4 class="fw-bold mb-2">Worksite Analytics</h4>
          <p class="text-muted mb-3">
            View safety performance metrics across all your worksites. Identify
            trends and areas for improvement.
          </p>
          <div class="bg-light p-3 rounded-3 mb-3">
            <div class="row">
              <div class="col-6">
                <strong class="d-block fs-4"
                  ><%= user.safetyOfficer?.incidentsReported || 0 %></strong
                >
                <small class="text-muted">Incidents</small>
              </div>
              <div class="col-6">
                <strong class="d-block fs-4"
                  ><%= user.safetyOfficer?.safetyTalksConducted || 0 %></strong
                >
                <small class="text-muted">Talks</small>
              </div>
            </div>
          </div>
          <a
            href="/worksites/analytics"
            class="btn w-100 py-2"
            style="
              background: linear-gradient(135deg, #5f2c82 0%, #49a09d 100%);
              color: white;
              border-radius: 30px;
            "
          >
            <i class="fas fa-chart-pie me-2"></i> View Analytics
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Team Management Section -->
  <div class="row mb-4">
    <div class="col-12">
      <h3 class="fw-bold mb-4" style="color: #667eea">
        <i class="fas fa-users me-2"></i>Team Management
      </h3>
    </div>
  </div>

  <div class="row g-4 mb-5">
    <!-- Add Team Member Card -->
    <div class="col-lg-4 col-md-6">
      <div class="card h-100 shadow-lg border-0 hover-card">
        <div class="card-body text-center p-4">
          <div
            class="icon-circle mb-3 mx-auto"
            style="
              background: linear-gradient(135deg, #ff9800 0%, #f57c00 100%);
              width: 80px;
              height: 80px;
              border-radius: 50%;
              display: flex;
              align-items: center;
              justify-content: center;
            "
          >
            <i class="fas fa-user-plus fa-3x text-white"></i>
          </div>
          <h4 class="fw-bold mb-2">Add Team Member</h4>
          <p class="text-muted mb-3">
            Invite workers, supervisors, or other safety officers to collaborate
            on your worksites.
          </p>
          <div class="bg-light p-3 rounded-3 mb-3">
            <small class="text-muted"
              >Send email invitations with role-based permissions</small
            >
          </div>
          <a
            href="/team/add"
            class="btn w-100 py-2"
            style="
              background: linear-gradient(135deg, #ff9800 0%, #f57c00 100%);
              color: white;
              border-radius: 30px;
            "
          >
            <i class="fas fa-envelope me-2"></i> Invite Member
          </a>
        </div>
      </div>
    </div>

    <!-- Manage Team Card -->
    <div class="col-lg-4 col-md-6">
      <div class="card h-100 shadow-lg border-0 hover-card">
        <div class="card-body text-center p-4">
          <div
            class="icon-circle mb-3 mx-auto"
            style="
              background: linear-gradient(135deg, #9c27b0 0%, #7b1fa2 100%);
              width: 80px;
              height: 80px;
              border-radius: 50%;
              display: flex;
              align-items: center;
              justify-content: center;
            "
          >
            <i class="fas fa-users-cog fa-3x text-white"></i>
          </div>
          <h4 class="fw-bold mb-2">Manage Team</h4>
          <p class="text-muted mb-3">
            View and manage your team members. Update roles, permissions, and
            access levels.
          </p>
          <div class="bg-light p-3 rounded-3 mb-3">
            <strong class="d-block fs-2">0</strong>
            <small class="text-muted">Team Members</small>
          </div>
          <a
            href="/team/manage"
            class="btn w-100 py-2"
            style="
              background: linear-gradient(135deg, #9c27b0 0%, #7b1fa2 100%);
              color: white;
              border-radius: 30px;
            "
          >
            <i class="fas fa-cog me-2"></i> Manage Team
          </a>
        </div>
      </div>
    </div>

    <!-- Share Worksite Card -->
    <div class="col-lg-4 col-md-6">
      <div class="card h-100 shadow-lg border-0 hover-card">
        <div class="card-body text-center p-4">
          <div
            class="icon-circle mb-3 mx-auto"
            style="
              background: linear-gradient(135deg, #03a9f4 0%, #0288d1 100%);
              width: 80px;
              height: 80px;
              border-radius: 50%;
              display: flex;
              align-items: center;
              justify-content: center;
            "
          >
            <i class="fas fa-share-alt fa-3x text-white"></i>
          </div>
          <h4 class="fw-bold mb-2">Share Worksite</h4>
          <p class="text-muted mb-3">
            Collaborate with other safety officers by sharing access to your
            worksites.
          </p>
          <div class="bg-light p-3 rounded-3 mb-3">
            <small class="text-muted">Grant view or edit permissions</small>
          </div>
          <a
            href="/worksites/share"
            class="btn w-100 py-2"
            style="
              background: linear-gradient(135deg, #03a9f4 0%, #0288d1 100%);
              color: white;
              border-radius: 30px;
            "
          >
            <i class="fas fa-share me-2"></i> Share Worksite
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Company Compliance Section -->
  <div class="row mb-4">
    <div class="col-12">
      <h3 class="fw-bold mb-4" style="color: #667eea">
        <i class="fas fa-shield-alt me-2"></i>Company Compliance
      </h3>
    </div>
  </div>

  <div class="row g-4">
    <!-- Compliance Overview Card -->
    <div class="col-lg-4 col-md-6">
      <div class="card h-100 shadow-lg border-0 hover-card">
        <div class="card-body text-center p-4">
          <div
            class="icon-circle mb-3 mx-auto"
            style="
              background: linear-gradient(135deg, #4caf50 0%, #388e3c 100%);
              width: 80px;
              height: 80px;
              border-radius: 50%;
              display: flex;
              align-items: center;
              justify-content: center;
            "
          >
            <i class="fas fa-check-circle fa-3x text-white"></i>
          </div>
          <h4 class="fw-bold mb-2">Compliance Overview</h4>
          <p class="text-muted mb-3">
            Track company-wide compliance with safety regulations and standards.
          </p>
          <div class="bg-light p-3 rounded-3 mb-3">
            <div class="progress mb-2" style="height: 10px">
              <div class="progress-bar bg-success" style="width: 98%"></div>
            </div>
            <small class="text-muted">Overall Compliance: 98%</small>
          </div>
          <a
            href="/compliance/overview"
            class="btn w-100 py-2"
            style="
              background: linear-gradient(135deg, #4caf50 0%, #388e3c 100%);
              color: white;
              border-radius: 30px;
            "
          >
            <i class="fas fa-chart-bar me-2"></i> View Compliance
          </a>
        </div>
      </div>
    </div>

    <!-- Compliance Reports Card -->
    <div class="col-lg-4 col-md-6">
      <div class="card h-100 shadow-lg border-0 hover-card">
        <div class="card-body text-center p-4">
          <div
            class="icon-circle mb-3 mx-auto"
            style="
              background: linear-gradient(135deg, #f44336 0%, #d32f2f 100%);
              width: 80px;
              height: 80px;
              border-radius: 50%;
              display: flex;
              align-items: center;
              justify-content: center;
            "
          >
            <i class="fas fa-file-pdf fa-3x text-white"></i>
          </div>
          <h4 class="fw-bold mb-2">Compliance Reports</h4>
          <p class="text-muted mb-3">
            Generate and download compliance documentation for audits and
            regulatory submissions.
          </p>
          <div class="bg-light p-3 rounded-3 mb-3">
            <small class="text-muted"
              >ISO 45001 • OSHA • Zambian Factories Act</small
            >
          </div>
          <a
            href="/compliance/reports"
            class="btn w-100 py-2"
            style="
              background: linear-gradient(135deg, #f44336 0%, #d32f2f 100%);
              color: white;
              border-radius: 30px;
            "
          >
            <i class="fas fa-download me-2"></i> Generate Reports
          </a>
        </div>
      </div>
    </div>

    <!-- Assign Safety Officers Card -->
    <div class="col-lg-4 col-md-6">
      <div class="card h-100 shadow-lg border-0 hover-card">
        <div class="card-body text-center p-4">
          <div
            class="icon-circle mb-3 mx-auto"
            style="
              background: linear-gradient(135deg, #673ab7 0%, #512da8 100%);
              width: 80px;
              height: 80px;
              border-radius: 50%;
              display: flex;
              align-items: center;
              justify-content: center;
            "
          >
            <i class="fas fa-user-tie fa-3x text-white"></i>
          </div>
          <h4 class="fw-bold mb-2">Assign Safety Officers</h4>
          <p class="text-muted mb-3">
            Delegate responsibilities by assigning safety officers to specific
            worksites and work areas.
          </p>
          <div class="bg-light p-3 rounded-3 mb-3">
            <small class="text-muted"
              >Manage officer assignments per worksite</small
            >
          </div>
          <a
            href="/admin/assign-officers"
            class="btn w-100 py-2"
            style="
              background: linear-gradient(135deg, #673ab7 0%, #512da8 100%);
              color: white;
              border-radius: 30px;
            "
          >
            <i class="fas fa-user-cog me-2"></i> Manage Assignments
          </a>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .hover-card {
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease;
  }

  .hover-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15) !important;
  }

  .icon-circle {
    transition: transform 0.3s ease;
  }

  .hover-card:hover .icon-circle {
    transform: scale(1.1);
  }

  .btn {
    transition: all 0.3s ease;
  }

  .btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
  }

  .card {
    border-radius: 16px;
  }
</style>

<%- include('../../partials/footer') %>
