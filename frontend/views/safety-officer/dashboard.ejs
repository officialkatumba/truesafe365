<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="container my-5">
  <!-- Header with Profile Summary -->
  <div class="row mb-4">
    <div class="col-12">
      <div class="card border-0" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
        <div class="card-body p-4 text-white">
          <div class="row align-items-center">
            <div class="col-md-8">
              <div class="d-flex align-items-center mb-2">
                <i class="fas fa-crown fa-2x me-3"></i>
                <div>
                  <h2 class="display-5 fw-bold mb-0">Solo Practitioner Dashboard</h2>
                  <p class="lead mb-0">You have full admin + safety officer privileges</p>
                </div>
              </div>
              <p class="mb-2 mt-3">
                Welcome back, <strong><%= user.safetyOfficer?.name || user.email %></strong>
              </p>
              <div class="mt-2">
                <span class="badge bg-warning text-dark p-2 me-2">
                  <i class="fas fa-crown me-1"></i> System Admin
                </span>
                <span class="badge bg-info p-2 me-2">
                  <i class="fas fa-hard-hat me-1"></i> Safety Officer
                </span>
                <span class="badge bg-secondary p-2">
                  <i class="fas fa-id-card me-1"></i> #<%= user.safetyOfficer?.officerNumber || 'N/A' %>
                </span>
                
                <% 
                let verificationBadge = '⏳ Pending Verification';
                let badgeClass = 'bg-warning text-dark';
                if (user.safetyOfficer?.verificationStatus === 'verified') {
                  verificationBadge = '✓ Verified';
                  badgeClass = 'bg-success';
                }
                %>
                
                <span class="badge <%= badgeClass %> p-2">
                  <i class="fas fa-certificate me-1"></i> <%= verificationBadge %>
                </span>
              </div>
            </div>
            <div class="col-md-4 text-center text-md-end mt-3 mt-md-0">
              <img src="<%= user.safetyOfficer?.profileImage || 'https://cdn.pixabay.com/photo/2015/10/05/22/37/blank-profile-picture-973460_960_720.png' %>" 
                   alt="Profile" 
                   class="rounded-circle border border-3 border-white shadow"
                   style="width: 120px; height: 120px; object-fit: cover;">
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Safety Summary Cards - Compact horizontal style -->
  <div class="row mb-5">
    <div class="col-12">
      <div class="card shadow-sm border-0">
        <div class="card-body p-4">
          <h4 class="fw-bold mb-4" style="color: #1e3c5c">
            <i class="fas fa-chart-line me-2"></i>Safety Performance Overview
          </h4>
          <div class="row g-3">
            <!-- Worksites -->
            <div class="col-md-3 col-6">
              <div class="d-flex align-items-center p-3 rounded" style="background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);">
                <div class="rounded-circle p-3 me-3" style="background: linear-gradient(135deg, #2196f3 0%, #1976d2 100%);">
                  <i class="fas fa-hard-hat fa-2x text-white"></i>
                </div>
                <div>
                  <h3 class="fw-bold mb-0"><%= user.safetyOfficer?.worksites?.length || 0 %></h3>
                  <small class="text-muted">Worksites</small>
                </div>
              </div>
            </div>

            <!-- Incidents -->
            <div class="col-md-3 col-6">
              <div class="d-flex align-items-center p-3 rounded" style="background: linear-gradient(135deg, #ffebee 0%, #ffcdd2 100%);">
                <div class="rounded-circle p-3 me-3" style="background: linear-gradient(135deg, #f44336 0%, #d32f2f 100%);">
                  <i class="fas fa-exclamation-triangle fa-2x text-white"></i>
                </div>
                <div>
                  <h3 class="fw-bold mb-0"><%= user.safetyOfficer?.incidentsReported || 0 %></h3>
                  <small class="text-muted">Incidents</small>
                </div>
              </div>
            </div>

            <!-- Safety Talks -->
            <div class="col-md-3 col-6">
              <div class="d-flex align-items-center p-3 rounded" style="background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%);">
                <div class="rounded-circle p-3 me-3" style="background: linear-gradient(135deg, #4caf50 0%, #388e3c 100%);">
                  <i class="fas fa-chalkboard-teacher fa-2x text-white"></i>
                </div>
                <div>
                  <h3 class="fw-bold mb-0"><%= user.safetyOfficer?.safetyTalksConducted || 0 %></h3>
                  <small class="text-muted">Safety Talks</small>
                </div>
              </div>
            </div>

            <!-- Team Members -->
            <div class="col-md-3 col-6">
              <div class="d-flex align-items-center p-3 rounded" style="background: linear-gradient(135deg, #fff3e0 0%, #ffe0b2 100%);">
                <div class="rounded-circle p-3 me-3" style="background: linear-gradient(135deg, #ff9800 0%, #f57c00 100%);">
                  <i class="fas fa-users fa-2x text-white"></i>
                </div>
                <div>
                  <h3 class="fw-bold mb-0">0</h3>
                  <small class="text-muted">Team Members</small>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Admin Actions Column (Full Width) -->
  <div class="row mb-4">
    <div class="col-12">
      <div class="card shadow-sm border-0">
        <div class="card-header bg-transparent border-0 pt-4 px-4">
          <h4 class="fw-bold mb-0" style="color: #667eea">
            <i class="fas fa-crown me-2"></i>Admin Actions
          </h4>
          <p class="text-muted">Manage your account and worksite structure</p>
        </div>
        <div class="card-body p-4">
          <div class="row g-4">
            <!-- Create Worksite -->
            <div class="col-lg-3 col-md-6">
              <div class="card border-0 h-100 hover-card" style="background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);">
                <div class="card-body text-center p-4">
                  <div class="icon-circle mb-3 mx-auto" style="background: linear-gradient(135deg, #2196f3 0%, #1976d2 100%); width: 70px; height: 70px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                    <i class="fas fa-plus-circle fa-2x text-white"></i>
                  </div>
                  <h5 class="fw-bold">Create Worksite</h5>
                  <p class="small text-muted mb-3">Add a new worksite to your portfolio</p>
                  <a href="/worksites/create" class="btn w-100" style="background: linear-gradient(135deg, #2196f3 0%, #1976d2 100%); color: white;">
                    Create
                  </a>
                </div>
              </div>
            </div>

            <!-- My Worksites -->
            <div class="col-lg-3 col-md-6">
              <div class="card border-0 h-100 hover-card" style="background: linear-gradient(135deg, #e8eaf6 0%, #c5cae9 100%);">
                <div class="card-body text-center p-4">
                  <div class="icon-circle mb-3 mx-auto" style="background: linear-gradient(135deg, #3f51b5 0%, #3949ab 100%); width: 70px; height: 70px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                    <i class="fas fa-list fa-2x text-white"></i>
                  </div>
                  <h5 class="fw-bold">My Worksites</h5>
                  <p class="small text-muted mb-3">View and manage all your worksites</p>
                  <a href="/worksites/my-worksites" class="btn w-100" style="background: linear-gradient(135deg, #3f51b5 0%, #3949ab 100%); color: white;">
                    View
                  </a>
                </div>
              </div>
            </div>

            <!-- Add Team Member -->
            <div class="col-lg-3 col-md-6">
              <div class="card border-0 h-100 hover-card" style="background: linear-gradient(135deg, #fff3e0 0%, #ffe0b2 100%);">
                <div class="card-body text-center p-4">
                  <div class="icon-circle mb-3 mx-auto" style="background: linear-gradient(135deg, #ff9800 0%, #f57c00 100%); width: 70px; height: 70px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                    <i class="fas fa-user-plus fa-2x text-white"></i>
                  </div>
                  <h5 class="fw-bold">Add Team Member</h5>
                  <p class="small text-muted mb-3">Invite workers or supervisors</p>
                  <a href="/team/add" class="btn w-100" style="background: linear-gradient(135deg, #ff9800 0%, #f57c00 100%); color: white;">
                    Invite
                  </a>
                </div>
              </div>
            </div>

            <!-- Share Worksite -->
            <div class="col-lg-3 col-md-6">
              <div class="card border-0 h-100 hover-card" style="background: linear-gradient(135deg, #e1f5fe 0%, #b3e5fc 100%);">
                <div class="card-body text-center p-4">
                  <div class="icon-circle mb-3 mx-auto" style="background: linear-gradient(135deg, #03a9f4 0%, #0288d1 100%); width: 70px; height: 70px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                    <i class="fas fa-share-alt fa-2x text-white"></i>
                  </div>
                  <h5 class="fw-bold">Share Worksite</h5>
                  <p class="small text-muted mb-3">Collaborate with other officers</p>
                  <a href="/worksites/share" class="btn w-100" style="background: linear-gradient(135deg, #03a9f4 0%, #0288d1 100%); color: white;">
                    Share
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Safety Officer Actions Column (Full Width) -->
  <div class="row mb-4">
    <div class="col-12">
      <div class="card shadow-sm border-0">
        <div class="card-header bg-transparent border-0 pt-4 px-4">
          <h4 class="fw-bold mb-0" style="color: #f093fb">
            <i class="fas fa-hard-hat me-2"></i>Safety Officer Actions
          </h4>
          <p class="text-muted">Daily safety operations and documentation</p>
        </div>
        <div class="card-body p-4">
          <div class="row g-4">
            <!-- Report Incident -->
            <div class="col-lg-3 col-md-6">
              <div class="card border-0 h-100 hover-card" style="background: linear-gradient(135deg, #ffebee 0%, #ffcdd2 100%);">
                <div class="card-body text-center p-4">
                  <div class="icon-circle mb-3 mx-auto" style="background: linear-gradient(135deg, #f44336 0%, #d32f2f 100%); width: 70px; height: 70px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                    <i class="fas fa-flag fa-2x text-white"></i>
                  </div>
                  <h5 class="fw-bold">Report Incident</h5>
                  <p class="small text-muted mb-3">Log new incidents or near-misses</p>
                  <a href="/incidents/report" class="btn w-100" style="background: linear-gradient(135deg, #f44336 0%, #d32f2f 100%); color: white;">
                    Report
                  </a>
                </div>
              </div>
            </div>

            <!-- Generate Talk -->
            <div class="col-lg-3 col-md-6">
              <div class="card border-0 h-100 hover-card" style="background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%);">
                <div class="card-body text-center p-4">
                  <div class="icon-circle mb-3 mx-auto" style="background: linear-gradient(135deg, #4caf50 0%, #388e3c 100%); width: 70px; height: 70px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                    <i class="fas fa-robot fa-2x text-white"></i>
                  </div>
                  <h5 class="fw-bold">Generate Talk</h5>
                  <p class="small text-muted mb-3">Create AI-powered safety briefings</p>
                  <a href="/safety-talks/generate" class="btn w-100" style="background: linear-gradient(135deg, #4caf50 0%, #388e3c 100%); color: white;">
                    Generate
                  </a>
                </div>
              </div>
            </div>

            <!-- Risk Assessment -->
            <div class="col-lg-3 col-md-6">
              <div class="card border-0 h-100 hover-card" style="background: linear-gradient(135deg, #e0f2f1 0%, #b2dfdb 100%);">
                <div class="card-body text-center p-4">
                  <div class="icon-circle mb-3 mx-auto" style="background: linear-gradient(135deg, #009688 0%, #00796b 100%); width: 70px; height: 70px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                    <i class="fas fa-chart-pie fa-2x text-white"></i>
                  </div>
                  <h5 class="fw-bold">Risk Assessment</h5>
                  <p class="small text-muted mb-3">Create and manage risk assessments</p>
                  <a href="/risk-assessments/new" class="btn w-100" style="background: linear-gradient(135deg, #009688 0%, #00796b 100%); color: white;">
                    Create
                  </a>
                </div>
              </div>
            </div>

            <!-- PPE Checklist -->
            <div class="col-lg-3 col-md-6">
              <div class="card border-0 h-100 hover-card" style="background: linear-gradient(135deg, #fff3e0 0%, #ffe0b2 100%);">
                <div class="card-body text-center p-4">
                  <div class="icon-circle mb-3 mx-auto" style="background: linear-gradient(135deg, #ff9800 0%, #f57c00 100%); width: 70px; height: 70px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                    <i class="fas fa-clipboard-check fa-2x text-white"></i>
                  </div>
                  <h5 class="fw-bold">PPE Checklist</h5>
                  <p class="small text-muted mb-3">Run compliance checks</p>
                  <a href="/ppe/checklist" class="btn w-100" style="background: linear-gradient(135deg, #ff9800 0%, #f57c00 100%); color: white;">
                    Check
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Three Cards Row - PPE, Risk Assessment, Compliance Reports -->
  <div class="row g-4 mb-4">
    <!-- PPE Compliance -->
    <div class="col-lg-4 col-md-6">
      <div class="card shadow-sm border-0 h-100 hover-card">
        <div class="card-body text-center p-4">
          <div class="icon-circle mb-3 mx-auto" style="background: linear-gradient(135deg, #ff9a9e 0%, #fad0c4 100%); width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
            <i class="fas fa-helmet-safety fa-3x text-white"></i>
          </div>
          <h5 class="card-title fw-bold">PPE Compliance</h5>
          <p class="card-text text-muted mb-4">Monitor PPE requirements and track compliance across worksites</p>
          <div class="d-grid gap-2">
            <a href="/ppe/requirements" class="btn" style="background: linear-gradient(135deg, #ff9a9e 0%, #fad0c4 100%); color: white; border: none;">
              <i class="fas fa-clipboard-check me-1"></i> View Requirements
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Risk Assessment -->
    <div class="col-lg-4 col-md-6">
      <div class="card shadow-sm border-0 h-100 hover-card">
        <div class="card-body text-center p-4">
          <div class="icon-circle mb-3 mx-auto" style="background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%); width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
            <i class="fas fa-chart-pie fa-3x text-white"></i>
          </div>
          <h5 class="card-title fw-bold">Risk Assessment</h5>
          <p class="card-text text-muted mb-4">Analyze risks, generate assessment reports</p>
          <div class="d-grid gap-2">
            <a href="/risk-assessments" class="btn" style="background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%); color: #1e3c5c; border: none;">
              <i class="fas fa-chart-bar me-1"></i> View Assessments
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Compliance Reports -->
    <div class="col-lg-4 col-md-6">
      <div class="card shadow-sm border-0 h-100 hover-card">
        <div class="card-body text-center p-4">
          <div class="icon-circle mb-3 mx-auto" style="background: linear-gradient(135deg, #fbc2eb 0%, #a6c1ee 100%); width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
            <i class="fas fa-file-pdf fa-3x text-white"></i>
          </div>
          <h5 class="card-title fw-bold">Compliance Reports</h5>
          <p class="card-text text-muted mb-4">Generate audit-ready documentation</p>
          <div class="d-grid gap-2">
            <a href="/compliance/reports" class="btn" style="background: linear-gradient(135deg, #fbc2eb 0%, #a6c1ee 100%); color: #1e3c5c; border: none;">
              <i class="fas fa-file-alt me-1"></i> View Reports
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Quick Actions (moved inside Safety Officer Card) - These are already in the safety officer actions above -->
  
  <!-- Recent Activity (optional) -->
  <div class="row mt-4">
    <div class="col-12">
      <div class="card border-0 shadow-sm">
        <div class="card-body p-4">
          <h5 class="fw-bold mb-3" style="color: #1e3c5c">
            <i class="fas fa-history me-2"></i>Recent Activity
          </h5>
          <p class="text-muted text-center py-3">
            Your recent safety activities will appear here
          </p>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .hover-card {
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  
  .hover-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 30px rgba(0,0,0,0.15) !important;
  }
  
  .icon-circle {
    transition: transform 0.3s ease;
  }
  
  .hover-card:hover .icon-circle {
    transform: scale(1.1);
  }
  
  .btn {
    transition: all 0.3s ease;
  }
  
  .btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 5px 15px rgba(0,0,0,0.2);
  }
  
  .card {
    border-radius: 12px;
  }
  
  .badge {
    font-size: 0.8rem;
    padding: 0.4rem 0.6rem;
  }
</style>

<%- include('../partials/footer') %>