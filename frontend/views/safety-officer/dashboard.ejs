<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="main-wrapper">
  <div class="content container py-4">
    <div class="officer-dashboard-container" style="max-width: 900px; margin: 0 auto;">
      <!-- Officer Header -->
      <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
        <div>
          <h3 class="mb-1">
            <i class="fas fa-user-shield me-2" style="color: #26a69a;"></i>
            Safety Officer Dashboards
          </h3>
          <div class="d-flex gap-2">
            <span class="badge text-bg-secondary">
              <i class="fas fa-id-card me-1"></i> <%= officer.officerNumber %>
            </span>
            <span class="badge text-bg-success">
              <i class="fas fa-check-circle me-1"></i> <%= officer.verificationStatus %>
            </span>
            <span class="badge text-bg-info">
              <i class="fas fa-calendar me-1"></i> <%= new Date().toLocaleDateString() %>
            </span>
          </div>
        </div>
        <span class="text-muted small">
          <i class="fas fa-user me-1"></i> Welcome, <strong><%= officer.name %></strong>
        </span>
      </div>

      <!-- Profile Card -->
      <div class="card border-0 shadow-sm mb-4" style="border-radius: 16px;">
        <div class="card-body p-4">
          <div class="row">
            <div class="col-md-3 text-center text-md-start">
              <div class="mx-auto mb-3" style="width: 100px; height: 100px; background: linear-gradient(135deg, #26a69a 0%, #1e3c5c 100%); border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                <i class="fas fa-user-tie fa-3x text-white"></i>
              </div>
            </div>
            <div class="col-md-9">
              <h5 class="fw-bold mb-2"><%= officer.name %></h5>
              <div class="row">
                <div class="col-md-6">
                  <p class="mb-1"><i class="fas fa-envelope me-2 text-muted"></i> <%= officer.email %></p>
                  <p class="mb-1"><i class="fas fa-phone me-2 text-muted"></i> <%= officer.phone || 'Not provided' %></p>
                </div>
                <div class="col-md-6">
                  <p class="mb-1"><i class="fas fa-building me-2 text-muted"></i> Worksites: <%= officer.worksites?.length || 0 %></p>
                  <p class="mb-1"><i class="fas fa-layer-group me-2 text-muted"></i> Work Areas: <%= officer.workAreas?.length || 0 %></p>
                </div>
              </div>
              <% if (officer.bio) { %>
              <div class="mt-2 p-2 rounded-3" style="background: #f8f9fa;">
                <small class="text-muted"><%= officer.bio %></small>
              </div>
              <% } %>
            </div>
          </div>
        </div>
      </div>

      <!-- Quick Stats -->
      <div class="row g-3 mb-4">
        <div class="col-md-3 col-6">
          <div class="d-flex align-items-center p-2 rounded bg-light">
            <div class="rounded-circle d-flex align-items-center justify-content-center me-2" style="background: #f44336; width: 35px; height: 35px;">
              <i class="fas fa-flag text-white" style="font-size: 0.9rem;"></i>
            </div>
            <div>
              <strong><%= stats.incidentsReported || 0 %></strong>
              <small class="text-muted d-block">Incidents</small>
            </div>
          </div>
        </div>
        <div class="col-md-3 col-6">
          <div class="d-flex align-items-center p-2 rounded bg-light">
            <div class="rounded-circle d-flex align-items-center justify-content-center me-2" style="background: #ff9800; width: 35px; height: 35px;">
              <i class="fas fa-chalkboard-teacher text-white" style="font-size: 0.9rem;"></i>
            </div>
            <div>
              <strong><%= stats.safetyTalks || 0 %></strong>
              <small class="text-muted d-block">Safety Talks</small>
            </div>
          </div>
        </div>
        <div class="col-md-3 col-6">
          <div class="d-flex align-items-center p-2 rounded bg-light">
            <div class="rounded-circle d-flex align-items-center justify-content-center me-2" style="background: #4caf50; width: 35px; height: 35px;">
              <i class="fas fa-clipboard-list text-white" style="font-size: 0.9rem;"></i>
            </div>
            <div>
              <strong><%= stats.riskAssessments || 0 %></strong>
              <small class="text-muted d-block">Assessments</small>
            </div>
          </div>
        </div>
        <div class="col-md-3 col-6">
          <div class="d-flex align-items-center p-2 rounded bg-light">
            <div class="rounded-circle d-flex align-items-center justify-content-center me-2" style="background: #2196f3; width: 35px; height: 35px;">
              <i class="fas fa-helmet-safety text-white" style="font-size: 0.9rem;"></i>
            </div>
            <div>
              <strong><%= stats.ppeChecks || 0 %></strong>
              <small class="text-muted d-block">PPE Checks</small>
            </div>
          </div>
        </div>
      </div>

      <hr />

      <!-- Assigned Work Areas Section - Tabular Format -->
      <h4 class="text-center mb-4 fw-bold">
        <i class="fas fa-layer-group me-2" style="color: #26a69a;"></i>
        My Assigned Work Areas
      </h4>

      <div class="card shadow-sm border-0 mb-4" style="border-radius: 16px;">
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
              <thead style="background: #f8f9fa;">
                <tr>
                  <th class="px-4 py-3">Work Area</th>
                  <th class="py-3">Worksite</th>
                  <th class="py-3">Location</th>
                  <th class="py-3">Status</th>
                  <th class="py-3 text-end pe-4">Actions</th>
                </tr>
              </thead>
              <tbody>
                <% if (workAreas && workAreas.length > 0) { %>
                  <% workAreas.forEach(area => { %>
                    <tr>
                      <td class="px-4 py-3">
                        <div class="d-flex align-items-center">
                          <div class="icon-circle-sm me-2" style="background: linear-gradient(135deg, #26a69a 0%, #1e3c5c 100%); width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                            <i class="fas fa-map-marked-alt text-white" style="font-size: 0.8rem;"></i>
                          </div>
                          <strong><%= area.name %></strong>
                        </div>
                      </td>
                      <td class="py-3"><%= area.worksite?.name || 'N/A' %></td>
                      <td class="py-3"><%= area.location || 'Not specified' %></td>
                      <td class="py-3">
                        <span class="badge bg-<%= area.status === 'active' ? 'success' : 'secondary' %> bg-opacity-10 text-<%= area.status === 'active' ? 'success' : 'secondary' %> px-3 py-2 rounded-pill">
                          <i class="fas fa-<%= area.status === 'active' ? 'check-circle' : 'pause-circle' %> me-1"></i>
                          <%= area.status || 'Active' %>
                        </span>
                      </td>
                      <td class="py-3 text-end pe-4">
                        <a href="/work-areas/<%= area._id %>" class="btn btn-sm btn-outline-primary" style="border-radius: 40px;">
                          <i class="fas fa-eye me-1"></i> View Details
                        </a>
                      </td>
                    </tr>
                  <% }) %>
                <% } else { %>
                  <tr>
                    <td colspan="5" class="text-center py-5">
                      <i class="fas fa-info-circle fa-2x text-muted mb-2 d-block"></i>
                      <p class="text-muted mb-0">No work areas assigned yet.</p>
                      <small class="text-muted">Contact your administrator to be assigned to work areas.</small>
                    </td>
                  </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Recent Activity Feed - Optional -->
      <div class="card shadow-sm border-0 mt-4">
        <div class="card-header bg-transparent border-0 pt-4 px-4">
          <h5 class="fw-bold mb-0">
            <i class="fas fa-history me-2" style="color: #26a69a;"></i>
            Recent Activity
          </h5>
        </div>
        <div class="card-body p-4">
          <% if (recentActivities && recentActivities.length > 0) { %>
            <div class="list-group list-group-flush">
              <% recentActivities.slice(0, 5).forEach(activity => { %>
                <div class="list-group-item px-0 d-flex align-items-center">
                  <div class="me-3">
                    <span class="badge bg-<%= activity.type === 'incident' ? 'danger' : activity.type === 'assessment' ? 'warning' : 'success' %> rounded-pill">
                      <%= activity.type %>
                    </span>
                  </div>
                  <div class="flex-grow-1">
                    <p class="mb-0"><%= activity.description %></p>
                    <small class="text-muted"><%= new Date(activity.createdAt).toLocaleString() %></small>
                  </div>
                  <a href="<%= activity.link %>" class="btn btn-sm btn-outline-secondary">View</a>
                </div>
              <% }) %>
            </div>
          <% } else { %>
            <p class="text-muted text-center py-4">No recent activity.</p>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .main-wrapper {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }
  
  .content {
    flex: 1;
  }

  .officer-dashboard-container {
    max-width: 900px;
    margin: 0 auto;
  }

  .hover-card {
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    border-radius: 16px;
  }

  .hover-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15) !important;
  }

  .icon-circle {
    transition: transform 0.3s ease;
  }

  .icon-circle-sm {
    transition: transform 0.3s ease;
  }

  .hover-card:hover .icon-circle {
    transform: scale(1.1);
  }

  .btn {
    transition: all 0.3s ease;
    border-radius: 40px;
  }

  .btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
  }
  
  .card {
    border-radius: 16px;
  }
  
  .badge {
    font-size: 0.75rem;
    padding: 0.35rem 0.75rem;
    border-radius: 40px;
  }

  .table th {
    font-weight: 600;
    color: #1e3c5c;
    border-bottom: 2px solid #e9ecef;
  }

  .table td {
    vertical-align: middle;
    border-bottom: 1px solid #e9ecef;
  }

  .table tr:hover {
    background-color: #f8f9fa;
  }
</style>

<%- include('../partials/footer') %>