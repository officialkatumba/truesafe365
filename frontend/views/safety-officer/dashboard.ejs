<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="main-wrapper">
  <div class="content container py-4">
    <div class="officer-dashboard-container" style="max-width: 1200px; margin: 0 auto;">
      <!-- Officer Header -->
      <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
        <div>
          <h3 class="mb-1">
            <i class="fas fa-user-shield me-2" style="color: #26a69a;"></i>
            Safety Officer Dashboard
          </h3>
          <div class="d-flex gap-2">
            <span class="badge text-bg-secondary">
              <i class="fas fa-id-card me-1"></i> <%= officer.officerNumber %>
            </span>
            <span class="badge text-bg-success">
              <i class="fas fa-check-circle me-1"></i> <%= officer.verificationStatus %>
            </span>
            <span class="badge text-bg-info">
              <i class="fas fa-calendar me-1"></i> <%= new Date().toLocaleDateString() %>
            </span>
          </div>
        </div>
        <span class="text-muted small">
          <i class="fas fa-user me-1"></i> Welcome, <strong><%= officer.name %></strong>
        </span>
      </div>

      <!-- Assigned Worksites Summary -->
      <div class="safety-talk-container text-center mb-4">
        <div class="timer-label">MY ASSIGNED WORK AREAS</div>
        <div class="safety-talk-content">
          <div class="row g-2">
            <% if (assignedWorksites && assignedWorksites.length > 0) { %>
              <% assignedWorksites.forEach(worksite => { %>
                <div class="col-md-4">
                  <div class="p-2 rounded border">
                    <strong><%= worksite.name %></strong>
                    <small class="d-block text-muted"><%= worksite.location %></small>
                    <span class="badge bg-success mt-1">Active</span>
                  </div>
                </div>
              <% }) %>
            <% } else { %>
              <p class="mb-0">No worksites assigned yet. Contact your administrator.</p>
            <% } %>
          </div>
        </div>
      </div>

      <!-- Quick Stats -->
      <div class="row g-3 mb-4">
        <div class="col-md-3 col-6">
          <div class="d-flex align-items-center p-2 rounded bg-light">
            <div class="rounded-circle d-flex align-items-center justify-content-center me-2" style="background: #f44336; width: 35px; height: 35px;">
              <i class="fas fa-flag text-white" style="font-size: 0.9rem;"></i>
            </div>
            <div>
              <strong><%= stats.incidentsReported || 0 %></strong>
              <small class="text-muted d-block">Incidents</small>
            </div>
          </div>
        </div>
        <div class="col-md-3 col-6">
          <div class="d-flex align-items-center p-2 rounded bg-light">
            <div class="rounded-circle d-flex align-items-center justify-content-center me-2" style="background: #ff9800; width: 35px; height: 35px;">
              <i class="fas fa-chalkboard-teacher text-white" style="font-size: 0.9rem;"></i>
            </div>
            <div>
              <strong><%= stats.safetyTalks || 0 %></strong>
              <small class="text-muted d-block">Safety Talks</small>
            </div>
          </div>
        </div>
        <div class="col-md-3 col-6">
          <div class="d-flex align-items-center p-2 rounded bg-light">
            <div class="rounded-circle d-flex align-items-center justify-content-center me-2" style="background: #4caf50; width: 35px; height: 35px;">
              <i class="fas fa-clipboard-list text-white" style="font-size: 0.9rem;"></i>
            </div>
            <div>
              <strong><%= stats.riskAssessments || 0 %></strong>
              <small class="text-muted d-block">Assessments</small>
            </div>
          </div>
        </div>
        <div class="col-md-3 col-6">
          <div class="d-flex align-items-center p-2 rounded bg-light">
            <div class="rounded-circle d-flex align-items-center justify-content-center me-2" style="background: #2196f3; width: 35px; height: 35px;">
              <i class="fas fa-helmet-safety text-white" style="font-size: 0.9rem;"></i>
            </div>
            <div>
              <strong><%= stats.ppeChecks || 0 %></strong>
              <small class="text-muted d-block">PPE Checks</small>
            </div>
          </div>
        </div>
      </div>

      <!-- Primary Action Buttons -->
      <div class="d-flex gap-2 justify-content-center flex-wrap mb-4">
        <button class="btn btn-danger btn-sm" onclick="showIncidentModal()">
          <i class="fas fa-flag me-1"></i> Report Incident
        </button>
        <button class="btn btn-warning btn-sm" onclick="showRiskAssessmentModal()">
          <i class="fas fa-chart-pie me-1"></i> Risk Assessment
        </button>
        <button class="btn btn-success btn-sm" onclick="showSafetyTalkModal()">
          <i class="fas fa-chalkboard-teacher me-1"></i> Safety Talk
        </button>
        <button class="btn btn-info btn-sm" onclick="showPPEModal()">
          <i class="fas fa-helmet-safety me-1"></i> PPE Checklist
        </button>
        <button class="btn btn-primary btn-sm" onclick="showObservationModal()">
          <i class="fas fa-eye me-1"></i> Safety Observation
        </button>
      </div>

      <hr />

      <!-- SECTION 1: Incident Management -->
      <h4 class="text-center mb-4 fw-bold">
        <i class="fas fa-exclamation-triangle me-2" style="color: #f44336;"></i>
        Incident Management
      </h4>

      <div class="row g-4 mb-5">
        <div class="col-md-6">
          <div class="card shadow-sm border-0 h-100 hover-card">
            <div class="card-body p-4">
              <div class="d-flex align-items-center mb-3">
                <div class="icon-circle me-3" style="background: linear-gradient(135deg, #f44336 0%, #d32f2f 100%); width: 50px; height: 50px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                  <i class="fas fa-flag fa-1x text-white"></i>
                </div>
                <h5 class="fw-bold mb-0">Report Incident</h5>
              </div>
              <p class="text-muted small">Report workplace incidents, near misses, and unsafe conditions as required by Section 23 of the Health and Safety Act.</p>
              <button onclick="showIncidentModal()" class="btn btn-outline-danger w-100" style="border-radius: 40px;">
                <i class="fas fa-plus-circle me-2"></i> Report Now
              </button>
            </div>
          </div>
        </div>
        <div class="col-md-6">
          <div class="card shadow-sm border-0 h-100 hover-card">
            <div class="card-body p-4">
              <div class="d-flex align-items-center mb-3">
                <div class="icon-circle me-3" style="background: linear-gradient(135deg, #ff9800 0%, #f57c00 100%); width: 50px; height: 50px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                  <i class="fas fa-clipboard-list fa-1x text-white"></i>
                </div>
                <h5 class="fw-bold mb-0">My Incidents</h5>
              </div>
              <p class="text-muted small">View and manage incidents you've reported. Track investigation status and corrective actions.</p>
              <a href="/safety-officer/incidents" class="btn btn-outline-secondary w-100" style="border-radius: 40px;">
                <i class="fas fa-arrow-right me-2"></i> View All
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- SECTION 2: Risk Management -->
      <h4 class="text-center mb-4 fw-bold">
        <i class="fas fa-chart-pie me-2" style="color: #ff9800;"></i>
        Risk Management
      </h4>

      <div class="row g-4 mb-5">
        <div class="col-md-6">
          <div class="card shadow-sm border-0 h-100 hover-card">
            <div class="card-body p-4">
              <div class="d-flex align-items-center mb-3">
                <div class="icon-circle me-3" style="background: linear-gradient(135deg, #ff9800 0%, #f57c00 100%); width: 50px; height: 50px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                  <i class="fas fa-chart-pie fa-1x text-white"></i>
                </div>
                <h5 class="fw-bold mb-0">Risk Assessment</h5>
              </div>
              <p class="text-muted small">Conduct risk assessments for work areas. Identify hazards, evaluate risks, and recommend controls per Section 7 of the Act.</p>
              <button onclick="showRiskAssessmentModal()" class="btn btn-outline-warning w-100" style="border-radius: 40px;">
                <i class="fas fa-plus-circle me-2"></i> New Assessment
              </button>
            </div>
          </div>
        </div>
        <div class="col-md-6">
          <div class="card shadow-sm border-0 h-100 hover-card">
            <div class="card-body p-4">
              <div class="d-flex align-items-center mb-3">
                <div class="icon-circle me-3" style="background: linear-gradient(135deg, #4caf50 0%, #388e3c 100%); width: 50px; height: 50px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                  <i class="fas fa-chart-line fa-1x text-white"></i>
                </div>
                <h5 class="fw-bold mb-0">My Assessments</h5>
              </div>
              <p class="text-muted small">View all risk assessments. Track high-risk areas and control implementation status.</p>
              <a href="/safety-officer/risk-assessments" class="btn btn-outline-secondary w-100" style="border-radius: 40px;">
                <i class="fas fa-arrow-right me-2"></i> View All
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- SECTION 3: Safety Communications -->
      <h4 class="text-center mb-4 fw-bold">
        <i class="fas fa-chalkboard-teacher me-2" style="color: #2196f3;"></i>
        Safety Communications
      </h4>

      <div class="row g-4 mb-5">
        <div class="col-md-6">
          <div class="card shadow-sm border-0 h-100 hover-card">
            <div class="card-body p-4">
              <div class="d-flex align-items-center mb-3">
                <div class="icon-circle me-3" style="background: linear-gradient(135deg, #2196f3 0%, #1976d2 100%); width: 50px; height: 50px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                  <i class="fas fa-chalkboard-teacher fa-1x text-white"></i>
                </div>
                <h5 class="fw-bold mb-0">Safety Talk</h5>
              </div>
              <p class="text-muted small">Generate AI-powered safety talks based on current work conditions and hazards. Perfect for toolbox talks.</p>
              <button onclick="showSafetyTalkModal()" class="btn btn-outline-primary w-100" style="border-radius: 40px;">
                <i class="fas fa-robot me-2"></i> Generate Talk
              </button>
            </div>
          </div>
        </div>
        <div class="col-md-6">
          <div class="card shadow-sm border-0 h-100 hover-card">
            <div class="card-body p-4">
              <div class="d-flex align-items-center mb-3">
                <div class="icon-circle me-3" style="background: linear-gradient(135deg, #9c27b0 0%, #7b1fa2 100%); width: 50px; height: 50px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                  <i class="fas fa-eye fa-1x text-white"></i>
                </div>
                <h5 class="fw-bold mb-0">Safety Observation</h5>
              </div>
              <p class="text-muted small">Document safety observations, positive behaviors, and areas for improvement. Support continuous improvement.</p>
              <button onclick="showObservationModal()" class="btn btn-outline-secondary w-100" style="border-radius: 40px;">
                <i class="fas fa-plus-circle me-2"></i> New Observation
              </button>
            </div>
          </div>
        </div>
      </div>

      <!-- SECTION 4: PPE & Compliance -->
      <h4 class="text-center mb-4 fw-bold">
        <i class="fas fa-helmet-safety me-2" style="color: #4caf50;"></i>
        PPE & Compliance
      </h4>

      <div class="row g-4 mb-5">
        <div class="col-md-6">
          <div class="card shadow-sm border-0 h-100 hover-card">
            <div class="card-body p-4">
              <div class="d-flex align-items-center mb-3">
                <div class="icon-circle me-3" style="background: linear-gradient(135deg, #4caf50 0%, #388e3c 100%); width: 50px; height: 50px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                  <i class="fas fa-helmet-safety fa-1x text-white"></i>
                </div>
                <h5 class="fw-bold mb-0">PPE Checklist</h5>
              </div>
              <p class="text-muted small">Conduct PPE inspections and ensure compliance with personal protective equipment requirements.</p>
              <button onclick="showPPEModal()" class="btn btn-outline-success w-100" style="border-radius: 40px;">
                <i class="fas fa-clipboard-check me-2"></i> New Checklist
              </button>
            </div>
          </div>
        </div>
        <div class="col-md-6">
          <div class="card shadow-sm border-0 h-100 hover-card">
            <div class="card-body p-4">
              <div class="d-flex align-items-center mb-3">
                <div class="icon-circle me-3" style="background: linear-gradient(135deg, #ff5722 0%, #e64a19 100%); width: 50px; height: 50px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                  <i class="fas fa-file-alt fa-1x text-white"></i>
                </div>
                <h5 class="fw-bold mb-0">Permit to Work</h5>
              </div>
              <p class="text-muted small">Request and manage work permits for high-risk activities as required by regulations.</p>
              <a href="/safety-officer/permits" class="btn btn-outline-secondary w-100" style="border-radius: 40px;">
                <i class="fas fa-file-signature me-2"></i> Manage Permits
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Recent Activity Feed -->
      <div class="card shadow-sm border-0 mt-4">
        <div class="card-header bg-transparent border-0 pt-4 px-4">
          <h5 class="fw-bold mb-0">
            <i class="fas fa-history me-2" style="color: #26a69a;"></i>
            Recent Activity
          </h5>
        </div>
        <div class="card-body p-4">
          <% if (recentActivities && recentActivities.length > 0) { %>
            <div class="list-group list-group-flush">
              <% recentActivities.slice(0, 5).forEach(activity => { %>
                <div class="list-group-item px-0 d-flex align-items-center">
                  <div class="me-3">
                    <span class="badge bg-<%= activity.type === 'incident' ? 'danger' : activity.type === 'assessment' ? 'warning' : 'success' %> rounded-pill">
                      <%= activity.type %>
                    </span>
                  </div>
                  <div class="flex-grow-1">
                    <p class="mb-0"><%= activity.description %></p>
                    <small class="text-muted"><%= new Date(activity.createdAt).toLocaleString() %></small>
                  </div>
                  <a href="<%= activity.link %>" class="btn btn-sm btn-outline-secondary">View</a>
                </div>
              <% }) %>
            </div>
          <% } else { %>
            <p class="text-muted text-center py-4">No recent activity. Start by reporting an incident or conducting a risk assessment.</p>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Modals for Forms -->
<!-- Incident Report Modal -->
<div class="modal fade" id="incidentModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content" style="border-radius: 16px;">
      <div class="modal-header border-0">
        <h5 class="modal-title fw-bold">Report Incident</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form action="/safety-officer/incidents" method="POST">
        <div class="modal-body">
          <div class="mb-3">
            <label class="form-label fw-semibold">Work Area *</label>
            <select class="form-select" name="workAreaId" required style="border-radius: 40px;">
              <option value="">Select work area...</option>
              <% if (workAreas) { %>
                <% workAreas.forEach(area => { %>
                  <option value="<%= area._id %>"><%= area.name %> - <%= area.worksite?.name %></option>
                <% }) %>
              <% } %>
            </select>
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold">Incident Type *</label>
            <select class="form-select" name="incidentType" required style="border-radius: 40px;">
              <option value="accident">Accident with injury</option>
              <option value="near_miss">Near Miss</option>
              <option value="property_damage">Property Damage</option>
              <option value="unsafe_condition">Unsafe Condition</option>
              <option value="unsafe_act">Unsafe Act</option>
            </select>
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold">Severity *</label>
            <select class="form-select" name="severity" required style="border-radius: 40px;">
              <option value="low">Low</option>
              <option value="medium">Medium</option>
              <option value="high">High</option>
              <option value="critical">Critical</option>
            </select>
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold">Title *</label>
            <input type="text" class="form-control" name="title" required style="border-radius: 40px;">
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold">Description *</label>
            <textarea class="form-control" name="description" rows="4" required style="border-radius: 16px;"></textarea>
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold">Immediate Actions Taken</label>
            <textarea class="form-control" name="immediateActions" rows="3" style="border-radius: 16px;"></textarea>
          </div>
          <div class="form-check mb-3">
            <input class="form-check-input" type="checkbox" name="requiresInvestigation" value="true">
            <label class="form-check-label">
              Requires formal investigation
            </label>
          </div>
        </div>
        <div class="modal-footer border-0">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal" style="border-radius: 40px;">Cancel</button>
          <button type="submit" class="btn btn-danger" style="border-radius: 40px;">Report Incident</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Risk Assessment Modal -->
<div class="modal fade" id="riskAssessmentModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content" style="border-radius: 16px;">
      <div class="modal-header border-0">
        <h5 class="modal-title fw-bold">Risk Assessment</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form action="/safety-officer/risk-assessments" method="POST">
        <div class="modal-body">
          <div class="mb-3">
            <label class="form-label fw-semibold">Work Area *</label>
            <select class="form-select" name="workAreaId" required style="border-radius: 40px;">
              <option value="">Select work area...</option>
              <% if (workAreas) { %>
                <% workAreas.forEach(area => { %>
                  <option value="<%= area._id %>"><%= area.name %></option>
                <% }) %>
              <% } %>
            </select>
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold">Activity/Task *</label>
            <input type="text" class="form-control" name="activity" required style="border-radius: 40px;">
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold">Hazard Identification</label>
            <div id="hazardsContainer">
              <div class="hazard-entry mb-3">
                <input type="text" class="form-control mb-2" name="hazards[]" placeholder="Describe hazard" style="border-radius: 40px;">
                <select class="form-select mb-2" name="riskLevels[]" style="border-radius: 40px;">
                  <option value="low">Low Risk</option>
                  <option value="medium">Medium Risk</option>
                  <option value="high">High Risk</option>
                  <option value="critical">Critical Risk</option>
                </select>
                <textarea class="form-control" name="controls[]" rows="2" placeholder="Existing controls / Recommended controls" style="border-radius: 16px;"></textarea>
              </div>
            </div>
            <button type="button" class="btn btn-sm btn-outline-primary" onclick="addHazard()" style="border-radius: 40px;">
              <i class="fas fa-plus me-1"></i> Add Hazard
            </button>
          </div>
        </div>
        <div class="modal-footer border-0">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal" style="border-radius: 40px;">Cancel</button>
          <button type="submit" class="btn btn-warning" style="border-radius: 40px;">Submit Assessment</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Safety Talk Modal -->
<div class="modal fade" id="safetyTalkModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content" style="border-radius: 16px;">
      <div class="modal-header border-0">
        <h5 class="modal-title fw-bold">Generate Safety Talk</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form action="/safety-officer/safety-talks/generate" method="POST">
        <div class="modal-body">
          <div class="mb-3">
            <label class="form-label fw-semibold">Work Area *</label>
            <select class="form-select" name="workAreaId" required style="border-radius: 40px;">
              <option value="">Select work area...</option>
              <% if (workAreas) { %>
                <% workAreas.forEach(area => { %>
                  <option value="<%= area._id %>"><%= area.name %></option>
                <% }) %>
              <% } %>
            </select>
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold">Topic (Optional)</label>
            <input type="text" class="form-control" name="topic" placeholder="e.g., Working at Heights, Manual Handling" style="border-radius: 40px;">
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold">Focus Area</label>
            <select class="form-select" name="focusArea" style="border-radius: 40px;">
              <option value="general">General Safety</option>
              <option value="ppe">PPE Usage</option>
              <option value="hazard">Hazard Identification</option>
              <option value="emergency">Emergency Response</option>
              <option value="ergonomics">Ergonomics</option>
            </select>
          </div>
        </div>
        <div class="modal-footer border-0">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal" style="border-radius: 40px;">Cancel</button>
          <button type="submit" class="btn btn-primary" style="border-radius: 40px;">Generate Talk</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- PPE Checklist Modal -->
<div class="modal fade" id="ppeModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content" style="border-radius: 16px;">
      <div class="modal-header border-0">
        <h5 class="modal-title fw-bold">PPE Inspection Checklist</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form action="/safety-officer/ppe-checklists" method="POST">
        <div class="modal-body">
          <div class="mb-3">
            <label class="form-label fw-semibold">Work Area *</label>
            <select class="form-select" name="workAreaId" required style="border-radius: 40px;">
              <option value="">Select work area...</option>
              <% if (workAreas) { %>
                <% workAreas.forEach(area => { %>
                  <option value="<%= area._id %>"><%= area.name %></option>
                <% }) %>
              <% } %>
            </select>
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold">Shift</label>
            <select class="form-select" name="shift" style="border-radius: 40px;">
              <option value="morning">Morning</option>
              <option value="afternoon">Afternoon</option>
              <option value="night">Night</option>
            </select>
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold">PPE Items</label>
            <div class="border rounded p-3">
              <div class="form-check mb-2">
                <input class="form-check-input" type="checkbox" name="ppeItems" value="hard_hat">
                <label class="form-check-label">Hard Hat - Condition OK</label>
              </div>
              <div class="form-check mb-2">
                <input class="form-check-input" type="checkbox" name="ppeItems" value="safety_glasses">
                <label class="form-check-label">Safety Glasses - Condition OK</label>
              </div>
              <div class="form-check mb-2">
                <input class="form-check-input" type="checkbox" name="ppeItems" value="high_vis_vest">
                <label class="form-check-label">High-Vis Vest - Condition OK</label>
              </div>
              <div class="form-check mb-2">
                <input class="form-check-input" type="checkbox" name="ppeItems" value="steel_toe_boots">
                <label class="form-check-label">Steel-Toe Boots - Condition OK</label>
              </div>
              <div class="form-check mb-2">
                <input class="form-check-input" type="checkbox" name="ppeItems" value="gloves">
                <label class="form-check-label">Gloves - Condition OK</label>
              </div>
              <div class="form-check mb-2">
                <input class="form-check-input" type="checkbox" name="ppeItems" value="ear_protection">
                <label class="form-check-label">Ear Protection - Condition OK</label>
              </div>
              <div class="form-check">
                <input class="form-check-input" type="checkbox" name="ppeItems" value="respirator">
                <label class="form-check-label">Respirator - Condition OK</label>
              </div>
            </div>
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold">Observations / Issues</label>
            <textarea class="form-control" name="observations" rows="3" style="border-radius: 16px;"></textarea>
          </div>
        </div>
        <div class="modal-footer border-0">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal" style="border-radius: 40px;">Cancel</button>
          <button type="submit" class="btn btn-success" style="border-radius: 40px;">Submit Checklist</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Safety Observation Modal -->
<div class="modal fade" id="observationModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content" style="border-radius: 16px;">
      <div class="modal-header border-0">
        <h5 class="modal-title fw-bold">Safety Observation</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form action="/safety-officer/observations" method="POST">
        <div class="modal-body">
          <div class="mb-3">
            <label class="form-label fw-semibold">Work Area *</label>
            <select class="form-select" name="workAreaId" required style="border-radius: 40px;">
              <option value="">Select work area...</option>
              <% if (workAreas) { %>
                <% workAreas.forEach(area => { %>
                  <option value="<%= area._id %>"><%= area.name %></option>
                <% }) %>
              <% } %>
            </select>
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold">Observation Type *</label>
            <select class="form-select" name="type" required style="border-radius: 40px;">
              <option value="positive">Positive - Safe Behavior</option>
              <option value="at_risk">At-Risk - Unsafe Behavior</option>
              <option value="condition">Condition - Unsafe Condition</option>
            </select>
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold">Description *</label>
            <textarea class="form-control" name="description" rows="4" required style="border-radius: 16px;"></textarea>
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold">Recommendations</label>
            <textarea class="form-control" name="recommendations" rows="3" style="border-radius: 16px;"></textarea>
          </div>
        </div>
        <div class="modal-footer border-0">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal" style="border-radius: 40px;">Cancel</button>
          <button type="submit" class="btn btn-info" style="border-radius: 40px;">Submit Observation</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  function showIncidentModal() {
    new bootstrap.Modal(document.getElementById('incidentModal')).show();
  }
  
  function showRiskAssessmentModal() {
    new bootstrap.Modal(document.getElementById('riskAssessmentModal')).show();
  }
  
  function showSafetyTalkModal() {
    new bootstrap.Modal(document.getElementById('safetyTalkModal')).show();
  }
  
  function showPPEModal() {
    new bootstrap.Modal(document.getElementById('ppeModal')).show();
  }
  
  function showObservationModal() {
    new bootstrap.Modal(document.getElementById('observationModal')).show();
  }
  
  function addHazard() {
    const container = document.getElementById('hazardsContainer');
    const newEntry = document.createElement('div');
    newEntry.className = 'hazard-entry mb-3';
    newEntry.innerHTML = `
      <input type="text" class="form-control mb-2" name="hazards[]" placeholder="Describe hazard" style="border-radius: 40px;">
      <select class="form-select mb-2" name="riskLevels[]" style="border-radius: 40px;">
        <option value="low">Low Risk</option>
        <option value="medium">Medium Risk</option>
        <option value="high">High Risk</option>
        <option value="critical">Critical Risk</option>
      </select>
      <textarea class="form-control" name="controls[]" rows="2" placeholder="Existing controls / Recommended controls" style="border-radius: 16px;"></textarea>
      <button type="button" class="btn btn-sm btn-outline-danger mt-2" onclick="this.parentElement.remove()" style="border-radius: 40px;">Remove</button>
    `;
    container.appendChild(newEntry);
  }
</script>

