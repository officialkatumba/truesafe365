
<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="main-wrapper">
  <div class="content container py-4">
    <div class="officer-dashboard-container">

      <!-- Clean Header -->
      <section class="dashboard-hero mb-4">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
          <div>
            <p class="text-uppercase text-muted fw-bold small mb-1">
              Safety Officer Dashboard
            </p>

            <h3 class="fw-bold mb-2">
              <i class="fas fa-user-shield me-2"></i>
              Welcome, <%= officer.name %>
            </h3>

            <div class="d-flex flex-wrap gap-2">
              <span class="soft-pill teal">
                <i class="fas fa-id-card me-1"></i> Safety Officer
              </span>

              <span class="soft-pill green">
                <i class="fas fa-check-circle me-1"></i>
                <%= officer.verificationStatus || 'Verified' %>
              </span>

              <span class="soft-pill blue">
                <i class="fas fa-calendar me-1"></i>
                <%= new Date().toLocaleDateString() %>
              </span>
            </div>
          </div>

          <div class="text-md-end">
            <div class="hero-avatar">
              <i class="fas fa-user-tie"></i>
            </div>
          </div>
        </div>
      </section>

      <!-- Profile Summary -->
      <div class="profile-card mb-4">
        <div class="row g-3 align-items-center">
          <div class="col-md-7">
            <h5 class="fw-bold mb-2"><%= officer.name %></h5>

            <div class="small text-muted mb-1">
              <i class="fas fa-envelope me-2"></i><%= officer.email %>
            </div>

            <div class="small text-muted">
              <i class="fas fa-phone me-2"></i><%= officer.phone || 'Not provided' %>
            </div>

            <% if (officer.bio) { %>
              <div class="officer-bio mt-3">
                <%= officer.bio %>
              </div>
            <% } %>
          </div>

          <div class="col-md-5">
            <div class="summary-grid">
              <div class="summary-pill">
                <i class="fas fa-layer-group"></i>
                <div>
                  <strong><%= workAreas?.length || 0 %></strong>
                  <span>Work Areas</span>
                </div>
              </div>

              <div class="summary-pill">
                <i class="fas fa-file-alt"></i>
                <div>
                  <strong><%= (stats.riskAssessments || 0) + (stats.safetyTalks || 0) %></strong>
                  <span>Documents</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Work Areas Header -->
      <!-- Site Risk Profiler -->
      <div class="card shadow-sm border-0 mb-4 risk-profiler-card">
        <div class="card-body">
          <h5 class="fw-bold mb-1">
            <i class="fas fa-radar me-2" style="color:#c0392b;"></i>
            Top Risk Areas This Week
          </h5>
          <p class="small text-muted mb-3">
            Auto-generated from active hazards, incidents, near-misses, and JSA activity logged in the last 7 days.
          </p>

          <% if (topRiskAreas && topRiskAreas.length > 0) { %>
            <div class="row g-3">
              <% topRiskAreas.forEach((entry, index) => { %>
                <div class="col-md-4">
                  <div class="risk-rank-card">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                      <span class="risk-rank-badge">#<%= index + 1 %></span>
                      <span class="badge bg-danger"><%= Math.round(entry.score) %> risk pts</span>
                    </div>
                    <strong><a href="/work-areas/<%= entry.workArea._id %>"><%= entry.workArea.name %></a></strong>
                    <div class="small text-muted mt-1">
                      <% if (entry.topHazardLabel) { %>
                        <div><i class="fas fa-triangle-exclamation me-1"></i><%= entry.topHazardLabel %></div>
                      <% } %>
                      <% if (entry.incidents > 0) { %>
                        <div><i class="fas fa-exclamation-circle me-1"></i><%= entry.incidents %> incident(s) this week</div>
                      <% } %>
                      <% if (entry.nearMisses > 0) { %>
                        <div><i class="fas fa-eye me-1"></i><%= entry.nearMisses %> near-miss(es) this week</div>
                      <% } %>
                      <% if (entry.activeHighRiskHazards > 0) { %>
                        <div><i class="fas fa-radiation me-1"></i><%= entry.activeHighRiskHazards %> high/critical hazard(s) active</div>
                      <% } %>
                    </div>
                  </div>
                </div>
              <% }) %>
            </div>
          <% } else { %>
            <p class="text-muted text-center py-3 mb-0">
              <i class="fas fa-shield-halved me-1"></i>
              No elevated risk signals this week - keep logging hazards and observations to keep this current.
            </p>
          <% } %>
        </div>
      </div>

      <div class="section-header mb-3">
        <div>
          <h4 class="fw-bold mb-1">
            <i class="fas fa-layer-group me-2"></i>
            Work Areas
          </h4>
          <span class="soft-pill neutral">
            <i class="fas fa-database me-1"></i>
            <%= workAreas?.length || 0 %> assigned
          </span>
        </div>

        <a href="/work-areas/create" class="btn-new-workarea">
          <i class="fas fa-plus-circle me-1"></i>
          New Work Area
        </a>
      </div>

      <!-- Search & Filter -->
      <div class="card shadow-sm border-0 mb-3 dashboard-filter-card">
        <div class="card-body">
          <div class="row g-2 align-items-center">
            <div class="col-md-5">
              <div class="input-group">
                <span class="input-group-text bg-white border-end-0"><i class="fas fa-search text-muted"></i></span>
                <input type="search" id="workAreaSearch" class="form-control border-start-0" placeholder="Search work areas by name or location...">
              </div>
            </div>
            <div class="col-md-3">
              <select id="workAreaStatusFilter" class="form-select">
                <option value="">All statuses</option>
                <option value="active">Active</option>
                <option value="planned">Planned</option>
                <option value="on_hold">On Hold</option>
                <option value="inspecting">Inspecting</option>
                <option value="completed">Completed</option>
              </select>
            </div>
            <div class="col-md-2">
              <input type="date" id="workAreaFromDate" class="form-control" title="Created from">
            </div>
            <div class="col-md-2">
              <input type="date" id="workAreaToDate" class="form-control" title="Created to">
            </div>
          </div>
          <div class="small text-muted mt-2" id="workAreaFilterCount"></div>
        </div>
      </div>

      <!-- Assigned Work Areas -->
      <div class="card shadow-sm border-0 mb-4 dashboard-table-card">
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" id="workAreaTable">
              <thead>
                <tr>
                  <th class="px-4 py-3">Work Area</th>
                  <th class="py-3">Location</th>
                  <th class="py-3">Status</th>
                  <th class="py-3 text-end pe-4">Actions</th>
                </tr>
              </thead>

              <tbody>
                <% if (workAreas && workAreas.length > 0) { %>
                  <% workAreas.forEach(area => { %>
                    <tr
                      data-name="<%= (area.name || '').toLowerCase() %>"
                      data-location="<%= (area.location?.zone || '').toLowerCase() %>"
                      data-status="<%= area.status || 'active' %>"
                      data-created="<%= new Date(area.createdAt).toISOString().slice(0, 10) %>"
                    >
                      <td class="px-4 py-3">
                        <div class="d-flex align-items-center">
                          <div class="icon-circle-sm me-2">
                            <i class="fas fa-map-marked-alt"></i>
                          </div>
                          <strong><%= area.name %></strong>
                        </div>
                      </td>

                      <td class="py-3">
                        <%= area.location?.zone || 'Not specified' %>
                      </td>

                      <td class="py-3">
                        <span class="status-badge <%= area.status === 'active' ? 'active' : 'inactive' %>">
                          <i class="fas fa-<%= area.status === 'active' ? 'check-circle' : 'pause-circle' %> me-1"></i>
                          <%= area.status || 'Active' %>
                        </span>
                      </td>

                      <td class="py-3 text-end pe-4">
                        <a href="/work-areas/<%= area._id %>" class="btn-view-details">
                          <i class="fas fa-eye me-1"></i>
                          View Details
                        </a>
                      </td>
                    </tr>
                  <% }) %>
                <% } else { %>
                  <tr>
                    <td colspan="4" class="text-center py-5">
                      <i class="fas fa-info-circle fa-2x text-muted mb-2 d-block"></i>
                      <p class="text-muted mb-3">No work areas yet.</p>

                      <a href="/work-areas/create" class="btn-new-workarea">
                        <i class="fas fa-plus me-1"></i>
                        Create your first work area
                      </a>
                    </td>
                  </tr>
                <% } %>
              </tbody>
            </table>
            <p class="text-muted text-center py-4 d-none" id="workAreaNoMatches">
              <i class="fas fa-filter-circle-xmark fa-2x mb-2 d-block"></i>
              No work areas match your search or filters.
            </p>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>

<style>
  .main-wrapper {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    background: #f6f8fb;
  }

  .content {
    flex: 1;
  }

  .officer-dashboard-container {
    max-width: 980px;
    margin: 0 auto;
  }

  .risk-profiler-card {
    border-radius: 16px;
    border-left: 4px solid #c0392b !important;
  }

  .risk-rank-card {
    background: #fff6f5;
    border: 1px solid #f3d3ce;
    border-radius: 12px;
    padding: 0.9rem;
    height: 100%;
  }

  .risk-rank-badge {
    background: #c0392b;
    color: white;
    font-weight: bold;
    border-radius: 999px;
    padding: 0.15rem 0.6rem;
    font-size: 0.85rem;
  }

  .dashboard-hero {
    background: #ffffff;
    border: 1px solid #e1e8ef;
    border-radius: 18px;
    padding: 1.4rem;
    box-shadow: 0 12px 28px rgba(20, 39, 60, 0.07);
  }

  .dashboard-hero h3 {
    color: #1e3c5c;
  }

  .dashboard-hero h3 i,
  .section-header h4 i {
    color: #26a69a;
  }

  .hero-avatar {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: linear-gradient(135deg, #26a69a, #1e3c5c);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    box-shadow: 0 10px 22px rgba(38, 166, 154, 0.3);
  }

  .profile-card {
    background: #ffffff;
    border: 1px solid #e1e8ef;
    border-radius: 18px;
    padding: 1.25rem;
    box-shadow: 0 10px 24px rgba(20, 39, 60, 0.05);
  }

  .officer-bio {
    background: #f8fafc;
    border-left: 4px solid #26a69a;
    border-radius: 10px;
    padding: 0.75rem;
    font-size: 0.85rem;
    color: #526173;
  }

  .soft-pill {
    min-height: 32px;
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    padding: 0.38rem 0.8rem;
    font-size: 0.78rem;
    font-weight: 800;
    border: 1px solid transparent;
  }

  .soft-pill.teal {
    background: #e6fcf5;
    color: #087f5b;
    border-color: #b2f2dd;
  }

  .soft-pill.green {
    background: #dff7ea;
    color: #137a3d;
    border-color: #bdeccc;
  }

  .soft-pill.blue {
    background: #e7f5ff;
    color: #1864ab;
    border-color: #bfdbfe;
  }

  .soft-pill.neutral {
    background: #edf2f7;
    color: #405468;
    border-color: #d8e1ea;
  }

  .summary-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }

  .summary-pill {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    background: #f8fafc;
    border: 1px solid #e1e8ef;
    border-radius: 999px;
    padding: 0.75rem 1rem;
  }

  .summary-pill i {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: #e6fcf5;
    color: #087f5b;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .summary-pill strong {
    display: block;
    color: #1e3c5c;
    font-size: 1.15rem;
    line-height: 1;
  }

  .summary-pill span {
    color: #6c757d;
    font-size: 0.8rem;
    font-weight: 700;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .section-header h4 {
    color: #1e3c5c;
  }

  .btn-new-workarea {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    border-radius: 999px;
    padding: 0.65rem 1rem;
    background: #e6fcf5;
    color: #087f5b;
    border: 1px solid #b2f2dd;
    font-weight: 800;
    font-size: 0.85rem;
    transition: all 0.25s ease;
  }

  .btn-new-workarea:hover {
    background: #26a69a;
    color: #ffffff;
    transform: translateY(-2px);
    box-shadow: 0 8px 18px rgba(38, 166, 154, 0.28);
  }

  .dashboard-table-card {
    border-radius: 18px;
    overflow: hidden;
  }

  .table thead {
    background: #f8fafc;
  }

  .table th {
    font-weight: 800;
    color: #1e3c5c;
    border-bottom: 2px solid #e9ecef;
    font-size: 0.85rem;
  }

  .table td {
    vertical-align: middle;
    border-bottom: 1px solid #e9ecef;
    color: #465668;
  }

  .table tr:hover {
    background-color: #f8fafc;
  }

  .icon-circle-sm {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    background: #e6fcf5;
    color: #087f5b;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .status-badge {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    padding: 0.4rem 0.8rem;
    font-size: 0.78rem;
    font-weight: 800;
  }

  .status-badge.active {
    background: #dff7ea;
    color: #137a3d;
  }

  .status-badge.inactive {
    background: #edf2f7;
    color: #405468;
  }

  .btn-view-details {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    padding: 0.45rem 0.85rem;
    text-decoration: none;
    border: 1px solid #bfdbfe;
    background: #e7f5ff;
    color: #1864ab;
    font-weight: 800;
    font-size: 0.78rem;
    transition: all 0.25s ease;
  }

  .btn-view-details:hover {
    background: #1864ab;
    color: #ffffff;
    transform: translateY(-2px);
  }

  @media (max-width: 768px) {
    .dashboard-hero,
    .profile-card {
      padding: 1rem;
    }

    .hero-avatar {
      width: 58px;
      height: 58px;
      font-size: 1.5rem;
    }

    .section-header {
      align-items: flex-start;
    }

    .btn-new-workarea {
      width: 100%;
    }

    .table {
      font-size: 0.85rem;
    }
  }
</style>

<script src="/js/dashboard-filter.js"></script>

<%- include('../partials/footer') %>
```
