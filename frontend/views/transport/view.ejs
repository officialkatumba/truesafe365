<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="container py-4">
  <div class="p-4 mb-4 rounded-3" style="background: linear-gradient(135deg, <%= checklist.overallResult === 'pass' ? '#1e3c5c, #2f5597' : '#c0392b, #e74c3c' %>);">
    <div class="d-flex justify-content-between align-items-center flex-wrap">
      <div>
        <h2 class="text-white fw-bold mb-1"><%= label %> #<%= checklist.checklistNumber %></h2>
        <p class="text-white-50 mb-0"><%= checklist.workArea?.name %> | <%= new Date(checklist.date).toLocaleString() %></p>
      </div>
      <div>
        <span class="badge <%= checklist.overallResult === 'pass' ? 'bg-success' : 'bg-danger' %> px-3 py-2 fs-6 me-2">
          <%= checklist.overallResult === 'pass' ? 'CLEARED TO PROCEED' : 'FAILED - DO NOT PROCEED' %>
        </span>
        <a href="/transport-checklists/<%= checklist._id %>/download-word" class="btn btn-light fw-bold">
          <i class="fas fa-file-word me-2"></i>Download
        </a>
      </div>
    </div>
  </div>

  <div class="card shadow-sm border-0 mb-4">
    <div class="card-body">
      <p><strong>Driver:</strong> <%= checklist.driverName %></p>
      <p><strong>Vehicle Registration:</strong> <%= checklist.vehicleRegistration || 'N/A' %></p>
      <p><strong>Route:</strong> <%= checklist.route || 'N/A' %></p>

      <% if (checklist.failureNotes) { %>
        <div class="alert alert-danger">
          <i class="fas fa-exclamation-triangle me-2"></i>
          <strong>Critical failures:</strong> <%= checklist.failureNotes %>
        </div>
      <% } %>

      <table class="table table-sm mt-3">
        <thead><tr><th>Item</th><th>Critical</th><th>Response</th><th>Notes</th></tr></thead>
        <tbody>
          <% checklist.items.forEach(item => { %>
            <tr class="<%= item.critical && item.response === 'no' ? 'table-danger' : '' %>">
              <td><%= item.question %></td>
              <td><%= item.critical ? 'Yes' : 'No' %></td>
              <td class="fw-bold"><%= item.response.toUpperCase() %></td>
              <td><%= item.notes %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>

  <a href="/work-areas/<%= checklist.workArea?._id %>" class="btn btn-outline-secondary">
    <i class="fas fa-arrow-left me-2"></i>Back to Work Area
  </a>
</div>

<%- include('../partials/footer') %>
